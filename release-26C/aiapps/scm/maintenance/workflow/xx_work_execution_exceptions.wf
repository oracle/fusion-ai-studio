        {
          "metadata": {
            "name": "Check Organization",
            "returnType": "object",
            "sourceCode": "//Get Org Context\nconst appContext = $context.$app.$OraAppContext ?? $context.$triggers.REST.$input.OraAppContext;\nlet OrganizationId = null;\n\nif (appContext != null && String(appContext).trim() != '') {\n  if (typeof appContext === 'object') {\n    OrganizationId = appContext?.OrganizationId ?? null;\n  } else if (typeof appContext === 'number') {\n    OrganizationId = String(appContext);\n  } else if (typeof appContext === 'string') {\n    const s = appContext.trim();\n    if (s.startsWith('{') || s.startsWith('[')) {\n      try {\n        const obj = JSON.parse(s);\n        OrganizationId = obj?.OrganizationId ?? null;\n      } catch {\n        // Malformed JSON; fall back to treating as plain ID or first CSV part\n        OrganizationId = s.includes(',') ? s.split(',')[0].trim() : s;\n      }\n    } else {\n      OrganizationId = s.includes(',') ? s.split(',')[0].trim() : s;\n    }\n  } else {\n    OrganizationId = String(appContext).trim() || null;\n  }\n}\n\nOrganizationId = String(OrganizationId ?? '').trim();\nOrganizationId = /^\\d+$/.test(OrganizationId) ? OrganizationId : null;\n\nconst result = {OrganizationId};\nreturn result;"
          },
          "outcomes": {
            "success": "1767760652134"
          },
          "code": "CHECK_ORGANIZATION",
          "id": "1767815766370",
          "inputs": [

          ],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
