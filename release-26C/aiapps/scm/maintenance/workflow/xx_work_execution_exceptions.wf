        {
          "metadata": {
            "name": "Prepare Work Execution Filters",
            "returnType": "object",
            "sourceCode": "const rawOrganizationId = String($context?.$variables?.OrganizationId ?? \"\").trim();\nconst organizationId = /^\\d+$/.test(rawOrganizationId) ? rawOrganizationId : '';\n\nreturn {\n  organizationId,\n  fields: '*',\n  onlyData: true,\n  limit: 25,\n  offset: 0\n};"
          },
          "outcomes": {
            "success": "1767761046590"
          },
