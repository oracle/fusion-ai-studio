        {
          "metadata": {
            "name": "Calculate date range",
            "returnType": "object",
            "sourceCode": "// Get current date (may be string or Date depending on platform)\nconst today = $context.$system.$currentDate ;\n\n// StartDate = today - 30 days\nconst startDateObj = new Date(today);\nstartDateObj.setDate(startDateObj.getDate() - 30);\n\n// EndDate = today + 7 days\nconst endDateObj = new Date(today);\nendDateObj.setDate(endDateObj.getDate() + 7);\n\n// RangeEnd = today\nconst rangeEndObj = new Date(today);\nrangeEndObj.setDate(rangeEndObj.getDate());\n\nconst StartDate = startDateObj.toISOString().split('T')[0];\nconst EndDate = endDateObj.toISOString().split('T')[0];\nconst RangeEnd = rangeEndObj.toISOString().split('T')[0];\nconst Limit = 100;\n\n//Get Org Context\nconst appContext = $context.$app.$OraAppContext ?? $context.$triggers.REST.$input.OraAppContext;\nlet OrganizationId = null;\n\nif (appContext != null && String(appContext).trim() != '') {\n  if (typeof appContext === 'object') {\n    OrganizationId = appContext?.OrganizationId ?? null;\n  } else if (typeof appContext === 'number') {\n    OrganizationId = String(appContext);\n  } else if (typeof appContext === 'string') {\n    const s = appContext.trim();\n    if (s.startsWith('{') || s.startsWith('[')) {\n      try {\n        const obj = JSON.parse(s);\n        OrganizationId = obj?.OrganizationId ?? null;\n      } catch {\n        // Malformed JSON; fall back to treating as plain ID or first CSV part\n        OrganizationId = s.includes(',') ? s.split(',')[0].trim() : s;\n      }\n    } else {\n      OrganizationId = s.includes(',') ? s.split(',')[0].trim() : s;\n    }\n  } else {\n    OrganizationId = String(appContext).trim() || null;\n  }\n}\n\nconst result = {StartDate, EndDate, RangeEnd, Limit, OrganizationId};\nreturn result;"
          },
          "outcomes": {
            "success": "1767760652134"
          },
          "code": "CALCULATE_DATE_RANGE",
