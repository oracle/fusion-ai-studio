        {
          "metadata": {
            "name": "Prepare Current Work Order Filters",
            "returnType": "object",
            "sourceCode": "const RangeEnd = String($context?.$variables?.RangeEnd ?? \"\").trim();\nconst OrganizationId = String($context?.$variables?.OrganizationId ?? \"\").trim();\n\nif (!/^\\d{4}-\\d{2}-\\d{2}$/.test(RangeEnd)) {\n  throw new Error('Invalid RangeEnd. Expected YYYY-MM-DD.');\n}\n\nif (!/^\\d+$/.test(OrganizationId)) {\n  throw new Error('Invalid OrganizationId. Expected digits only.');\n}\n\nreturn {\n  pEndRange: RangeEnd,\n  pOrganizationId: OrganizationId,\n  pWorkOrders: 'OPEN'\n};"
          },
          "outcomes": {
            "success": "1767761046590"
          },
          "code": "PREPARE_CURRENT_WORK_ORDER_FILTERS",
          "id": "1772000000001",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "type": "CODE",
