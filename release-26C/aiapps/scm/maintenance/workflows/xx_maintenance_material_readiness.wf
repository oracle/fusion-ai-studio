        {
          "metadata": {
            "name": "Get Invoke Action Payload",
            "returnType": "object",
            "sourceCode": "const rawInput =\n  $context?.$app?.$OraAction ??\n  $context?.$triggers?.REST?.$input?.OraAction ??\n  null;\n\nlet payload = null;\nlet OrganizationId = null;\nlet WorkOrderNumber = null;\n\nif (rawInput != null) {\n  try {\n    payload = typeof rawInput === 'object' ? rawInput : JSON.parse(String(rawInput));\n    OrganizationId = payload?.OrganizationId ?? payload?.organizationId ?? null;\n    WorkOrderNumber = payload?.WorkOrderNumber ?? payload?.workOrderNumber ?? null;\n  } catch {\n    payload = String(rawInput);\n  }\n}\n\nconst workOrderNumber = String(WorkOrderNumber ?? '').trim();\nconst workOrderNumberList = /^[A-Za-z0-9 _./-]{1,80}$/.test(workOrderNumber) ? `'${workOrderNumber}'` : '';\n\nreturn { payload, OrganizationId, WorkOrderNumber, workOrderNumberList };"
          },
