        {
          "metadata": {
            "name": "Calculate date range",
            "returnType": "object",
            "sourceCode": "const rawToday = $context?.$system?.$currentDate;\nconst baseDate = rawToday ? new Date(rawToday) : new Date();\nconst today = Number.isNaN(baseDate.getTime()) ? new Date() : baseDate;\nconst formatDate = (value) => value.toISOString().split('T')[0];\n\nconst startDateObj = new Date(today);\nstartDateObj.setDate(startDateObj.getDate() - 30);\n\nconst endDateObj = new Date(today);\nendDateObj.setDate(endDateObj.getDate() + 7);\n\nconst rangeStartObj = new Date(today);\nrangeStartObj.setDate(rangeStartObj.getDate() + 1);\n\nconst rangeEndObj = new Date(today);\nrangeEndObj.setDate(rangeEndObj.getDate() + 30);\n\nconst StartDate = formatDate(startDateObj);\nconst EndDate = formatDate(endDateObj);\nconst RangeStart = formatDate(rangeStartObj);\nconst RangeEnd = formatDate(rangeEndObj);\nconst Limit = 100;\n\nconst appContext = $context?.$app?.$OraAppContext ?? $context?.$triggers?.REST?.$input?.OraAppContext;\nlet OrganizationId = null;\n\nif (appContext !== null && appContext !== undefined) {\n  if (typeof appContext === 'object') {\n    OrganizationId = appContext?.OrganizationId != null ? String(appContext.OrganizationId).trim() : null;\n  } else if (typeof appContext === 'number') {\n    OrganizationId = String(appContext);\n  } else if (typeof appContext === 'string') {\n    const s = appContext.trim();\n    if (s) {\n      if (s.startsWith('{') || s.startsWith('[')) {\n        try {\n          const obj = JSON.parse(s);\n          OrganizationId = obj?.OrganizationId != null ? String(obj.OrganizationId).trim() : null;\n        } catch {\n          OrganizationId = s.includes(',') ? s.split(',')[0].trim() : s;\n        }\n      } else {\n        OrganizationId = s.includes(',') ? s.split(',')[0].trim() : s;\n      }\n    }\n  } else {\n    const normalized = String(appContext).trim();\n    OrganizationId = normalized || null;\n  }\n}\n\nreturn { StartDate, EndDate, RangeStart, RangeEnd, Limit, OrganizationId };"
          },
          "outcomes": {
            "success": "1767760652134"
          },
