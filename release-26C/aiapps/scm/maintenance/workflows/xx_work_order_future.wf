        {
          "metadata": {
            "name": "Prepare Future Work Orders",
            "returnType": "object",
            "sourceCode": "const rawItems = $context?.$nodes?.FETCH_WORK_ORDERS?.$output?.items ?? [];\nconst items = Array.isArray(rawItems) ? rawItems : [];\n\nconst toDate = (v) => {\n  const s = String(v ?? \"\").trim();\n  const d = s ? new Date(s) : null;\n  return d && !Number.isNaN(d.getTime()) ? d : null;\n};\n\nconst formatDate = (v) => {\n  const d = toDate(v);\n  if (!d) return \"\";\n  return d.toLocaleDateString(\"en-US\", {\n    month: \"numeric\",\n    day: \"numeric\",\n    year: \"2-digit\"\n  });\n};\n\nconst futureWorkOrdersByNumber = new Map();\nlet FutureCount = 0;\n\nfor (const it of items) {\n  const WorkOrderNumber = it?.WorkOrderNumber;\n  if (!WorkOrderNumber) continue;\n\n  FutureCount += 1;\n\n  const statusName = String(it?.[\"WorkOrderStatusInformation.WorkStatusName\"] ?? \"\").trim();\n  const normalizedStatus = statusName.toLowerCase();\n  const statusText = normalizedStatus.includes(\"unreleased\") ? \"Unreleased\" : \"Released\";\n\n  const rec = {\n    WorkOrderNumber,\n    WorkOrderType: it?.WorkOrderType,\n    WorkOrderDescription: String(it?.WorkOrderDescription ?? \"\").trim(),\n    AssetNumber: it?.WoaInformation?.[0]?.[\"WoaInformation.AssetInformation.AssetNumber\"] ?? it?.[\"WoaInformation.AssetInformation.AssetNumber\"],\n    AssetDescription: it?.WoaInformation?.[0]?.[\"WoaInformation.AssetInformation.AssetDescription\"] ?? it?.[\"WoaInformation.AssetInformation.AssetDescription\"],\n    WorkStatusName: statusName,\n    ResourceAssignCode: it?.ResourceAssignCode,\n    PlannedStartDate: formatDate(it?.PlannedStartDate),\n    PlannedStartDateDisplay: formatDate(it?.PlannedStartDate),\n    PlannedCompletionDate: formatDate(it?.PlannedCompletionDate),\n    WorkOrderPriority: it?.WorkOrderPriority,\n    FutureFlag: true,\n    StatusBadge: { type: \"badge\", text: statusText }\n  };\n  futureWorkOrdersByNumber.set(WorkOrderNumber, rec);\n}\n\nconst FutureWorkOrders = Array.from(futureWorkOrdersByNumber.values());\n\nreturn { FutureCount, FutureWorkOrders };"
          },
          "outcomes": {
            "success": "1767762459641"
          },
          "code": "PREPARE_FUTURE_WORK_ORDERS",
          "id": "1771594150914",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "type": "CODE",
          "diagram": {
