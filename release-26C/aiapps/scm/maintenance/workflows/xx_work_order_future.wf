        {
          "metadata": {
            "name": "Prepare Future Work Order Filters",
            "returnType": "object",
            "sourceCode": "const RangeStart = String($context?.$variables?.RangeStart ?? '').trim();\nconst RangeEnd = String($context?.$variables?.RangeEnd ?? '').trim();\nconst OrganizationId = String($context?.$variables?.OrganizationId ?? \"\").trim();\n\nif (!/^\\d{4}-\\d{2}-\\d{2}$/.test(RangeStart)) {\n  throw new Error('Invalid RangeStart. Expected YYYY-MM-DD.');\n}\n\nif (!/^\\d{4}-\\d{2}-\\d{2}$/.test(RangeEnd)) {\n  throw new Error('Invalid RangeEnd. Expected YYYY-MM-DD.');\n}\n\nif (!/^\\d+$/.test(OrganizationId)) {\n  throw new Error('Invalid OrganizationId. Expected digits only.');\n}\n\nreturn {\n  pWorkOrders: 'OPEN_FUTURE',\n  pStartRange: RangeStart,\n  pEndRange: RangeEnd,\n  pOrganizationId: OrganizationId\n};"
          },
          "outcomes": {
            "success": "1767761046590"
          },
