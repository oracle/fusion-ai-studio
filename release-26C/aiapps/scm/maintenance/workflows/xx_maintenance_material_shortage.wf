        {
          "id": "1782800000014",
          "code": "GET_DISTINCT_UOM_VALUES",
          "type": "CODE",
          "metadata": {
            "name": "Get Distinct UOM Values",
            "description": "Collect all distinct unit of measure values across itemAtOrgs.",
            "returnType": "object",
            "sourceCode": "const itemAtOrgs = Array.isArray($context.$variables.itemAtOrgs) ? $context.$variables.itemAtOrgs : [];\nconst values = itemAtOrgs\n  .map((item) => item?.PrimaryUOMCode ?? null)\n  .filter((value) => value !== null && value !== undefined && String(value).trim() !== '')\n  .map((value) => String(value).trim());\nconst distinctUnitOfMeasures = [...new Set(values)];\nreturn { distinctUnitOfMeasures };"
          },
          "outcomes": {
            "success": "1782800000015"
          },
          "inputs": [

          ],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "diagram": {
            "x": 5316.5,
            "y": 7480
          }
        },
        {
          "metadata": {
            "name": "Set Distinct UOM Values"
          },
          "outcomes": {
            "success": "1782811825566"
          },
          "code": "SET_DISTINCT_UOM_VALUES",
          "id": "1782800000015",
          "inputs": [
            {
              "id": "1782800000005_1",
              "name": "distinctUnitOfMeasures",
              "scope": "JOB",
              "type": "array",
              "value": "{{$context.$nodes.GET_DISTINCT_UOM_VALUES.$output.result.distinctUnitOfMeasures}}"
            }
          ],
          "type": "SET_FIELDS",
          "diagram": {
            "x": 5316.5,
            "y": 7702
          }
        },
        {
          "id": "1782811825566",
          "code": "BUILD_UOM_QUERY",
          "type": "CODE",
          "metadata": {
            "name": "Build UOM Query",
            "description": "Build q filter for unit of measure lookup from distinct unit codes.",
            "returnType": "object",
            "sourceCode": "const distinctUnitOfMeasures = Array.isArray($context.$variables.distinctUnitOfMeasures) ? $context.$variables.distinctUnitOfMeasures : [];\n\nconst safeCodes = distinctUnitOfMeasures\n  .map((value) => String(value).trim())\n  .filter((value) => /^[A-Za-z0-9_-]{1,30}$/.test(value));\n\nconst quotedValues = [...new Set(safeCodes)]\n  .map((value) => `'${value}'`);\n\nconst uomCodeList = quotedValues.join(',');\nreturn { uomCodeList };"
          },
          "outcomes": {
            "success": "1782811825567"
          },
          "inputs": [

          ],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "diagram": {
            "x": 5316.5,
            "y": 7924
          }
        },
        {
          "id": "1782734670583",
          "code": "VERIFY_ITEM_AVAILABLE_AT_ORGS",
          "type": "CONDITION",
          "convergenceTargetId": "end",
          "metadata": {
