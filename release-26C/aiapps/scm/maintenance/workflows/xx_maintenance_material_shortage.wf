              "required": false
            }
          ]
        },
        {
          "id": "1782811825568",
          "code": "CLEAN_UNITS_OF_MEASURE_NAME_DATA",
          "type": "CODE",
          "metadata": {
            "name": "Clean Units Of Measure Name Data",
            "description": "Remove @context and normalize units of measure lookup rows.",
            "returnType": "object",
            "sourceCode": "const rows = Array.isArray($context.$nodes.FETCH_UNITS_OF_MEASURE_NAME.$output.items) ? $context.$nodes.FETCH_UNITS_OF_MEASURE_NAME.$output.items : [];\nconst cleanedUnitsOfMeasure = rows.map((row) => {\n  const cleanedRow = { ...row };\n  delete cleanedRow['@context'];\n  return cleanedRow;\n});\nreturn { cleanedUnitsOfMeasure };"
          },
          "outcomes": {
            "success": "1782811825569"
          },
          "inputs": [

          ],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "diagram": {
            "x": 5292.5,
            "y": 8368
          }
        },
        {
          "id": "1782811825569",
          "code": "UPDATE_ITEM_AVAILABILITY",
          "type": "CODE",
          "metadata": {
            "name": "Update Item Availability",
            "description": "Enrich item availability rows with resolved UOM names.",
            "returnType": "object",
            "sourceCode": "const itemAtOrgs = Array.isArray($context.$variables.itemAtOrgs) ? $context.$variables.itemAtOrgs : [];\nconst cleanedUnitsOfMeasure = Array.isArray($context.$nodes.CLEAN_UNITS_OF_MEASURE_NAME_DATA.$output.result.cleanedUnitsOfMeasure) ? $context.$nodes.CLEAN_UNITS_OF_MEASURE_NAME_DATA.$output.result.cleanedUnitsOfMeasure : [];\nconst uomMap = new Map(\n  cleanedUnitsOfMeasure\n    .filter((row) => row && row.UOMCode)\n    .map((row) => [String(row.UOMCode).trim(), row.UOM])\n);\nconst updatedItemAtOrgs = itemAtOrgs.map((item) => {\n  const uomCode = item?.PrimaryUOMCode ? String(item.PrimaryUOMCode).trim() : '';\n  return {\n    ...item,\n    UOM: uomMap.get(uomCode) ?? item?.UOM ?? item?.PrimaryUOMCode ?? ''\n  };\n});\nreturn { updatedItemAtOrgs };"
          },
          "outcomes": {
            "success": "1782811825570"
          },
          "inputs": [

          ],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "diagram": {
            "x": 5316.5,
            "y": 8590
          }
        },
