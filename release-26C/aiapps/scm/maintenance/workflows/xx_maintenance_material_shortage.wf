        {
          "metadata": {
            "name": "Get Invoke Action Payload",
            "returnType": "object",
            "sourceCode": "const rawInput =\n  $context?.$app?.$OraAction ??\n  $context?.$triggers?.REST?.$input?.OraAction ??\n  null;\n\nlet payload = null;\nlet InventoryItemId = null;\n\nif (rawInput != null) {\n  try {\n    payload = typeof rawInput === 'object' ? rawInput : JSON.parse(String(rawInput));\n    InventoryItemId = payload?.InventoryItemId ?? payload?.inventoryItemId ?? null;\n  } catch {\n    payload = String(rawInput);\n  }\n}\n\nconst inventoryItemId = String(InventoryItemId ?? '').trim();\nInventoryItemId = /^\\d+$/.test(inventoryItemId) ? inventoryItemId : '';\n\nreturn { payload, InventoryItemId };"
          },
          "outcomes": {
            "success": "1782800000002"
          },
