                    "name": "Append Additional Information",
                    "returnType": "object",
                    "sourceCode": "let retValue = {};\n\nlet InventoryItemId = $context.$nodes.GET_ITEM_SHORTAGE_ADDITIONAL_DATA.$currentItem.InventoryItemId;\nlet OrganizationId = $context.$nodes.GET_ITEM_SHORTAGE_ADDITIONAL_DATA.$currentItem.OrganizationId;\nlet ItemNumber = $context.$nodes.GET_ITEM_SHORTAGE_ADDITIONAL_DATA.$currentItem.Material;\nlet ItemDescription = $context.$nodes.GET_ITEM_SHORTAGE_ADDITIONAL_DATA.$currentItem.MaterialDescription;\nlet UOM = $context.$nodes.GET_ITEM_SHORTAGE_ADDITIONAL_DATA.$currentItem.UnitOfMeasure;\nlet RequiredQuantity = $context.$nodes.GET_ITEM_SHORTAGE_ADDITIONAL_DATA.$currentItem.RequiredQuantity;\nlet OpenQuantity = $context.$nodes.GET_ITEM_SHORTAGE_ADDITIONAL_DATA.$currentItem.OpenQuantity;\nlet ShortageQuantity = $context.$nodes.GET_ITEM_SHORTAGE_ADDITIONAL_DATA.$currentItem.ShortageQuantity;\nlet OrgsWithStock = ($context.$nodes.GET_ITEM_SHORTAGE_ADDITIONAL_DATA.FETCH_ON_HAND?.$output?.items ?? []).filter(r => (Number(r?.OnhandQuantity ?? 0) || 0) > 0).length;\n\nif (OrgsWithStock <= 0) {\n  return null;\n}\n\nretValue = { InventoryItemId, OrganizationId, ItemNumber, ItemDescription, UOM, RequiredQuantity, OpenQuantity, ShortageQuantity, OrgsWithStock };\n\nreturn retValue;"
                  },
