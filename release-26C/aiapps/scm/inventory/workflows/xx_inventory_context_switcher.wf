              "value": "{{$context.$nodes.GET_ORGANIZATION_ID.$output.items.length === 0}}"
            }
          ],
          "type": "CONDITION"
        },
        {
          "metadata": {
            "name": "Set Empty Organization App Context",
            "returnType": "object",
            "sourceCode": "const appContextId = JSON.stringify({ organizationId: -1 });\n\nreturn {\n  name: \"All Organizations\",\n  appContext: appContextId\n};\n\n"
          },
          "outcomes": {
            "success": "end"
          },
          "code": "SET_EMPTY_ORGANIZATION_APP_CONTEXT",
          "id": "1782305495146",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "type": "CODE"
        },
        {
          "metadata": {
            "name": "Set Default Organization App Context",
            "returnType": "object",
            "sourceCode": "const defaultOutput = $context.$nodes.DEFAULT_ORGANIZATION.$output || {};\nconst defaultItems = defaultOutput.items || [];\nconst defaultOrganizationId =\n  (defaultItems[0] && defaultItems[0].ProfileOptionValue) ||\n  defaultOutput.ProfileOptionValue ||\n  \"\";\n\nconst detailOutput = $context.$nodes.GET_DEFAULT_ORGANIZATION_DETAILS.$output || {};\nconst detailItems = detailOutput.items || [];\nconst organization = detailItems[0] || {};\n\nlet organizationId =\n  organization.OrganizationId ||\n  organization.organizationId ||\n  defaultOrganizationId;\n\nlet organizationName =\n  organization.OrganizationName ||\n  organization.organizationName;\n\nif (organizationId === undefined || organizationId === null || organizationId === \"\") {\n  organizationId = -1;\n}\n\nif (!organizationName && organizationId === -1) {\n  organizationName = \"All Organizations\";\n}\n\nconst appContextId = JSON.stringify({\n  organizationId: organizationId\n});\n\nreturn {\n  name: organizationName,\n  appContext: appContextId\n};"
          },
          "outcomes": {
            "success": "end"
          },
          "code": "SET_DEFAULT_ORGANIZATION_APP_CONTEXT",
          "id": "1782305554254",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "type": "CODE"
        },
        {
          "metadata": {
            "businessObjectCode": "ORA_SCM_INVENTORYM_XX_INVENTORYORGANIZATIONSLIST",
            "functionName": "getDefaultOrganizationName",
            "name": "Get Default Organization Details"
          },
          "outcomes": {
            "success": "1782305554254"
          },
