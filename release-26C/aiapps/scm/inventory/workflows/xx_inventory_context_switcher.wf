          "convergenceTargetId": "end",
          "id": "1782304813335",
          "inputs": [
            {
              "id": "1782304813335_condition",
              "name": "condition",
              "type": "string",
              "value": "{{!!$context.$nodes.DEFAULT_ORGANIZATION.$output.items?.[0]?.ProfileOptionValue}}"
