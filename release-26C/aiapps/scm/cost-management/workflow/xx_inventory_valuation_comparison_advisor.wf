              "value": "The selected organisation or Book does not exist in SCM Inventory"
            }
          ]
        },
        {
          "id": "1782374848142",
          "code": "PROCESSING_ORGANIZATION_CONTEXT",
          "type": "CODE",
          "metadata": {
            "name": "Processing Organization Context",
            "description": "Parses the provided app context so the next node can set the valuation period, cost book, and cost organization variables.",
            "sourceCode": "let context =  $context.$app.$OraAppContext;\n\nconst values = context.trim().split(':');\n\nconst numericIdPattern = /^\\d+$/;\nconst periodIdPattern = /^[A-Za-z]{3}-\\d{2}$/;\n\nif (values[2]) {\n  const [month, year] = values[2].split(\"-\");\n  values[3] = `${month}-${Number(year) - 1}`;\n}\n\nconst isValid = \n  values.length >= 3 &&\n  numericIdPattern.test(values[0]) &&\n  numericIdPattern.test(values[1]) &&\n  periodIdPattern.test(values[2]) &&\n  periodIdPattern.test(values[3])\n\nvalues[4] = isValid ? \"1\" : \"0\";\n\nreturn values;",
            "returnType": "array",
            "errorNodeId": "1782381843533"
          },
          "diagram": {
            "x": 4851.944818451136,
            "y": 5038.3377504301
          },
          "outcomes": {
            "success": "1783057828445"
          },
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
        {
          "id": "1782375747436",
          "code": "FETCH_COST_BOOK_CODE",
          "type": "BO_FUNCTION",
          "metadata": {
            "name": "Fetch Cost Book Code",
            "description": "Retrieves the cost book code for the selected cost book identifier.",
            "businessObjectCode": "ORA_SCM_XX_COSTMANAGE_INVENTORYVALUATIONCOMPARISONADVISOR",
            "functionName": "getCostBookCode",
            "errorNodeId": "1782381843533"
          },
          "diagram": {
            "x": 4872.122474541086,
            "y": 5372.97512095778
          },
          "outcomes": {
            "success": "1782331356930"
          },
          "inputs": [
            {
              "id": "1782375747436_CostBookId",
              "name": "CostBookId",
              "value": "{{$context.$nodes.PROCESSING_ORGANIZATION_CONTEXT.$output.result[1]}}",
              "required": false,
              "type": "string"
            }
