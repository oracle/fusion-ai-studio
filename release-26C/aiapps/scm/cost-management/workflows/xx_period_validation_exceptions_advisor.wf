        {
          "metadata": {
            "description": "Parses the provided app context so the next node can set the valuation period, cost book, and cost organization variables.",
            "errorNodeId": "1782382468028",
            "name": "Processing Organization Context",
            "returnType": "array",
            "sourceCode": "let context =  $context.$app.$OraAppContext;\nconst values = context.trim().split(':');\n\nconst numericIdPattern = /^\\d+$/;\nconst periodIdPattern = /^[A-Za-z]{3}-\\d{2}$/;\n\nconst isValid = \n  values.length >= 3 &&\n  numericIdPattern.test(values[0]) &&\n  numericIdPattern.test(values[1]) &&\n  periodIdPattern.test(values[2])\n\n\nvalues[3] = isValid ? \"1\" : \"0\";\nreturn values;"
          },
          "outcomes": {
            "success": "1783057128281"
          },
          "code": "PROCESSING_ORGANIZATION_CONTEXT",
          "id": "1782382487628",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "type": "CODE",
