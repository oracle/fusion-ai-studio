          "code": "FETCH_PERSON_LIFE_EVENTS_STATUS_AGGREGATION",
          "type": "BO_FUNCTION",
          "metadata": {
            "description": "",
            "name": "Fetch Person Life Events Status Aggregation",
            "businessObjectCode": "ORA_HCM_BENEFITS_XX_PERSONLIFEEVENTSTATUSAGGREGATIONS",
            "functionName": "get_aggregations_for_benefits_person_facet",
            "errorNodeId": "1783060157249"
