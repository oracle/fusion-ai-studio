  "objectProperties": {
    "jsonSchemaName": "supportedObjectProperties",
    "jsonSchemaVersion": 1,
    "tools": [
      {
        "name": "getDirectReportsForPerson",
        "description": "Get All Direct Reports under given employee",
        "operationType": "POST",
        "resourcePath": "/hcmRestApi/resources/11.13.18.05/myTeamDetails/action/findByObject",
        "resourceType": "ADF_BC_FIXED_QUERY",
        "bodyTemplate": "{\n    \"personId\": {pPersonId},\n    \"assignmentId\": {pAssignmentId},\n    \"objectType\": \"workers\",\n    \"viewType\": \"employment\",\n    \"autocompleteQuery\": null,\n    \"searchFields\": [\n        \"DisplayName\"\n    ],\n    \"displayFields\": [],\n    \"filters\": [\n        {\n            \"name\": [\n                \"ManagerReports\"\n            ],\n            \"terms\": [\n                \"DIRECTS\"\n            ]\n        },\n        {\n            \"name\": [\n                \"ManagerReportingRelationship\"\n            ],\n            \"terms\": [\n                \"Line manager\"\n            ]\n        },\n        {\n            \"name\": [\n                \"TotalHeadcount\"\n            ],\n            \"terms\": [\n                \"Y\"\n            ]\n        }\n    ],\n    \"offset\": 0\n}",
        "useNativeAuthentication": true,
        "type": "BUS_OBJECT",
        "parameterDefinitions": [
          {
            "name": "pPersonId",
            "dataType": "string",
            "description": "Person Id of employee for whom direct reports are required to fetch",
            "id": 2,
            "isToken": true,
            "location": "body",
            "source": "placeholder",
            "defaultValue": ""
          },
          {
            "name": "pAssignmentId",
            "dataType": "string",
            "description": "Assignment Id of employee for whom direct reports are required to fetch",
            "id": 3,
            "isToken": true,
            "location": "body",
            "source": "placeholder",
            "defaultValue": ""
          }
        ],
        "headers": {
          "content-type": "application/vnd.oracle.adf.action+json"
        },
        "sampleQueries": [
          {
            "description": "Get All Direct Reports under given employee",
            "query": {
              "pPersonId": "<pPersonId>",
              "pAssignmentId": "<pAssignmentId>"
            },
            "sampleType": "request"
          }
        ]
      }
    ]
  }
