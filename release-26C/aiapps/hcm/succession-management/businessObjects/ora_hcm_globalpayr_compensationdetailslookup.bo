      {
        "name": "getCompensationHistory",
        "description": "Retrieves the salary history of a worker assignment using the assignment ID and salary history start date. It returns the salary amount, annual salary, currency, and salary effective date range.",
        "operationType": "GET",
        "resourcePath": "/hcmRestApi/resources/11.13.18.05/compensationInfoSalaries?finder=findAssignmentSalaryHistory;AssignmentId={pAssignmentId},EffectiveStartDate={pDate}&onlyData=true&fields=SalaryAmount,AnnualSalary,AnnualFullTimeSalary,CurrencyCode,DateFrom,DateTo",
        "resourceType": "ADF_BC_FIXED_QUERY",
        "bodyTemplate": "",
        "useNativeAuthentication": true,
        "type": "BUS_OBJECT",
        "parameterDefinitions": [
          {
            "name": "pAssignmentId",
            "dataType": "string",
            "description": "To store the assignment id of an employee.",
