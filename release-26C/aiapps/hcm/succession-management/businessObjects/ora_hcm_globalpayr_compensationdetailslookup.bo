        "resourcePath": "/hcmRestApi/resources/11.13.18.05/compensationInfoSalaries?finder=findByAssignmentIdAndDate;EffectiveDate={EffectiveDate}&q=AssignmentId IN ({employees})&expand=salaryComponents,salarySimpleComponents,salaryPayRateComponents",
