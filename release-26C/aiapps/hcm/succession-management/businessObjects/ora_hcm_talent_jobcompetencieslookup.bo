        "name": "getProfileIdbyPersonId",
        "description": "Retrieves ProfileId for a given PersonId",
        "operationType": "GET",
        "resourcePath": "/hcmRestApi/resources/11.13.18.05/talentModelProfiles?finder=findEmployeeJobProfile;PersonId={pPersonId}&fields=ProfileId,ProfileCode,Name&onlyData=true",
        "resourceType": "ADF_BC_FIXED_QUERY",
        "bodyTemplate": "",
        "useNativeAuthentication": true,
        "type": "BUS_OBJECT",
        "parameterDefinitions": [
