            "name": "pPersonId",
            "dataType": "string",
            "description": "Person id of the role holder",
            "id": 2,
            "isToken": true,
            "location": "query",
            "source": "placeholder",
            "defaultValue": ""
          }
        ],
        "headers": {
          "REST-Framework-Version": "9"
        },
        "sampleQueries": [
          {
            "description": "To get Profile Id of a person",
            "query": {
              "items": [
                {
                  "ProfileId": "<profile id>",
                  "ProfileCode": "<profile code>",
                  "Name": "<name>"
                }
              ],
              "count": "<count>",
              "hasMore": "<has more>",
              "limit": "<limit>",
              "offset": "<offset>"
            },
            "sampleType": "response"
          }
        ]
      },
