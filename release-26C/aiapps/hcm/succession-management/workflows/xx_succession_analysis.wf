        {
          "id": "1781185759867",
          "code": "VALIDATE_PERSON",
          "type": "CODE",
          "metadata": {
            "name": "Validate Person",
            "returnType": "boolean",
            "sourceCode": "function clean(value) {\n  return value === undefined || value === null ? \"\" : String(value).trim();\n}\n\nconst appContext = $context.$variables.appContext || {};\nconst data = appContext.data || {};\nconst pId = clean(data.pId);\nconst aId = clean(data.aId);\nconst managerAId = clean(data.managerAId);\n\nreturn /^\\d+$/.test(pId) && /^\\d+$/.test(aId) && /^\\d+$/.test(managerAId);"
          },
          "diagram": {
            "x": 6300.5,
            "y": 5428
          },
