        {
          "id": "1781252595446",
          "code": "FETCH_DIRECT_REPORTS_FOR_LOGGEDIN_EMPLOYEE",
          "type": "BO_FUNCTION",
          "metadata": {
            "businessObjectCode": "ORA_HCM_SUCCESSION_XX_SUCCESSIONDETAILSLOOKUP",
            "functionName": "getSuccessionForDirectReportsUnderManager",
            "name": "Fetch Direct Reports For Loggedin Employee"
          },
          "diagram": {
            "x": 5712.5,
            "y": 6094
          },
          "outcomes": {
            "success": "1781252662931"
          },
          "inputs": [
            {
              "id": "1777027124914_1",
              "name": "pAssignmentId",
              "value": "{{$context.$nodes.FETCH_LOGGEDIN_EMPLOYEE_CONTEXT.$output.items[0].AssignmentId}}",
              "required": false
            }
          ]
        },
        {
          "id": "1781252662931",
          "code": "VALIDATE_PERSONS",
          "type": "CODE",
          "metadata": {
            "name": "Validate Persons",
            "returnType": "boolean",
            "sourceCode": "function clean(value) {\n  return value === undefined || value === null ? \"\" : String(value).trim();\n}\n\nconst appContext = $context.$variables.appContext || {};\nconst data = appContext.data || {};\nconst res = $context.$nodes.FETCH_DIRECT_REPORTS_FOR_LOGGEDIN_EMPLOYEE.$output || {};\nconst loggedInContext = $context.$nodes.FETCH_LOGGEDIN_EMPLOYEE_CONTEXT.$output || {};\nconst loggedInItems = loggedInContext.items || [];\nconst loggedInAssignmentId = clean(loggedInItems[0] && loggedInItems[0].AssignmentId);\n\nconst targetPersonId = clean(data.pId);\nconst targetAssignmentId = clean(data.aId);\nconst targetManagerAssignmentId = clean(data.managerAId);\n\nconst idsAreNumeric =\n  /^\\d+$/.test(targetPersonId) &&\n  /^\\d+$/.test(targetAssignmentId) &&\n  /^\\d+$/.test(targetManagerAssignmentId) &&\n  /^\\d+$/.test(loggedInAssignmentId);\n\nif (!idsAreNumeric) {\n  return false;\n}\n\nconst directReports = res.items || [];\nconst directReportMatches = directReports.some(item =>\n  clean(item && item.PersonId) === targetPersonId &&\n  clean(item && item.AssignmentId) === targetAssignmentId\n);\n\nreturn directReportMatches && targetManagerAssignmentId === loggedInAssignmentId;"
          },
          "diagram": {
            "x": 5781.5,
            "y": 6316
          },
          "outcomes": {
            "success": "1781252795984"
          },
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
