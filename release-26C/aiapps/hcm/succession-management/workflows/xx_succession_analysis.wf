          "code": "FETCH_PERFORMANCE_RATING_DETAILS_FOR_PERSON",
          "id": "1775459205483",
          "inputs": [
            {
              "id": "1775459205483_pPersonId",
              "name": "pPersonId",
              "value": "{{$context.$variables.appContext.data.pId}}",
              "required": false
