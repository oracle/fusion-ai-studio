            "returnType": "string",
            "sourceCode": "let res = $context.$nodes.FETCH_ALL_DIRECT_REPORTS_UNDER_MANAGER.$output ;\n\nlet ids = res.items.map(i => i.AssignmentId).join(\",\");\n\nlet idString = `(${ids})`;\n\nidString;"
          },
