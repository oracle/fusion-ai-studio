            "sourceCode": "let managerPId = $context.$nodes.PARSE_ACTION_PAYLOAD.$output.result.data.managerPId;\nlet aId = $context.$nodes.PARSE_ACTION_PAYLOAD.$output.result.data.aId;\nlet managerName = $context.$nodes.PARSE_ACTION_PAYLOAD.$output.result.data.managerName;\nlet pName = $context.$nodes.PARSE_ACTION_PAYLOAD.$output.result.data.pName;\n\nreturn /^\\d+$/.test(managerPId) && /^\\d+$/.test(aId) && String(managerName).trim() !== \"\" && String(pName).trim() !== \"\";"
