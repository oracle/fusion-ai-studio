        {
          "metadata": {
            "name": "Sanitize Succession Data",
            "returnType": "object",
            "sourceCode": "function sanitizeText(value, maxLen) {\n    maxLen = maxLen || 200;\n\n    if (value === null || value === undefined) {\n        return \"\";\n    }\n\n    let s = String(value);\n\n    // Remove HTML/script-sensitive chars\n    s = s.replace(new RegExp(\"[<>\\\"'&]\", \"g\"), \"\");\n\n    s = s.trim().slice(0, maxLen);\n\n    return s;\n}\n\nconst managerName = sanitizeText(\n    $context.$nodes.PARSE_ACTION_PAYLOAD.$output.result.data.managerName\n);\n\nconst pName = sanitizeText(\n    $context.$nodes.PARSE_ACTION_PAYLOAD.$output.result.data.pName\n);\n\nreturn {\n    managerName: managerName,\n    pName: pName\n};",
            "description": ""
          },
          "outcomes": {
            "success": "1773643629396"
          },
          "code": "SANITIZE_SUCCESSION_DATA",
          "id": "1773488758016",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
