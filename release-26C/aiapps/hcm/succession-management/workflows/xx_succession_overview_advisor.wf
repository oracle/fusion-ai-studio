        {
          "id": "1781166413536",
          "code": "VALIDATE_PERSONID_AND_ASSIGNMENTID",
          "type": "CODE",
          "metadata": {
            "description": "",
            "name": "Validate PersonId and AssignmentId",
            "returnType": "boolean",
            "sourceCode": "let pId =$context.$nodes.PARSE_ACTION_PAYLOAD.$output.result.data.pId;\nlet aId = $context.$nodes.PARSE_ACTION_PAYLOAD.$output.result.data.aId;\nlet managerPId=$context.$nodes.PARSE_ACTION_PAYLOAD.$output.result.data.managerPId;\nlet managerAId=$context.$nodes.PARSE_ACTION_PAYLOAD.$output.result.data.managerAId;\n\nreturn /^\\d+$/.test(pId) && /^\\d+$/.test(aId)&&/^\\d+$/.test(managerPId) && /^\\d+$/.test(managerAId);"
          },
