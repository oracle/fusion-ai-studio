        {
          "metadata": {
            "name": "Parse Action Payload",
            "returnType": "object",
            "sourceCode": "const allowedCommands = new Set([\n  \"rowNavigate\",\n  \"successionCandidates\",\n  \"addSuccessor\",\n  \"viewSuccessorDetails\",\n  \"viewSuccessorInfo\"\n]);\n\nconst allowedDataKeys = new Set([\n  \"pId\",\n  \"aId\",\n  \"managerPId\",\n  \"managerAId\",\n  \"managerName\",\n  \"pName\"\n]);\n\nconst viewSuccessorInfoDataKeys = new Set([\n  \"Employee Name\",\n  \"Person Id\",\n  \"Assignment Id\",\n  \"Current job title\",\n  \"Fit Score\",\n  \"Common skills\",\n  \"Matching competencies\",\n  \"Performance level\"\n]);\n\nconst requiredViewSuccessorInfoDataKeys = [\n  \"Employee Name\",\n  \"Person Id\",\n  \"Assignment Id\",\n  \"Current job title\",\n  \"Fit Score\",\n  \"Common skills\",\n  \"Matching competencies\",\n  \"Performance level\"\n];\n\nconst idKeys = new Set([\"pId\", \"aId\", \"managerPId\", \"managerAId\"]);\nconst viewSuccessorInfoIdKeys = new Set([\"Person Id\", \"Assignment Id\"]);\n\nfunction reject(error) {\n  return { valid: false, error, command: null, data: {} };\n}\n\nfunction extractOraInvokePayload(text) {\n  const value = String(text).trim();\n  if (!/^ora\\.Invoke\\s*\\(/.test(value)) {\n    return value;\n  }\n\n  const firstBrace = value.indexOf(\"{\");\n  const lastBrace = value.lastIndexOf(\"}\");\n  if (firstBrace === -1 || lastBrace === -1 || lastBrace <= firstBrace) {\n    return value;\n  }\n\n  return value.slice(firstBrace, lastBrace + 1);\n}\n\nfunction normalizeBacktickValues(text) {\n  return String(text)\n    .replace(/`([^`]*)`/g, function (match, value) {\n      return JSON.stringify(String(value).trim());\n    })\n    .replace(/:\\s*`(\\d{1,18})\\s*\"/g, function (match, value) {\n      return \": \" + JSON.stringify(value);\n    });\n}\n\nfunction parseActionPayload(oraAction) {\n  if (typeof oraAction !== \"string\") {\n    return oraAction;\n  }\n\n  const payloadText = extractOraInvokePayload(oraAction);\n  try {\n    return JSON.parse(payloadText);\n  } catch (e) {\n    return JSON.parse(normalizeBacktickValues(payloadText));\n  }\n}\n\nfunction mergeExtrasIntoData(obj) {\n  const data = (obj && typeof obj.data === \"object\" && !Array.isArray(obj.data)) ? { ...obj.data } : {};\n\n  for (const [key, value] of Object.entries(obj || {})) {\n    if (key !== \"command\" && key !== \"data\") {\n      data[key] = value;\n    }\n  }\n\n  return { command: obj.command, data };\n}\n\nfunction normalizePayload(payload) {\n  if (!payload || typeof payload !== \"object\" || Array.isArray(payload)) {\n    return payload;\n  }\n\n  // Wraps like: { action: { text, command: \"ora.Invoke(...)\" } }\n  if (payload.action && typeof payload.action === \"object\") {\n    const actionCommand = payload.action.command;\n    if (typeof actionCommand === \"string\") {\n      return normalizePayload(parseActionPayload(actionCommand));\n    }\n  }\n\n  // Direct invoke string stored in command\n  if (typeof payload.command === \"string\" && /^ora\\.Invoke\\s*\\(/.test(payload.command.trim())) {\n    return normalizePayload(parseActionPayload(payload.command));\n  }\n\n  // Normal { command, data } payload\n  if (\n    typeof payload.command === \"string\" &&\n    payload.data &&\n    typeof payload.data === \"object\" &&\n    !Array.isArray(payload.data)\n  ) {\n    return mergeExtrasIntoData(payload);\n  }\n\n  // Flat successor payload without command/data wrapper\n  const looksLikeViewSuccessorInfo =\n    Object.prototype.hasOwnProperty.call(payload, \"Employee Name\") ||\n    Object.prototype.hasOwnProperty.call(payload, \"Person Id\") ||\n    Object.prototype.hasOwnProperty.call(payload, \"Assignment Id\") ||\n    Object.prototype.hasOwnProperty.call(payload, \"Current job title\") ||\n    Object.prototype.hasOwnProperty.call(payload, \"Fit Score\") ||\n    Object.prototype.hasOwnProperty.call(payload, \"Common skills\") ||\n    Object.prototype.hasOwnProperty.call(payload, \"Matching competencies\") ||\n    Object.prototype.hasOwnProperty.call(payload, \"Performance level\");\n\n  if (looksLikeViewSuccessorInfo) {\n    return {\n      command: \"viewSuccessorInfo\",\n      data: { ...payload }\n    };\n  }\n\n  return payload;\n}\n\nfunction isAllowedDataKey(command, key) {\n  return allowedDataKeys.has(key) || (\n    command === \"viewSuccessorInfo\" && viewSuccessorInfoDataKeys.has(key)\n  );\n}\n\nfunction shouldValidateId(command, key) {\n  return idKeys.has(key) || (\n    command === \"viewSuccessorInfo\" && viewSuccessorInfoIdKeys.has(key)\n  );\n}\n\nconst app = $context.$app || {};\nconst oraAction = app.$OraAction;\n\nif (!oraAction) {\n  return reject(\"missing $OraAction\");\n}\n\nlet payload;\ntry {\n  payload = normalizePayload(parseActionPayload(oraAction));\n} catch (e) {\n  return reject(\"malformed action payload\");\n}\n\nif (!payload || typeof payload !== \"object\" || Array.isArray(payload)) {\n  return reject(\"invalid action payload\");\n}\n\nif (!payload.command) {\n  return reject(\"missing action command\");\n}\n\nif (!allowedCommands.has(payload.command)) {\n  return reject(\"unsupported action command: \" + String(payload.command));\n}\n\nconst data = payload.data || {};\nif (!data || typeof data !== \"object\" || Array.isArray(data)) {\n  return reject(\"invalid action data\");\n}\n\nfor (const key of Object.keys(data)) {\n  if (!isAllowedDataKey(payload.command, key)) {\n    return reject(\"unsupported action data key: \" + key);\n  }\n}\n\nif (payload.command === \"viewSuccessorInfo\") {\n  for (const key of requiredViewSuccessorInfoDataKeys) {\n    if (!Object.prototype.hasOwnProperty.call(data, key)) {\n      return reject(\"missing successor data key: \" + key);\n    }\n  }\n}\n\nfor (const key of Object.keys(data)) {\n  if (data[key] !== undefined && shouldValidateId(payload.command, key)) {\n    const value = String(data[key]).trim();\n    if (!/^\\d{1,18}$/.test(value)) {\n      return reject(\"invalid \" + key);\n    }\n    if (idKeys.has(key)) {\n      data[key] = value;\n    }\n  }\n}\n\nreturn {\n  valid: true,\n  command: payload.command,\n  data,\n  error: null\n};",
            "sourceType": "code"
          },
          "outcomes": {
            "success": "1781270000001"
          },
