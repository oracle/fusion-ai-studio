          "code": "VALIDATE_PERSON_AND_MANAGER",
          "type": "CODE",
          "metadata": {
            "description": "",
            "name": "Validate Person and Manager",
            "returnType": "boolean",
            "sourceCode": "const res = $context.$nodes.FETCH_DIRECT_REPORTS_FOR_LOGGEDIN_EMPLOYEE.$output;\nconst targetPersonId = $context.$nodes.PARSE_ACTION_PAYLOAD.$output.result.data.pId;\n\nconst managerAId = $context.$nodes.PARSE_ACTION_PAYLOAD.$output.result.data.managerAId;\n\nconst personExists = (res.items ?? []).some(\n  item => String(item.PersonId) === String(targetPersonId)\n);\n\nreturn personExists && String(managerAId) === String($context.$nodes.FETCH_LOGGEDIN_EMPLOYEE_CONTEXT.$output.items[0].AssignmentId);"
          },
