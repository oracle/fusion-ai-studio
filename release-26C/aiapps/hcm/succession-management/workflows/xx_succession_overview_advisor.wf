            "name": "Sanitize Potential Candidate Details",
            "returnType": "object",
            "sourceCode": "function scrubString(value) {\n  return String(value)\n    .replace(/[\\u0000-\\u001F\\u007F-\\u009F]/g, \" \")\n    .replace(/[<>]/g, \"\")\n    .replace(/\\s+/g, \" \")\n    .trim();\n}\n\nfunction scrub(value) {\n  if (typeof value === \"string\") {\n    return scrubString(value);\n  }\n  if (Array.isArray(value)) {\n    return value.map(function(item) {\n      return scrub(item);\n    });\n  }\n  if (value && typeof value === \"object\") {\n    const clean = {};\n    Object.keys(value).forEach(function(key) {\n      clean[key] = scrub(value[key]);\n    });\n    return clean;\n  }\n  return value;\n}\n\nreturn scrub({ candidateDetails: $context.$nodes.GET_POTENTIAL_CANDIDATE_SUCCESSION_DETAILS.$output, salaryInfo: $context.$nodes.GET_POTENTIAL_CANDIDATE_SALARY.$output, performanceInfo: $context.$nodes.GET_POTENTIAL_CANDIDATE_TALENT_RATINGS.$output });"
