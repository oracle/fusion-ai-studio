        {
          "id": "1781164852166",
          "code": "VALIDATE_PERSON_AND_MANAGER_FOR_SUCCESSION",
          "type": "CODE",
          "metadata": {
            "name": "Validate Person and Manager For Succession",
            "returnType": "boolean",
            "sourceCode": "const res = $context.$nodes.FETCH_DIRECT_REPORTS_FOR_LOGGEDIN_EMPLOYEE.$output;\nconst result = $context.$nodes.FETCH_DIRECT_REPORTS_FOR_PERSON.$output;\nconst targetPersonId = $context.$nodes.PARSE_ACTION_PAYLOAD.$output.result.data.pId;\nconst managerPId = $context.$nodes.PARSE_ACTION_PAYLOAD.$output.result.data.managerPId;\n\nconst personExists1 = (res.items ?? []).some(\n  item => String(item.PersonId) === String(targetPersonId)\n);\n\nconst personExists2 = (result.items ?? []).some(\n  item => String(item.PersonId) === String(targetPersonId)\n);\n\nconst managerPIdExists = (res.items ?? []).some(\n  item => String(item.PersonId) === String(managerPId)\n);\n\n\nreturn (personExists1 || personExists2) && managerPIdExists;",
            "sourceType": "code"
          },
