        {
          "id": "1782100000031",
          "code": "SANITIZE_IMPACT_DETAILS_FOR_DIRECT_REPORTS",
          "type": "CODE",
          "metadata": {
            "description": "Sanitizes HCM data before LLM rendering by stripping control characters, newlines, and angle brackets from string fields.",
            "name": "Sanitize Impact Details For Direct Reports",
            "returnType": "object",
            "sourceCode": "function scrubString(value) {\n  return String(value)\n    .replace(/[\\u0000-\\u001F\\u007F-\\u009F]/g, \" \")\n    .replace(/[<>]/g, \"\")\n    .replace(/\\s+/g, \" \")\n    .trim();\n}\n\nfunction scrub(value) {\n  if (typeof value === \"string\") {\n    return scrubString(value);\n  }\n  if (Array.isArray(value)) {\n    return value.map(function(item) {\n      return scrub(item);\n    });\n  }\n  if (value && typeof value === \"object\") {\n    const clean = {};\n    Object.keys(value).forEach(function(key) {\n      clean[key] = scrub(value[key]);\n    });\n    return clean;\n  }\n  return value;\n}\n\nreturn scrub($context.$nodes.FETCH_IMPACT_DETAILS_FOR_DIRECT_REPORTS.$output.output);"
          },
          "diagram": {
            "x": 5280,
            "y": 5700
          },
          "outcomes": {
            "success": "1776079162540"
          },
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": [\n        \"object\",\n        \"array\",\n        \"string\",\n        \"number\",\n        \"boolean\",\n        \"null\"\n      ]\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
        {
          "id": "1782100000032",
          "code": "SANITIZE_IMPACT_QUERY_RESPONSE",
          "type": "CODE",
          "metadata": {
            "description": "Sanitizes HCM data before LLM rendering by stripping control characters, newlines, and angle brackets from string fields.",
            "name": "Sanitize Impact Query Response",
            "returnType": "object",
            "sourceCode": "function scrubString(value) {\n  return String(value)\n    .replace(/[\\u0000-\\u001F\\u007F-\\u009F]/g, \" \")\n    .replace(/[<>]/g, \"\")\n    .replace(/\\s+/g, \" \")\n    .trim();\n}\n\nfunction scrub(value) {\n  if (typeof value === \"string\") {\n    return scrubString(value);\n  }\n  if (Array.isArray(value)) {\n    return value.map(function(item) {\n      return scrub(item);\n    });\n  }\n  if (value && typeof value === \"object\") {\n    const clean = {};\n    Object.keys(value).forEach(function(key) {\n      clean[key] = scrub(value[key]);\n    });\n    return clean;\n  }\n  return value;\n}\n\nreturn scrub($context.$nodes.PROCESS_USER_QUERY.$output.output);"
          },
          "diagram": {
            "x": 5842.5,
            "y": 5700
          },
          "outcomes": {
            "success": "1776079311505"
          },
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        }
