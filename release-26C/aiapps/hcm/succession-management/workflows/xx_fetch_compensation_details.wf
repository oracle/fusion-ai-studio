            "name": "Validate Persons",
            "returnType": "boolean",
            "sourceCode": "let aIds = $context.$nodes.AGGREGATE_ASSIGNMENTS.$output.result;\n\nreturn String(aIds)\n  .split(\",\")\n  .every(id => /^\\d+$/.test(id.trim()));"
          },
