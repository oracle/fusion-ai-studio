        {
          "metadata": {
            "name": "Aggregate Assignments",
            "returnType": "string",
            "sourceCode": "const res = $context.$nodes.FETCH_DIRECT_REPORTS_FOR_LOGGEDIN_EMPLOYEE.$output;\n\nconst result = (res.items ?? [])\n  .map(i => i.AssignmentId)\n  .filter(Boolean)\n  .join(\",\");\n\nresult;"
          },
          "outcomes": {
            "success": "1781180816751"
          },
          "code": "AGGREGATE_ASSIGNMENTS",
          "id": "1777043471982",
          "inputs": [],
