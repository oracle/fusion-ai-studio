        {
          "id": "1781360000001",
          "code": "SANITIZE_EMPLOYEE_EDITABLE_FIELD_DATA",
          "type": "CODE",
          "metadata": {
            "description": "Sanitizes employee-editable HCM fields before successor ranking prompts.",
            "name": "Sanitize Employee Editable Field Data",
            "returnType": "object",
            "sourceCode": "function scrubString(value) {\n  return String(value)\n    .replace(/[\\u0000-\\u001F\\u007F-\\u009F]/g, \" \")\n    .replace(/[<>]/g, \"\")\n    .replace(/\\s+/g, \" \")\n    .trim();\n}\n\nfunction scrub(value) {\n  if (typeof value === \"string\") {\n    return scrubString(value);\n  }\n  if (Array.isArray(value)) {\n    return value.map(function(item) {\n      return scrub(item);\n    });\n  }\n  if (value && typeof value === \"object\") {\n    const clean = {};\n    Object.keys(value).forEach(function(key) {\n      clean[key] = scrub(value[key]);\n    });\n    return clean;\n  }\n  return value;\n}\n\nreturn {\n  Peers: scrub($context.$nodes.GET_PEERS_OF_CANDIDATE.$output || {}),\n  DirectReports: scrub($context.$nodes.GET_DIRECT_REPORTS_OF_CANDIDATE.$output || {}),\n  PeersTalentRatings: scrub($context.$nodes.GET_TALENT_RATINGS_OF_PEERS.$output || {}),\n  DirectReportsTalentRatings: scrub($context.$nodes.GET_TALENT_RATINGS_OF_DIRECT_REPORTS.$output || {}),\n  PeersSkills: scrub($context.$nodes.GET_SKILLS_OF_PEERS.$output || {}),\n  DirectReportsSkills: scrub($context.$nodes.GET_SKILLS_OF_DIRECT_REPORTS.$output || {}),\n  PeersCompetencies: scrub($context.$nodes.GET_COMPETENCIES_OF_PEERS.$output || {}),\n  DirectReportsCompetencies: scrub($context.$nodes.GET_COMPETENCIES_OF_DIRECT_REPORTS.$output || {}),\n  JobCompetencies: scrub($context.$nodes.GET_JOB_COMPETENCIES.$output || {})\n};"
          },
          "diagram": {
            "x": 5327,
            "y": 9860
          },
          "outcomes": {
            "success": "1776678905453"
          },
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": [\n        \"object\",\n        \"array\",\n        \"string\",\n        \"number\",\n        \"boolean\",\n        \"null\"\n      ]\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
