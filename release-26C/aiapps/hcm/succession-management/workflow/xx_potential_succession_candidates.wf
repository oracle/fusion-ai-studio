        {
          "id": "1781263583155",
          "code": "VALIDATE_SELECTED_PERSON_IN_PEERS",
          "type": "CODE",
          "metadata": {
            "description": "Validate that the requested selected person is in the logged-in manager direct-report set before ranking successors.",
            "name": "Validate Selected Person In Peers",
            "returnType": "object",
            "sourceCode": "function clean(value) {\n  return value === undefined || value === null ? \"\" : String(value).trim();\n}\n\nconst selectedPersonId = clean($context.$triggers.REST.$input.pId);\nconst peerOutput = $context.$nodes.GET_PEERS_OF_CANDIDATE && $context.$nodes.GET_PEERS_OF_CANDIDATE.$output || {};\nconst result = peerOutput.result || {};\nconst peers = result.items || [];\n\nif (!/^\\d+$/.test(selectedPersonId)) {\n  return { valid: false, selectedPersonId };\n}\n\nconst valid = peers.some(peer =>\n  clean(peer && peer.PersonId) === selectedPersonId\n);\n\nreturn { valid, selectedPersonId };"
          },
          "diagram": {
            "x": 5543,
            "y": 5872
          },
          "outcomes": {
            "success": "1781263727243"
          },
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
