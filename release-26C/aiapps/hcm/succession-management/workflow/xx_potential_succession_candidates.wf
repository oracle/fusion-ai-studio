          "id": "1781263727243",
          "code": "CHECK_SELECTED_PERSON_IN_PEERS",
          "type": "CONDITION",
          "convergenceTargetId": "end",
          "metadata": {
            "description": "Route only validated selected-person requests to the candidate ranking step.",
            "name": "Check Selected Person In Peers"
          },
          "diagram": {
            "x": 5556.5,
            "y": 6094
          },
          "outcomes": {
            "false": "1781263748560",
            "true": "1773125019350"
          },
