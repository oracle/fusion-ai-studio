: \"string\"\n                    },\n                    \"ProficiencyLevelCode\": {\n                      \"type\": \"integer\"\n                    }\n                  },\n                  \"required\": [\n                    \"SkillName\",\n                    \"ProficiencyLevelCode\"\n                  ],\n                  \"additionalProperties\": false\n                }\n              },\n              \"Matching competencies\": {\n                \"type\": \"array\",\n                \"items\": {\n                  \"type\": \"object\",\n                  \"properties\": {\n                    \"CompetencyName\": {\n                      \"type\": \"string\"\n                    },\n                    \"ProficiencyRatingCode\": {\n                      \"type\": \"integer\"\n                    }\n                  },\n                  \"required\": [\n                    \"CompetencyName\",\n                    \"ProficiencyRatingCode\"\n                  ],\n                  \"additionalProperties\": false\n                }\n              },\n              \"Performance level\": {\n                \"type\": \"object\",\n                \"properties\": {\n                  \"PerformanceLevel\": {\n                    \"type\": \"string\"\n                  },\n                  \"PerformanceLevelCode\": {\n                    \"type\": \"integer\"\n                  },\n                  \"AssignmentId\": {\n                    \"type\": \"integer\"\n                  }\n                },\n                \"required\": [\n                  \"PerformanceLevel\",\n                  \"PerformanceLevelCode\",\n                  \"AssignmentId\"\n                ],\n                \"additionalProperties\": false\n              }\n            },\n            \"required\": [\n              \"Employee Name\",\n              \"Person Id\",\n              \"Assignment Id\",\n              \"Current job title\",\n              \"Fit Score\",\n              \"Common skills\",\n              \"Matching competencies\",\n              \"Performance level\"\n            ],\n            \"additionalProperties\": false\n          }\n        }\n      },\n      \"required\": [\n        \"Summary\",\n        \"Selected Person\",\n        \"RankedSuccessors\"\n      ],\n      \"additionalProperties\": false\n    }\n  },\n  \"required\": [\n    \"result\"\n  ],\n  \"additionalProperties\": false\n}",
