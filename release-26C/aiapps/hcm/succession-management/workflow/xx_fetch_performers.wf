            "name": "Validate Persons",
            "returnType": "boolean",
            "sourceCode": "let pIds = $context.$nodes.AGGREGATE_PERSONS.$output.result;\n\nreturn String(pIds)\n  .split(\",\")\n  .every(id => /^\\d+$/.test(id.trim()));"
          },
