            "name": "Check for Input Message",
            "returnType": "string",
            "sourceCode": "if($context.$system.$inputMessage === \"Top Performers\" || $context.$system.$inputMessage === \"Bottom Performers\"){\n    return $context.$system.$inputMessage;\n}\nelse\n    return \"Query\";"
          },
          "outcomes": {
            "success": "1777027285710"
          },
          "code": "CHECK_FOR_INPUT_MESSAGE",
          "id": "1777034583202",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"required\": [\n    \"output\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "type": "CODE",
