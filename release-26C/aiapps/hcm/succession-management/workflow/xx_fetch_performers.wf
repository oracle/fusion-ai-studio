            "name": "Aggregate Persons",
            "returnType": "string",
            "sourceCode": "const res = $context.$nodes.FETCH_DIRECT_REPORTS_FOR_LOGGEDIN_EMPLOYEE.$output;\n\nconst result = (res.items ?? [])\n  .map(i => i.PersonId)\n  .filter(Boolean)\n  .join(\",\");\n\nresult;"
          },
