        {
          "metadata": {
            "name": "Bottom Performers",
            "returnType": "object",
            "sourceCode": "const input = $context.$nodes.FETCH_PERFORMANCE_RATINGS_FOR_DIRECT_REPORTS.$output;\n\nreturn (input?.items || [])\n  .map(item => {\n    const perf = item.performanceRatings?.items?.find(p => p.ToDate === null);\n    if (!perf) return null;\n\n    return {\n      EmployeeName: item.DisplayName,\n      PersonId: item.PersonId,\n      AssignmentId: perf.AssignmentId,\n      PerformanceLevelCode: Number(perf.PerformanceLevelCode),\n      PerformanceLevel: perf.PerformanceLevel\n    };\n  })\n  .filter(item => item && item.PerformanceLevelCode <= 3)\n  .sort((a, b) => a.PerformanceLevelCode - b.PerformanceLevelCode);"
          },
          "outcomes": {
            "success": "end"
          },
          "code": "RETURN_BOTTOM_PERFORMERS",
          "id": "1777027378369",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "type": "CODE",
          "diagram": {
            "x": 5000,
            "y": 6800
          }
        },
        {
          "metadata": {
            "name": "Top Performers",
            "returnType": "object",
            "sourceCode": "const input = $context.$nodes.FETCH_PERFORMANCE_RATINGS_FOR_DIRECT_REPORTS.$output;\n\nreturn (input?.items || [])\n  .map(item => {\n    const perf = item.performanceRatings?.items?.find(p => p.ToDate === null);\n    if (!perf) return null;\n\n    return {\n      EmployeeName: item.DisplayName,\n      PersonId: item.PersonId,\n      AssignmentId: perf.AssignmentId,\n      PerformanceLevelCode: Number(perf.PerformanceLevelCode),\n      PerformanceLevel: perf.PerformanceLevel\n    };\n  })\n  .filter(item => item && item.PerformanceLevelCode > 3)\n  .sort((a, b) => b.PerformanceLevelCode - a.PerformanceLevelCode);"
          },
          "outcomes": {
            "success": "end"
          },
          "code": "TOP_PERFORMERS",
          "id": "1777027412744",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "type": "CODE",
          "diagram": {
            "x": 5450,
            "y": 6800
          }
