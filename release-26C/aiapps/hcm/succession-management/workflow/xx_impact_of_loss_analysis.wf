          },
          "inputs": [
            {
              "id": "1777027124914_1",
              "name": "pAssignmentId",
              "value": "{{$context.$nodes.FETCH_LOGGEDIN_EMPLOYEE_CONTEXT.$output.items[0].AssignmentId}}",
