          ]
        },
        {
          "id": "1781253941569",
          "code": "VALIDATE_PERSONS",
          "type": "CODE",
          "metadata": {
            "name": "Validate Persons",
            "returnType": "boolean",
            "sourceCode": "function clean(value) {\n  return value === undefined || value === null ? \"\" : String(value).trim();\n}\n\nconst appContext = $context.$variables.appContext || {};\nconst data = appContext.data || {};\nconst res = $context.$nodes.FETCH_DIRECT_REPORTS_FOR_LOGGEDIN_EMPLOYEE.$output || {};\nconst loggedInContext = $context.$nodes.FETCH_LOGGEDIN_EMPLOYEE_CONTEXT.$output || {};\nconst loggedInItems = loggedInContext.items || [];\nconst loggedInAssignmentId = clean(loggedInItems[0] && loggedInItems[0].AssignmentId);\n\nconst targetPersonId = clean(data.pId);\nconst targetManagerAssignmentId = clean(data.managerAId);\n\nconst idsAreNumeric =\n  /^\\d+$/.test(targetPersonId) &&\n  /^\\d+$/.test(targetManagerAssignmentId) &&\n  /^\\d+$/.test(loggedInAssignmentId);\n\nif (!idsAreNumeric) {\n  return false;\n}\n\nconst directReports = res.items || [];\nconst directReportMatches = directReports.some(item =>\n  clean(item && item.PersonId) === targetPersonId\n);\n\nreturn directReportMatches && targetManagerAssignmentId === loggedInAssignmentId;"
          },
