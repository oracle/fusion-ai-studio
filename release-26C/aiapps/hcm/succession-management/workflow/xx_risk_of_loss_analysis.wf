            "name": "Validate Person and Manager",
            "returnType": "boolean",
            "sourceCode": "function clean(value) {\n  return value === undefined || value === null ? \"\" : String(value).trim();\n}\n\nconst appContext = $context.$variables.appContext || {};\nconst data = appContext.data || {};\nconst pId = clean(data.pId);\nconst managerAId = clean(data.managerAId);\n\nreturn /^\\d+$/.test(pId) && /^\\d+$/.test(managerAId);"
          },
