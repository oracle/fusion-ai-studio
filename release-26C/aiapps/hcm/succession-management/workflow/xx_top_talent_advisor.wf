        {
          "id": "1782100000001",
          "code": "SANITIZE_TOP_PERFORMERS_FOR_DIRECT_REPORTS",
          "type": "CODE",
          "metadata": {
            "description": "Sanitizes HCM data before LLM rendering by stripping control characters, newlines, and angle brackets from string fields.",
            "name": "Sanitize Top Performers For Direct Reports",
            "returnType": "object",
            "sourceCode": "function scrubString(value) {\n  return String(value)\n    .replace(/[\\u0000-\\u001F\\u007F-\\u009F]/g, \" \")\n    .replace(/[<>]/g, \"\")\n    .replace(/\\s+/g, \" \")\n    .trim();\n}\n\nfunction scrub(value) {\n  if (typeof value === \"string\") {\n    return scrubString(value);\n  }\n  if (Array.isArray(value)) {\n    return value.map(function(item) {\n      return scrub(item);\n    });\n  }\n  if (value && typeof value === \"object\") {\n    const clean = {};\n    Object.keys(value).forEach(function(key) {\n      clean[key] = scrub(value[key]);\n    });\n    return clean;\n  }\n  return value;\n}\n\nreturn scrub($context.$nodes.FETCH_TOP_PERFORMERS_FOR_DIRECT_REPORTS.$output.output);"
          },
          "diagram": {
            "x": 6210,
            "y": 5922
          },
          "outcomes": {
            "success": "INIT_DISPLAY_LLM"
          },
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": [\n        \"object\",\n        \"array\",\n        \"string\",\n        \"number\",\n        \"boolean\",\n        \"null\"\n      ]\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
        {
          "id": "1782100000002",
          "code": "SANITIZE_TOP_TALENT_QUERY_RESPONSE",
          "type": "CODE",
          "metadata": {
            "description": "Sanitizes HCM data before LLM rendering by stripping control characters, newlines, and angle brackets from string fields.",
            "name": "Sanitize Top Talent Query Response",
            "returnType": "object",
            "sourceCode": "function scrubString(value) {\n  return String(value)\n    .replace(/[\\u0000-\\u001F\\u007F-\\u009F]/g, \" \")\n    .replace(/[<>]/g, \"\")\n    .replace(/\\s+/g, \" \")\n    .trim();\n}\n\nfunction scrub(value) {\n  if (typeof value === \"string\") {\n    return scrubString(value);\n  }\n  if (Array.isArray(value)) {\n    return value.map(function(item) {\n      return scrub(item);\n    });\n  }\n  if (value && typeof value === \"object\") {\n    const clean = {};\n    Object.keys(value).forEach(function(key) {\n      clean[key] = scrub(value[key]);\n    });\n    return clean;\n  }\n  return value;\n}\n\nreturn scrub($context.$nodes.FETCH_QUERY_RESPONSE.$output.output);"
          },
          "diagram": {
            "x": 6771,
            "y": 5922
          },
          "outcomes": {
            "success": "DISPLAY_QUERY_LLM"
          },
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": [\n        \"object\",\n        \"array\",\n        \"string\",\n        \"number\",\n        \"boolean\",\n        \"null\"\n      ]\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        }
