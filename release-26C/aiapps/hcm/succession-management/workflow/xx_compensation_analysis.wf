        {
          "metadata": {
            "businessObjectCode": "ORA_HCM_GLOBALPAYR_XX_COMPENSATIONDETAILSLOOKUP",
            "functionName": "getCompensationHistory",
            "name": "Get Salary History Details For Person"
          },
          "outcomes": {
            "success": "1776794746183"
          },
          "code": "GET_SALARY_HISTORY_DETAILS_FOR_PERSON",
          "id": "1776064458356",
          "inputs": [
            {
              "id": "1776163835880_1",
              "name": "pAssignmentId",
              "value": "{{$context.$variables.appContext.data.aId}}",
              "required": true
            },
            {
              "id": "1776163835880_2",
              "name": "pDate",
