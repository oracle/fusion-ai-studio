          "type": "BO_FUNCTION",
          "diagram": {
            "x": 5040.5,
            "y": 6760
          }
        },
        {
          "metadata": {
            "name": "Fetch Compensation History",
            "returnType": "object",
            "sourceCode": "let items = $context.$nodes.GET_SALARY_HISTORY_DETAILS_FOR_PERSON.$output.items;\n\nconst currentYear = new Date().getFullYear();\n\n  let result = {}\n  for (let year = 2017; year <= currentYear; year++) {\n    let salaryForYear;\n\n    for (let i = 0; i < items.length; i++) {\n      const item = items[i];\n\n      const fromYear = new Date(item.DateFrom).getFullYear();\n      const toYear = new Date(item.DateTo).getFullYear();\n\n      if (year >= fromYear && year <= toYear) {\n        // since data is ordered, keep updating so last match wins\n        salaryForYear = item.AnnualSalary;\n      }\n    }\n\n    if (salaryForYear !== undefined) {\n      result [year] = salaryForYear;\n    }\n  }\n\nJSON.stringify(result);"
          },
          "outcomes": {
            "success": "1776064720106"
          },
          "code": "FETCH_COMPENSATION_HISTORY",
          "id": "1776794746183",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "type": "CODE",
          "diagram": {
            "x": 5087,
            "y": 6982
          }
        },
        {
          "aiAppOutputSpecification": {
            "dataDisplay": {
              "layouts": [
                "ORA_LAYOUT_CHART"
              ],
              "enableActions": false,
              "enableCommunications": false,
              "customNotes": "**DIRECTIVE:** Your sole purpose is to transform input compensation history data into a valid `oraInfoDisplay` XML block using the `chartWidget`.\n\n**ROOT CONFIGURATION:**\n\n1. `title`:  Do not include any title.\n2. `subtitle`: Do not include any subtitle.\n3. `description`: Do not include a `description` property.\n\n**STRICT MAPPING RULES:**\n\n1. `type`: Set this explicitly to `\"line\"` to render a line chart.\n2. Build a complete ordered year list from all keys in `$SalaryInfo`.\n3. `data.labels` must contain every year from that list.\n4. `data.datasets[0].data` must contain one value for every label, in the same order.\n5. Never hardcode a fixed year range.\n6. Never remove keys just because the year has no adjacent years.\n7. Ensure exactly one dataset is used.\n8. Do not include `insights` unless explicitly provided in the input.\n9. `data.datasets[0].label`: \"Annual Salary on yearly basis (in USD)\".\n\n\n**ACTION LOGIC:**\n\n* Do not include an `action` property.\n\n**FORMATTING CONSTRAINTS**\n* DO NOT add any extra information.\n\n** FINAL OUTPUT RULE:\n  * Return ONLY a single <oraInfoDisplay> XML block and NOTHING ELSE.\n  * No trailing text. No leading text. No explanations."
            }
          },
          "metadata": {
            "name": "Generate Compensation History Chart For Person"
          },
          "outcomes": {
            "success": "end"
          },
          "code": "GENERATE_COMPENSATION_HISTORY_CHART_FOR_PERSON",
          "id": "1776064720106",
          "inputs": [
            {
              "id": "1776064720107_1",
              "name": "prompt",
              "type": "string",
              "value": "SalaryInfo: {{$context.$nodes.FETCH_COMPENSATION_HISTORY.$output.result}} \n\nYou are a specialized UI rendering assistant for Employee Compensation Analytics. You must adhere to the standard oraInfoDisplay Knowledge Base.\n\n-Placeholder: $AssignmentName is in the list"
            }
          ],
          "type": "LLM",
          "diagram": {
            "x": 5000,
            "y": 7204
          }
        },
        {
          "id": "1781186391090",
          "code": "VALIDATE_PERSON",
          "type": "CODE",
          "metadata": {
            "name": "Validate Person",
            "returnType": "boolean",
            "sourceCode": "function clean(value) {\n  return value === undefined || value === null ? \"\" : String(value).trim();\n}\n\nconst appContext = $context.$variables.appContext || {};\nconst data = appContext.data || {};\nconst pId = clean(data.pId);\nconst aId = clean(data.aId);\nconst managerAId = clean(data.managerAId);\n\nreturn /^\\d+$/.test(pId) && /^\\d+$/.test(aId) && /^\\d+$/.test(managerAId);"
          },
          "diagram": {
