            "sourceCode": "let res = $context.$nodes.GET_WORKER_DETAILS.$output;\n\nlet count = 0;\n\nconst values = res?.facets?.[0]?.values;\n\nif (Array.isArray(values) && values.length > 0) {\n  count = Number(values[0]?.count) || 0;\n}\n\nreturn count;"
