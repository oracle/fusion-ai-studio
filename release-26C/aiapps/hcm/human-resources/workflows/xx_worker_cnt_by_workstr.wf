        {
          "id": "1777374374350",
          "code": "CREATE_PAYLOAD",
          "type": "CODE",
          "metadata": {
            "name": "Create Payload",
            "returnType": "object",
            "sourceCode": "function hasValue(v) {\n  return v !== null && v !== undefined && String(v).trim() !== \"\";\n}\n\nfunction addTermsFilter(filtersArray, name, value) {\n  if (hasValue(value)) {\n    filtersArray.push({\n      name: name,\n      terms: [String(value).trim()]\n    });\n  }\n}\n\nlet filtersArray = [];\nlet selectedFacet = null;\nlet selectedFacetValue = null;\n\n// Pick ONE input as facet + facetValueQuery (first non-empty in priority order)\nif (hasValue($context.$triggers.REST.$input.LocationName)) {\n  selectedFacet = \"LocationName\";\n  selectedFacetValue = $context.$triggers.REST.$input.LocationName;\n} else if (hasValue($context.$triggers.REST.$input.LocationCode)) {\n  selectedFacet = \"LocationCode\";\n  selectedFacetValue = $context.$triggers.REST.$input.LocationCode;\n} else if (hasValue($context.$triggers.REST.$input.JobName)) {\n  selectedFacet = \"JobName\";\n  selectedFacetValue = $context.$triggers.REST.$input.JobName;\n} else if (hasValue($context.$triggers.REST.$input.JobCode)) {\n  selectedFacet = \"JobCode\";\n  selectedFacetValue = $context.$triggers.REST.$input.JobCode;\n} else if (hasValue($context.$triggers.REST.$input.GradeName)) {\n  selectedFacet = \"GradeName\";\n  selectedFacetValue = $context.$triggers.REST.$input.GradeName;\n} else if (hasValue($context.$triggers.REST.$input.GradeCode)) {\n  selectedFacet = \"GradeCode\";\n  selectedFacetValue = $context.$triggers.REST.$input.GradeCode;\n} else if (hasValue($context.$triggers.REST.$input.DepartmentName)) {\n  selectedFacet = \"DepartmentName\";\n  selectedFacetValue = $context.$triggers.REST.$input.DepartmentName;\n} else if (hasValue($context.$triggers.REST.$input.PositionName)) {\n  selectedFacet = \"PositionName\";\n  selectedFacetValue = $context.$triggers.REST.$input.PositionName;\n} else if (hasValue($context.$triggers.REST.$input.PositionCode)) {\n  selectedFacet = \"PositionCode\";\n  selectedFacetValue = $context.$triggers.REST.$input.PositionCode;\n} else if (hasValue($context.$triggers.REST.$input.BusinessUnitName)) {\n  selectedFacet = \"BusinessUnitName\";\n  selectedFacetValue = $context.$triggers.REST.$input.BusinessUnitName;\n}\n\nlet payload = {\n  securityFilters: {\n    type: \"PersonSearch\",\n    value: \"AdvancedSearch\"\n  }\n};\n\nif (hasValue(selectedFacet)) {\n  payload.facets = [selectedFacet];\n}\n\nif (hasValue(selectedFacetValue)) {\n  payload.facetValueQuery = String(selectedFacetValue).trim();\n}\n\n// Add the rest as filters, skipping the selected facet field\nif (selectedFacet !== \"LocationName\") {\n  if (hasValue($context.$triggers.REST.$input.LocationName)) {\n    addTermsFilter(filtersArray, \"LocationName\", $context.$triggers.REST.$input.LocationName);\n  } else if (hasValue($context.$triggers.REST.$input.LocationCode)) {\n    addTermsFilter(filtersArray, \"LocationCode\", $context.$triggers.REST.$input.LocationCode);\n  }\n}\n\nif (selectedFacet !== \"JobName\") {\n  if (hasValue($context.$triggers.REST.$input.JobName)) {\n    addTermsFilter(filtersArray, \"JobName\", $context.$triggers.REST.$input.JobName);\n  } else if (hasValue($context.$triggers.REST.$input.JobCode)) {\n    addTermsFilter(filtersArray, \"JobCode\", $context.$triggers.REST.$input.JobCode);\n  }\n}\n\nif (selectedFacet !== \"GradeName\") {\n  if (hasValue($context.$triggers.REST.$input.GradeName)) {\n    addTermsFilter(filtersArray, \"GradeName\", $context.$triggers.REST.$input.GradeName);\n  } else if (hasValue($context.$triggers.REST.$input.GradeCode)) {\n    addTermsFilter(filtersArray, \"GradeCode\", $context.$triggers.REST.$input.GradeCode);\n  }\n}\n\nif (selectedFacet !== \"DepartmentName\") {\n  if (hasValue($context.$triggers.REST.$input.DepartmentName)) {\n    addTermsFilter(filtersArray, \"DepartmentName\", $context.$triggers.REST.$input.DepartmentName);\n  }\n}\n\nif (selectedFacet !== \"PositionName\") {\n  if (hasValue($context.$triggers.REST.$input.PositionName)) {\n    addTermsFilter(filtersArray, \"PositionName\", $context.$triggers.REST.$input.PositionName);\n  } else if (hasValue($context.$triggers.REST.$input.PositionCode)) {\n    addTermsFilter(filtersArray, \"PositionCode\", $context.$triggers.REST.$input.PositionCode);\n  }\n}\n\nif (selectedFacet !== \"BusinessUnitName\") {\n  if (hasValue($context.$triggers.REST.$input.BusinessUnitName)) {\n    addTermsFilter(filtersArray, \"BusinessUnitName\", $context.$triggers.REST.$input.BusinessUnitName);\n  }\n}\n\n// Only add filters if any exist\nif (filtersArray.length > 0) {\n  payload.filters = filtersArray;\n}\n\n\n$context.$variables.inputFacet = selectedFacetValue;\nreturn payload;\n"
          },
