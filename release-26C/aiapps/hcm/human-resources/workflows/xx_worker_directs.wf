        {
          "id": "1780300541407",
          "code": "CREATE_HIERARCHY",
          "type": "CODE",
          "metadata": {
            "name": "Create Hierarchy",
            "returnType": "string",
            "sourceCode": "const maxHierarchyLength = 65536;\nconst rawHierarchy = $context?.$nodes?.GET_PERSON_HIERARCHY?.$output?.output;\nlet parsedHierarchy = null;\n\nif (typeof rawHierarchy === \"string\" && rawHierarchy.length > 0 && rawHierarchy.length <= maxHierarchyLength) {\n  try {\n    parsedHierarchy = JSON.parse(rawHierarchy);\n  } catch (e) {\n    parsedHierarchy = null;\n  }\n} else if (rawHierarchy && typeof rawHierarchy === \"object\") {\n  parsedHierarchy = rawHierarchy;\n}\n\nconst hierarchy = parsedHierarchy && Array.isArray(parsedHierarchy.result)\n  ? parsedHierarchy.result.slice(0, 100)\n  : [];\n\nconst normalizeName = function (value) {\n  if (typeof value !== \"string\") return null;\n  const normalized = value.replace(/[\\u0000-\\u001F\\u007F]/g, \" \").trim();\n  return normalized ? normalized.slice(0, 240) : null;\n};\n\nconst names = [];\nfor (let index = 0; index < hierarchy.length; index += 1) {\n  const name = normalizeName(hierarchy[index]?.DisplayName);\n  if (name) names.push(name);\n}\n\nconst currentName = normalizeName($context?.$nodes?.GET_PERSON_DETAILS?.$output?.DisplayName);\nif (currentName) names.push(currentName);\n\nreturn names.join(\" -> \");"
          },
          "diagram": {
