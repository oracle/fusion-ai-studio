  \"required\": [\n                        \"key\",\n                        \"headers\"\n                      ],\n                      \"additionalProperties\": false\n                    }\n                  },\n                  \"required\": [\n                    \"TagId\",\n                    \"Tag\",\n                    \"ContentItemId\",\n                    \"@context\"\n                  ],\n                  \"additionalProperties\": false\n                }\n              },\n              \"count\": {\n                \"type\": \"number\"\n              },\n              \"hasMore\": {\n                \"type\": \"boolean\"\n              },\n              \"limit\": {\n                \"type\": \"number\"\n              },\n              \"offset\": {\n                \"type\": \"number\"\n              },\n              \"links\": {\n                \"type\": \"array\",\n                \"items\": {\n                  \"type\": \"object\",\n                  \"properties\": {\n                    \"rel\": {\n                      \"type\": \"string\"\n                    },\n                    \"href\": {\n                      \"type\": \"string\"\n                    },\n                    \"name\": {\n                      \"type\": \"string\"\n                    },\n                    \"kind\": {\n                      \"type\": \"string\"\n                    }\n                  },\n                  \"required\": [\n                    \"rel\",\n                    \"href\",\n                    \"name\",\n                    \"kind\"\n                  ],\n                  \"additionalProperties\": false\n                }\n              }\n            },\n            \"required\": [\n              \"items\",\n              \"count\",\n              \"hasMore\",\n              \"limit\",\n              \"offset\",\n              \"links\"\n            ],\n            \"additionalProperties\": false\n          },\n          \"skillSections\": {\n            \"type\": \"object\",\n            \"properties\": {\n              \"items\": {\n                \"type\": \"array\"\n              },\n              \"count\": {\n                \"type\": \"number\"\n              },\n              \"hasMore\": {\n                \"type\": \"boolean\"\n              },\n              \"limit\": {\n                \"type\": \"number\"\n              },\n              \"offset\": {\n                \"type\": \"number\"\n              },\n              \"links\": {\n                \"type\": \"array\",\n                \"items\": {\n                  \"type\": \"object\",\n                  \"properties\": {\n                    \"rel\": {\n                      \"type\": \"string\"\n                    },\n                    \"href\": {\n                      \"type\": \"string\"\n                    },\n                    \"name\": {\n                      \"type\": \"string\"\n                    },\n                    \"kind\": {\n                      \"type\": \"string\"\n                    }\n                  },\n                  \"required\": [\n                    \"rel\",\n                    \"href\",\n                    \"name\",\n                    \"kind\"\n                  ],\n                  \"additionalProperties\": false\n                }\n              }\n            },\n            \"required\": [\n              \"items\",\n              \"count\",\n              \"hasMore\",\n              \"limit\",\n              \"offset\",\n              \"links\"\n            ],\n            \"additionalProperties\": false\n          },\n          \"@context\": {\n            \"type\": \"object\",\n            \"properties\": {\n              \"key\": {\n                \"type\": \"string\"\n              },\n              \"headers\": {\n                \"type\": \"object\",\n                \"properties\": {\n                  \"ETag\": {\n                    \"type\": \"string\"\n                  }\n                },\n                \"required\": [\n                  \"ETag\"\n                ],\n                \"additionalProperties\": false\n              }\n            },\n            \"required\": [\n              \"key\",\n              \"headers\"\n            ],\n            \"additionalProperties\": false\n          }\n        },\n        \"required\": [\n          \"ProfileId\",\n          \"Summary\",\n          \"CareerAmbassadorFlag\",\n          \"CareerAmbassadorSummary\",\n          \"favoriteLinks\",\n          \"areasOfExpertise\",\n          \"areasOfInterest\",\n          \"tags\",\n          \"skillSections\",\n          \"@context\"\n        ],\n        \"additionalProperties\": false\n      }\n    },\n    \"count\": {\n      \"type\": \"number\"\n    },\n    \"hasMore\": {\n      \"type\": \"boolean\"\n    },\n    \"limit\": {\n      \"type\": \"number\"\n    },\n    \"offset\": {\n      \"type\": \"number\"\n    },\n    \"links\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"rel\": {\n            \"type\": \"string\"\n          },\n          \"href\": {\n            \"type\": \"string\"\n          },\n          \"name\": {\n            \"type\": \"string\"\n          },\n          \"kind\": {\n            \"type\": \"string\"\n          }\n        },\n        \"required\": [\n          \"rel\",\n          \"href\",\n          \"name\",\n          \"kind\"\n        ],\n        \"additionalProperties\": false\n      }\n    }\n  },\n  \"required\": [\n    \"items\",\n    \"count\",\n    \"hasMore\",\n    \"limit\",\n    \"offset\",\n    \"links\"\n  ],\n  \"additionalProperties\": false\n}"
