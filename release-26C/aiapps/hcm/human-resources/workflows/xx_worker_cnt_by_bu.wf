        {
          "id": "1777027019626",
          "code": "GET_WORKERS_CNT_BY_BUSINESSUNIT_NAME",
          "type": "BO_FUNCTION",
          "metadata": {
            "businessObjectCode": "ORA_HCM_GLOBALHUMA_PERSONSEARCHESGHR",
            "functionName": "GetWorkersCountByBusinessUnitName",
            "processJson": true,
            "name": "Get Worker Count by Business Unit Name",
            "description": "Returns the number of workers whose business unit name matches the supplied value."
          },
          "outcomes": {
            "success": "1777027070708"
          },
          "inputs": [
            {
              "id": "1777027046125_1",
              "name": "businessUnitName",
              "type": "string",
              "value": "{{$context.$triggers.REST.$input.businessUnitName}}",
              "required": true
            }
          ],
          "diagram": {
            "x": 4673,
            "y": 5690
          },
          "convergenceTargetId": "1778058611972",
          "outputSpecification": "{}"
        },
        {
          "id": "1777027070708",
          "code": "GET_WORKERS_CNT",
          "type": "CODE",
          "metadata": {
            "name": "Get Worker Count",
            "returnType": "number",
            "sourceCode": "const type = $context.$nodes.GET_QUERY_TYPE.$output.result;\nconst input = $context.$triggers.REST.$input || {};\nlet response = {};\n\nif (type === \"BusinessUnitName\") {\n  response = $context.$nodes.GET_WORKERS_CNT_BY_BUSINESSUNIT_NAME.$output ?? {};\n}\n\nconst values = response?.facets?.[0]?.values ?? [];\nconst match = values.find((item) => String(item?.value) === String(input.businessUnitName));\nreturn Number(match?.count ?? values[0]?.count ?? 0);"
          },
          "outcomes": {
            "success": "end"
          },
          "inputs": [],
          "diagram": {
            "x": 5000,
            "y": 5912
          },
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
