          "code": "GET_QUERY_TYPE",
          "type": "CODE",
          "metadata": {
            "name": "Get Query Type",
            "returnType": "string",
            "sourceCode": "const input = $context.$triggers.REST.$input || {};\nconst hasValue = (value) => value !== null && value !== undefined && String(value).trim() !== \"\";\n\nif (hasValue(input.businessUnitName)) return \"BusinessUnitName\";\nreturn \"\";"
          },
          "outcomes": {
            "success": "1778058581972"
          },
          "inputs": [],
          "diagram": {
