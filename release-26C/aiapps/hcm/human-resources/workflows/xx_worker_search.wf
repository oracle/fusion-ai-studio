          "type": "CODE",
          "metadata": {
            "name": "Prepare to Update Group Details",
            "returnType": "object",
            "errorNodeId": "1782892870788",
            "sourceCode": "var payload = {\n  actionId: \"selectFacet\",\n  actionType: $context.$nodes.CREATE_AGGREGATIONS_PAYLOAD.$output.result?.filterName,\n  facetValue: $context.$nodes.GET_WORKERS_AGGREGATIONS_FOR_QUERY.$output?.facets?.[0]?.values?.[0]?.value,\n  entitiesArray: $context.$nodes.CREATE_AGGREGATIONS_PAYLOAD.$output.result?.entitiesArray || [],\n  finalPayload: $context.$nodes.RESOLVE_ENTITIES_ARRAY_AND_FINAL_PAYLOAD.$output.result?.finalPayload || [],\n  additionalContext: $context.$nodes.CREATE_AGGREGATIONS_PAYLOAD.$output.result?.additionalContext || {},\n  intent: $context.$nodes.CREATE_AGGREGATIONS_PAYLOAD.$output.result?.intent\n};\n\nreturn {\n  followUpCommand: 'ora.Invoke(\"selectFacet\", ' + JSON.stringify(payload) + ')',\n  message: \"Calculating ...\"\n};",
            "description": "Builds refresh context for the selected aggregation result."
          },
