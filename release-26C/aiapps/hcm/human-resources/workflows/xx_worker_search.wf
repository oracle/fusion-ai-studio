          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"items\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"ProfileId\": {\n            \"type\": \"string\"\n          },\n          \"Summary\": {\n            \"type\": \"string\"\n          },\n          \"CareerAmbassadorFlag\": {\n            \"type\": \"null\"\n          },\n          \"CareerAmbassadorSummary\": {\n            \"type\": \"null\"\n          },\n          \"favoriteLinks\": {\n            \"type\": \"object\",\n            \"properties\": {\n              \"items\": {\n                \"type\": \"array\"\n              },\n              \"count\": {\n                \"type\": \"number\"\n              },\n              \"hasMore\": {\n                \"type\": \"boolean\"\n              },\n              \"limit\": {\n                \"type\": \"number\"\n              },\n              \"offset\": {\n                \"type\": \"number\"\n              },\n              \"links\": {\n                \"type\": \"array\",\n                \"items\": {\n                  \"type\": \"object\",\n                  \"properties\": {\n                    \"rel\": {\n                      \"type\": \"string\"\n                    },\n                    \"href\": {\n                      \"type\": \"string\"\n                    },\n                    \"name\": {\n                      \"type\": \"string\"\n                    },\n                    \"kind\": {\n                      \"type\": \"string\"\n                    }\n                  },\n                  \"required\": [\n                    \"rel\",\n                    \"href\",\n                    \"name\",\n                    \"kind\"\n                  ],\n                  \"additionalProperties\": false\n                }\n              }\n            },\n        