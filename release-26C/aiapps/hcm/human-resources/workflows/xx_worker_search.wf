        {
          "id": "1780553551236",
          "code": "PARSE_PAYLOAD",
          "type": "CODE",
          "metadata": {
            "name": "Read the Action Details",
            "returnType": "object",
            "sourceCode": "var validationError = false;\n\nfunction invalidPayload() {\n  validationError = true;\n}\n\nfunction invalidResult() {\n  return {\n    valid: false,\n    errorMessage: \"Invalid action payload\",\n    actionId: \"\",\n    actionType: \"\",\n    facetValue: \"\",\n    finalPayload: [],\n    entitiesArray: [],\n    currentPayload: {},\n    additionalContext: {},\n    intent: \"\",\n    assignmentId: \"\"\n  };\n}\n\nfunction isObject(value) {\n  return value !== null && typeof value === \"object\" && !Array.isArray(value);\n}\n\nfunction hasOwn(object, key) {\n  return Object.prototype.hasOwnProperty.call(object, key);\n}\n\nfunction assertAllowedKeys(object, allowedKeys) {\n  var keys = Object.keys(object);\n\n  for (var index = 0; index < keys.length; index += 1) {\n    if (allowedKeys.indexOf(keys[index]) === -1) {\n      invalidPayload();\n    }\n  }\n}\n\nfunction parseJson(value, expectedType, maximumLength) {\n  var parsed = value;\n\n  if (typeof value === \"string\") {\n    if (value.length > maximumLength) {\n      invalidPayload();\n    }\n\n    try {\n      parsed = JSON.parse(value);\n    } catch (e) {\n      invalidPayload();\n    }\n  }\n\n  if (expectedType === \"object\" && !isObject(parsed)) {\n    invalidPayload();\n  }\n\n  if (expectedType === \"array\" && !Array.isArray(parsed)) {\n    invalidPayload();\n  }\n\n  return parsed;\n}\n\nfunction cleanText(value, maximumLength, allowEmpty) {\n  if (typeof value !== \"string\") {\n    invalidPayload();\n  }\n\n  var text = value.trim();\n\n  if ((!allowEmpty && text.length === 0) || text.length > maximumLength || /[\\u0000-\\u001F\\u007F]/.test(text)) {\n    invalidPayload();\n  }\n\n  return text;\n}\n\nfunction cleanIdentifier(value) {\n  if (typeof value === \"number\") {\n    if (!Number.isSafeInteger(value) || value <= 0) {\n      invalidPayload();\n    }\n\n    value = String(value);\n  }\n\n  var identifier = cleanText(value, 20, false);\n\n  if (!/^[1-9][0-9]{0,19}$/.test(identifier)) {\n    invalidPayload();\n  }\n\n  return identifier;\n}\n\nfunction cleanFacetValue(value) {\n  if (typeof value === \"number\") {\n    if (!Number.isSafeInteger(value) || value < 0) {\n      invalidPayload();\n    }\n\n    return String(value);\n  }\n\n  return cleanText(value, 200, false);\n}\n\nfunction cleanInteger(value, minimum, maximum) {\n  var numberValue = typeof value === \"string\" && /^[0-9]+$/.test(value.trim())\n    ? Number(value.trim())\n    : value;\n\n  if (!Number.isInteger(numberValue) || numberValue < minimum || numberValue > maximum) {\n    invalidPayload();\n  }\n\n  return numberValue;\n}\n\nfunction cleanEmail(value) {\n  var email = cleanText(value, 254, false);\n\n  if (!/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(email)) {\n    invalidPayload();\n  }\n\n  return email;\n}\n\nfunction cleanPhone(value) {\n  var phone = cleanText(value, 25, false);\n\n  if (!/^[0-9]+$/.test(phone)) {\n    invalidPayload();\n  }\n\n  return phone;\n}\n\nfunction cleanRepresentativeType(value, allowEmpty) {\n  var representativeType = cleanText(value, 40, allowEmpty);\n\n  if ([\"\", \"Benefits representative\", \"Human resources representative\", \"Payroll representative\"].indexOf(representativeType) === -1) {\n    invalidPayload();\n  }\n\n  return representativeType;\n}\n\nvar filterNames = [\n  \"Manager\",\n  \"ManagerReports\",\n  \"AssignmentManagerFlag\",\n  \"WorkPhone\",\n  \"WorkEmail\",\n  \"LocationName\",\n  \"City\",\n  \"Country\",\n  \"DepartmentName\",\n  \"PositionName\",\n  \"JobName\",\n  \"PersonName\"\n];\n\nvar entityNames = [\n  \"Manager\",\n  \"LocationName\",\n  \"City\",\n  \"Country\",\n  \"DepartmentName\",\n  \"PositionName\",\n  \"JobName\",\n  \"PersonName\"\n];\n\nfunction validateEntityArray(value) {\n  if (value.length > 8) {\n    invalidPayload();\n  }\n\n  var seenNames = {};\n\n  return value.map(function (item) {\n    if (!isObject(item)) {\n      invalidPayload();\n    }\n\n    assertAllowedKeys(item, [\"name\", \"terms\"]);\n\n    var name = cleanText(item.name, 40, false);\n    var terms = cleanText(item.terms, 200, false);\n\n    if (entityNames.indexOf(name) === -1 || seenNames[name]) {\n      invalidPayload();\n    }\n\n    seenNames[name] = true;\n    return { name: name, terms: terms };\n  });\n}\n\nfunction validateAdditionalContext(value) {\n  assertAllowedKeys(value, [\n    \"timeEntity\",\n    \"RepresentativeType\",\n    \"PhoneNumber\",\n    \"phoneNumber\",\n    \"WorkEmail\",\n    \"DirectType\",\n    \"PersonAboutType\",\n    \"myself\"\n  ]);\n\n  var result = {};\n\n  if (hasOwn(value, \"timeEntity\")) {\n    var timeEntity = parseJson(value.timeEntity, \"object\", 2048);\n    assertAllowedKeys(timeEntity, [\"TimeOperator\", \"FromTime\", \"ToTime\", \"Timezone\"]);\n\n    var operator = cleanText(timeEntity.TimeOperator, 16, false);\n\n    if ([\"Between\", \"Timezone\"].indexOf(operator) === -1) {\n      invalidPayload();\n    }\n\n    var fromTime = hasOwn(timeEntity, \"FromTime\") ? cleanText(timeEntity.FromTime, 8, true) : \"\";\n    var toTime = hasOwn(timeEntity, \"ToTime\") ? cleanText(timeEntity.ToTime, 8, true) : \"\";\n    var timezone = hasOwn(timeEntity, \"Timezone\") ? cleanText(timeEntity.Timezone, 64, true) : \"\";\n\n    if (operator === \"Between\") {\n      if (!/^(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]$/.test(fromTime) || !/^(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]$/.test(toTime) || timezone) {\n        invalidPayload();\n      }\n    } else if (!timezone || !/^[A-Za-z0-9_+\\-]+(?:\\/[A-Za-z0-9_+\\-]+)*$/.test(timezone) || fromTime || toTime) {\n      invalidPayload();\n    }\n\n    result.timeEntity = {\n      TimeOperator: operator,\n      FromTime: fromTime,\n      ToTime: toTime,\n      Timezone: timezone\n    };\n  }\n\n  if (hasOwn(value, \"RepresentativeType\")) {\n    result.RepresentativeType = cleanRepresentativeType(value.RepresentativeType, true);\n  }\n\n  if (hasOwn(value, \"PhoneNumber\") && hasOwn(value, \"phoneNumber\")) {\n    invalidPayload();\n  }\n\n  if (hasOwn(value, \"PhoneNumber\")) {\n    result.PhoneNumber = cleanPhone(value.PhoneNumber);\n  }\n\n  if (hasOwn(value, \"phoneNumber\")) {\n    var legacyPhone = cleanText(value.phoneNumber, 25, true);\n    result.phoneNumber = legacyPhone ? cleanPhone(legacyPhone) : \"\";\n  }\n\n  if (hasOwn(value, \"WorkEmail\")) {\n    result.WorkEmail = cleanEmail(value.WorkEmail);\n  }\n\n  if (hasOwn(value, \"DirectType\")) {\n    var directType = cleanText(value.DirectType, 16, false);\n\n    if ([\"DIRECTS\", \"ALL\"].indexOf(directType) === -1) {\n      invalidPayload();\n    }\n\n    result.DirectType = directType;\n  }\n\n  if (hasOwn(value, \"PersonAboutType\")) {\n    var aboutType = cleanText(value.PersonAboutType, 16, false);\n\n    if ([\"AboutMe\", \"Feedback\"].indexOf(aboutType) === -1) {\n      invalidPayload();\n    }\n\n    result.PersonAboutType = aboutType;\n  }\n\n  if (hasOwn(value, \"myself\")) {\n    if (typeof value.myself !== \"boolean\") {\n      invalidPayload();\n    }\n\n    result.myself = value.myself;\n  }\n\n  return result;\n}\n\nfunction validateWorkerFilter(item) {\n  if (!isObject(item)) {\n    invalidPayload();\n  }\n\n  assertAllowedKeys(item, [\"name\", \"terms\", \"term\", \"value\"]);\n\n  var name = cleanText(item.name, 40, false);\n\n  if (filterNames.indexOf(name) === -1) {\n    invalidPayload();\n  }\n\n  var valueKeys = [\"terms\", \"term\", \"value\"].filter(function (key) {\n    return hasOwn(item, key);\n  });\n\n  if (valueKeys.length !== 1) {\n    invalidPayload();\n  }\n\n  var result = { name: name };\n\n  if (valueKeys[0] === \"terms\") {\n    if (!Array.isArray(item.terms) || item.terms.length === 0 || item.terms.length > 8) {\n      invalidPayload();\n    }\n\n    result.terms = item.terms.map(function (term) {\n      return cleanText(term, 200, false);\n    });\n  } else if (valueKeys[0] === \"term\") {\n    result.term = name === \"WorkPhone\"\n      ? cleanPhone(item.term)\n      : name === \"WorkEmail\"\n        ? cleanEmail(item.term)\n        : cleanText(item.term, 200, false);\n  } else {\n    result.value = cleanText(item.value, 32, false);\n  }\n\n  if (name === \"ManagerReports\" && [\"ALL\", \"DIRECTS\"].indexOf(result.value) === -1) {\n    invalidPayload();\n  }\n\n  if (name === \"AssignmentManagerFlag\" && (!result.terms || result.terms.length !== 1 || result.terms[0] !== \"Yes\")) {\n    invalidPayload();\n  }\n\n  return result;\n}\n\nfunction validateCurrentPayload(value) {\n  var representativePayload = hasOwn(value, \"personId\") || hasOwn(value, \"assignmentId\") || hasOwn(value, \"representativeTypeFlag\") || hasOwn(value, \"representativeType\");\n\n  if (representativePayload) {\n    assertAllowedKeys(value, [\"assignmentId\", \"personId\", \"offset\", \"representativeTypeFlag\", \"representativeType\"]);\n\n    var representativeResult = {\n      assignmentId: cleanIdentifier(value.assignmentId),\n      personId: cleanIdentifier(value.personId),\n      offset: cleanInteger(value.offset, 0, 500)\n    };\n\n    if (hasOwn(value, \"representativeTypeFlag\")) {\n      if (typeof value.representativeTypeFlag !== \"boolean\") {\n        invalidPayload();\n      }\n\n      representativeResult.representativeTypeFlag = value.representativeTypeFlag;\n    }\n\n    if (hasOwn(value, \"representativeType\")) {\n      representativeResult.representativeType = cleanRepresentativeType(value.representativeType, true);\n    }\n\n    if (representativeResult.representativeTypeFlag === true && !representativeResult.representativeType) {\n      invalidPayload();\n    }\n\n    return representativeResult;\n  }\n\n  assertAllowedKeys(value, [\"securityFilters\", \"displayFields\", \"offset\", \"limit\", \"filters\", \"query\", \"searchFields\"]);\n\n  var securityFilters = parseJson(value.securityFilters, \"object\", 1024);\n  assertAllowedKeys(securityFilters, [\"type\", \"value\"]);\n\n  if (securityFilters.type !== \"PersonSearch\" || securityFilters.value !== \"AdvancedSearch\") {\n    invalidPayload();\n  }\n\n  var allowedDisplayFields = [\n    \"PersonId\",\n    \"DisplayName\",\n    \"AssignmentNumber\",\n    \"AssignmentId\",\n    \"LocationName\",\n    \"DepartmentName\",\n    \"JobName\",\n    \"PositionName\",\n    \"BusinessUnitName\",\n    \"ManagerDisplayName\"\n  ];\n\n  if (!Array.isArray(value.displayFields) || value.displayFields.length === 0 || value.displayFields.length > allowedDisplayFields.length) {\n    invalidPayload();\n  }\n\n  var seenDisplayFields = {};\n  var displayFields = value.displayFields.map(function (field) {\n    var cleanField = cleanText(field, 40, false);\n\n    if (allowedDisplayFields.indexOf(cleanField) === -1 || seenDisplayFields[cleanField]) {\n      invalidPayload();\n    }\n\n    seenDisplayFields[cleanField] = true;\n    return cleanField;\n  });\n\n  var workerResult = {\n    securityFilters: { type: \"PersonSearch\", value: \"AdvancedSearch\" },\n    displayFields: displayFields,\n    offset: cleanInteger(value.offset, 0, 500),\n    limit: cleanInteger(value.limit, 1, 50)\n  };\n\n  if (hasOwn(value, \"filters\")) {\n    if (!Array.isArray(value.filters) || value.filters.length > 12) {\n      invalidPayload();\n    }\n\n    var seenFilterNames = {};\n    workerResult.filters = value.filters.map(function (item) {\n      var validatedFilter = validateWorkerFilter(item);\n\n      if (seenFilterNames[validatedFilter.name]) {\n        invalidPayload();\n      }\n\n      seenFilterNames[validatedFilter.name] = true;\n      return validatedFilter;\n    });\n  }\n\n  if (hasOwn(value, \"query\")) {\n    workerResult.query = cleanText(value.query, 200, false);\n  }\n\n  if (hasOwn(value, \"searchFields\")) {\n    if (!Array.isArray(value.searchFields) || value.searchFields.length !== 1 || value.searchFields[0] !== \"DisplayName\") {\n      invalidPayload();\n    }\n\n    workerResult.searchFields = [\"DisplayName\"];\n  }\n\n  return workerResult;\n}\n\ntry {\n  var rawContext = $context?.$app?.$OraAction;\nvar actionContext = parseJson(rawContext, \"object\", 32768);\n\nif (JSON.stringify(actionContext).length > 32768) {\n  invalidPayload();\n}\n\nassertAllowedKeys(actionContext, [\n  \"actionId\",\n  \"actionType\",\n  \"facetValue\",\n  \"finalPayload\",\n  \"entitiesArray\",\n  \"currentPayload\",\n  \"additionalContext\",\n  \"intent\",\n  \"assignmentId\"\n]);\n\nvar actionId = cleanText(actionContext.actionId, 32, false);\n\nif ([\"selectFacet\", \"selectPerson\", \"showMore\"].indexOf(actionId) === -1) {\n  invalidPayload();\n}\n\nvar allowedActionTypes = [\n  \"LocationName\",\n  \"City\",\n  \"Country\",\n  \"DepartmentName\",\n  \"PositionName\",\n  \"JobName\",\n  \"Manager\",\n  \"PersonName\",\n  \"Representative\"\n];\n\nvar actionType;\nif (hasOwn(actionContext, \"actionType\")) {\n  actionType = cleanText(actionContext.actionType, 40, false);\n\n  if (allowedActionTypes.indexOf(actionType) === -1) {\n    invalidPayload();\n  }\n}\n\nvar intent;\nif (hasOwn(actionContext, \"intent\")) {\n  intent = cleanText(actionContext.intent, 32, true);\n\n  if ([\"\", \"PersonDetails\", \"PersonAbout\", \"PersonRepresentatives\"].indexOf(intent) === -1) {\n    invalidPayload();\n  }\n}\n\nvar facetValue;\nif (hasOwn(actionContext, \"facetValue\")) {\n  facetValue = cleanFacetValue(actionContext.facetValue);\n}\n\nvar assignmentId;\nif (hasOwn(actionContext, \"assignmentId\")) {\n  assignmentId = cleanIdentifier(actionContext.assignmentId);\n}\n\nvar finalPayload = hasOwn(actionContext, \"finalPayload\")\n  ? validateEntityArray(parseJson(actionContext.finalPayload, \"array\", 8192))\n  : [];\nvar entitiesArray = hasOwn(actionContext, \"entitiesArray\")\n  ? validateEntityArray(parseJson(actionContext.entitiesArray, \"array\", 8192))\n  : [];\nvar additionalContext = hasOwn(actionContext, \"additionalContext\")\n  ? validateAdditionalContext(parseJson(actionContext.additionalContext, \"object\", 8192))\n  : {};\nvar currentPayload = hasOwn(actionContext, \"currentPayload\")\n  ? validateCurrentPayload(parseJson(actionContext.currentPayload, \"object\", 16384))\n  : {};\n\nif (actionId === \"selectPerson\") {\n  if (!facetValue || !/^[1-9][0-9]{0,19}$/.test(facetValue) || hasOwn(actionContext, \"currentPayload\") || hasOwn(actionContext, \"finalPayload\") || hasOwn(actionContext, \"entitiesArray\") || hasOwn(actionContext, \"additionalContext\")) {\n    invalidPayload();\n  }\n\n  if (actionType && actionType !== \"PersonName\") {\n    invalidPayload();\n  }\n}\n\nif (actionId === \"selectFacet\") {\n  if (!facetValue || hasOwn(actionContext, \"currentPayload\")) {\n    invalidPayload();\n  }\n\n  if (!actionType && !/^[1-9][0-9]{0,19}$/.test(facetValue)) {\n    invalidPayload();\n  }\n}\n\nif (actionId === \"showMore\") {\n  if (!hasOwn(actionContext, \"currentPayload\") || !intent || hasOwn(actionContext, \"facetValue\")) {\n    invalidPayload();\n  }\n\n  if (intent === \"PersonRepresentatives\" && actionType && actionType !== \"Representative\") {\n    invalidPayload();\n  }\n\n  if (intent === \"PersonDetails\" && actionType === \"Representative\") {\n    invalidPayload();\n  }\n}\n\nif (validationError) {\n  return invalidResult();\n}\n\nreturn {\n  valid: true,\n  errorMessage: \"\",\n  actionId: actionId,\n  actionType: actionType,\n  facetValue: facetValue,\n  finalPayload: finalPayload,\n  entitiesArray: entitiesArray,\n  currentPayload: currentPayload,\n  additionalContext: additionalContext,\n  intent: intent,\n  assignmentId: assignmentId\n};\n} catch (e) {\n  return invalidResult();\n}\n",
            "errorNodeId": "1782892870788",
            "description": "Parses and normalizes the incoming app action payload."
          },
          "diagram": {
            "x": 9310.3125,
            "y": 6316
          },
          "outcomes": {
            "success": "1782892870790"
          },
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
        {
          "id": "1782892870790",
