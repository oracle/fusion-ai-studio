            "sourceCode": "const hasValue = ( value) => value !== null && value !== undefined && String( value).trim() !== \"\";\n\nreturn {\n  \"assignmentId\": $context.$nodes.GET_PRIMARY_ASSIGNMENTID.$output.result,\n  \"personId\": $context.$nodes.PARSE_PAYLOAD.$output.result.facetValue,\n  \"offset\": 0,\n  \"representativeTypeFlag\" :  hasValue($context.$nodes.PARSE_PAYLOAD.$output.result?.additionalContext?.RepresentativeType),\n  \"representativeType\" : $context.$nodes.PARSE_PAYLOAD.$output.result?.additionalContext?.RepresentativeType\n};",
