          "inputs": [
            {
              "id": "1780051187124_prompt",
              "name": "prompt",
              "type": "string",
              "value": "Render exactly one oraImmediateInsight whose followUpCommand equals the supplied followUpCommand verbatim, followed by the supplied message. Do not expose the command payload as visible text.\\n\\nPREPARED_ACTION:\\n{{$context.$nodes.PREPARE_REFRESH_AGGREGATION.$output.result}}"
            },
