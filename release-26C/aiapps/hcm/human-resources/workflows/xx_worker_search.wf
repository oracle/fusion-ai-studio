            "sourceCode": "const filterName = $context.$nodes.RESOLVE_ENTITIES_ARRAY_AND_FINAL_PAYLOAD.$output.result?.entitiesArray?.[0]?.name;\n\nlet result  = [\"Manager\", \"PersonName\"].includes(filterName);\n\nreturn (result || (!filterName));",
            "description": "Determines which worker filter type applies to the current request."
          },
