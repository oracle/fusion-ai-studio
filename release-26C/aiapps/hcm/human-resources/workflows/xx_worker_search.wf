format\": \"date-time\"\n          },\n          \"AuthorName\": {\n            \"type\": \"string\"\n          },\n          \"WorkerName\": {\n            \"type\": \"string\"\n          },\n          \"AuthorKnownAs\": {\n            \"type\": [\n              \"string\",\n              \"null\"\n            ]\n          },\n          \"WorkerKnownAs\": {\n            \"type\": [\n              \"string\",\n              \"null\"\n            ]\n          },\n          \"HideShowNonRecipientFlag\": {\n            \"type\": \"string\",\n            \"enum\": [\n              \"true\",\n              \"false\"\n            ]\n          },\n          \"DeleteNonAuthorFlag\": {\n            \"type\": \"string\",\n            \"enum\": [\n              \"true\",\n              \"false\"\n            ]\n          },\n          \"ThankYouFlag\": {\n            \"type\": \"boolean\"\n          },\n          \"ForeignKeyReferenceFlag\": {\n            \"type\": \"boolean\"\n          },\n          \"NoteVisibilityMeaning\": {\n            \"type\": \"string\"\n          },\n          \"CardTitle\": {\n            \"type\": [\n              \"string\",\n              \"null\"\n            ]\n          },\n          \"ImageReferenceURL\": {\n            \"type\": [\n              \"string\",\n              \"null\"\n            ]\n          },\n          \"HideShowFlag\": {\n            \"type\": \"boolean\"\n          },\n          \"ContextName\": {\n            \"type\": [\n              \"string\",\n              \"null\"\n            ]\n          },\n          \"ContextName2\": {\n            \"type\": [\n              \"string\",\n              \"null\"\n            ]\n          },\n          \"NoteCode\": {\n            \"type\": \"string\"\n          },\n          \"TagList\": {\n            \"type\": [\n              \"string\",\n              \"null\"\n            ]\n          },\n          \"NoteTypeCode\": {\n            \"type\": [\n              \"string\",\n              \"null\"\n            ]\n          },\n          \"NoteTypeCodeMeaning\": {\n            \"type\": [\n              \"string\",\n              \"null\"\n            ]\n          },\n          \"ContextTypeMeaning\": {\n            \"type\": [\n              \"string\",\n              \"null\"\n            ]\n          },\n          \"@context\": {\n            \"type\": \"object\",\n            \"properties\": {\n              \"key\": {\n                \"type\": \"string\"\n              },\n              \"headers\": {\n                \"type\": \"object\",\n                \"properties\": {\n                  \"ETag\": {\n                    \"type\": \"string\"\n                  }\n                },\n                \"required\": [\n                  \"ETag\"\n                ],\n                \"additionalProperties\": false\n              },\n              \"links\": {\n                \"type\": \"array\",\n                \"items\": {\n                  \"type\": \"object\",\n                  \"properties\": {\n                    \"rel\": {\n                      \"type\": \"string\"\n                    },\n                    \"href\": {\n                      \"type\": \"string\",\n                      \"format\": \"uri\"\n                    },\n                    \"name\": {\n                      \"type\": \"string\"\n                    },\n                    \"kind\": {\n                      \"type\": \"string\"\n                    }\n                  },\n                  \"required\": [\n                    \"rel\",\n                    \"href\",\n                    \"name\",\n                    \"kind\"\n                  ],\n                  \"additionalProperties\": false\n                }\n              }\n            },\n            \"required\": [\n              \"key\",\n              \"headers\",\n              \"links\"\n            ],\n            \"additionalProperties\": false\n          }\n        },\n      