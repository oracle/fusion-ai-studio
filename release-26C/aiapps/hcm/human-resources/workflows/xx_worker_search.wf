        {
          "id": "1782892870793",
          "code": "PREPARE_FEEDBACK_SUMMARY",
          "type": "CODE",
          "metadata": {
            "name": "Prepare the Feedback Summary",
            "sourceCode": "function cleanText(value, maximumLength) {\n  if (value === null || value === undefined) return \"\";\n  return String(value)\n    .replace(/[\\u0000-\\u001F\\u007F-\\u009F\\u202A-\\u202E\\u2066-\\u2069]/g, \" \")\n    .replace(/[<>]/g, \"\")\n    .replace(/\\s+/g, \" \")\n    .trim()\n    .slice(0, maximumLength);\n}\n\nvar rows = $context.$nodes.GET_PERSON_NOTES.$output?.items;\nrows = Array.isArray(rows) ? rows.slice(0, 20) : [];\n\nvar items = rows.map(function (row) {\n  return {\n    NoteText: cleanText(row?.NoteText, 2000),\n    AuthorName: cleanText(row?.AuthorName, 200),\n    LastUpdateDate: cleanText(row?.LastUpdateDate, 64)\n  };\n}).filter(function (row) {\n  return !!row.NoteText;\n});\n\nreturn {\n  items: items,\n  myself: $context.$nodes.PARSE_PAYLOAD.$output.result?.additionalContext?.myself === true\n};",
            "returnType": "object",
            "errorNodeId": "1782892870788",
            "description": "Shapes person-note data for secure feedback summarization."
          },
          "outcomes": {
            "success": "1782891496144"
          },
          "inputs": [],
          "diagram": {
            "x": 6350.3125,
            "y": 9478
          },
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
