        {
          "id": "1782118039090",
          "code": "GENERATE_INTENT_AND_ENTITIES_ARRAY",
          "type": "CODE",
          "metadata": {
            "name": "Prepare the Search Request",
            "sourceCode": "let entities = $context.$nodes.CHECK_THE_SEARCH_TERMS.$output.result.entities || {};\n\nconst hasValue = ( value) => value !== null && value !== undefined && String( value).trim() !== \"\";\n\n\nlet entitiesArray = [];\n\nif(hasValue(entities?.Manager)) entitiesArray.push({\"name\" : \"Manager\", \"terms\":  entities.Manager});\n\nif(hasValue(entities?.LocationName)) {\n  if(hasValue(entities?.LocationType)) {\n    entitiesArray.push({\"name\" :entities.LocationType, \"terms\": entities.LocationName});\n   }\n  else entitiesArray.push({\"name\" :\"LocationName\", \"terms\": entities.LocationName});\n}\n\nif(hasValue(entities?.DepartmentName)) entitiesArray.push({\"name\" :\"DepartmentName\", \"terms\" :entities.DepartmentName});\n\nif(hasValue(entities?.PositionName)) entitiesArray.push({\"name\" :\"PositionName\", \"terms\" :entities.PositionName});\n\nif(hasValue(entities?.JobName)) entitiesArray.push({\"name\" :\"JobName\", \"terms\" :entities.JobName});\n\nif(hasValue(entities?.PersonName)) entitiesArray.push({\"name\" :\"PersonName\", \"terms\":entities.PersonName});\n\nreturn {\n  \"entitiesArray\" : entitiesArray,\n  \"intent\" : entities?.Intent\n};",
            "returnType": "object",
            "description": "Builds the normalized intent and entity list used by search routing."
          },
          "diagram": {
            "x": 6927.8125,
            "y": 6982
          },
          "outcomes": {
            "success": "1782118039091"
          },
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
        {
          "id": "1782118039091",
          "code": "GET_ADDITIONAL_CONTEXT",
          "type": "CODE",
          "metadata": {
            "name": "Gather More Search Information",
            "returnType": "object",
            "sourceCode": "let entities = $context.$nodes.CHECK_THE_SEARCH_TERMS.$output.result.entities || {};\n\nconst hasValue = ( value) => value !== null && value !== undefined && String( value).trim() !== \"\";\n\n\nlet returnObj = {};\n\nif(hasValue(entities?.TimeOperator)) {\n  returnObj.timeEntity = {\n  \"TimeOperator\": entities.TimeOperator,\n  \"FromTime\": entities.FromTime,\n  \"ToTime\": entities.ToTime,\n  \"Timezone\" : entities.Timezone\n  };\n}\n\nif(hasValue(entities?.RepresentativeType) && $context.$nodes.GENERATE_INTENT_AND_ENTITIES_ARRAY.$output.result.intent == \"PersonRepresentatives\") {\n    returnObj.RepresentativeType = entities?.RepresentativeType;\n}\n\nif($context.$nodes.GENERATE_INTENT_AND_ENTITIES_ARRAY.$output.result.intent == \"PersonDetails\") {\n    if(hasValue(entities?.PhoneNumber)) returnObj.PhoneNumber = entities?.PhoneNumber;\n    if(hasValue(entities?.WorkEmail)) returnObj.WorkEmail = entities?.WorkEmail;\n}\n\nif(hasValue(entities?.DirectType) && $context.$nodes.GENERATE_INTENT_AND_ENTITIES_ARRAY.$output.result.intent == \"PersonDetails\") {\n    returnObj.DirectType = entities?.DirectType;\n}\n\nif(hasValue(entities?.PersonAboutType) && $context.$nodes.GENERATE_INTENT_AND_ENTITIES_ARRAY.$output.result.intent == \"PersonAbout\") {\n    returnObj.PersonAboutType = entities?.PersonAboutType;\n}\n\nreturnObj.myself = (entities?.PersonName == \"-1\") || (entities?.Manager == \"-1\");\n\nreturn returnObj;",
            "description": "Builds supplemental context needed to resolve the worker-search request."
          },
          "diagram": {
            "x": 6917.8125,
            "y": 7204
          },
          "outcomes": {
            "success": "1781169320627"
          },
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
