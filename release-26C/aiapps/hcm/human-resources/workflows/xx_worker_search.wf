        {
          "id": "1780554767359",
          "code": "EXTRACT_PERSON_CONTEXT",
          "type": "CODE",
          "metadata": {
            "name": "Identify the Person",
            "sourceCode": "var validationError = false;\n\nfunction invalidContext() {\n  validationError = true;\n}\n\nfunction parseOptionalObject(value, maximumLength) {\n  if (value === null || value === undefined || value === \"\") return null;\n\n  var parsed = value;\n  if (typeof value === \"string\") {\n    if (value.length > maximumLength) {\n      invalidContext();\n      return null;\n    }\n    try {\n      parsed = JSON.parse(value);\n    } catch (e) {\n      invalidContext();\n      return null;\n    }\n  }\n\n  if (!parsed || typeof parsed !== \"object\" || Array.isArray(parsed)) {\n    invalidContext();\n    return null;\n  }\n  return parsed;\n}\n\nfunction normalizePersonId(value) {\n  if (typeof value === \"number\") {\n    if (!Number.isSafeInteger(value) || value <= 0) return null;\n    value = String(value);\n  }\n  if (typeof value !== \"string\") return null;\n  var normalized = value.trim();\n  return /^[1-9][0-9]{0,19}$/.test(normalized) ? normalized : null;\n}\n\nvar userContext = parseOptionalObject($context?.$app?.$OraUserContext, 8192);\nvar appContext = parseOptionalObject($context?.$app?.$OraAppContext, 4096);\nvar callerPersonId = normalizePersonId(userContext?.userId);\n\nif (!callerPersonId) invalidContext();\n\nvar appPersonId = null;\nif (appContext && Object.prototype.hasOwnProperty.call(appContext, \"personId\")) {\n  appPersonId = normalizePersonId(appContext.personId);\n  if (!appPersonId) invalidContext();\n}\n\nif (validationError) {\n  return { valid: false, errorMessage: \"Invalid person context\", callerPersonId: null, personId: null };\n}\n\nreturn {\n  valid: true,\n  errorMessage: \"\",\n  callerPersonId: callerPersonId,\n  personId: appPersonId || callerPersonId\n};",
            "returnType": "object",
            "errorNodeId": "1782892870788",
            "description": "Extracts and normalizes the selected or logged-in person context for downstream processing."
          },
          "diagram": {
            "x": 9760.3125,
            "y": 5206
          },
          "outcomes": {
            "success": "1782892870789"
          },
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
