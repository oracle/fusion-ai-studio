            "name": "Prepare to Update My Search Result",
            "returnType": "object",
            "errorNodeId": "1782892870788",
            "sourceCode": "var personId = String($context.$nodes.EXTRACT_PERSON_CONTEXT.$output.result?.personId || \"\").trim();\nvar intent = $context.$nodes.GENERATE_INTENT_AND_ENTITIES_ARRAY.$output.result?.intent;\nif (!/^[1-9][0-9]{0,19}$/.test(personId) || [\"PersonAbout\",\"PersonRepresentatives\"].indexOf(intent) === -1) return { valid:false, followUpCommand:\"\", message:\"\" };\nvar payload = { actionId:\"selectFacet\", facetValue:personId, additionalContext:$context.$nodes.GET_ADDITIONAL_CONTEXT.$output.result || {}, intent:intent };\nreturn { valid:true, followUpCommand:'ora.Invoke(\"selectFacet\", ' + JSON.stringify(payload) + ')', message:\"Calculating ...\" };",
