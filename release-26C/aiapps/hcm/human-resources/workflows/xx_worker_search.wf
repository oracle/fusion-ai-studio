            "sourceCode": "return {\n  \"entitiesArray\": \n  $context.$nodes.GENERATE_INTENT_AND_ENTITIES_ARRAY.$output?.result?.entitiesArray ?? $context.$nodes.PARSE_PAYLOAD.$output?.result?.entitiesArray,\n  \"finalPayload\" : $context.$nodes.GET_FINAL_PAYLOAD.$output?.result?? [],\n  \"additionalContext\" : $context.$nodes.GET_ADDITIONAL_CONTEXT.$output?.result ?? $context.$nodes.PARSE_PAYLOAD.$output?.result?.additionalContext ?? {},\n  \"intent\" : $context.$nodes.GENERATE_INTENT_AND_ENTITIES_ARRAY.$output?.result?.intent ?? $context.$nodes.PARSE_PAYLOAD.$output?.result?.intent ?? \"\"\n}\n",
