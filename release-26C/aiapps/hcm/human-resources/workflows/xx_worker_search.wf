        {
          "id": "1780909222656",
          "code": "CREATE_AGGREGATIONS_PAYLOAD",
          "type": "CODE",
          "metadata": {
            "name": "Prepare the Grouped Search",
            "sourceCode": "const input = $context.$nodes.RESOLVE_ENTITIES_ARRAY_AND_FINAL_PAYLOAD.$output.result?.entitiesArray || [];\n\nconst payload = {\n  securityFilters: {\n    \"type\": \"PersonSearch\",\n    \"value\": \"AdvancedSearch\"\n  }\n};\n\nconst filterName = input[0].name;\n\nconst finalPayload = $context.$nodes.RESOLVE_ENTITIES_ARRAY_AND_FINAL_PAYLOAD.$output.result?.finalPayload || [];\nconst additionalContext = $context.$nodes.RESOLVE_ENTITIES_ARRAY_AND_FINAL_PAYLOAD.$output.result?.additionalContext || {};\nconst intent = $context.$nodes.RESOLVE_ENTITIES_ARRAY_AND_FINAL_PAYLOAD.$output.result?.intent || \"\";\n\nconst filtersArray = [];\n\nfinalPayload.forEach(item => {\n  filtersArray.push({\n        \"name\" : item.name,\n        terms: [item.terms]\n  });\n\n  if(item.name == \"Manager\") {\n     filtersArray.push( {\"name\" : \"ManagerReports\",\n        value: \"ALL\"\n      });\n  }\n});\n\nconst personNameEntity = input.find(\n  item => item.name === \"PersonName\"\n);\n\nif(personNameEntity) {\n    payload.query = personNameEntity.terms;\n    payload.searchFields = [ \"DisplayName\"];\n  }\n\nif( input?.length) {\n  payload.facetValueQuery = input[0].terms;\n  payload.facets = [input[0].name];\n  input.shift();\n}\n\nif(filtersArray?.length) {\n  payload.filters = filtersArray;\n}\n\nreturn {\n\"payload\" : JSON.stringify(payload),\n\"entitiesArray\" : input,\n\"filterName\" : filterName,\n\"additionalContext\" : additionalContext,\n\"intent\" : intent\n}",
            "returnType": "object",
            "description": "Builds the payload used to retrieve worker aggregation results."
          },
          "diagram": {
            "x": 5552.5,
            "y": 10144
          },
          "outcomes": {
            "success": "1781000107887"
          },
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
        {
          "id": "1781000107887",
          "code": "CREATE_AGGREGATIONS_DESCRIPTION",
          "type": "CODE",
          "metadata": {
            "name": "Describe the Grouped Results",
            "returnType": "string",
            "sourceCode": "let description = \"\";\n\nif ($context.$nodes.CREATE_AGGREGATIONS_PAYLOAD.$output.result.filterName == \"JobName\") description = $context.$nodes.GET_INFO_MESSAGES.$output.result.jobNameSelect;\nelse if ($context.$nodes.CREATE_AGGREGATIONS_PAYLOAD.$output.result.filterName == \"DepartmentName\") description = $context.$nodes.GET_INFO_MESSAGES.$output.result.departmentNameSelect;\nelse if ($context.$nodes.CREATE_AGGREGATIONS_PAYLOAD.$output.result.filterName == \"PositionName\") description = $context.$nodes.GET_INFO_MESSAGES.$output.result.positionNameSelect;\nelse if ($context.$nodes.CREATE_AGGREGATIONS_PAYLOAD.$output.result.filterName == \"LocationName\") description = $context.$nodes.GET_INFO_MESSAGES.$output.result.locationNameSelect;\n\nreturn description;",
            "description": "Creates a human-readable description of the selected aggregation criteria."
          },
          "diagram": {
