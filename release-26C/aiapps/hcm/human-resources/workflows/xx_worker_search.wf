                {
                  "id": "1781778807396",
                  "code": "CREATE_PAYLOAD",
                  "type": "CODE",
                  "metadata": {
                    "name": "Prepare the Worker Search",
                    "sourceCode": "const input = $context.$nodes.RESOLVE_ENTITIES_ARRAY_AND_FINAL_PAYLOAD.$output.result?.entitiesArray|| [];\n\nconst additionalContext = $context.$nodes.RESOLVE_ENTITIES_ARRAY_AND_FINAL_PAYLOAD.$output.result?.additionalContext || {};\n\nconst finalPayload = $context.$nodes.RESOLVE_ENTITIES_ARRAY_AND_FINAL_PAYLOAD.$output.result.finalPayload || [];\n\nlet offset = Number($context.$variables.offset) ?? 0;\n\nconst payload = {\n  securityFilters: {\n    \"type\": \"PersonSearch\",\n    \"value\": \"AdvancedSearch\"\n  },\n  displayFields: [\"PersonId\",\"DisplayName\",\"AssignmentNumber\", \"AssignmentId\", \"LocationName\", \"DepartmentName\", \"JobName\", \"PositionName\", \"BusinessUnitName\", \"ManagerDisplayName\"],\n  offset: offset,\n  limit: $context.$variables.limit\n};\n\nconst filtersArray = [];\nconst filterName = input[0]?.name;\n\nfinalPayload.forEach(item => {\n  filtersArray.push({\n        \"name\" : item.name,\n        terms: [item.terms]\n  });\n\n  if(item.name == \"Manager\") {\n     filtersArray.push( {\"name\" : \"ManagerReports\",\n        value: additionalContext?.DirectType ?? \"ALL\"\n      });\n  }\n});\n\nif(input?.length) {\n    payload.query = input[0].terms;\n    payload.searchFields = [ \"DisplayName\"];\n    \n     if(filterName == \"Manager\") {\n        filtersArray.push( {\"name\" : \"AssignmentManagerFlag\",\n        \"terms\": [\"Yes\"]\n        });\n      }\n}\n\nconst hasValue = ( value) => value !== null && value !== undefined && String( value).trim() !== \"\";\n\n// Work Phone \nif(filterName != \"Manager\" && hasValue(additionalContext?.PhoneNumber)) {\n  filtersArray.push( {\n    \"name\" : \"WorkPhone\",\n     \"term\": additionalContext?.PhoneNumber\n  });\n}\n\nif(filterName != \"Manager\" && hasValue(additionalContext?.WorkEmail)) {\n  filtersArray.push( {\n    \"name\" : \"WorkEmail\",\n     \"term\": additionalContext?.WorkEmail\n  });\n}\n\nif( filtersArray.length > 0) {\n  payload.filters = filtersArray;\n}\nreturn {\n\"payload\" : JSON.stringify( payload),\n\"entitiesArray\" : input,\n\"filterName\" : filterName ?? \"PersonName\",\n\"offset\": offset + $context.$variables.limit,\n\"additionalContext\" : additionalContext\n}",
                    "returnType": "object",
                    "description": "Builds the next worker-search request payload for the collection loop."
                  },
                  "diagram": {
                    "x": 6068.90625,
                    "y": 10829
                  },
                  "outcomes": {
                    "success": "1781778823060"
                  },
                  "inputs": [],
                  "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
