        {
          "id": "1782807789875",
          "code": "GET_ASSIGNMENTID",
          "type": "CODE",
          "metadata": {
            "name": "Identify My Assignment",
            "returnType": "string",
            "sourceCode": "const rows = Array.isArray( $context.$nodes.GET_WORKER_PRIMARY_ASSIGNMENT.$output?.items) ? $context.$nodes.GET_WORKER_PRIMARY_ASSIGNMENT.$output.items : [];\nreturn rows[0]?.AssignmentId ?? null;",
