": {\n                \"type\": \"number\"\n              },\n              \"hasMore\": {\n                \"type\": \"boolean\"\n              },\n              \"limit\": {\n                \"type\": \"number\"\n              },\n              \"offset\": {\n                \"type\": \"number\"\n              },\n              \"links\": {\n                \"type\": \"array\",\n                \"items\": {\n                  \"type\": \"object\",\n                  \"properties\": {\n                    \"rel\": {\n                      \"type\": \"string\"\n                    },\n                    \"href\": {\n                      \"type\": \"string\"\n                    },\n                    \"name\": {\n                      \"type\": \"string\"\n                    },\n                    \"kind\": {\n                      \"type\": \"string\"\n                    }\n                  },\n                  \"required\": [\n                    \"rel\",\n                    \"href\",\n                    \"name\",\n                    \"kind\"\n                  ],\n                  \"additionalProperties\": false\n                }\n              }\n            },\n            \"required\": [\n              \"items\",\n              \"count\",\n              \"hasMore\",\n              \"limit\",\n              \"offset\",\n              \"links\"\n            ],\n            \"additionalProperties\": false\n          },\n          \"areasOfInterest\": {\n            \"type\": \"object\",\n            \"properties\": {\n              \"items\": {\n                \"type\": \"array\",\n                \"items\": {\n                  \"type\": \"object\",\n                  \"properties\": {\n                    \"InterestId\": {\n                      \"type\": \"string\"\n                    },\n                    \"Interest\": {\n                      \"type\": \"string\"\n                    },\n                    \"@context\": {\n                 