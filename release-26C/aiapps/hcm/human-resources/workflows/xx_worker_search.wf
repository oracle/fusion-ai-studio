                {
                  "id": "1781858213254",
                  "code": "CREATE_PAYLOAD_SHOW_MORE",
                  "type": "CODE",
                  "metadata": {
                    "name": "Prepare to Find More Workers",
                    "sourceCode": "let payload = $context.$nodes.PARSE_PAYLOAD.$output.result.currentPayload;\n\nlet offset = payload.offset;\nif($context.$variables.offset) offset = $context.$variables.offset;\n\npayload.offset = offset + $context.$variables.limit;\n\nreturn {\n  \"payload\": JSON.stringify(payload),\n  \"offset\": payload.offset\n};",
                    "returnType": "object",
                    "description": "Builds the next paging payload for expanded worker retrieval."
                  },
