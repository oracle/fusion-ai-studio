        {
          "id": "1782892870794",
          "code": "PREPARE_ABOUT_ME_SUMMARY",
          "type": "CODE",
          "metadata": {
            "name": "Prepare the About Me Summary",
            "sourceCode": "function cleanText(value, maximumLength) {\n  if (value === null || value === undefined) return \"\";\n  return String(value)\n    .replace(/[\\u0000-\\u001F\\u007F-\\u009F\\u202A-\\u202E\\u2066-\\u2069]/g, \" \")\n    .replace(/[<>]/g, \"\")\n    .replace(/\\s+/g, \" \")\n    .trim()\n    .slice(0, maximumLength);\n}\n\nfunction listValues(value, fieldName) {\n  var rows = value?.items;\n  rows = Array.isArray(rows) ? rows.slice(0, 20) : [];\n  return rows.map(function (row) {\n    return cleanText(fieldName ? row?.[fieldName] : row, 300);\n  }).filter(function (text) { return !!text; });\n}\n\nvar rows = $context.$nodes.GET_PERSON_TALENT_PROFILE.$output?.items;\nvar profile = Array.isArray(rows) && rows.length ? rows[0] : {};\n\nreturn {\n  summary: cleanText(profile?.Summary, 2000),\n  expertise: listValues(profile?.areasOfExpertise, \"Expertise\"),\n  interests: listValues(profile?.areasOfInterest, \"Interest\"),\n  tags: listValues(profile?.tags, null),\n  myself: $context.$nodes.PARSE_PAYLOAD.$output.result?.additionalContext?.myself === true\n};",
            "returnType": "object",
            "errorNodeId": "1782892870788",
            "description": "Shapes talent-profile data for secure About Me summarization."
          },
          "outcomes": {
            "success": "1782892870781"
          },
          "inputs": [],
          "diagram": {
            "x": 6800.3125,
            "y": 9478
          },
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
