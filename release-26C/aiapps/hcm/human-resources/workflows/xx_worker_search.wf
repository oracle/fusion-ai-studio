            "returnType": "string",
            "sourceCode": "let description = \"\";\nif ($context.$variables.contextObj.filterName == \"Manager\") description = $context.$nodes.GET_INFO_MESSAGES.$output.result.managerNameSelect;\nelse description = $context.$nodes.GET_INFO_MESSAGES.$output.result.personNameSelect;\n\nreturn description;",
            "description": "Creates a human-readable description of the worker search criteria."
