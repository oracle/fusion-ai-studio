            "name": "Prepare Helpful Messages",
            "returnType": "object",
            "sourceCode": "return {\n\"personNameSelect\" : \"Please select a Person to continue\",\n\"managerNameSelect\" : \"Please select a Manager to continue\",\n\"locationNameSelect\" : \"Please select a Location to continue\",\n\"departmentNameSelect\" : \"Please select a Department to continue\",\n\"jobNameSelect\" : \"Please select a Job to continue\",\n\"positionNameSelect\" : \"Please select a Position to continue\",\n\"noSuchPersonPresent\": \"Sorry, couldn't find any such person\",\n\"entityResolutionFailed\" : \"Sorry, couldn't understand the input. Please try again.\"\n};",
            "description": "Builds informational messages from the current workflow and app context."
          },
