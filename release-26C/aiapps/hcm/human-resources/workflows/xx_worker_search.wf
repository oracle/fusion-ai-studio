            "sourceCode": "function buildInvoke(payload) {\n  return 'ora.Invoke(\"selectFacet\", ' + JSON.stringify(payload) + ')';\n}\n\nvar response = $context.$nodes.GET_PERSON_REPRESENTATIVES_SHOW_MORE.$output || {};\nvar rows = response.items || [];\nvar itemActions = rows.map(function (row) {\n  return buildInvoke({\n    actionId: \"selectPerson\",\n    facetValue: row?.PersonId\n  });\n});\n\nvar showMoreAction = null;\nif (response.hasMore === true) {\n  showMoreAction = {\n    title: \"Show More\",\n    actionText: \"showMore\",\n    followUpCommand: buildInvoke({\n      currentPayload: $context.$nodes.CREATE_REPRESENTATIVE_CURRENT_PAYLOAD_SHOW_MORE.$output.result,\n      actionId: \"showMore\",\n      actionType: \"Representative\",\n      intent: $context.$nodes.PARSE_PAYLOAD.$output.result.intent\n    })\n  };\n}\n\nreturn { itemActions: itemActions, showMoreAction: showMoreAction };",
