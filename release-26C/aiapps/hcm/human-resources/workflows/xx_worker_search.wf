                    }
                  ],
                  "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"items\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"PersonId\": {\n            \"type\": \"string\"\n          },\n          \"DisplayName\": {\n            \"type\": \"string\"\n          },\n          \"AssignmentId\": {\n            \"type\": \"string\"\n          },\n          \"AssignmentNumber\": {\n            \"type\": \"string\"\n          },\n          \"ManagerDisplayName\": {\n            \"type\": \"string\"\n          },\n          \"JobName\": {\n            \"anyOf\": [\n              {\n                \"type\": \"string\"\n              },\n              {\n                \"type\": \"null\"\n              }\n            ]\n          },\n          \"DepartmentName\": {\n            \"anyOf\": [\n              {\n                \"type\": \"string\"\n              },\n              {\n                \"type\": \"null\"\n              }\n            ]\n          },\n          \"LocationName\": {\n            \"anyOf\": [\n              {\n                \"type\": \"string\"\n              },\n              {\n                \"type\": \"null\"\n              }\n            ]\n          },\n          \"PositionName\": {\n            \"anyOf\": [\n              {\n                \"type\": \"string\"\n              },\n              {\n                \"type\": \"null\"\n              }\n            ]\n          },\n          \"BusinessUnitName\": {\n            \"anyOf\": [\n              {\n                \"type\": \"string\"\n              },\n              {\n                \"type\": \"null\"\n              }\n            ]\n          }\n        },\n        \"required\": [\n          \"PersonId\",\n          \"DisplayName\",\n          \"AssignmentId\",\n          \"AssignmentNumber\",\n          \"ManagerDisplayName\",\n          \"JobName\",\n          \"DepartmentName\",\n          \"LocationName\",\n          \"PositionName\",\n          \"BusinessUnitName\"\n        ],\n        \"additionalProperties\": true\n      }\n    },\n    \"count\": {\n      \"type\": \"number\"\n    },\n    \"limit\": {\n      \"type\": \"number\"\n    },\n    \"offset\": {\n      \"type\": \"number\"\n    },\n    \"hasMore\": {\n      \"type\": \"boolean\"\n    }\n  },\n  \"required\": [\n    \"items\",\n    \"count\",\n    \"limit\",\n    \"offset\",\n    \"hasMore\"\n  ],\n  \"additionalProperties\": false\n}"
                },
                {
                  "id": "1781778899855",
                  "code": "GET_TIMEZONES",
                  "type": "LLM",
                  "metadata": {
                    "name": "Find Worker Time Zones",
                    "description": "Determines time-zone information needed for the retrieved workers."
                  },
                  "diagram": {
                    "x": 6068.90625,
                    "y": 11273
                  },
                  "outcomes": {
                    "success": "1781778868839"
                  },
                  "inputs": [
                    {
                      "id": "1781778899855_prompt",
                      "name": "prompt",
                      "type": "string",
                      "value": "You are a location timezone and UTC resolution agent.\n\nYour sole purpose is to return the input worker result object with `items`,\n`count`, `limit`, `offset`, and `hasMore`, preserving the original envelope\nand adding `TimeZone`, `UtcDate`, and `UtcOffset` to each item based on each\nitem's `LocationName`.\n\nDo not answer unrelated questions or explain the request. For personal questions,\nonly state that you resolve timezone and UTC details from a location name.\nFor self-harm, violence, abuse, or immediate-safety topics, follow platform\nsafety rules first.\n\nSOURCE OF TRUTH\n1. Treat `Input` as the complete source of truth.\n2. `Input` is expected to be an object with these top-level fields:\n   - `items`\n   - `count`\n   - `limit`\n   - `offset`\n   - `hasMore`\n3. `Input.items` is expected to be an array of worker items.\n4. Preserve the top-level `count`, `limit`, `offset`, and `hasMore` values\n   exactly as provided.\n5. For each item in `Input.items`, use that item's `LocationName` as the target\n   location.\n6. Preserve every input item and every existing input field exactly as provided.\n7. Add or populate only these fields on each item:\n   - `TimeZone`\n   - `UtcDate`\n   - `UtcOffset`\n8. Do not remove, rename, reorder, rewrite, summarize, normalize, or invent\n   worker fields.\n9. If an item already includes usable `TimeZone`, `UtcDate`, or `UtcOffset`,\n   copy those values exactly and do not recalculate or overwrite them.\n10. Do not invent a location that is not present in an item's `LocationName`.\n\nTIMEZONE AND UTC RULES\n1. Process every item in `Input.items`.\n2. For each item, read `LocationName`.\n3. If `LocationName` is missing, null, blank, or ambiguous, set that item's\n   added fields to existing usable values when present, otherwise empty strings.\n4. If `LocationName` is present, derive the IANA timezone for that location.\n5. Derive `UtcDate` and `UtcOffset` for the resolved timezone.\n6. Return `UtcDate` in `YYYY-MM-DD` format.\n7. Return `UtcOffset` in `+HH:MM` or `-HH:MM` format.\n8. Do not add or output `UtcTime`, `localDateTime`, `timeZone`, `utcOffset`,\n   current local time, current UTC time, status fields, commentary, or any\n   other new fields.\n9. If timezone or UTC details cannot be resolved with high confidence, set\n   only the unresolved added fields to empty strings.\n\nOUTPUT CONTRACT\nReturn only one valid JSON object.\n\nThe output object must contain exactly these top-level fields:\n- `items`\n- `count`\n- `limit`\n- `offset`\n- `hasMore`\n\nThe output `items` array must contain the same number of items as\n`Input.items`.\n\nEach output item must preserve all original fields from the corresponding\ninput item and add or populate only `TimeZone`, `UtcDate`, and `UtcOffset`.\n\nThe output must conform to the separate `OUTPUT_SCHEMA` provided below.\n\nDo not include the schema in the runtime output. The schema is only the expected\noutput specification for this node.\n\nUse double quotes for all JSON property names and string values.\nReturn empty strings, not nulls or omitted added fields.\nDo not include markdown, commentary, analysis, or debug text.\n\nInput:\n{{$context.$nodes.WHILE_WORKERS_LIST_LESS_THAN_LIMIT.GET_WORKERS_FOR_QUERY.$output}}"
                    }
                  ],
                  "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"items\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"PersonId\": {\n            \"type\": \"string\"\n          },\n          \"DisplayName\": {\n            \"type\": \"string\"\n          },\n          \"AssignmentId\": {\n            \"type\": \"string\"\n          },\n          \"AssignmentNumber\": {\n            \"type\": \"string\"\n          },\n          \"ManagerDisplayName\": {\n            \"type\": \"string\"\n          },\n          \"JobName\": {\n            \"anyOf\": [\n              {\n                \"type\": \"string\"\n              },\n              {\n                \"type\": \"null\"\n              }\n            ]\n          },\n          \"DepartmentName\": {\n            \"anyOf\": [\n              {\n                \"type\": \"string\"\n              },\n              {\n                \"type\": \"null\"\n              }\n            ]\n          },\n          \"LocationName\": {\n            \"anyOf\": [\n              {\n                \"type\": \"string\"\n              },\n              {\n                \"type\": \"null\"\n              }\n            ]\n          },\n          \"PositionName\": {\n            \"anyOf\": [\n              {\n                \"type\": \"string\"\n              },\n              {\n                \"type\": \"null\"\n              }\n            ]\n          },\n          \"BusinessUnitName\": {\n            \"anyOf\": [\n              {\n                \"type\": \"string\"\n              },\n              {\n                \"type\": \"null\"\n              }\n            ]\n          },\n          \"TimeZone\": {\n            \"type\": \"string\"\n          },\n          \"UtcDate\": {\n            \"type\": \"string\"\n          },\n          \"UtcOffset\": {\n            \"type\": \"string\"\n          }\n        },\n        \"required\": [\n          \"PersonId\",\n          \"DisplayName\",\n          \"AssignmentId\",\n          \"AssignmentNumber\",\n          \"ManagerDisplayName\",\n          \"JobName\",\n          \"DepartmentName\",\n          \"LocationName\",\n          \"PositionName\",\n          \"BusinessUnitName\",\n          \"TimeZone\",\n          \"UtcDate\",\n          \"UtcOffset\"\n        ],\n        \"additionalProperties\": true\n      }\n    },\n    \"count\": {\n      \"type\": \"number\"\n    },\n    \"limit\": {\n      \"type\": \"number\"\n    },\n    \"offset\": {\n      \"type\": \"number\"\n    },\n    \"hasMore\": {\n      \"type\": \"boolean\"\n    }\n  },\n  \"required\": [\n    \"items\",\n    \"count\",\n    \"limit\",\n    \"offset\",\n    \"hasMore\"\n  ],\n  \"additionalProperties\": false\n}"
                },
                {
                  "id": "1781778868839",
                  "code": "FILTER_BASED_ON_TIMEZONE",
                  "type": "CODE",
                  "metadata": {
                    "name": "Keep Workers in the Right Time Zone",
                    "returnType": "object",
                    "sourceCode": "function hasValue(value) {\n  return value !== null && value !== undefined && String(value).trim() !== \"\";\n}\n\nfunction offsetToMinutes(offset) {\n  if (!hasValue(offset)) {\n    return null;\n  }\n\n  var text = String(offset).trim();\n  var sign = text[0] === \"-\" ? -1 : 1;\n  var parts = text.slice(1).split(\":\");\n\n  if (parts.length < 2) {\n    return null;\n  }\n\n  var hours = Number(parts[0]);\n  var minutes = Number(parts[1]);\n\n  if (Number.isNaN(hours) || Number.isNaN(minutes)) {\n    return null;\n  }\n\n  return sign * (hours * 60 + minutes);\n}\n\nfunction timeToMinutes(time) {\n  if (!hasValue(time)) {\n    return null;\n  }\n\n  var parts = String(time).trim().split(\":\");\n  var hours = Number(parts[0]);\n  var minutes = Number(parts[1] || 0);\n\n  if (Number.isNaN(hours) || Number.isNaN(minutes)) {\n    return null;\n  }\n\n  return hours * 60 + minutes;\n}\n\nfunction normalizeOperator(value) {\n  return hasValue(value) ? String(value).trim().toLowerCase() : \"\";\n}\n\nfunction normalizeTimezone(value) {\n  return hasValue(value) ? String(value).trim().toLowerCase() : \"\";\n}\n\nfunction filterItemsByTimeEntity(items, timeEntity) {\n  var operator = normalizeOperator(timeEntity?.TimeOperator);\n\n  if (operator === \"timezone\") {\n    var requestedTimezone = normalizeTimezone(timeEntity?.Timezone);\n\n    if (!requestedTimezone) {\n      return items;\n    }\n\n    return items.filter(function (item) {\n      return normalizeTimezone(item.TimeZone) === requestedTimezone;\n    });\n  }\n\n  if (operator === \"between\") {\n    var fromMinutes = timeToMinutes(timeEntity?.FromTime);\n    var toMinutes = timeToMinutes(timeEntity?.ToTime);\n\n    if (fromMinutes === null || toMinutes === null) {\n      return items;\n    }\n\n    var now = new Date();\n    var utcMs = now.getTime() + now.getTimezoneOffset() * 60000;\n\n    return items.filter(function (item) {\n      var offsetMinutes = offsetToMinutes(item.UtcOffset);\n\n      if (offsetMinutes === null) {\n        return false;\n      }\n\n      var localDate = new Date(utcMs + offsetMinutes * 60000);\n      var minutesOfDay = localDate.getUTCHours() * 60 + localDate.getUTCMinutes();\n\n      return minutesOfDay >= fromMinutes && minutesOfDay <= toMinutes;\n    });\n  }\n\n  return items;\n}\n\nconst response = $context.$nodes.WHILE_WORKERS_LIST_LESS_THAN_LIMIT.GET_TIMEZONES.$output;\nconst input = response.items || [];\n\nconst payload = $context.$nodes.WHILE_WORKERS_LIST_LESS_THAN_LIMIT.CREATE_PAYLOAD.$output.result || {};\n\nlet result = input;\n\nconst additionalContext = payload.additionalContext || $context.$nodes.RESOLVE_ENTITIES_ARRAY_AND_FINAL_PAYLOAD.$output.result?.additionalContext || $context.$nodes.GET_ADDITIONAL_CONTEXT.$output.result || {};\nconst timeEntity = additionalContext?.timeEntity || {};\n\nconst filterName = payload.filterName ?? \"PersonName\";\n\nif (\n  filterName == \"PersonName\" &&\n  timeEntity?.TimeOperator\n) {\n  result = filterItemsByTimeEntity(input, timeEntity);\n}\n\nlet existingWorkers = $context.$variables.workersListObj || {};\n\nconst newList = (existingWorkers.items || []).concat(result);\n\nlet workersArray = {\n  ...existingWorkers,\n  items: newList,\n  hasMore: response.hasMore,\n  offset: response.offset,\n  limit: response.limit,\n  count: newList.length\n};\n\nreturn workersArray;",
                    "description": "Filters retrieved workers using the resolved time-zone criteria."
                  },
                  "diagram": {
                    "x": 6068.90625,
                    "y": 11495
                  },
                  "outcomes": {
                    "success": "1781783376013"
                  },
                  "inputs": [],
                  "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
                },
