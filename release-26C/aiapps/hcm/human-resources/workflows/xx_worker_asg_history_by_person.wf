          "code": "GET_QUERY_TYPE",
          "type": "CODE",
          "metadata": {
            "name": "Get Query Type",
            "returnType": "string",
            "sourceCode": "const input = $context.$triggers.REST.$input || {};\nconst hasValue = (value) => value !== null && value !== undefined && String(value).trim() !== \"\";\n\nlet type = \"\";\nif (hasValue(input.personId)) {\n  type = \"PersonId\";\n} else if (hasValue(input.assignmentId)) {\n  type = \"AssignmentId\";\n}\n\nreturn type;"
          },
          "outcomes": {
            "success": "1777879057307"
          },
          "inputs": [],
          "diagram": {
            "x": 5225,
            "y": 5246
          },
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
        {
          "id": "1777879057307",
          "code": "SWITCH_QUERY",
          "type": "CONDITION",
          "metadata": {
            "name": "Switch Query"
          },
