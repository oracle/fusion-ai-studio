          "code": "GET_WORKER_PRIMARY_ASSIGNMENT",
          "type": "BO_FUNCTION",
          "metadata": {
            "businessObjectCode": "ORA_HCM_GLOBALHUMA_EMPLOYMENTGHR",
            "functionName": "GetAssignmentInformationByPerson",
            "processJson": true,
            "name": "Get Worker Primary Assignment",
            "description": "Returns worker assignment rows for the supplied person so the workflow can select the primary assignment locally."
          },
          "outcomes": {
            "success": "1777456888914"
          },
          "inputs": [
            {
              "id": "1777456829024_personId",
              "name": "personId",
              "value": "{{$context.$triggers.REST.$input.personId}}",
              "required": true,
              "type": "string"
            }
          ],
          "diagram": {
            "x": 4691,
            "y": 5617
          },
          "convergenceTargetId": "1777879107769",
          "outputSpecification": "{}"
        },
        {
          "id": "1777456888914",
          "code": "GET_PAYLOAD",
          "type": "CODE",
          "metadata": {
            "name": "Get Payload",
            "returnType": "object",
            "sourceCode": "let assignmentId=null;\nlet type = $context.$nodes.GET_QUERY_TYPE.$output.result;\n\nif (type === \"AssignmentId\") {\n  assignmentId =$context.$triggers.REST.$input.assignmentId ;\n} else if (type === \"PersonId\") {\n  assignmentId = $context.$nodes.GET_WORKER_PRIMARY_ASSIGNMENT.$output.items[0]?.AssignmentId;\n}\n\nconst effectiveDate = $context.$system.$currentDate || new Date().toISOString().split(\"T\")[0];\n\nconst result = {\n  assignmentId,\n  effectiveDate\n};\nreturn result;"
          },
          "outcomes": {
            "success": "1777879057308"
          },
          "inputs": [],
          "diagram": {
            "x": 5133.894827772379,
            "y": 5789.335061008531
          },
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
