          "code": "MODIFY_RESPONSE",
          "type": "CODE",
          "metadata": {
            "name": "Modify Response",
            "returnType": "array",
            "sourceCode": "const hasValue = (value) => value !== null && value !== undefined && String(value).trim() !== \"\";\n\nconst assignmentId = $context.$nodes.GET_PAYLOAD.$output.result?.assignmentId;\n\nif (!hasValue(assignmentId)) {\n  return [];\n}\n\nreturn $context.$nodes.GET_WORKER_ASSIGNMENT_HISTORY.$output?.items ?? [];"
          },
