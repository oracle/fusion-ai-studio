          "code": "GET_QUERY_TYPE",
          "type": "CODE",
          "metadata": {
            "name": "Get Query Type",
            "returnType": "string",
            "sourceCode": "const input = $context.$triggers.REST.$input || {};\nconst hasValue = (value) => value !== null && value !== undefined && String(value).trim() !== \"\" && String(value).trim() !== \"<provide a value>\";\n\nlet type = \"\";\nif (hasValue(input.locationName)) {\n  type = \"LocationName\";\n} else if (hasValue(input.locationCode)) {\n  type = \"LocationCode\";\n}\n\nreturn type;"
          },
          "outcomes": {
            "success": "1776336326908"
          },
          "inputs": [],
          "diagram": {
