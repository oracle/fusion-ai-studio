          "code": "MODIFY_RESPONSE",
          "type": "CODE",
          "metadata": {
            "name": "Modify Response",
            "returnType": "number",
            "sourceCode": "const type = $context.$nodes.GET_QUERY_TYPE.$output.result;\nlet response = {};\n\nif (type === \"LocationName\") {\n  response = $context.$nodes.GET_WORKER_COUNT_BY_LOCATION_NAME?.$output ?? {};\n} else if (type === \"LocationCode\") {\n  response = $context.$nodes.GET_WORKER_COUNT_BY_LOCATION_CODE?.$output ?? {};\n}\n\nreturn response?.facets?.[0]?.values?.[0]?.count ?? 0;"
          },
          "outcomes": {
            "success": "end"
          },
