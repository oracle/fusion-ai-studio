          "type": "CODE",
          "metadata": {
            "name": "Get Query Type",
            "returnType": "string",
            "sourceCode": "const input = $context.$triggers.REST.$input || {};\nconst hasValue = (value) => value !== null && value !== undefined && String(value).trim() !== \"\" ;\n\nif (hasValue(input.businessUnitId)) return \"BusinessUnitId\";\nif (hasValue(input.businessUnitName)) return \"BusinessUnitName\";\nreturn \"\";"
          },
          "outcomes": {
            "success": "1777022280397"
