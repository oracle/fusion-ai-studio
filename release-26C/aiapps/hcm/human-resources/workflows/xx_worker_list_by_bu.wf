          "code": "GET_LIST_OF_WORKERS",
          "type": "CODE",
          "metadata": {
            "name": "Get List of Workers",
            "returnType": "array",
            "sourceCode": "const type = $context.$nodes.GET_QUERY_TYPE.$output.result;\n\nif (type === \"BusinessUnitId\") return $context.$nodes.GET_WORKER_DETAILS_BY_BUSINESSUNIT_ID.$output?.items ?? [];\nif (type === \"BusinessUnitName\") return $context.$nodes.GET_WORKER_DETAILS_BY_BUSINESSUNIT_NAME.$output?.items ?? [];\nreturn [];"
