        {
          "id": "1777368546973",
          "code": "GET_WORKER_CONNECTIONS",
          "type": "BO_FUNCTION",
          "metadata": {
            "businessObjectCode": "ORA_HCM_GLOBALHUMA_EMPLOYMENTGHR",
            "functionName": "GetWorkerConnections",
            "processJson": true,
            "name": "Get Worker Connections",
            "description": "Returns worker connection records for the supplied person and assignment, including line-manager hierarchy relationships."
          },
          "outcomes": {
            "success": "1777368656803"
          },
          "inputs": [
            {
              "id": "1777368572503_1",
              "name": "personId",
              "type": "string",
              "value": "{{$context.$triggers.REST.$input.personId}}",
              "required": true
            },
            {
              "id": "1777368572503_2",
              "name": "assignmentId",
              "type": "string",
              "value": "{{$context.$nodes.GET_ASSIGNMENTID.$output.result}}",
              "required": true
            }
          ],
          "outputSpecification": "{}"
        },
        {
          "id": "1777368656803",
          "code": "WORKER_CONNECTIONS_TRANSFORM",
          "type": "CODE",
          "metadata": {
            "name": "Worker Connections Transform",
            "returnType": "array",
            "sourceCode": "const input = $context.$triggers.REST.$input || {};\nconst data = $context.$nodes.GET_WORKER_CONNECTIONS.$output?.items;\nconst items = Array.isArray(data) ? data : [];\nconst personId = Number(input.personId);\n\nif (!Number.isFinite(personId)) {\n  return [];\n}\n\nconst filteredList = items.filter((obj) =>\n  Number(obj?.PersonId) === personId && obj?.RelationshipType === \"LINE_MANAGER\"\n);\n\nfilteredList.sort((a, b) => Number(b?.Level ?? 0) - Number(a?.Level ?? 0));\n\nreturn filteredList.map((obj) => ({\n  DisplayName: obj?.RelatedDisplayName ?? \"\",\n  ManagerPersonId: obj?.RelatedPersonId ?? null,\n  ManagerAssignmentId: obj?.RelatedPersonAssignmentId ?? null,\n  RelationshipType: obj?.RelationshipType ?? \"\",\n  RelationshipTypeMeaning: \"Line Manager\",\n  Level: obj?.Level ?? 0\n}));"
          },
          "outcomes": {
            "success": "1777368521121"
          },
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"object\",\n        \"additionalProperties\": true\n      }\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        }
      ],
