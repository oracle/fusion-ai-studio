        {
          "id": "1777368447477",
          "code": "GET_WORKER_PRIMARY_ASSIGNMENT",
          "type": "BO_FUNCTION",
          "metadata": {
            "businessObjectCode": "ORA_HCM_GLOBALHUMA_EMPLOYMENTGHR",
            "functionName": "GetWorkerPrimaryAssignmentInfo",
            "processJson": true,
            "name": "Get Worker Primary Assignment",
            "description": "Returns the primary assignment identifier for the supplied person."
          },
          "outcomes": {
            "success": "1777368483604"
          },
          "inputs": [
            {
              "id": "1777368459713_1",
              "name": "personId",
              "type": "string",
              "value": "{{$context.$triggers.REST.$input.personId}}",
              "required": true
            }
          ],
          "outputSpecification": "{}"
        },
        {
          "id": "1777368483604",
          "code": "GET_ASSIGNMENTID",
          "type": "CODE",
          "metadata": {
            "name": "Get AssignmentId",
            "returnType": "string",
            "sourceCode": "return $context.$nodes.GET_WORKER_PRIMARY_ASSIGNMENT.$output?.items?.[0]?.AssignmentId ?? null;"
          },
          "outcomes": {
            "success": "1777368498154"
          },
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": [\n        \"string\",\n        \"number\",\n        \"null\"\n      ]\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
        {
          "id": "1777368521121",
          "code": "MODIFY_RESPONSE",
          "type": "CODE",
          "metadata": {
            "name": "Modify Response",
            "returnType": "array",
            "sourceCode": "const hasValue = (value) => value !== null && value !== undefined && String(value).trim() !== \"\" && String(value).trim() !== \"<provide a value>\";\n\nif (!hasValue($context.$nodes.GET_ASSIGNMENTID.$output.result)) {\n  return [];\n}\n\nreturn $context.$nodes.WORKER_CONNECTIONS_TRANSFORM.$output.result ?? [];"
          },
          "outcomes": {
            "success": "end"
          },
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"object\",\n        \"additionalProperties\": true\n      }\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
        {
          "id": "1777368498154",
          "code": "ASSIGNMENTID_PRESENT",
          "type": "CONDITION",
          "metadata": {
