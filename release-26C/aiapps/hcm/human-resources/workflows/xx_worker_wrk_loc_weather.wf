        {
          "id": "1779890638529",
          "code": "NORMALIZE_LOCATION_INPUT",
          "type": "CODE",
          "metadata": {
            "name": "Normalize Location Input",
            "returnType": "object",
            "sourceCode": "let placeValue = $context.$nodes.GET_PRIMARY_ASSIGNMENT.$output.items[0].LocationName ?? \"\";\n\nreturn {\n  LocationName: placeValue,\n  requestTimestampUtc: new Date().toISOString()\n};"
          },
