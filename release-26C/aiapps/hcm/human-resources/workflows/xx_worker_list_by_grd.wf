          "code": "MODIFY_RESPONSE",
          "type": "CODE",
          "metadata": {
            "name": "Modify Response",
            "returnType": "array",
            "sourceCode": "const type = $context.$nodes.GET_QUERY_TYPE.$output.result;\nlet response = [];\n\nif (type === \"GradeId\") {\n  response = $context.$nodes.GET_WORKER_DETAILS_BY_GRADE_ID?.$output?.items ?? [];\n} else if (type === \"GradeName\") {\n  response = $context.$nodes.GET_WORKER_DETAILS_BY_GRADE_NAME?.$output?.items ?? [];\n} else if (type === \"GradeCode\") {\n  response = $context.$nodes.GET_WORKER_DETAILS_BY_GRADE_CODE?.$output?.items ?? [];\n}\n\nreturn response;"
          },
          "outcomes": {
            "success": "end"
          },
