          "code": "MODIFY_RESPONSE",
          "type": "CODE",
          "metadata": {
            "name": "Modify Response",
            "returnType": "array",
            "sourceCode": "const type = $context.$nodes.GET_QUERY_TYPE.$output.result;\nlet response = [];\n\nif (type === \"LocationId\") {\n  response = $context.$nodes.GET_PERSON_DETAILS_BY_LOCATION_ID?.$output?.items ?? [];\n} else if (type === \"LocationName\") {\n  response = $context.$nodes.GET_PERSON_DETAILS_BY_LOCATION_NAME?.$output?.items ?? [];\n} else if (type === \"LocationCode\") {\n  response = $context.$nodes.GET_PERSON_DETAILS_BY_LOCATION_CODE?.$output?.items ?? [];\n}\n\nreturn response;"
          },
          "outcomes": {
            "success": "end"
          },
