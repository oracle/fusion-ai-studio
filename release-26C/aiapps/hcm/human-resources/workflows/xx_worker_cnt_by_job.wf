          "type": "BO_FUNCTION",
          "metadata": {
            "businessObjectCode": "ORA_HCM_GLOBALHUMA_XX_PERSONSEARCHESGHR",
            "functionName": "GetWorkersCountByJobName",
            "processJson": true,
            "name": "Get Worker Count by Job Name",
            "description": "Returns the number of workers whose job name matches the supplied value."
          },
