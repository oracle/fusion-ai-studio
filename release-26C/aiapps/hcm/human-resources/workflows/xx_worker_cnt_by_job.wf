        {
          "id": "1777025319070",
          "code": "GET_WORKERS_CNT",
          "type": "CODE",
          "metadata": {
            "name": "Get Worker Count",
            "returnType": "number",
            "sourceCode": "const type = $context.$nodes.GET_QUERY_TYPE.$output.result;\nconst input = $context.$triggers.REST.$input || {};\nlet response = {};\nlet expectedValue = null;\n\nif (type === \"JobCode\") {\n  response = $context.$nodes.GET_WORKES_CNT_BY_JOB_CODE.$output ?? {};\n  expectedValue = input.jobCode;\n} else if (type === \"JobName\") {\n  response = $context.$nodes.GET_WORKERS_CNT_BY_JOB_NAME.$output ?? {};\n  expectedValue = input.jobName;\n}\n\nconst values = response?.facets?.[0]?.values ?? [];\nconst match = values.find((item) => String(item?.value) === String(expectedValue));\nreturn Number(match?.count ?? values[0]?.count ?? 0);"
          },
          "outcomes": {
            "success": "end"
          },
          "inputs": [],
          "diagram": {
            "x": 5225,
            "y": 5912
          },
