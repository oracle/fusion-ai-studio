          "metadata": {
            "name": "Get Query Type",
            "returnType": "string",
            "sourceCode": "const input = $context.$triggers.REST.$input || {};\nconst hasValue = (value) => value !== null && value !== undefined && String(value).trim() !== \"\";\n\nif (hasValue(input.jobId)) return \"JobId\";\nif (hasValue(input.jobCode)) return \"JobCode\";\nif (hasValue(input.jobName)) return \"JobName\";\nreturn \"\";"
          },
          "outcomes": {
            "success": "1777020311844"
          },
          "inputs": [],
          "diagram": {
            "x": 5450,
            "y": 5246
          },
