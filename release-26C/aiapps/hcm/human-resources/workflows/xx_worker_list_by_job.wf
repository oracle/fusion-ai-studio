          "code": "GET_LIST_OF_WORKERS",
          "type": "CODE",
          "metadata": {
            "name": "Get List of Workers",
            "returnType": "array",
            "sourceCode": "const type = $context.$nodes.GET_QUERY_TYPE.$output.result;\n\nif (type === \"JobId\") return $context.$nodes.GET_WORKER_DETAILS_BY_JOB_ID.$output?.items ?? [];\nif (type === \"JobCode\") return $context.$nodes.GET_WORKER_DETAILS_BY_JOB_CODE.$output?.items ?? [];\nif (type === \"JobName\") return $context.$nodes.GET_WORKER_DETAILS_BY_JOB_NAME.$output?.items ?? [];\nreturn [];"
          },
          "outcomes": {
            "success": "end"
          },
