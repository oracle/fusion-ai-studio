        {
          "id": "1782288761466",
          "code": "CALCULATE_DOCUMENT_EXPIRY_DATE_RANGE",
          "type": "CODE",
          "metadata": {
            "name": "Calculate Document Expiry Date Range",
            "returnType": "object",
            "sourceCode": "function pad(value) {\n  return String(value).padStart(2, \"0\");\n}\n\nfunction formatLocalDate(date) {\n  return date.getFullYear() + \"-\" + pad(date.getMonth() + 1) + \"-\" + pad(date.getDate());\n}\n\nconst today = new Date();\nconst currentDate = formatLocalDate(today);\n\nconst dateAfter30 = new Date(today.getTime());\ndateAfter30.setDate(dateAfter30.getDate() + 30);\n\nreturn {\n  currentDate: currentDate,\n  dateAfter30Days: formatLocalDate(dateAfter30)\n};"
          },
          "diagram": {
            "x": 5379.5,
            "y": 5428
          },
          "outcomes": {
            "success": "1783065300001"
          },
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
        {
          "id": "1783065300001",
          "code": "VALIDATE_DOCUMENT_RECORD_EXPIRY_INPUTS",
          "type": "CODE",
          "metadata": {
            "name": "Validate Document Record Expiry Inputs",
            "description": "Validates person number and calculated date inputs before fetching expiring document records.",
            "returnType": "boolean",
            "sourceCode": "function parseDateOnly(value) {\n  if (value === undefined || value === null) return null;\n  const text = String(value).trim();\n  const match = text.match(/^(\\d{4})-(\\d{2})-(\\d{2})$/);\n  if (!match) return null;\n\n  const year = Number(match[1]);\n  const month = Number(match[2]);\n  const day = Number(match[3]);\n  const date = new Date(year, month - 1, day);\n\n  if (date.getFullYear() !== year || date.getMonth() !== month - 1 || date.getDate() !== day) {\n    return null;\n  }\n\n  return date;\n}\n\nfunction validPersonNumber(value) {\n  const text = String(value || \"\").trim();\n  return text.length > 0 && text.length <= 50 && /^[A-Za-z0-9_.@-]+$/.test(text);\n}\n\nconst personNumber = (($context.$nodes.FETCH_PERSON_NUMBER_OF_LOGGEDIN_USER.$output.items || [])[0] || {}).PersonNumber;\nconst dateRange = ($context.$nodes.CALCULATE_DOCUMENT_EXPIRY_DATE_RANGE.$output || {}).result || {};\nconst currentDate = parseDateOnly(dateRange.currentDate);\nconst dateAfter30Days = parseDateOnly(dateRange.dateAfter30Days);\n\nif (!validPersonNumber(personNumber) || !currentDate || !dateAfter30Days) {\n  return false;\n}\n\nreturn currentDate.getTime() <= dateAfter30Days.getTime();"
          },
          "diagram": {
            "x": 5370.5,
            "y": 5650
          },
          "outcomes": {
            "success": "1783065300002"
          },
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
