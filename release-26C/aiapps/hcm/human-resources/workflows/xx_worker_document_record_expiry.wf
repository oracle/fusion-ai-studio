        {
          "id": "1782288793680",
          "code": "FETCH_EXPIRING_DOCUMENT_RECORDS",
          "type": "BO_FUNCTION",
          "metadata": {
            "name": "Fetch Expiring Document Records",
            "businessObjectCode": "ORA_HCM_GLOBALHUMA_DOCUMENTRECORDSEXPIRINGLOOKUP",
            "functionName": "getDocumentRecordsForPersonWithinDateRange"
          },
          "diagram": {
            "x": 5045,
            "y": 6094
          },
          "outcomes": {
            "success": "1782288898014"
          },
          "inputs": [
            {
              "id": "1782288793680_pPersonNumber",
              "name": "pPersonNumber",
              "value": "{{$context.$nodes.FETCH_PERSON_NUMBER_OF_LOGGEDIN_USER.$output.items[0].PersonNumber}}",
              "required": false,
              "type": "string"
            },
            {
              "id": "1782288793680_pStartDate",
              "name": "pStartDate",
              "value": "{{$context.$nodes.CALCULATE_DOCUMENT_EXPIRY_DATE_RANGE.$output.result.currentDate}}",
              "required": false,
              "type": "string"
            },
            {
              "id": "1782288793680_pEndDate",
              "name": "pEndDate",
              "value": "{{$context.$nodes.CALCULATE_DOCUMENT_EXPIRY_DATE_RANGE.$output.result.dateAfter30Days}}",
              "required": false,
              "type": "string"
            }
          ]
        },
        {
          "id": "1782288898014",
          "code": "PROCESS_DOCUMENT_RECORDS_DATA",
          "type": "CODE",
          "metadata": {
            "name": "Process Document Records Data",
            "returnType": "array",
            "sourceCode": "function scrubString(value) {\n  return String(value)\n    .replace(/[\\u0000-\\u001F\\u007F-\\u009F]/g, \" \")\n    .replace(/[<>]/g, \"\")\n    .replace(/\\s+/g, \" \")\n    .trim();\n}\n\nfunction scrub(value) {\n  if (typeof value === \"string\") {\n    return scrubString(value);\n  }\n  if (Array.isArray(value)) {\n    return value.map(function(item) {\n      return scrub(item);\n    });\n  }\n  if (value && typeof value === \"object\") {\n    const clean = {};\n    Object.keys(value).forEach(function(key) {\n      if (key !== \"@context\") {\n        clean[key] = scrub(value[key]);\n      }\n    });\n    return clean;\n  }\n  return value;\n}\n\nfunction firstValue(values) {\n  for (let i = 0; i < values.length; i++) {\n    if (values[i] !== undefined && values[i] !== null && values[i] !== \"\") {\n      return values[i];\n    }\n  }\n  return \"\";\n}\n\nfunction formatLastUpdateDate(value) {\n  if (!value) return \"\";\n\n  const date = new Date(value);\n  if (isNaN(date.getTime())) return \"\";\n\n  const year = date.getFullYear();\n  const month = String(date.getMonth() + 1).padStart(2, \"0\");\n  const day = String(date.getDate()).padStart(2, \"0\");\n\n  let hours = date.getHours();\n  const minutes = String(date.getMinutes()).padStart(2, \"0\");\n  const meridiem = hours >= 12 ? \"PM\" : \"AM\";\n\n  hours = hours % 12;\n  if (hours === 0) hours = 12;\n\n  return year + \"/\" + month + \"/\" + day + \" \" + hours + \":\" + minutes + \" \" + meridiem;\n}\n\nconst output = $context.$nodes.FETCH_EXPIRING_DOCUMENT_RECORDS.$output || [];\nconst items = Array.isArray(output) ? output : (Array.isArray(output.items) ? output.items : []);\nconst currentDate = $context.$nodes.CALCULATE_DOCUMENT_EXPIRY_DATE_RANGE.$output.result.currentDate;\nconst todayUtc = new Date(currentDate + \"T00:00:00Z\");\nconst millisecondsPerDay = 24 * 60 * 60 * 1000;\n\nreturn items.map(function(item) {\n  const clean = scrub(item);\n  let expiringInDays = \"\";\n\n  if (clean.DateTo) {\n    const dateTo = new Date(clean.DateTo + \"T00:00:00Z\");\n    if (!isNaN(dateTo.getTime())) {\n      expiringInDays = Math.ceil((dateTo.getTime() - todayUtc.getTime()) / millisecondsPerDay);\n    }\n  }\n\n  return {\n    DisplayName: clean.DisplayName || \"\",\n    DocumentType: clean.DocumentType || \"\",\n    DocumentName: clean.DocumentName || \"\",\n    DateTo: clean.DateTo || \"\",\n    LastUpdateDate: formatLastUpdateDate(clean.LastUpdateDate),\n    AttachmentsCount: firstValue([clean.AttachmentsCount, clean.AttachmentCount, clean.attachmentsCount, clean.attachmentCount])\n  };\n});"
          },
          "diagram": {
            "x": 5054,
            "y": 6316
          },
          "outcomes": {
            "success": "1782288932908"
          },
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
        {
          "id": "1782288932908",
          "code": "GENERATE_OUTPUT_FOR_DOCUMENT_RECORDS_DATA",
          "type": "LLM",
          "metadata": {
            "name": "Generate output for Document Records Data"
          },
          "diagram": {
            "x": 5000,
            "y": 6538
          },
          "outcomes": {
