        {
          "id": "1782882055179",
          "code": "PARSE_OUTPUT",
          "type": "CODE",
          "metadata": {
            "name": "Parse Output",
            "sourceCode": "let primaryAssignmentDetails = $context.$nodes.GET_ASSIGNMENT_INFORMATION_BY_PERSON.$output?.items?.[0] ?? {};\n\nlet personDetails = $context.$nodes.GET_PERSON_DETAILS.$output;\nlet emailDetails = {\n  \"WorkEmail\": $context.$nodes.GET_PERSON_DETAILS.$output.WorkEmail\n};\n\nlet phoneDetails = $context.$nodes.GET_PERSON_PHONES.$output;\n\nlet otherCommunicationAccountsDetails = $context.$nodes.GET_PERSON_OTHER_COMMUNICATION_ACCOUNTS.$output?.items?.[0]?.otherCommunicationAccounts?.items ?? [];\n\nreturn {\n  \"personDetails\": personDetails,\n  \"primaryAssignmentDetails\": primaryAssignmentDetails,\n  \"emailDetails\": emailDetails,\n  \"phoneDetails\": phoneDetails,\n  \"otherCommunicationAccountsDetails\": otherCommunicationAccountsDetails\n};",
            "returnType": "object"
          },
          "diagram": {
            "x": 5245,
            "y": 5926
          },
          "outcomes": {
            "success": "1779693615076"
          },
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
