  },\n          \"InternalBuilding\": {\n            \"type\": \"null\"\n          },\n          \"InternalFloor\": {\n            \"type\": \"null\"\n          },\n          \"InternalOfficeNumber\": {\n            \"type\": \"null\"\n          },\n          \"InternalMailstop\": {\n            \"type\": \"null\"\n          },\n          \"LocationAddressLine1\": {\n            \"type\": \"string\"\n          },\n          \"LocationAddressLine2\": {\n            \"type\": \"null\"\n          },\n          \"LocationAddressLine3\": {\n            \"type\": \"null\"\n          },\n          \"LocationAddressLine4\": {\n            \"type\": \"null\"\n          },\n          \"LocationRegion1\": {\n            \"type\": \"string\"\n          },\n          \"LocationRegion2\": {\n            \"type\": \"string\"\n          },\n          \"LocationRegion3\": {\n            \"type\": \"null\"\n          },\n          \"LocationTownOrCity\": {\n            \"type\": \"string\"\n          },\n          \"LocationPostalCode\": {\n            \"type\": \"string\"\n          },\n          \"LocationCountry\": {\n            \"type\": \"string\"\n          },\n          \"LocationLongPostalCode\": {\n            \"type\": \"null\"\n          },\n          \"LocationTimezoneCode\": {\n            \"type\": \"null\"\n          },\n          \"LocationSingleLineAddress\": {\n            \"type\": \"string\"\n          },\n          \"LocationMultiLineAddress\": {\n            \"type\": \"string\"\n          },\n          \"LengthOfServiceYears\": {\n            \"type\": \"number\"\n          },\n          \"LengthOfServiceMonths\": {\n            \"type\": \"number\"\n          },\n          \"LengthOfServiceDays\": {\n            \"type\": \"number\"\n          },\n          \"MarkedAsFavoriteFlag\": {\n            \"type\": \"boolean\"\n          },\n          \"DateProbationEnd\": {\n            \"type\": \"null\"\n          },\n          \"ProjectedStartDate\": {\n            \"type\": \"null\"\n          },\n          \"@context\": {\n            \"type\": \"object\",\n            \"properties\": {\n              \"key\": {\n                \"type\": \"string\"\n              }\n            },\n            \"required\": [\n              \"key\"\n            ],\n            \"additionalProperties\": false\n          }\n        },\n        \"required\": [\n          \"AssignmentId\",\n          \"AssignmentNumber\",\n          \"AssignmentName\",\n          \"LegalEmployerName\",\n          \"StartDate\",\n          \"PrimaryFlag\",\n          \"PrimaryAssignmentFlag\",\n          \"WorkerType\",\n          \"WorkerNumber\",\n          \"WorkAtHomeFlag\",\n          \"FullPartTime\",\n          \"ManagerName\",\n          \"BusinessUnitName\",\n          \"DepartmentName\",\n          \"JobCode\",\n          \"JobName\",\n          \"PositionCode\",\n          \"PositionName\",\n          \"LocationCode\",\n          \"LocationName\",\n          \"GradeCode\",\n          \"GradeName\",\n          \"InternalBuilding\",\n          \"InternalFloor\",\n          \"InternalOfficeNumber\",\n          \"InternalMailstop\",\n          \"LocationAddressLine1\",\n          \"LocationAddressLine2\",\n          \"LocationAddressLine3\",\n          \"LocationAddressLine4\",\n          \"LocationRegion1\",\n          \"LocationRegion2\",\n          \"LocationRegion3\",\n          \"LocationTownOrCity\",\n          \"LocationPostalCode\",\n          \"LocationCountry\",\n          \"LocationLongPostalCode\",\n          \"LocationTimezoneCode\",\n          \"LocationSingleLineAddress\",\n          \"LocationMultiLineAddress\",\n          \"LengthOfServiceYears\",\n          \"LengthOfServiceMonths\",\n          \"LengthOfServiceDays\",\n          \"MarkedAsFavoriteFlag\",\n          \"DateProbationEnd\",\n          \"ProjectedStartDate\",\n          \"@context\"\n        ],\n        \"additionalProperties\": false\n      }\n    },\n    \"count\": {\n      \"type\": \"number\"\n    },\n    \"hasMore\": {\n      \"type\": \"boolean\"\n    },\n    \"limit\": {\n      \"type\": \"number\"\n    },\n    \"offset\": {\n      \"type\": \"number\"\n    },\n    \"links\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"rel\": {\n            \"type\": \"string\"\n          },\n          \"href\": {\n            \"type\": \"string\"\n          },\n          \"name\": {\n            \"type\": \"string\"\n          },\n          \"kind\": {\n            \"type\": \"string\"\n          }\n        },\n        \"required\": [\n          \"rel\",\n          \"href\",\n          \"name\",\n          \"kind\"\n        ],\n        \"additionalProperties\": false\n      }\n    }\n  },\n  \"required\": [\n    \"items\",\n    \"count\",\n    \"hasMore\",\n    \"limit\",\n    \"offset\",\n    \"links\"\n  ],\n  \"additionalProperties\": false\n}"
