        {
          "id": "1777550487606",
          "code": "GET_QUERY_TYPE",
          "type": "CODE",
          "metadata": {
            "name": "Get Query Type",
            "returnType": "string",
            "sourceCode": "const input = $context.$triggers.REST.$input || {};\nconst hasValue = (value) => value !== null && value !== undefined && String(value).trim() !== \"\" && String(value).trim() !== \"<provide a value>\";\n\nif (hasValue(input.managerId)) return \"ManagerId\";\nreturn \"\";"
          },
          "outcomes": {
            "success": "1777550506265"
          },
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
        {
          "id": "1777550525211",
          "code": "GET_WORKERS_CNT",
          "type": "CODE",
          "metadata": {
            "name": "Get Worker Counts",
            "returnType": "array",
            "sourceCode": "const type = $context.$nodes.GET_QUERY_TYPE.$output.result;\nif (type !== \"ManagerId\") return [];\nreturn $context.$nodes.WORKERCOUNTBYMANAGERANDLOCATION.$output?.facets?.[0]?.values ?? [];"
          },
          "outcomes": {
            "success": "end"
          },
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"object\",\n        \"additionalProperties\": true\n      }\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
        {
          "id": "1777550506265",
          "code": "CHECKMANAGERID",
          "type": "CONDITION",
          "metadata": {
            "name": "checkManagerId"
          },
          "outcomes": {
            "true": "1777550589991",
            "false": "1777550525211"
          },
          "inputs": [
            {
              "id": "1777550506266_1",
              "name": "condition",
              "type": "string",
              "value": "{{$context.$nodes.GET_QUERY_TYPE.$output.result == \"ManagerId\"}}"
            }
          ],
          "convergenceTargetId": "1777550525211"
        },
