        {
          "id": "1777550589991",
          "code": "WORKERCOUNTBYMANAGERANDLOCATION",
          "type": "BO_FUNCTION",
          "metadata": {
            "businessObjectCode": "ORA_HCM_GLOBALHUMA_XX_PERSONSEARCHESGHR",
            "functionName": "GetWorkerCount",
            "processJson": true,
            "name": "Get Worker Count by Manager and Location",
            "description": "Returns worker aggregation counts using the supplied workerAggregationsV2 JSON payload."
          },
          "outcomes": {
            "success": "1777550525211"
          },
          "inputs": [
            {
              "id": "1777550613713_1",
              "name": "payload",
              "value": "{\n  \"facets\": [\n    \"LocationName\"\n  ],\n  \"securityFilters\": {\n    \"type\": \"PersonSearch\",\n    \"value\": \"AdvancedSearch\"\n  },\n  \"filters\": [\n    {\n      \"name\": \"Reports\",\n      \"value\": \"{{$context.$triggers.REST.$input.managerId}}\"\n    },\n    {\n      \"name\": \"PrimaryAssignmentOnly\",\n      \"value\": true\n    }\n  ]\n}",
              "required": false,
              "type": "string"
            }
          ],
