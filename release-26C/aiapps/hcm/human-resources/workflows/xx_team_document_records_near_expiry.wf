          "inputs": []
        },
        {
          "id": "1783063057876",
          "code": "VALIDATE_PERSON_NUMBER",
          "type": "CODE",
          "metadata": {
            "name": "Validate Person Number",
            "returnType": "object",
            "sourceCode": "function validPersonNumber(value) {\n  const text = String(value || \"\").trim();\n  return text.length > 0 && text.length <= 50 && /^[A-Za-z0-9_.@-]+$/.test(text);\n}\n\nconst output = $context.$nodes.FETCH_PERSON_NUMBER_OF_LOGGEDIN_USER.$output || {};\nconst items = Array.isArray(output.items) ? output.items : [];\nconst context = items[0] || {};\nconst personNumber = String(context.PersonNumber || \"\").trim();\nconst isValid = validPersonNumber(personNumber);\n\nreturn {\n  isValid: isValid,\n  personNumber: isValid ? personNumber : \"\"\n};"
          },
          "diagram": {
            "x": 5267,
            "y": 5650
          },
          "outcomes": {
            "success": "1783063129679"
          },
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
        {
          "id": "1783063129679",
          "code": "CHECK_PERSON_NUMBER",
          "type": "CONDITION",
          "convergenceTargetId": "end",
