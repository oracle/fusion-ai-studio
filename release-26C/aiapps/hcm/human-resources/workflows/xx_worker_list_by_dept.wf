          "type": "CODE",
          "metadata": {
            "name": "Get Query Type",
            "returnType": "string",
            "sourceCode": "const input = $context.$triggers.REST.$input || {};\nconst hasValue = (value) => value !== null && value !== undefined && String(value).trim() !== \"\";\n\nif (hasValue(input.departmentName)) return \"DepartmentName\";\nreturn \"\";"
          },
          "outcomes": {
            "success": "1778058136741"
