          "metadata": {
            "name": "Get List of Workers",
            "returnType": "array",
            "sourceCode": "const type = $context.$nodes.GET_QUERY_TYPE.$output.result;\n\nif (type === \"DepartmentName\") return $context.$nodes.GET_WORKER_DETAILS_BY_DEPARTMENT_NAME.$output?.items ?? [];\nreturn [];"
          },
