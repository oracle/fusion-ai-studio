        {
          "id": "1777012416532",
          "code": "GET_LIST_OF_EMAILS",
          "type": "CODE",
          "metadata": {
            "name": "Get List of Emails",
            "returnType": "array",
            "sourceCode": "const type = $context.$nodes.GET_QUERY_TYPE.$output.result;\nlet workers = [];\n\nif (type === \"PersonId\") {\n  workers = $context.$nodes.GET_WORKER_EMAILS_VIA_PERSON_ID?.$output?.items ?? [];\n} else if (type === \"PersonNumber\") {\n  workers = $context.$nodes.GET_WORKER_EMAILS_VIA_PERSON_NUMBER?.$output?.items ?? [];\n}\n\nreturn workers[0]?.emails?.items ?? [];"
          },
          "outcomes": {
            "success": "end"
          },
