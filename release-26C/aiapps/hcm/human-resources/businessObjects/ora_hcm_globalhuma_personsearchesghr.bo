      {
        "name": "GetWorkersByGradeCode",
        "description": "Lists workers whose grade code matches the supplied value.",
        "operationType": "POST",
        "resourcePath": "/hcmRestApi/redwood/11.13.18.05/workerSearchesV2",
        "resourceType": "ADF_BC_FIXED_QUERY",
        "bodyTemplate": "{\n    \"securityFilters\": {\n        \"type\": \"QuickAction\",\n        \"value\": \"HRIdentificationInfo\",\n        \"context\": \"MyClientGroups\"\n    },\n    \"filters\": [\n        {\n            \"name\": \"GradeCode\",\n            \"terms\": [\n                \"{gradeCode}\"\n            ]\n        }\n    ],\n    \"displayFields\": [\n        \"DisplayName\",\n        \"DepartmentName\",\n        \"JobName\",\n        \"LocationName\",\n        \"PositionName\",\n        \"PersonId\",\n        \"PersonNumber\",\n        \"AssignmentNumber\"\n    ],\n    \"offset\": 0\n}",
