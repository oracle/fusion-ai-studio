        {
          "id": "1782414465803",
          "code": "FETCH_OPEN_PHASE_AND_EXPIRED_REQUISITIONS",
          "type": "BO_FUNCTION",
          "metadata": {
            "name": "Fetch Open Phase and Expired Requisitions",
            "businessObjectCode": "ORA_HCM_RECRUITING_XX_EXPIREDJOBREQUISITIONS",
            "functionName": "get_job_requisitions",
