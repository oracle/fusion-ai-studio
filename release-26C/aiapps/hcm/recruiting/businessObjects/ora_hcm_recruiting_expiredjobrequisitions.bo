  "name": "Expired Job Requisitions",
  "description": "Expired Job Requisitions retrieves open recruiting requisitions whose postings have expired, including requisition details, application counts, ownership, and organizational attributes.",
  "objectCode": "ORA_HCM_RECRUITING_XX_EXPIREDJOBREQUISITIONS",
