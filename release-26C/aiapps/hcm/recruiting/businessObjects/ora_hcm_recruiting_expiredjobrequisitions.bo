  "objectProperties": {
    "jsonSchemaName": "supportedObjectProperties",
    "jsonSchemaVersion": 1,
    "tools": [
      {
        "name": "get_job_requisitions",
        "description": "Retrieves open job requisition records whose postings have expired. This function returns requisition numbers, titles, hiring managers, recruiters, application counts, and organizational attributes for expired requisition review.",
        "operationType": "POST",
        "resourcePath": "/hcmRestApi/resources/11.13.18.05/recruitingUIJobRequisitions/action/findByAdvancedSearchQuery",
        "resourceType": "ADF_BC_FIXED_QUERY",
        "bodyTemplate": "{\n  \"searchFields\": [\n    \"REQUISITION_NUMBER\",\n    \"TITLE\",\n    \"JOB_NAME\",\n    \"POSITION_NAME\",\n    \"BUSINESS_UNIT_NAME\",\n    \"ORGANIZATION_NAME\",\n    \"DEPARTMENT_NAME\",\n    \"MANAGER_TITLE\",\n    \"SKILL_NAME\",\n    \"INTERNAL_DESCRIPTION\",\n    \"INTERNAL_QUALIFICATIONS\",\n    \"INTERNAL_RESPONSIBILITIES\",\n    \"INTERNAL_SHORT_DESCRIPTION\",\n    \"EXTERNAL_DESCRIPTION\",\n    \"EXTERNAL_QUALIFICATIONS\",\n    \"EXTERNAL_RESPONSIBILITIES\",\n    \"EXTERNAL_SHORT_DESCRIPTION\"\n  ],\n  \"displayFields\": [\n    \"REQUISITION_ID\",\n    \"REQUISITION_NUMBER\",\n    \"TITLE\",\n    \"PHASE_CODE\",\n    \"PHASE_NAME\",\n    \"STATE_CODE\",\n    \"STATE_NAME\",\n    \"NEW_JOB_APPLICATION_COUNT\",\n    \"JOB_APPLICATION_COUNT\",\n    \"PROSPECT_COUNT\",\n    \"HIRING_MANAGER_DISPLAY_NAME\",\n    \"RECRUITER_DISPLAY_NAME\",\n    \"REQUISITION_TYPE\",\n    \"LOCATION\",\n    \"WORK_LOCATION\",\n    \"RECRUITING_TYPE_NAME\",\n    \"RECRUITING_TYPE_CODE\",\n    \"MANAGER_TITLE\",\n    \"ORGANIZATION_NAME\",\n    \"BUSINESS_UNIT_NAME\",\n    \"LEGAL_EMPLOYER_NAME\",\n    \"DEPARTMENT_NAME\",\n    \"JOB_NAME\",\n    \"POSITION_NAME\",\n    \"JOB_FAMILY_NAME\",\n    \"JOB_FUNCTION_NAME\",\n    \"CREATION_DATE\",\n    \"TN_AGENCY_STATUS_NAME\"\n  ],\n  \"offset\": 0,\n  \"limit\": 25,\n  \"filters\": [\n    {\n      \"PHASE_ID\": [\n        5\n      ]\n    },\n    {\n      \"STATE_ID\": [\n        31\n      ]\n    },\n    {\n      \"REQUISITION_OWNERSHIP\": [\n        \"ORA_RECRUITER\",\n        \"ORA_HIRINGMANAGER\",\n        \"ORA_COLLABORATOR\"\n      ]\n    }\n  ],\n  \"sort\": [\n    {\n      \"name\": \"CREATION_DATE\",\n      \"direction\": \"desc\"\n    }\n  ]\n}",
        "useNativeAuthentication": true,
        "type": "BUS_OBJECT",
        "parameterDefinitions": [],
        "headers": {
          "Content-Type": "application/vnd.oracle.adf.action+json",
          "REST-Framework-Version": "9"
        },
        "sampleQueries": [
          {
            "description": "This example payload demonstrates a request to retrieve open job requisitions whose postings have expired using the get_job_requisitions function.",
            "query": {
