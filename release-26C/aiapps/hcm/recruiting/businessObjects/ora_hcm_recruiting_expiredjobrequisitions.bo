                "MANAGER_TITLE",
                "SKILL_NAME",
                "INTERNAL_DESCRIPTION",
                "INTERNAL_QUALIFICATIONS",
                "INTERNAL_RESPONSIBILITIES",
                "INTERNAL_SHORT_DESCRIPTION",
                "EXTERNAL_DESCRIPTION",
                "EXTERNAL_QUALIFICATIONS",
                "EXTERNAL_RESPONSIBILITIES",
                "EXTERNAL_SHORT_DESCRIPTION"
              ],
              "displayFields": [
                "REQUISITION_ID",
                "REQUISITION_NUMBER",
                "TITLE",
                "PHASE_CODE",
                "PHASE_NAME",
                "STATE_CODE",
                "STATE_NAME",
                "NEW_JOB_APPLICATION_COUNT",
                "JOB_APPLICATION_COUNT",
                "PROSPECT_COUNT",
                "HIRING_MANAGER_DISPLAY_NAME",
                "RECRUITER_DISPLAY_NAME",
                "REQUISITION_TYPE",
                "LOCATION",
                "WORK_LOCATION",
                "RECRUITING_TYPE_NAME",
                "RECRUITING_TYPE_CODE",
                "MANAGER_TITLE",
                "ORGANIZATION_NAME",
                "BUSINESS_UNIT_NAME",
                "LEGAL_EMPLOYER_NAME",
                "DEPARTMENT_NAME",
                "JOB_NAME",
                "POSITION_NAME",
                "JOB_FAMILY_NAME",
                "JOB_FUNCTION_NAME",
                "CREATION_DATE",
                "TN_AGENCY_STATUS_NAME"
              ],
              "offset": 0,
              "limit": 25,
              "filters": [
                {
                  "PHASE_ID": [
                    "3"
                  ]
                },
                {
                  "STATE_ID": [
                    "12"
                  ]
                },
                {
                  "REQUISITION_OWNERSHIP": [
                    "ORA_RECRUITER",
