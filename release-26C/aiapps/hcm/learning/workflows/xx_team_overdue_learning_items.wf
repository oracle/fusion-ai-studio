        {
          "id": "1782388094382",
          "code": "FETCH_OVERDUE_LEARNING_ITEMS",
          "type": "BO_FUNCTION",
          "metadata": {
            "name": "Fetch Overdue Learning Items",
            "businessObjectCode": "ORA_HCM_LEARNING_XX_LEARNINGSEARCHES",
            "functionName": "learning_item_aggregations",
            "errorNodeId": "1783070086077"
          },
          "diagram": {
