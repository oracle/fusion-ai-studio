          "inputs": [
            {
              "id": "1782388151386_selectedLearningItemId",
              "name": "selectedLearningItemId",
              "value": "{{$context.$nodes.EXTRACT_SELECTED_LEARNING_ITEM_ACTION.$output.result.learningItemId}}",
              "type": "string"
            }
          ],
          "diagram": {
            "x": 5252,
            "y": 5650
          }
        },
        {
          "id": "1782388151387",
          "code": "EXTRACT_SELECTED_LEARNING_ITEM_ACTION",
          "type": "CODE",
          "metadata": {
            "name": "Extract Selected Learning Item Action",
            "sourceCode": "const app = $context.$app || {};\nconst system = $context.$system || {};\nconst actionText = String(app.$OraAction || '');\nlet payload = {};\n\nif (actionText) {\n  const start = actionText.indexOf('{');\n  const end = actionText.lastIndexOf('}');\n  if (start >= 0 && end > start) {\n    const payloadText = actionText.slice(start, end + 1);\n    try {\n      payload = JSON.parse(payloadText);\n    } catch (e) {\n      payload = {};\n    }\n  }\n}\n\nconst result = {\n  learningItemId: payload.learningItemId != null ? String(payload.learningItemId) : '',\n  learningItemTitle: payload.learningItemTitle != null ? String(payload.learningItemTitle) : '',\n  instruction: payload.instruction != null ? String(payload.instruction) : ''\n};\nreturn result;",
            "returnType": "object"
          },
          "outcomes": {
            "success": "1782388151386"
          },
          "inputs": [],
          "diagram": {
            "x": 5216,
            "y": 5428
          },
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
        {
          "id": "1783064303930",
          "code": "VALIDATE_LEARNING_ITEM_ID",
          "type": "CODE",
          "metadata": {
            "name": "Validate Learning Item Id",
            "returnType": "boolean",
            "sourceCode": "function clean(value) {\n  return value === undefined || value === null ? \"\" : String(value).trim();\n}\n\nconst learningItemId = clean($context.$variables.selectedLearningItemId);\n\nreturn /^\\d+$/.test(learningItemId);"
          },
          "diagram": {
            "x": 5262.5,
            "y": 5872
          },
          "outcomes": {
            "success": "1783068096339"
          },
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
        {
          "id": "1783068096339",
          "code": "CHECK_IF_VALID_LEARNING_ITEM_ID",
          "type": "CONDITION",
          "convergenceTargetId": "end",
          "metadata": {
