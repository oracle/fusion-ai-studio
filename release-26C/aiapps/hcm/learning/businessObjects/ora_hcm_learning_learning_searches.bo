      {
        "name": "learner_aggregations",
        "description": "This business object function gives learning aggregations by learner",
        "operationType": "POST",
        "resourcePath": "/hcmRestApi/indexSearch/learningRecordLearnerAggregations",
        "resourceType": "ADF_BC_FIXED_QUERY",
        "bodyTemplate": "{\"securityFilters\":{\"type\":\"MANAGER\"},\"filters\":[{\"name\":\"reports\",\"value\":\"DIRECT_REPORTS\"},{\"name\":\"enrollments\",\"value\":\"CURRENT\"}],\"sort\":[{\"name\":\"overdueLearning\",\"direction\":\"desc\"}],\"offset\":0,\"limit\":25}",
        "useNativeAuthentication": true,
        "type": "BUS_OBJECT",
        "parameterDefinitions": [],
        "sampleQueries": [
          {
            "description": "This is a sample response for learner search aggregations",
            "query": {
              "items": [
                {
                  "assignedToId": "{assignedToId_1}",
                  "assignedToDisplayName": "{assignedToDisplayName_1}",
                  "assignmentName": "{assignedToAssignment_name1}",
                  "requiredLearningCount": 3,
                  "voluntaryLearningCount": 1,
                  "overdueLearningCount": 3,
                  "dueNextMonthLearningCount": 0,
                  "assignedToPersonPrimaryEmailAddress": "{assignedToPersonPrimaryEmailAddress_1}",
                  "assignedToNumber": "{assignedToNumber_1}",
                  "badgeText": "Overdue",
                  "badgeStatus": "danger"
                },
                {
                  "assignedToId": "{assignedToId_2}",
                  "assignedToDisplayName": "{assignedToDisplayName_2}",
                  "assignmentName": "{assignedToAssignment_name2}",
                  "requiredLearningCount": 13,
                  "voluntaryLearningCount": 0,
                  "overdueLearningCount": 0,
                  "dueNextMonthLearningCount": 0,
                  "assignedToPersonPrimaryEmailAddress": "{assignedToPersonPrimaryEmailAddress_2}",
                  "assignedToNumber": "{assignedToNumber_2}"
                }
              ],
              "count": 2,
              "limit": 25,
              "offset": 0,
              "hasMore": false,
              "totalResults": 2
            },
            "sampleType": "response"
          }
        ]
      },
