      {
        "name": "enrollment_status",
        "description": "This business object function give aggregation of status of all enrollments in my team",
        "operationType": "POST",
        "resourcePath": "/hcmRestApi/indexSearch/learningRecordAggregations",
        "resourceType": "ADF_BC_FIXED_QUERY",
        "bodyTemplate": "{\n    \"securityFilters\": {\n        \"type\": \"MANAGER\"\n    },\n    \"filters\": [\n        {\n            \"name\": \"reports\",\n            \"value\": \"DIRECT_REPORTS\"\n        },\n        {\n            \"name\": \"enrollments\",\n            \"value\": \"CURRENT\"\n        }\n    ],\n    \"facets\": [\n        \"assignmentSubStatus\"\n    ]\n}",
        "useNativeAuthentication": true,
        "type": "BUS_OBJECT",
        "parameterDefinitions": [],
        "sampleQueries": [
          {
            "description": "This is a sample response for learn enrollment status aggregation request",
            "query": {
              "facets": [
                {
                  "name": "assignmentSubStatus",
                  "values": [
                    {
                      "value": "ORA_ASSN_REC_INPROGRESS",
                      "displayValue": "In Progress",
                      "count": 13
                    },
                    {
                      "value": "ORA_ASSN_REC_NOTSTARTED",
                      "displayValue": "Not Started",
                      "count": 3
                    },
                    {
                      "value": "ORA_ASSN_REC_PENDING_ACTIVE",
                      "displayValue": "Pending Active",
                      "count": 1
                    }
                  ]
                }
              ]
            },
            "sampleType": "response"
          }
        ]
      },
      {
        "name": "learning_record_searches",
        "description": "This business object fucntion searches learning item records by learning item id",
        "operationType": "POST",
        "resourcePath": "/hcmRestApi/indexSearch/learningRecordSearches",
        "resourceType": "ADF_BC_FIXED_QUERY",
        "bodyTemplate": "{\"securityFilters\":{\"type\":\"MANAGER\"},\"filters\":[{\"name\":\"reports\",\"value\":\"DIRECT_REPORTS\"},{\"name\":\"enrollments\",\"value\":\"CURRENT\"},{\"name\":\"learningItemId\",\"value\":\"{learningItemId}\" }],\"sort\":[{\"name\":\"assignmentDueDate\",\"direction\":\"asc\"}],\"offset\":0,\"limit\":25}",
        "useNativeAuthentication": true,
        "type": "BUS_OBJECT",
        "parameterDefinitions": [
          {
            "name": "learningItemId",
            "dataType": "string",
            "description": "Primary key identifier for the learning item id to search the learning records for a learning item",
            "id": 8,
