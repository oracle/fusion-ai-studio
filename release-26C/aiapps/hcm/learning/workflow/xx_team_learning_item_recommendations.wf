        },
        {
          "id": "1783063907417",
          "code": "VALIDATE_LEARNING_ITEM_IDS",
          "type": "CODE",
          "metadata": {
            "name": "Validate Learning Item Ids",
            "returnType": "object",
            "sourceCode": "const selected = ($context.$nodes.SELECT_TOP_LEARNING_ITEM_IDS.$output || {}).result || {};\nconst rawIds = Array.isArray(selected.learningItemIds) ? selected.learningItemIds : [];\nconst listValue = selected.listOfLearningItemIds;\nconst ids = rawIds.length > 0\n  ? rawIds.map(function(id) { return String(id).trim(); }).filter(function(id) { return id !== \"\"; })\n  : String(listValue || \"\").split(\",\").map(function(id) { return id.trim(); }).filter(function(id) { return id !== \"\"; });\n\nconst isValid = ids.every(function(id) {\n  return /^\\d{1,18}$/.test(id);\n});\n\nreturn {\n  isValid: isValid,\n  learningItemIds: isValid ? ids : [],\n  listOfLearningItemIds: isValid ? ids.join(\",\") : \"\"\n};"
          },
          "diagram": {
            "x": 5258,
            "y": 5872
          },
          "outcomes": {
            "success": "1783063978966"
          },
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
        {
