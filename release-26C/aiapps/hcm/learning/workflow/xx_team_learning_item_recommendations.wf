          "metadata": {
            "name": "Fetch WLF Recommendation Aggregations",
            "businessObjectCode": "ORA_HCM_LEARNING_XX_WLFRECOMMENDATIONAGGREGATIONSLOOKUP",
            "functionName": "getWlfRecommendationAggregations",
            "processJson": true
          },
          "outcomes": {
