        {
          "metadata": {
            "name": "Getting Location from Action",
            "returnType": "string",
            "sourceCode": "let oraAction = $context.$app.$OraAction || \"{}\";\nlet payload = JSON.parse(oraAction);\n\nconst data = payload.data || {};\nconst location = String(data.location || \"\").trim();\n\nif (!/^[a-zA-Z0-9\\s,._-]{1,100}$/.test(location)) {\n  throw new Error(\"Invalid location\");\n}\n\nreturn location;"
          },
          "outcomes": {
            "success": "1782293924086"
          },
          "code": "GETTING_LOCATION_FROM_ACTION",
          "convergenceTargetId": "1775638239097",
          "id": "1775551739927",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "type": "CODE",
