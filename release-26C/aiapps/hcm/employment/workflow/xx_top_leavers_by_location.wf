        {
          "id": "1783066912549",
          "code": "VALIDATING_LOCATION_FROM_INPUT",
          "type": "CODE",
          "metadata": {
            "name": "Validating Location from input",
            "sourceCode": "const rawLocation = $context.$triggers.REST.$input.Location;\n\nlet valid = true;\nlet invalid = false;\nlet reason = \"\";\nlet location = \"\";\nlet sqlSafeLocation = \"\";\n\nfunction markInvalid(message) {\n  valid = false;\n  invalid = true;\n  reason = message;\n}\n\nif (rawLocation === null || rawLocation === undefined || rawLocation === \"\") {\n  // Location is optional. Null/undefined/empty is valid.\n  valid = true;\n  invalid = false;\n  reason = \"\";\n  location = \"\";\n  sqlSafeLocation = \"\";\n} else if (typeof rawLocation !== \"string\") {\n  markInvalid(\"Location must be a string\");\n} else {\n  location = rawLocation.trim();\n\n  if (!location) {\n    markInvalid(\"Location cannot be empty\");\n  } else if (location.length > 50) {\n    markInvalid(\"Location is too long\");\n  } else {\n    // Reject hidden/control characters.\n    // Special characters like =, \", ', &, /, -, _, @, #, %, (, ), :, ; etc. are allowed.\n    for (let i = 0; i < location.length; i++) {\n      const code = location.charCodeAt(i);\n\n      if ((code >= 0 && code <= 31) || code === 127) {\n        markInvalid(\"Location contains invalid control characters\");\n        break;\n      }\n    }\n\n    if (valid) {\n      // SQL string literal escaping.\n      // Example: O'Brien -> O''Brien\n      sqlSafeLocation = location.split(\"'\").join(\"''\");\n    }\n  }\n}\n\nreturn {\n  valid: valid,\n  invalid: invalid,\n  reason: reason,\n  originalLocation: location,\n  sqlSafeLocation: sqlSafeLocation\n};",
            "returnType": "object"
          },
          "diagram": {
            "x": 7548.5,
            "y": 5428
          },
          "outcomes": {
            "success": "1783066929803"
          },
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
