            "name": "Generating OTBI Query to get leavers",
            "returnType": "object",
            "sourceCode": "const locationName = $context.$nodes.VALIDATING_LOCATION.$output.result.sqlSafeLocationName;\nconst managerId = $context.$nodes.VALIDATING_MANAGER_ID.$output.result.managerPersonId;\n\nlet payload = {\n  sqlQuery:\n    \"SET VARIABLE PREFERRED_CURRENCY='User Preferred Currency 1'; SELECT 0 s_0, \" +\n    \"\\\"Workforce Management - Worker Assignment Event Real Time\\\".\\\"Worker\\\".\\\"Employee Display Name\\\" s_1, \" +\n    \"\\\"Workforce Management - Workforce Trend Real Time\\\".\\\"HR Action Reason\\\".\\\"Action Reason\\\" s_2, \" +\n    \"\\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Manager\\\".\\\"Manager Display Name\\\" s_3, \" +\n    \"CAST(\\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Time\\\".\\\"Calendar Year\\\" AS INT) s_4, \" +\n    \"CAST(RIGHT(\\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Time\\\".\\\"Month\\\",2) AS INT) s_5, \" +\n    \"\\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Workforce Trend\\\".\\\"Termination Headcount\\\" s_6, \" +\n    \"\\\"Workforce Management - Worker Assignment Event Real Time\\\".\\\"Worker\\\".\\\"Manager ID\\\" s_7, \" +\n    \"\\\"Workforce Management - Worker Assignment Event Real Time\\\".\\\"Worker\\\".\\\"Manager Assignment ID\\\" s_8, \" +\n    \"\\\"Workforce Management - Worker Assignment Event Real Time\\\".\\\"Location\\\".\\\"Worker Location Name\\\" s_9, \" +\n    \"\\\"Workforce Management - Worker Assignment Event Real Time\\\".\\\"Department\\\".\\\"Department Name\\\" s_10, \" +\n    \"\\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Job\\\".\\\"Job Name\\\" s_11, \" +\n    \"\\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Worker\\\".\\\"Termination Date\\\" s_12, \" +\n    \"\\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Worker\\\".\\\"Employee Hire Date\\\" s_13, \" +\n    \"DESCRIPTOR_IDOF(\\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Job\\\".\\\"Job Name\\\") s_14, \" +\n    \"\\\"Workforce Management - Worker Assignment Event Real Time\\\".\\\"Worker\\\".\\\"Manager Department Name\\\" s_15 \" +\n    \"FROM \\\"Workforce Management - Workforce Trend Real Time\\\" \" +\n    \"WHERE ((\\\"Workforce Trend\\\".\\\"Termination Headcount\\\" > 0) \" +\n    \"AND (\\\"Workforce Management - Worker Assignment Event Real Time\\\".\\\"Worker\\\".\\\"Termination Date\\\" \" +\n    \"BETWEEN TIMESTAMPADD(SQL_TSI_MONTH, -6, CURRENT_DATE) AND CURRENT_DATE) \" +\n    \"AND (\\\"Location\\\".\\\"Worker Location Name\\\" = '\" + locationName + \"') \" +\n    \"AND (\\\"Workforce Management - Worker Assignment Event Real Time\\\".\\\"Worker\\\".\\\"Manager ID\\\" = \" + managerId + \")) \" +\n    \"AND (\\\"Business Unit\\\".\\\"Business Unit Id\\\" = 300100648781671) \" +\n    \"ORDER BY 5 DESC NULLS FIRST, 6 ASC NULLS LAST, 3 ASC NULLS LAST, 4 ASC NULLS LAST \" +\n    \"FETCH FIRST 75001 ROWS ONLY\",\n\n  outputFormat: \"CollectionDataFormat\",\n\n  executionOptions: {\n    async: false,\n    refresh: true,\n    presentationInfo: true,\n    maxRowsPerPage: 25\n  },\n\n  sessionId: $context.$nodes.PERFORMING_LOGON.$output.token\n};\n\nreturn payload;"
          },
