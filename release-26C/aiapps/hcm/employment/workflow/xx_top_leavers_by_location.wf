          "code": "VALIDATING_LOCATION",
          "type": "CODE",
          "metadata": {
            "name": "Validating Location ",
            "sourceCode": "const rawLocation =\n  $context.$nodes.GETTING_LOCATION.$output.result;\n\nlet valid = true;\nlet invalid = false;\nlet reason = \"\";\nlet locationName = \"\";\nlet sqlSafeLocationName = \"\";\n\nfunction markInvalid(message) {\n  valid = false;\n  invalid = true;\n  reason = message;\n}\n\nif (typeof rawLocation !== \"string\") {\n  markInvalid(\"location must be a string\");\n} else {\n  locationName = rawLocation.trim();\n\n  if (!locationName) {\n    markInvalid(\"location cannot be empty\");\n  } else if (locationName.length > 50) {\n    markInvalid(\"location is too long\");\n  } else {\n    // Reject hidden/control characters.\n    // Special characters like =, \", ', &, /, -, _, @, #, %, (, ), :, ; etc. are allowed.\n    for (let i = 0; i < locationName.length; i++) {\n      const code = locationName.charCodeAt(i);\n\n      if ((code >= 0 && code <= 31) || code === 127) {\n        markInvalid(\"location contains invalid control characters\");\n        break;\n      }\n    }\n\n    if (valid) {\n      // SQL string literal escaping.\n      // Example: O'Brien -> O''Brien\n      sqlSafeLocationName = locationName.split(\"'\").join(\"''\");\n    }\n  }\n}\n\nreturn {\n  valid: valid,\n  invalid: invalid,\n  reason: reason,\n  originalLocationName: locationName,\n  sqlSafeLocationName: sqlSafeLocationName\n};",
            "returnType": "object"
          },
          "diagram": {
