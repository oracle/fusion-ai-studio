            "y": 7648
          }
        },
        {
          "metadata": {
            "businessObjectCode": "ORA_HCM_GLOBALHUMA_XX_HR_ATTRITION_ANALYTIC_REPORTS",
            "functionName": "run_sql_query_using_payload",
            "processJson": true,
            "name": "Executing OTBI Query for Actions"
          },
          "outcomes": {
            "success": "1774962157841"
          },
          "code": "EXECUTING_OTBI_QUERY_FOR_ACTIONS",
          "convergenceTargetId": "1775731825740",
          "id": "1775551556561",
          "inputs": [
            {
              "id": "1777457551039_1",
              "name": "runSqlQueryPayload",
              "type": "string",
              "value": "{{$context.$nodes.GENERATING_OTBI_QUERY_FOR_ACTIONS.$output.result}}"
            }
          ],
          "outputSpecification": "{}",
          "type": "BO_FUNCTION",
          "diagram": {
            "x": 5036,
            "y": 7870
          }
        },
        {
          "metadata": {
            "name": "Filtering Results for Actions",
            "returnType": "object",
            "sourceCode": "const data = $context?.$nodes?.EXECUTING_OTBI_QUERY_FOR_ACTIONS?.$output;\n\n// Supports both direct Rows and nested output.response.Rows\nconst rows =\n  (Array.isArray(data?.Rows) && data.Rows) ||\n  (Array.isArray(data?.response?.Rows) && data.response.Rows) ||\n  (Array.isArray(data?.output?.response?.Rows) && data.output.response.Rows) ||\n  [];\n\nconst groupedByLocation = {};\n\nfunction toNumber(value) {\n  const num = Number(value ?? 0);\n  return Number.isFinite(num) ? num : 0;\n}\n\nrows.forEach((row) => {\n  const location = row[\"Location Name\"] || \"UNKNOWN\";\n  const managerPersonId = row[\"Manager Person Identifier\"] ?? null;\n  const managerAssignmentId = row[\"Manager Assignment Identifier\"] ?? null;\n  const managerName = row[\"Manager Display Name\"] || \"UNKNOWN\";\n  const managerDepartmentName = row[\"Manager Department Name\"] || \"\";\n  const headcount = toNumber(row[\"Termination Headcount\"]);\n\n  if (!groupedByLocation[location]) {\n    groupedByLocation[location] = {\n      location,\n      count: 0,\n      managersMap: {}\n    };\n  }\n\n  groupedByLocation[location].count += headcount;\n\n  const managerKey = [\n    managerPersonId ?? \"\",\n    managerAssignmentId ?? \"\",\n    managerName || \"UNKNOWN\"\n  ].join(\"|\");\n\n  if (!groupedByLocation[location].managersMap[managerKey]) {\n    groupedByLocation[location].managersMap[managerKey] = {\n      managerPersonId,\n      managerAssignmentId,\n      managerName,\n      managerDepartmentName,\n      count: 0\n    };\n  }\n\n  // backfill in case first row was blank and later row has value\n  if (\n    !groupedByLocation[location].managersMap[managerKey].managerDepartmentName &&\n    managerDepartmentName\n  ) {\n    groupedByLocation[location].managersMap[managerKey].managerDepartmentName = managerDepartmentName;\n  }\n\n  groupedByLocation[location].managersMap[managerKey].count += headcount;\n});\n\nconst result = Object.values(groupedByLocation).map((locationObj) => ({\n  location: locationObj.location,\n  count: locationObj.count,\n  managers: Object.values(locationObj.managersMap)\n}));\n\nreturn result;"
          },
          "outcomes": {
            "success": "1774966224640"
          },
          "code": "FILTERING_RESULTS_FOR_ACTIONS",
          "convergenceTargetId": "1775806189786",
          "id": "1774962157841",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "type": "CODE",
          "diagram": {
