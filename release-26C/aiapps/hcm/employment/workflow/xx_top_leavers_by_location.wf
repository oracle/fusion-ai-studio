              "enableActions": false,
              "enableCommunications": true,
              "customNotes": "FINAL OUTPUT RULE\nReturn only these 2 concatenated blocks in this order:\n1. `<oraInfoDisplay key=\"list-leavers\">...</oraInfoDisplay>`\n2. `<oraInfoDisplay key=\"list-active\">...</oraInfoDisplay>`"
            }
