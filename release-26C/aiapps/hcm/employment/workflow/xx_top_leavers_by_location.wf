        {
          "metadata": {
            "name": "Filtering Results",
            "returnType": "object",
            "sourceCode": "const data = $context.$nodes.EXECUTING_OTBI_QUERY.$output;\n\n// Aggregate\nconst locationMap = {};\nlet totalTerminationCount = 0;\n\ndata.Rows.forEach(row => {\n  const location = row[\"Location Name\"];\n  const count = Number(row[\"Termination Headcount\"] || 0);\n\n  // Skip UNKNOWN / empty locations\n  if (!location || location.trim() === \"\") return;\n\n  // Use location as key\n  if (!locationMap[location]) {\n    locationMap[location] = {\n      location: location,\n      count: 0\n    };\n  }\n\n  locationMap[location].count += count;\n  totalTerminationCount += count;\n});\n\n// Final object with sorting\nconst result = {\n  totalTerminationCount,\n  locations: Object.values(locationMap)\n    .sort((a, b) => b.count - a.count)\n};\n\nreturn result;"
          },
          "outcomes": {
            "success": "1777113259933"
          },
          "code": "FILTERING_RESULTS",
          "id": "1777113216883",
          "inputs": [],
