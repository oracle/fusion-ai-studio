          "id": "1782296528413",
          "code": "VALIDATING_MANAGER_ID",
          "type": "CODE",
          "metadata": {
            "name": "Validating Manager ID",
            "sourceCode": "const actionData =\n  $context.$nodes.GETTING_ACTION_FROM_APP.$output.result.payload.data || {};\n\nfunction isIntegerOnly(value) {\n  return typeof value === \"number\"\n    ? Number.isInteger(value)\n    : /^\\d+$/.test(String(value));\n}\n\nconst managerPersonId = actionData.managerPersonId;\nconst managerAssignmentId = actionData.managerAssignmentId;\n\nreturn {\n  managerPersonId: managerPersonId,\n  managerAssignmentId: managerAssignmentId,\n  managerPersonIdValid: isIntegerOnly(managerPersonId),\n  managerAssignmentIdValid: isIntegerOnly(managerAssignmentId),\n  valid:\n    isIntegerOnly(managerPersonId) &&\n    isIntegerOnly(managerAssignmentId)\n};",
            "returnType": "object"
          },
          "diagram": {
            "x": 6213.5,
            "y": 6982
          },
          "outcomes": {
            "success": "1782297309296"
