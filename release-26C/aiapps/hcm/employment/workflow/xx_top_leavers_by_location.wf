        {
          "id": "1782296791723",
          "code": "SANITIZE_DATA",
          "type": "CODE",
          "metadata": {
            "name": "Sanitize Data",
            "sourceCode": "const selectedLeaver = $context.$nodes.FILTERING_RESULTS_FOR_TO_GET_LEAVERS.$output.result || {};\n\nconst activeEmployees =\n  $context.$nodes.GETTING_ACTIVE_EMPLOYEES.$output || {};\n\nconst promoteLink =\n  $context.$nodes.GENERATING_LINK_FOR_PROMOTE_ACTION.$output || {};\n\nconst changeSalaryLink =\n  $context.$nodes.GENERATING_LINK_FOR_CHANGE_SALARY_ACTION.$output || {};\n\nfunction cleanString(value) {\n  return String(value)\n    .trim()\n    .replace(/[\\u0000-\\u001F\\u007F]/g, \"\")\n    .replace(/[<>]/g, \"\").replace(/\\s+/g, \" \");\n}\n\nfunction cleanId(value) {\n  return String(value || \"\")\n    .trim()\n    .replace(/[\\u0000-\\u001F\\u007F]/g, \"\")\n    .replace(/[^\\d]/g, \"\");\n}\n\nfunction sanitize(value, key) {\n  if (key === \"managerPersonId\" || key === \"managerAssignmentId\") {\n    return cleanId(value);\n  }\n\n  if (typeof value === \"string\") {\n    return cleanString(value);\n  }\n\n  if (Array.isArray(value)) {\n    return value.map(item => sanitize(item));\n  }\n\n  if (value && typeof value === \"object\") {\n    const output = {};\n\n    Object.keys(value).forEach(currentKey => {\n      output[currentKey] = sanitize(value[currentKey], currentKey);\n    });\n\n    return output;\n  }\n\n  return value;\n}\n\nreturn {\n  selectedLeaver: sanitize(selectedLeaver),\n  activeEmployees: sanitize(activeEmployees),\n  promoteLink: promoteLink,\n  changeSalaryLink: changeSalaryLink\n};",
            "returnType": "object"
          },
          "diagram": {
            "x": 5779.25,
            "y": 9424
          },
          "outcomes": {
            "success": "1775806189786"
          },
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
