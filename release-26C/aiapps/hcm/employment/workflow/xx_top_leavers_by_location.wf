          "code": "GETTING_LOCATION",
          "type": "CODE",
          "metadata": {
            "name": "Getting Location ",
            "returnType": "string",
            "sourceCode": "let oraAction = $context.$app.$OraAction || \"{}\";\nlet payload = JSON.parse(oraAction);\n\nconst data = payload.data || {};\nconst location = String(data.location || \"\").trim();\n\nif (!/^[a-zA-Z0-9\\s,._-]{1,100}$/.test(location)) {\n  throw new Error(\"Invalid location\");\n}\n\nreturn location;"
