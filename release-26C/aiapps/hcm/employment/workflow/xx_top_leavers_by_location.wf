        {
          "metadata": {
            "name": "Setting Hint for Display",
            "returnType": "object",
            "sourceCode": "let hint = $context.$app.$OraMessageHint;\nlet location = $context.$nodes.VALIDATING_LOCATION_FROM_INPUT.$output.result.sqlSafeLocation;\n\nlet hint1 = hint;\nlet hint2 = hint;\n\nif (hint === undefined) {\n  hint1 = \"default\";\n  hint2 = \"init\";\n} else if (\n  hint === \"InitDisplay\" ||\n  hint === \"AdditionalContent\" ||\n  hint === \"InitActions\" ||\n  hint === \"FillParameters\"\n) {\n  hint2 = \"init\";\n}\n\nif (location !== null && location !== undefined && String(location).trim() !== \"\") {\n  hint2 = \"workflow\";\n}\n\nreturn {\n  hint1: hint1,\n  hint2: hint2\n};"
          },
          "outcomes": {
            "success": "1774942103471"
          },
