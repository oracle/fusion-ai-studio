          "metadata": {
            "name": "Generating OTBI Query",
            "returnType": "object",
            "sourceCode": "let payload = {\n  \"sqlQuery\": \"SET VARIABLE PREFERRED_CURRENCY='User Preferred Currency 1'; SELECT CASE WHEN TIMESTAMPDIFF(SQL_TSI_MONTH, \\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Worker\\\".\\\"Employee Hire Date\\\", \\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Worker\\\".\\\"Termination Date\\\") < 12 THEN 1 WHEN TIMESTAMPDIFF(SQL_TSI_MONTH, \\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Worker\\\".\\\"Employee Hire Date\\\", \\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Worker\\\".\\\"Termination Date\\\") < 36 THEN 2 WHEN TIMESTAMPDIFF(SQL_TSI_MONTH, \\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Worker\\\".\\\"Employee Hire Date\\\", \\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Worker\\\".\\\"Termination Date\\\") < 72 THEN 3 WHEN TIMESTAMPDIFF(SQL_TSI_MONTH, \\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Worker\\\".\\\"Employee Hire Date\\\", \\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Worker\\\".\\\"Termination Date\\\") < 120 THEN 4 ELSE 5 END, CASE WHEN TIMESTAMPDIFF(SQL_TSI_MONTH, \\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Worker\\\".\\\"Employee Hire Date\\\", \\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Worker\\\".\\\"Termination Date\\\") < 12 THEN '0-1yr' WHEN TIMESTAMPDIFF(SQL_TSI_MONTH, \\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Worker\\\".\\\"Employee Hire Date\\\", \\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Worker\\\".\\\"Termination Date\\\") < 36 THEN '1-3yrs' WHEN TIMESTAMPDIFF(SQL_TSI_MONTH, \\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Worker\\\".\\\"Employee Hire Date\\\", \\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Worker\\\".\\\"Termination Date\\\") < 72 THEN '3-6yrs' WHEN TIMESTAMPDIFF(SQL_TSI_MONTH, \\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Worker\\\".\\\"Employee Hire Date\\\", \\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Worker\\\".\\\"Termination Date\\\") < 120 THEN '6-10yrs' ELSE '10+yrs' END, \\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Workforce Trend\\\".\\\"Termination Headcount\\\" FROM \\\"Workforce Management - Workforce Trend Real Time\\\" WHERE (\\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Workforce Trend\\\".\\\"Termination Headcount\\\" > 0 AND \\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Worker\\\".\\\"Termination Date\\\" BETWEEN TIMESTAMPADD(SQL_TSI_MONTH, -6, CURRENT_DATE) AND CURRENT_DATE AND \\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Business Unit\\\".\\\"Business Unit Id\\\" = 300100648781671 AND \\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Worker\\\".\\\"Employee Hire Date\\\" IS NOT NULL AND \\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Worker\\\".\\\"Termination Date\\\" IS NOT NULL) ORDER BY 1 ASC FETCH FIRST 75001 ROWS ONLY\",\n  \"outputFormat\": \"CollectionDataFormat\",\n  \"executionOptions\": {\n    \"async\": false,\n    \"refresh\": true,\n    \"presentationInfo\": true,\n    \"maxRowsPerPage\": 25\n  },\n  \"sessionId\": $context.$nodes.PERFORMING_LOGON.$output.token\n};\n\nreturn payload;"
          },
          "outcomes": {
