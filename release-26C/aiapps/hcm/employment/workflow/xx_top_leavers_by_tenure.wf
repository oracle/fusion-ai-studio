        },
        {
          "metadata": {
            "name": "Filtering Results",
            "returnType": "object",
            "sourceCode": "const data = $context.$nodes.EXECUTING_OTBI_QUERY.$output;\n\n// Aggregate\nconst tenureMap = {\n  \"0-1yr\": 0,\n  \"1-3yrs\": 0,\n  \"3-6yrs\": 0,\n  \"6-10yrs\": 0,\n  \"10+yrs\": 0\n};\n\nconst validTenures = Object.keys(tenureMap);\n\n(data.Rows || []).forEach(row => {\n  const count = Number(row[\"Termination Headcount\"] || 0);\n\n  // Find the column whose value is one of the expected tenure buckets\n  const tenureColumn = Object.keys(row).find(\n    key => validTenures.includes(row[key])\n  );\n\n  if (!tenureColumn) return;\n\n  const tenure = row[tenureColumn];\n  tenureMap[tenure] += count;\n});\n\n// Final object\nconst result = {\n  tenures: Object.entries(tenureMap)\n    .map(([tenure, count]) => ({\n      tenure,\n      count\n    }))\n    .sort((a, b) => b.count - a.count)\n};\n\nreturn result;"
          },
          "outcomes": {
            "success": "1776332074542"
          },
