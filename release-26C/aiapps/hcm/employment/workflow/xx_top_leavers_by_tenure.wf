          "code": "DISPLAYING_FOR_TENURE",
          "id": "1777363396861",
          "inputs": [
            {
              "id": "1777363396861_1",
              "name": "prompt",
              "type": "string",
              "value": "You are given a JSON object containing employee termination records.\n\nInput JSON:\n {{$context.$nodes.EXECUTING_SQL_QUERY.$output}} \nTask:\nReturn an aggregated JSON array with manager name, department, and count.\n\nRules:\n1. Read the data only from the \"Rows\" array.\n2. Use \"Manager Display Name\" as \"managerName\".\n3. Use \"Department Name\" as \"department\".\n4. Group records by the same managerName and department.\n5. For each group, calculate \"count\" by summing \"Termination Headcount\".\n6. If \"Termination Headcount\" is missing, count that row as 1.\n7. Return only valid JSON.\n8. Do not include explanations, markdown, comments, or extra text.\n\nOutput format:\n[\n  {\n    \"managerName\": \"string\",\n    \"department\": \"string\",\n    \"count\": number\n  }\n]"
            }
          ],
          "type": "LLM",
          "diagram": {
            "x": 8961.5,
            "y": 6316
          }
        },
        {
          "id": "1783241015521",
          "code": "GETTING_TENURE",
          "type": "CODE",
          "metadata": {
            "name": "Getting Tenure",
            "returnType": "string",
            "sourceCode": "let oraAction = $context.$app.$OraAction || \"{}\";\nlet payload = JSON.parse(oraAction);\n\nconst data = payload.data || {};\nconst tenure = String(data.tenureBand || \"\").trim();\n\nconst allowedTenures = [\n  \"0-1yr\",\n  \"1-3yrs\",\n  \"3-6yrs\",\n  \"6-10yrs\",\n  \"10+yrs\"\n];\n\nif (!allowedTenures.includes(tenure)) {\n  throw new Error(\"Invalid tenure\");\n}\n\nreturn tenure;"
          },
          "diagram": {
            "x": 6020,
            "y": 7204
          },
          "outcomes": {
            "success": "1783241020969"
          },
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
        {
          "id": "1783241020969",
          "code": "VALIDATING_TENURE",
          "type": "CODE",
          "metadata": {
            "description": "",
            "name": "Validating Tenure",
            "sourceCode": "const rawTenure =\n  $context.$nodes.GETTING_TENURE.$output.result;\n\nlet valid = true;\nlet invalid = false;\nlet reason = \"\";\nlet tenure = \"\";\nlet selectedTenure = \"\";\n\nconst allowedTenures = [\n  \"0-1yr\",\n  \"1-3yrs\",\n  \"3-6yrs\",\n  \"6-10yrs\",\n  \"10+yrs\"\n];\n\nfunction markInvalid(message) {\n  valid = false;\n  invalid = true;\n  reason = message;\n}\n\nif (typeof rawTenure !== \"string\") {\n  markInvalid(\"tenure must be a string\");\n} else {\n  tenure = rawTenure.trim();\n\n  if (!tenure) {\n    markInvalid(\"tenure cannot be empty\");\n  } else if (tenure.length > 20) {\n    markInvalid(\"tenure is too long\");\n  } else {\n    // Reject hidden/control characters.\n    for (let i = 0; i < tenure.length; i++) {\n      const code = tenure.charCodeAt(i);\n\n      if ((code >= 0 && code <= 31) || code === 127) {\n        markInvalid(\"tenure contains invalid control characters\");\n        break;\n      }\n    }\n\n    if (valid && !allowedTenures.includes(tenure)) {\n      markInvalid(\"tenure is not an allowed value\");\n    }\n\n    if (valid) {\n      selectedTenure = tenure;\n    }\n  }\n}\n\nreturn {\n  valid: valid,\n  invalid: invalid,\n  reason: reason,\n  originalTenure: tenure,\n  selectedTenure: selectedTenure,\n  allowedTenures: allowedTenures\n};",
            "returnType": "object"
          },
          "diagram": {
            "x": 6026,
            "y": 7426
          },
          "outcomes": {
            "success": "1783241030511"
          },
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
        {
          "id": "1783241030511",
