        {
          "metadata": {
            "processJson": true,
            "name": "Getting Active Worker Count",
            "businessObjectCode": "ORA_HCM_GLOBALHUMA_XX_HR_ATTRITION_PERSON_SEARCHES",
            "functionName": "get_WorkersCntByBusinessUnitName"
          },
          "outcomes": {
            "success": "1776167507717"
          },
          "code": "GETACTIVEWORKERSINITIAL",
          "convergenceTargetId": "1774876051145",
          "id": "1774604624874",
          "inputs": [
            {
              "id": "1774604624874_pBusinessUnitName",
              "name": "pBusinessUnitName",
              "value": "Global Business Services",
              "required": false,
              "type": "string"
            }
          ],
          "outputSpecification": "{}",
          "type": "BO_FUNCTION",
          "diagram": {
            "x": 5225,
            "y": 5428
          }
        },
        {
          "metadata": {
            "name": "Generating SQL Payload",
            "returnType": "object",
            "sourceCode": "let payload = {\n    \"sqlQuery\": \"SET VARIABLE PREFERRED_CURRENCY='User Preferred Currency 1';SELECT s_0, s_1, s_2, s_3, s_4 FROM ( SELECT 0 s_0, CAST(\\\"Workforce Management - Worker Assignment Event Real Time\\\".\\\"Time\\\".\\\"Calendar Year\\\" AS INT) s_1, CAST(RIGHT(\\\"Workforce Management - Worker Assignment Event Real Time\\\".\\\"Time\\\".\\\"Month\\\",2) AS INT) s_2, REPORT_AGGREGATE(FILTER(IFNULL(\\\"Workforce Management - Worker Assignment Event Real Time\\\".\\\"Assignment Event\\\".\\\"Hire Headcount\\\",0) USING (DESCRIPTOR_IDOF(\\\"Workforce Management - Worker Assignment Event Real Time\\\".\\\"Assignment Event Details\\\".\\\"Assignment Status Type\\\")='ACTIVE')) BY CAST(\\\"Workforce Management - Worker Assignment Event Real Time\\\".\\\"Time\\\".\\\"Calendar Year\\\" AS INT), CAST(RIGHT(\\\"Workforce Management - Worker Assignment Event Real Time\\\".\\\"Time\\\".\\\"Month\\\",2) AS INT)) s_3, REPORT_SUM(\\\"Workforce Management - Worker Assignment Event Real Time\\\".\\\"Assignment Event\\\".\\\"Termination Headcount\\\" BY CAST(\\\"Workforce Management - Worker Assignment Event Real Time\\\".\\\"Time\\\".\\\"Calendar Year\\\" AS INT), CAST(RIGHT(\\\"Workforce Management - Worker Assignment Event Real Time\\\".\\\"Time\\\".\\\"Month\\\",2) AS INT)) s_4 FROM \\\"Workforce Management - Worker Assignment Event Real Time\\\" WHERE ((CAST(\\\"Workforce Management - Worker Assignment Event Real Time\\\".\\\"Time\\\".\\\"Calendar Year\\\" AS INT) BETWEEN CAST(YEAR(TIMESTAMPADD(SQL_TSI_MONTH, -6, CURRENT_DATE)) AS INTEGER) AND VALUEOF(\\\"CURRENT_YEAR\\\") )) AND (\\\"Business Unit\\\".\\\"Business Unit Id\\\" = 300100648781671)) djm ORDER BY 1 ASC NULLS LAST, 2 ASC NULLS LAST FETCH FIRST 75001 ROWS ONLY\",\n    \"outputFormat\": \"CollectionDataFormat\",\n    \"executionOptions\": {\n        \"async\": false,\n        \"refresh\": true,\n        \"presentationInfo\": true,\n        \"maxRowsPerPage\": 25\n    },\n    \"sessionId\": $context.$nodes.LOGON.$output.token\n};\n\nreturn payload;"
          },
          "outcomes": {
            "success": "1776167697091"
          },
          "code": "SETSQLPAYLOAD",
          "id": "1776167507717",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "type": "CODE",
          "diagram": {
            "x": 5225,
            "y": 5650
          }
        },
        {
          "metadata": {
            "businessObjectCode": "ORA_HCM_GLOBALHUMA_XX_HR_ATTRITION_ANALYTIC_REPORTS",
            "functionName": "run_sql_query_using_payload",
            "processJson": true,
            "name": "Executing Logical SQL Query"
          },
          "outcomes": {
            "success": "1776168018040"
          },
          "code": "RUN_LOGICAL_SQL_ADV",
          "id": "1776167697091",
          "inputs": [
            {
              "id": "1777458442225_1",
              "name": "runSqlQueryPayload",
              "type": "string",
              "value": "{{$context.$nodes.SETSQLPAYLOAD.$output.result}}"
            }
          ],
          "outputSpecification": "{}",
          "type": "BO_FUNCTION",
          "diagram": {
            "x": 5225,
            "y": 5872
          }
        },
        {
          "metadata": {
            "name": "Consolidate Results",
            "returnType": "object",
            "sourceCode": "const rows = $context.$nodes.RUN_LOGICAL_SQL_ADV.$output.Rows;\nconst safeRows = Array.isArray(rows) ? rows : [];\n\nconst result = safeRows.reduce(\n  (acc, row) => {\n    const joiners = Number((row && row.s_3) || 0);\n    const leavers = Number((row && row.s_4) || 0);\n\n    acc.joiners += Number.isFinite(joiners) ? joiners : 0;\n    acc.leavers += Number.isFinite(leavers) ? leavers : 0;\n    return acc;\n  },\n  { joiners: 0, leavers: 0 }\n);\n\nreturn result;"
          },
          "outcomes": {
            "success": "1774611541314"
          },
          "code": "CONSOLIDATE_RESULTS",
          "id": "1776168018040",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "type": "CODE",
          "diagram": {
            "x": 5225,
            "y": 6094
          }
        },
        {
          "metadata": {
            "name": "Calculating Attrition Percentage",
            "returnType": "object",
            "sourceCode": "const consolidated = $context.$nodes.CONSOLIDATE_RESULTS.$output.result || {};\nconst endEmployeeValues = $context.$nodes.GETACTIVEWORKERSINITIAL.$output.facets?.[0]?.values;\n\nconst rawJoiners = Number(consolidated.joiners || 0);\nconst rawLeavers = Number(consolidated.leavers || 0);\nconst rawEndEmployees = Array.isArray(endEmployeeValues) && endEmployeeValues.length > 0\n  ? Number(endEmployeeValues[0].count || 0)\n  : 0;\n\nconst joiners = Number.isFinite(rawJoiners) ? rawJoiners : 0;\nconst leavers = Number.isFinite(rawLeavers) ? rawLeavers : 0;\nconst endEmployees = Number.isFinite(rawEndEmployees) ? rawEndEmployees : 0;\nconst startEmployees = endEmployees + leavers - joiners;\nconst avgEmployees = (startEmployees + endEmployees) / 2;\n\nlet attritionPercentage = 0;\n\nif (avgEmployees !== 0) {\n  attritionPercentage = (leavers / avgEmployees) * 100;\n}\n\nif (!Number.isFinite(attritionPercentage)) {\n  attritionPercentage = 0;\n}\n\nconst result = {\n  emp: startEmployees,\n  leavers: leavers,\n  attrition: attritionPercentage.toFixed(2),\n  joiners: joiners\n};\n\nreturn result;"
          },
          "outcomes": {
            "success": "1783000000101"
          },
          "code": "GETATTRITIONPERCENTAGE",
          "convergenceTargetId": "1774876051145",
          "id": "1774611541314",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "type": "CODE",
          "diagram": {
            "x": 5225,
            "y": 6316
          }
        },
        {
          "id": "1783000000101",
          "code": "SANITY_CHECK_ATTRITION_SUMMARY",
          "type": "CODE",
          "metadata": {
            "name": "Sanity Check Attrition Summary",
            "returnType": "object",
            "sourceCode": "const data = $context.$nodes.GETATTRITIONPERCENTAGE.$output.result || {};\n\nconst emp = Number(data.emp || 0);\nconst leavers = Number(data.leavers || 0);\nconst joiners = Number(data.joiners || 0);\nconst attrition = Number(data.attrition || 0);\n\nreturn {\n  emp: Number.isFinite(emp) ? emp : 0,\n  leavers: Number.isFinite(leavers) ? leavers : 0,\n  joiners: Number.isFinite(joiners) ? joiners : 0,\n  attrition: (Number.isFinite(attrition) ? attrition : 0).toFixed(2)\n};"
          },
          "outcomes": {
            "success": "1777138478282"
          },
          "inputs": [],
          "diagram": {
            "x": 5225,
            "y": 6538
          },
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
        {
          "metadata": {
            "name": "Setting Hint",
            "returnType": "string",
            "sourceCode": "let hint = $context.$app.$OraMessageHint;\n\nif(hint == \"InitDisplay\" || hint == \"Summary\") return hint;\n\nreturn \"Summary\";"
