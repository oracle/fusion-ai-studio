        {
          "metadata": {
            "name": "Filtering Results",
            "returnType": "object",
            "sourceCode": "const data = ($context.$nodes.EXECUTING_OTBI_QUERY.$output);\n\n// Aggregate\nconst managerMap = {};\nlet totalTerminationCount = 0;\n\ndata.Rows.forEach(row => {\n  const managerName = row[\"Manager Display Name\"];\n  const managerId = row[\"Manager Person Identifier\"];\n  const managerAssignmentId = row[\"Manager Assignment Identifier\"];\n  const count = row[\"Termination Headcount\"] || 0;\n  const departmentName = row[\"Department Name\"];\n\n  // Skip UNKNOWN / empty managers\n  if (!managerName || managerName.trim() === \"\" || !managerId) return;\n\n  // Use managerId as key for uniqueness\n  if (!managerMap[managerId]) {\n    managerMap[managerId] = {\n      manager: managerName,\n      managerId: managerId,\n      managerAssignmentId: managerAssignmentId, \n      departmentName : departmentName,\n      count: 0\n    };\n  }\n\n  managerMap[managerId].count += count;\n  totalTerminationCount += count;\n});\n\n// Final object with sorting\nconst result = {\n  totalTerminationCount,\n  managers: Object.values(managerMap)\n    .sort((a, b) => b.count - a.count)\n};\n\nreturn result;"
          },
          "outcomes": {
            "success": "1781766406356"
          },
          "diagram": {
            "x": 7250,
            "y": 6316
          },
          "code": "FILTERING_RESULTS",
          "convergenceTargetId": "1775557872641",
