        {
          "metadata": {
            "name": "Setting Hint for Display",
            "returnType": "object",
            "sourceCode": "let hint = $context.$app.$OraMessageHint;\nlet managerId = $context.$triggers.REST.$input.ManagerId ;\n\nlet hint1 = hint;\nlet hint2 = hint;\n\nif (hint === undefined) {\n  hint1 = \"default\";\n  hint2 = \"init\";\n} else if (\n  hint === \"InitDisplay\" ||\n  hint === \"AdditionalContent\" ||\n  hint === \"InitActions\" ||\n  hint === \"FillParameters\"\n) {\n  hint2 = \"init\";\n}\n\nif (managerId !== null && managerId !== undefined && String(managerId).trim() !== \"\") {\n  hint2 = \"workflow\";\n}\n\nreturn {\n  hint1: hint1,\n  hint2: hint2\n};"
          },
          "outcomes": {
            "success": "1774942103471"
          },
          "diagram": {
            "x": 6800,
            "y": 5428
          },
          "code": "SETTING_HINT_FOR_DISPLAY",
          "id": "1776332186792",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "type": "CODE"
        },
