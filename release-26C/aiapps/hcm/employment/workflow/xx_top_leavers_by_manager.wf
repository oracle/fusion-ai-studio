          "metadata": {
            "name": "Generating OTBI Query for Actions",
            "returnType": "object",
            "sourceCode": "const managerId = String(\n  $context.$nodes.GETTING_MANAGER_FROM_ACTION.$output.result || \"\"\n).trim();\n\nif (!/^\\d{1,18}$/.test(managerId)) {\n  throw new Error(\"Invalid managerId\");\n}\n\nlet payload = {\n  sqlQuery:\n    \"SET VARIABLE PREFERRED_CURRENCY='User Preferred Currency 1'; SELECT 0 s_0, \" +\n    \"\\\"Compensation - Workforce Assignment Salary Real Time\\\".\\\"Worker\\\".\\\"Employee Display Name\\\" s_1, \" +\n    \"\\\"Compensation - Workforce Assignment Salary Real Time\\\".\\\"Assignment Details\\\".\\\"Action Reason\\\" s_2, \" +\n    \"\\\"Compensation - Workforce Assignment Salary Real Time\\\".\\\"Worker\\\".\\\"Manager ID\\\" s_7, \" +\n    \"\\\"Compensation - Workforce Assignment Salary Real Time\\\".\\\"Location\\\".\\\"Worker Location Name\\\" s_9, \" +\n    \"\\\"Compensation - Workforce Assignment Salary Real Time\\\".\\\"Department\\\".\\\"Department Name\\\" s_10, \" +\n    \"\\\"Compensation - Workforce Assignment Salary Real Time\\\".\\\"Worker\\\".\\\"Termination Date\\\" s_12, \" +\n    \"\\\"Compensation - Workforce Assignment Salary Real Time\\\".\\\"Worker\\\".\\\"Employee Hire Date\\\" s_13, \" +\n    \"\\\"Compensation - Workforce Assignment Salary Real Time\\\".\\\"Job\\\".\\\"Job Name\\\" s_14, \" +\n    \"DESCRIPTOR_IDOF(\\\"Compensation - Workforce Assignment Salary Real Time\\\".\\\"Job\\\".\\\"Job Name\\\") s_15, \" +\n    \"\\\"Compensation - Workforce Assignment Salary Real Time\\\".\\\"Salary Facts\\\".\\\"Quartile\\\" s_16, \" +\n    \"\\\"Compensation - Workforce Assignment Salary Real Time\\\".\\\"Salary Facts\\\".\\\"Quintile\\\" s_17 \" +\n    \"FROM \\\"Compensation - Workforce Assignment Salary Real Time\\\" \" +\n    \"WHERE (\\\"Compensation - Workforce Assignment Salary Real Time\\\".\\\"Worker\\\".\\\"Termination Date\\\" BETWEEN TIMESTAMPADD(SQL_TSI_MONTH, -6, CURRENT_DATE) AND CURRENT_DATE \" +\n    \"AND \\\"Business Unit\\\".\\\"Business Unit Id\\\" = 300100648781671 \" +\n    \"AND \\\"Compensation - Workforce Assignment Salary Real Time\\\".\\\"Worker\\\".\\\"Manager ID\\\" = '\" + managerId + \"') \" +\n    \"FETCH FIRST 75001 ROWS ONLY\",\n  outputFormat: \"CollectionDataFormat\",\n  executionOptions: {\n    async: false,\n    refresh: true,\n    presentationInfo: true,\n    maxRowsPerPage: 25\n  },\n  sessionId: $context.$nodes.PERFORMING_LOGON.$output.token\n};\n\nreturn payload;"
