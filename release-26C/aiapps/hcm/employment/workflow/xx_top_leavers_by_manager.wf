        {
          "metadata": {
            "name": "Generating OTBI Query",
            "returnType": "object",
            "sourceCode": "let payload = {\n  sqlQuery:\n    \"SELECT \" +\n    \"\\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Manager\\\".\\\"Manager Display Name\\\" s_3, \" +\n    \"\\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Worker\\\".\\\"Manager ID\\\" s_7, \" +\n    \"\\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Worker\\\".\\\"Manager Assignment ID\\\" s_8, \" +\n    \"\\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Workforce Trend\\\".\\\"Termination Headcount\\\" s_2, \" +\n    \"\\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Manager\\\".\\\"Department Name\\\" s_1 \" +\n    \"FROM \\\"Workforce Management - Workforce Trend Real Time\\\" \" +\n    \"WHERE ((\\\"Workforce Trend\\\".\\\"Termination Headcount\\\" > 0) \" +\n    \"AND (\\\"Business Unit\\\".\\\"Business Unit Id\\\" = 300100648781671) \" +\n    \"AND (\\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Worker\\\".\\\"Termination Date\\\" BETWEEN TIMESTAMPADD(SQL_TSI_MONTH, -6, CURRENT_DATE) AND CURRENT_DATE)) \" +\n    \"ORDER BY 3 DESC NULLS FIRST, 4 ASC NULLS LAST, 2 ASC NULLS LAST \" +\n    \"FETCH FIRST 75001 ROWS ONLY\",\n  outputFormat: \"CollectionDataFormat\",\n  executionOptions: {\n    async: false,\n    refresh: true,\n    presentationInfo: true,\n    maxRowsPerPage: 25\n  },\n  sessionId: $context.$nodes.PERFORMING_LOGON.$output.token\n};\n\nreturn payload;"
          },
          "outcomes": {
            "success": "1775557872641"
          },
          "diagram": {
            "x": 7250,
            "y": 5872
          },
          "code": "GENERATING_OTBI_QUERY",
          "id": "1775557603885",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "type": "CODE"
        },
        {
          "metadata": {
            "name": "Getting Action from App",
            "returnType": "object",
            "sourceCode": "let oraAction = $context.$app.$OraAction;\nlet payload = {};\nlet parseError = \"\";\n\ntry {\n  payload = JSON.parse(oraAction || \"{}\");\n} catch (error) {\n  parseError = error && error.message ? error.message : \"Invalid action payload\";\n  payload = {};\n}\n\nlet action = payload && payload.command ? String(payload.command) : \"\";\nlet validActions = {\n  displayEmp: true,\n  rowNavigate: true\n};\nlet valid = !!validActions[action];\nlet validationError = \"\";\n\nif (!valid) {\n  validationError = \"Invalid action command\";\n}\n\nlet data = payload && payload.data ? payload.data : {};\nlet managerId = data.managerId === undefined || data.managerId === null ? \"\" : String(data.managerId).trim();\nlet managerAssignmentId = data.managerAssignmentId === undefined || data.managerAssignmentId === null ? \"\" : String(data.managerAssignmentId).trim();\n\nif (valid && !/^\\d{1,18}$/.test(managerId)) {\n  valid = false;\n  validationError = \"Invalid managerId\";\n}\n\nif (valid && !/^\\d{1,18}$/.test(managerAssignmentId)) {\n  valid = false;\n  validationError = \"Invalid managerAssignmentId\";\n}\n\nif (valid) {\n  payload.data = Object.assign({}, data, {\n    managerId: managerId,\n    managerAssignmentId: managerAssignmentId\n  });\n}\n\nif (!valid) {\n  action = \"INVALID_ACTION\";\n}\n\nreturn {\n  payload: valid ? payload : {},\n  action,\n  valid,\n  error: parseError || validationError\n};"
          },
          "outcomes": {
            "success": "1775731791343"
          },
          "diagram": {
            "x": 5450,
            "y": 5872
          },
          "code": "GETTING_ACTION_FROM_APP",
          "id": "1775731742157",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "type": "CODE"
        },
        {
          "metadata": {
            "name": "Generating Workflow Query for Manager",
            "returnType": "object",
            "sourceCode": "const managerId = String(\n  $context.$triggers.REST.$input.ManagerId || \"\"\n).trim();\n\nif (!/^\\d{1,18}$/.test(managerId)) {\n  throw new Error(\"Invalid ManagerId\");\n}\n\nlet payload = {\n  sqlQuery:\n    \"SET VARIABLE PREFERRED_CURRENCY='User Preferred Currency 1'; SELECT 0 s_0, \" +\n    \"\\\"Compensation - Workforce Assignment Salary Real Time\\\".\\\"Worker\\\".\\\"Employee Display Name\\\" s_1, \" +\n    \"\\\"Compensation - Workforce Assignment Salary Real Time\\\".\\\"Assignment Details\\\".\\\"Action Reason\\\" s_2, \" +\n    \"\\\"Compensation - Workforce Assignment Salary Real Time\\\".\\\"Worker\\\".\\\"Manager ID\\\" s_7, \" +\n    \"\\\"Compensation - Workforce Assignment Salary Real Time\\\".\\\"Location\\\".\\\"Worker Location Name\\\" s_9, \" +\n    \"\\\"Compensation - Workforce Assignment Salary Real Time\\\".\\\"Department\\\".\\\"Department Name\\\" s_10, \" +\n    \"\\\"Compensation - Workforce Assignment Salary Real Time\\\".\\\"Worker\\\".\\\"Termination Date\\\" s_12, \" +\n    \"\\\"Compensation - Workforce Assignment Salary Real Time\\\".\\\"Worker\\\".\\\"Employee Hire Date\\\" s_13, \" +\n    \"\\\"Compensation - Workforce Assignment Salary Real Time\\\".\\\"Job\\\".\\\"Job Name\\\" s_14, \" +\n    \"DESCRIPTOR_IDOF(\\\"Compensation - Workforce Assignment Salary Real Time\\\".\\\"Job\\\".\\\"Job Name\\\") s_15, \" +\n    \"\\\"Compensation - Workforce Assignment Salary Real Time\\\".\\\"Salary Facts\\\".\\\"Quartile\\\" s_16, \" +\n    \"\\\"Compensation - Workforce Assignment Salary Real Time\\\".\\\"Salary Facts\\\".\\\"Quintile\\\" s_17 \" +\n    \"FROM \\\"Compensation - Workforce Assignment Salary Real Time\\\" \" +\n    \"WHERE (\\\"Compensation - Workforce Assignment Salary Real Time\\\".\\\"Worker\\\".\\\"Termination Date\\\" BETWEEN TIMESTAMPADD(SQL_TSI_MONTH, -6, CURRENT_DATE) AND CURRENT_DATE \" +\n    \"AND \\\"Business Unit\\\".\\\"Business Unit Id\\\" = 300100648781671 \" +\n    \"AND \\\"Compensation - Workforce Assignment Salary Real Time\\\".\\\"Worker\\\".\\\"Manager ID\\\" = '\" + managerId + \"') \" +\n    \"FETCH FIRST 75001 ROWS ONLY\",\n  outputFormat: \"CollectionDataFormat\",\n  executionOptions: {\n    async: false,\n    refresh: true,\n    presentationInfo: true,\n    maxRowsPerPage: 25\n  },\n  sessionId: $context.$nodes.PERFORMING_LOGON.$output.token\n};\n\nreturn payload;"
          },
