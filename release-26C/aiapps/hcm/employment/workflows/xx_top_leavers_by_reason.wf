            "returnType": "string",
            "sourceCode": "let reason = $context.$nodes.PARSING_ACTION_OBJECT.$output.result.data.reason;\nif (reason !== \"Compensation\" && reason !== \"Career Growth\") {\n  reason = \"Others\";\n}\n\nreturn reason;"
          },
          "outcomes": {
