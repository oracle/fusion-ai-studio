        {
          "metadata": {
            "name": "Processing Career Growth Query",
            "returnType": "object",
            "sourceCode": "let allrecords = $context.$nodes.EXECUTING_CAREER_GROWTH_ACTION_QUERY.$output;\nlet leavers = $context.$nodes.MAPPING_LEAVER_IDS.$output.result;\nlet active = $context.$nodes.MAPPING_ACTIVE_EMPLOYEE_IDS.$output.result;\nconst legacyLocKey = \"loc\" + \"ation\";\n\nconst rows =\n  (Array.isArray(allrecords) && allrecords) ||\n  (Array.isArray(allrecords?.Rows) && allrecords.Rows) ||\n  (Array.isArray(allrecords?.response?.Rows) && allrecords.response.Rows) ||\n  (Array.isArray(allrecords?.output?.response?.Rows) && allrecords.output.response.Rows) ||\n  (Array.isArray(allrecords?.result?.Rows) && allrecords.result.Rows) ||\n  [];\n\nfunction normalizeLeaversMap(source) {\n  return Object.entries(source || {}).reduce((acc, [personId, assignments]) => {\n    const personKey = String(personId);\n    const normalizedAssignments = {};\n\n    if (Array.isArray(assignments)) {\n      assignments.forEach((assignmentId) => {\n        if (assignmentId == null) return;\n\n        const assignmentKey = String(assignmentId);\n\n        normalizedAssignments[assignmentKey] = {\n          personId: personKey,\n          assignmentId: assignmentKey,\n          employeeName: \"\",\n          departmentName: \"\",\n          jobName: \"\",\n          LocationName: \"\",\n          actionReason: \"\",\n          hireDate: null,\n          terminationDate: null\n        };\n      });\n    } else if (assignments && typeof assignments === \"object\") {\n      Object.entries(assignments).forEach(([assignmentId, details]) => {\n        const assignmentKey = String(details?.assignmentId ?? assignmentId);\n\n        normalizedAssignments[assignmentKey] = {\n          personId: personKey,\n          assignmentId: assignmentKey,\n          employeeName: details?.employeeName ?? \"\",\n          departmentName: details?.departmentName ?? \"\",\n          jobName: details?.jobName ?? \"\",\n          LocationName: details?.LocationName ?? details?.LocalTimeLocationName ?? details?.[legacyLocKey] ?? \"\",\n          actionReason: details?.actionReason ?? details?.ActionReason ?? \"\",\n          hireDate: details?.hireDate ?? null,\n          terminationDate: details?.terminationDate ?? null\n        };\n      });\n    }\n\n    if (Object.keys(normalizedAssignments).length > 0) {\n      acc[personKey] = normalizedAssignments;\n    }\n\n    return acc;\n  }, {});\n}\n\nfunction normalizeActiveMap(source) {\n  return Object.entries(source || {}).reduce((acc, [personId, assignments]) => {\n    const personKey = String(personId);\n    const normalizedAssignments = {};\n\n    if (Array.isArray(assignments)) {\n      assignments.forEach((assignmentId) => {\n        if (assignmentId == null) return;\n\n        const assignmentKey = String(assignmentId);\n\n        normalizedAssignments[assignmentKey] = {\n          personId: personKey,\n          assignmentId: assignmentKey,\n          employeeName: \"\",\n          departmentName: \"\",\n          jobName: \"\",\n          LocationName: \"\",\n          hireDate: null\n        };\n      });\n    } else if (assignments && typeof assignments === \"object\") {\n      Object.entries(assignments).forEach(([assignmentId, details]) => {\n        const assignmentKey = String(details?.assignmentId ?? assignmentId);\n\n        normalizedAssignments[assignmentKey] = {\n          personId: personKey,\n          assignmentId: assignmentKey,\n          employeeName: details?.employeeName ?? \"\",\n          departmentName: details?.departmentName ?? \"\",\n          jobName: details?.jobName ?? \"\",\n          LocationName: details?.LocationName ?? details?.LocalTimeLocationName ?? details?.[legacyLocKey] ?? \"\",\n          hireDate: details?.hireDate ?? null\n        };\n      });\n    }\n\n    if (Object.keys(normalizedAssignments).length > 0) {\n      acc[personKey] = normalizedAssignments;\n    }\n\n    return acc;\n  }, {});\n}\n\nfunction removePair(detailMap, personId, assignmentId) {\n  const personKey = String(personId);\n  const assignmentKey = String(assignmentId);\n\n  if (!detailMap[personKey] || !detailMap[personKey][assignmentKey]) return;\n\n  delete detailMap[personKey][assignmentKey];\n\n  if (Object.keys(detailMap[personKey]).length === 0) {\n    delete detailMap[personKey];\n  }\n}\n\nfunction getDateValue(dateStr) {\n  if (!dateStr) return -Infinity;\n  const t = new Date(dateStr).getTime();\n  return Number.isNaN(t) ? -Infinity : t;\n}\n\nconst remainingLeavers = normalizeLeaversMap(leavers);\nconst remainingActive = normalizeActiveMap(active);\n\nconst recordsMap = {};\n\nrows.forEach((row) => {\n  const personId =\n    row[\"Person ID\"] ??\n    row[\"Person Identifier\"] ??\n    row[\"PersonId\"] ??\n    null;\n\n  const assignmentId =\n    row[\"Assignment ID\"] ??\n    row[\"Assignment Identifier\"] ??\n    row[\"AssignmentId\"] ??\n    null;\n\n  if (personId == null || assignmentId == null) return;\n\n  const personKey = String(personId);\n  const assignmentKey = String(assignmentId);\n\n  const effectiveStartDate = row[\"Effective Start Date\"] ?? null;\n\n  const employeeName =\n    row[\"Employee Display Name\"] ??\n    row[\"Display Name\"] ??\n    \"\";\n\n  const jobName = row[\"Job Name\"] ?? \"\";\n\n  const terminationDate = row[\"Termination Date\"] ?? null;\n\n  const hireDate =\n    row[\"Employee Hire Date\"] ??\n    row[\"Work Relationship Start Date\"] ??\n    row[\"Date Start\"] ??\n    null;\n\n  const actionReason =\n    row[\"Action Reason\"] ??\n    row[\"Termination Reason\"] ??\n    row[\"Reason\"] ??\n    \"\";\n\n  if (!recordsMap[personKey]) {\n    recordsMap[personKey] = {};\n  }\n\n  const existing = recordsMap[personKey][assignmentKey];\n  const currentDateValue = getDateValue(effectiveStartDate);\n  const existingDateValue = existing ? getDateValue(existing.effectiveStartDate) : -Infinity;\n\n  if (!existing || currentDateValue >= existingDateValue) {\n    recordsMap[personKey][assignmentKey] = {\n      personId: personKey,\n      assignmentId: assignmentKey,\n      employeeName,\n      jobName,\n      actionReason,\n      effectiveStartDate,\n      terminationDate,\n      hireDate\n    };\n  }\n});\n\nObject.keys(recordsMap).forEach((personId) => {\n  Object.keys(recordsMap[personId]).forEach((assignmentId) => {\n    removePair(remainingLeavers, personId, assignmentId);\n    removePair(remainingActive, personId, assignmentId);\n  });\n});\n\nreturn {\n  recordsMap,\n  leavers: remainingLeavers,\n  active: remainingActive\n};"
          },
