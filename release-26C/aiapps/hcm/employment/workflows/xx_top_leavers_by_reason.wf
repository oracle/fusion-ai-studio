        {
          "id": "1781766623114",
          "code": "VALIDATE_REASON",
          "type": "CODE",
          "metadata": {
            "name": "Validate Reason",
            "returnType": "object",
            "sourceCode": "const rawReason =\n  $context.$nodes.GETTING_REASON_FROM_ACTION.$output.result;\n\nlet valid = true;\nlet invalid = false;\nlet reason = \"\";\nlet reasonName = \"\";\nlet sqlSafeReasonName = \"\";\n\nfunction markInvalid(message) {\n  valid = false;\n  invalid = true;\n  reason = message;\n}\n\nif (typeof rawReason !== \"string\") {\n  markInvalid(\"reason must be a string\");\n} else {\n  reasonName = rawReason.trim();\n\n  if (!reasonName) {\n    markInvalid(\"reason cannot be empty\");\n  } else if (reasonName.length > 50) {\n    markInvalid(\"reason is too long\");\n  } else {\n    // Reject hidden/control characters.\n    // Special characters like =, \", ', &, /, -, _, @, #, %, (, ), :, ; etc. are allowed.\n    for (let i = 0; i < reasonName.length; i++) {\n      const code = reasonName.charCodeAt(i);\n\n      if ((code >= 0 && code <= 31) || code === 127) {\n        markInvalid(\"reason contains invalid control characters\");\n        break;\n      }\n    }\n\n    if (valid) {\n      // SQL string literal escaping.\n      // Example: O'Brien -> O''Brien\n      sqlSafeReasonName = reasonName.split(\"'\").join(\"''\");\n    }\n  }\n}\n\nreturn {\n  valid: valid,\n  invalid: invalid,\n  reason: reason,\n  originalReasonName: reasonName,\n  sqlSafeReasonName: sqlSafeReasonName\n};"
          },
          "outcomes": {
            "success": "1781766623116"
          },
          "inputs": [],
          "diagram": {
            "x": 7250,
            "y": 6538
          },
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
