            "name": "Consolidating Employee Results",
            "returnType": "array",
            "sourceCode": "const data = $context.$nodes.EXECUTING_LEAVER_EMPLOYEE_QUERY.$output ;\n\n// Supports both direct Rows and nested output.response.Rows\nconst rows =\n  (Array.isArray(data?.Rows) && data.Rows) ||\n  (Array.isArray(data?.response?.Rows) && data.response.Rows) ||\n  (Array.isArray(data?.output?.response?.Rows) && data.output.response.Rows) ||\n  [];\n\nconst leavers = rows.map((row) => ({\n  employeeName: row[\"Display Name\"] || null,\n  actionReason: row[\"Action Reason\"] || \"\",\n  location: row[\"Location Name\"] || \"\",\n  departmentName: row[\"Department Name\"] || \"\",\n  hireDate: row[\"Work Relationship Start Date\"] || null,\n  terminationDate: row[\"Termination Date\"] || null,\n  jobName: row[\"Job Name\"] || \"\",\n  quartile: row[\"Quartile\"] ?? null\n}));\n\nreturn leavers;"
