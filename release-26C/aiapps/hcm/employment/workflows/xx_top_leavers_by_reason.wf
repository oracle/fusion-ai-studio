        {
          "metadata": {
            "name": "Consolidating Compensation Action Results",
            "returnType": "object",
            "sourceCode": "const data = $context?.$nodes?.EXECUTING_COMPENSATION_ACTION_QUERY?.$output;\nconst selectedReason = ($context?.$nodes?.GETTING_REASON_FROM_ACTION?.$output?.result || \"\").trim();\n\n// Supports both direct Rows and nested output.response.Rows\nconst rows =\n  (Array.isArray(data?.Rows) && data.Rows) ||\n  (Array.isArray(data?.response?.Rows) && data.response.Rows) ||\n  (Array.isArray(data?.output?.response?.Rows) && data.output.response.Rows) ||\n  [];\n\nconst resultObj = {\n  reason: selectedReason,\n  count: 0,\n  managersMap: {}\n};\n\nrows.forEach((row) => {\n  const managerName = (row[\"Manager Display Name\"] || \"\").trim();\n\n  if (!managerName || managerName.toUpperCase() === \"UNKNOWN\") return;\n\n  const managerPersonId = row[\"Manager Person Identifier\"] ?? null;\n  const managerAssignmentId = row[\"Manager Assignment Identifier\"] ?? null;\n  const managerDepartmentName = row[\"Manager Department Name\"] || \"\";\n  const headcount = Number(row[\"Termination Headcount\"] || 0);\n\n  resultObj.count += headcount;\n\n  const managerKey = String(managerPersonId);\n\n  if (!resultObj.managersMap[managerKey]) {\n    resultObj.managersMap[managerKey] = {\n      managerPersonId,\n      managerAssignmentId,\n      managerName,\n      managerDepartmentName,\n      count: 0\n    };\n  }\n\n  // Backfill if first row had blank manager department name\n  if (\n    !resultObj.managersMap[managerKey].managerDepartmentName &&\n    managerDepartmentName\n  ) {\n    resultObj.managersMap[managerKey].managerDepartmentName = managerDepartmentName;\n  }\n\n  resultObj.managersMap[managerKey].count += headcount;\n});\n\nreturn {\n  reason: resultObj.reason,\n  count: resultObj.count,\n  managers: Object.values(resultObj.managersMap)\n};"
          },
          "outcomes": {
            "success": "1781766623124"
          },
          "code": "CONSOLIDATING_COMPENSATION_ACTION_RESULTS",
          "id": "1776696317800",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "type": "CODE",
          "diagram": {
            "x": 6912.5,
            "y": 7648
          }
        },
        {
          "metadata": {
            "name": "Consolidating Reason Action Results",
            "returnType": "object",
            "sourceCode": "const data = $context?.$nodes?.EXECUTING_REASON_ACTION_QUERY?.$output;\n\n// Supports both direct Rows and nested output.response.Rows\nconst rows =\n  (Array.isArray(data?.Rows) && data.Rows) ||\n  (Array.isArray(data?.response?.Rows) && data.response.Rows) ||\n  (Array.isArray(data?.output?.response?.Rows) && data.output.response.Rows) ||\n  [];\n\nlet resultObj = null;\n\nrows.forEach((row) => {\n  const reason = (row[\"Action Reason\"] || \"\").trim();\n  const managerName = (row[\"Manager Display Name\"] || \"\").trim();\n\n  if (!reason || reason.toUpperCase() === \"UNKNOWN\") return;\n  if (!managerName || managerName.toUpperCase() === \"UNKNOWN\") return;\n\n  const managerPersonId = row[\"Manager Person Identifier\"] ?? null;\n  const managerAssignmentId = row[\"Manager Assignment Identifier\"] ?? null;\n  const managerDepartmentName = row[\"Manager Department Name\"] || \"\";\n  const headcount = Number(row[\"Termination Headcount\"] || 0);\n\n  if (!resultObj) {\n    resultObj = {\n      reason,\n      count: 0,\n      managersMap: {}\n    };\n  }\n\n  resultObj.count += headcount;\n\n  const managerKey = String(managerPersonId);\n\n  if (!resultObj.managersMap[managerKey]) {\n    resultObj.managersMap[managerKey] = {\n      managerPersonId,\n      managerAssignmentId,\n      managerName,\n      managerDepartmentName,\n      count: 0\n    };\n  }\n\n  if (\n    !resultObj.managersMap[managerKey].managerDepartmentName &&\n    managerDepartmentName\n  ) {\n    resultObj.managersMap[managerKey].managerDepartmentName =\n      managerDepartmentName;\n  }\n\n  resultObj.managersMap[managerKey].count += headcount;\n});\n\nif (!resultObj) {\n  return {\n    reason: \"\",\n    count: 0,\n    managers: []\n  };\n}\n\nreturn {\n  reason: resultObj.reason,\n  count: resultObj.count,\n  managers: Object.values(resultObj.managersMap)\n};"
          },
          "outcomes": {
            "success": "1781766623125"
          },
          "code": "CONSOLIDATING_REASON_ACTION_RESULTS",
          "convergenceTargetId": "1774966224640",
          "id": "1774962157841",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "type": "CODE",
          "diagram": {
