            "returnType": "object",
            "sourceCode": "let active = $context.$nodes.GETTING_ACTIVE_REPORTS_FOR_MANAGER.$output;\n\nlet items = active?.result?.items || [];\n\nconst result = items.reduce((acc, item) => {\n  const personId = item?.PersonId ?? null;\n  const assignmentId = item?.AssignmentId ?? null;\n\n  if (personId == null || assignmentId == null) return acc;\n\n  const personKey = String(personId);\n  const assignmentKey = String(assignmentId);\n\n  if (!acc[personKey]) {\n    acc[personKey] = {};\n  }\n\n  const existing = acc[personKey][assignmentKey] || {};\n\n  acc[personKey][assignmentKey] = {\n    personId: personKey,\n    assignmentId: assignmentKey,\n    employeeName: item?.DisplayName ?? existing.employeeName ?? \"\",\n    departmentName: item?.DepartmentName ?? existing.departmentName ?? \"\",\n    jobName: item?.JobName ?? item?.AssignmentName ?? existing.jobName ?? \"\",\n    [\"location\"]: item?.LocationName ?? item?.LocalTimeLocationName ?? existing?.[\"location\"] ?? \"\",\n    hireDate: item?.EffectiveStartDate ?? existing.hireDate ?? null\n  };\n\n  return acc;\n}, {});\n\nreturn result;"
