            "returnType": "object",
            "sourceCode": "const leaversData = $context.$nodes.CALCULATING_LATEST_JOB_TENURE.$output.result || {};\nconst promoteLink = $context.$nodes.GENERATING_PROMOTE_LINK_FOR_REASON.$output || {};\nconst salaryLink = $context.$nodes.GENERATING_SALARY_LINK_FOR_REASON.$output || {};\n\nfunction cleanString(value) {\n  return String(value)\n    .replace(/[\\u0000-\\u001F\\u007F]/g, \"\")\n    .replace(/[<>]/g, \"\")\n    .replace(/\\s+/g, \" \")\n    .trim();\n}\n\nfunction sanitize(value) {\n  if (typeof value === \"string\") return cleanString(value);\n  if (Array.isArray(value)) return value.map(item => sanitize(item));\n  if (value && typeof value === \"object\") {\n    const output = {};\n    Object.keys(value).forEach(key => {\n      output[key] = sanitize(value[key]);\n    });\n    return output;\n  }\n  return value;\n}\n\nreturn {\n  leaversData: sanitize(leaversData),\n  promoteLink,\n  salaryLink\n};"
