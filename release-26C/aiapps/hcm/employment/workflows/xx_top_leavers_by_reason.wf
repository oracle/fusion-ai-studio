        {
          "metadata": {
            "businessObjectCode": "ORA_HCM_GLOBALHUMA_XX_HR_ATTRITION_ANALYTIC_REPORTS",
            "functionName": "run_sql_query_using_payload",
            "name": "Executing Reason Employee Query"
          },
          "outcomes": {
            "success": "1784000000003"
          },
          "code": "EXECUTING_REASON_EMPLOYEE_QUERY",
          "convergenceTargetId": "1784000000005",
          "id": "1784000000002",
          "inputs": [
            {
              "id": "1784000000002_1",
              "name": "runSqlQueryPayload",
              "type": "string",
              "value": "{{$context.$nodes.GENERATING_REASON_EMPLOYEE_QUERY.$output.result}}"
            }
          ],
          "outputSpecification": "{}",
          "type": "BO_FUNCTION",
          "diagram": {
            "x": 6462.5,
            "y": 7870
          }
        },
        {
          "metadata": {
            "name": "Consolidating Reason Employee Results",
            "returnType": "object",
            "sourceCode": "const data = $context.$nodes.EXECUTING_REASON_EMPLOYEE_QUERY.$output;\nconst actionData = $context.$nodes.PARSING_ACTION_OBJECT.$output.result.payload.data || {};\nconst selectedReason = String(actionData.reason || \"\").trim();\nconst validatedManagerPersonId = $context.$nodes.VALIDATING_MANAGER_ID.$output.result.managerPersonId || null;\nconst validatedManagerAssignmentId = $context.$nodes.VALIDATING_MANAGER_ID.$output.result.managerAssignmentId || null;\n\nconst rows =\n  (Array.isArray(data?.Rows) && data.Rows) ||\n  (Array.isArray(data?.response?.Rows) && data.response.Rows) ||\n  (Array.isArray(data?.output?.response?.Rows) && data.output.response.Rows) ||\n  [];\n\nfunction calculateTenureYears(hireDate, terminationDate) {\n  if (!hireDate || !terminationDate) return null;\n\n  const hire = new Date(hireDate);\n  const termination = new Date(terminationDate);\n\n  if (isNaN(hire.getTime()) || isNaN(termination.getTime())) return null;\n\n  const totalDays = (termination - hire) / (1000 * 60 * 60 * 24);\n  if (totalDays < 0) return null;\n\n  const tenureYears = totalDays / 365;\n\n  return Number(tenureYears.toFixed(1));\n}\n\nlet managerName = String(actionData.managerName || \"\").trim();\nlet managerDepartmentName = String(actionData.managerDepartmentName || \"\").trim();\nlet count = 0;\n\nconst employees = rows.map((row) => {\n  const hireDate = row[\"Work Relationship Start Date\"] || null;\n  const terminationDate = row[\"Termination Date\"] || null;\n  const headcount = Number(row[\"Termination Headcount\"] || 0);\n\n  count += headcount;\n\n  if (!managerName) {\n    managerName = String(row[\"Manager Display Name\"] || \"\").trim();\n  }\n\n  if (!managerDepartmentName) {\n    managerDepartmentName = String(row[\"Manager Department Name\"] || \"\").trim();\n  }\n\n  return {\n    personId: row[\"Person Identifier\"] ?? row[\"Person ID\"] ?? null,\n    assignmentId: row[\"Assignment Identifier\"] ?? row[\"Assignment ID\"] ?? null,\n    employeeName: row[\"Display Name\"] || null,\n    actionReason: row[\"Action Reason\"] || selectedReason || \"\",\n    location: row[\"Location Name\"] || \"\",\n    departmentName: row[\"Department Name\"] || \"\",\n    jobName: row[\"Job Name\"] || \"\",\n    hireDate,\n    terminationDate,\n    tenure: calculateTenureYears(hireDate, terminationDate)\n  };\n});\n\nreturn {\n  reason: selectedReason,\n  count,\n  managerPersonId: validatedManagerPersonId,\n  managerAssignmentId: validatedManagerAssignmentId,\n  managerName,\n  managerDepartmentName,\n  managerCount: Number(actionData.managerCount ?? count ?? 0),\n  employees\n};"
          },
          "outcomes": {
            "success": "1784000000005"
          },
          "code": "CONSOLIDATING_REASON_EMPLOYEE_RESULTS",
          "convergenceTargetId": "1784000000005",
          "id": "1784000000003",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "type": "CODE",
          "diagram": {
            "x": 6462.5,
            "y": 8092
          }
        },
        {
