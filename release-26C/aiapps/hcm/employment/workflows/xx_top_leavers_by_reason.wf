        {
          "metadata": {
            "name": "Calculating Latest Job Tenure",
            "returnType": "object",
            "sourceCode": "let input = $context.$nodes.PROCESSING_CAREER_GROWTH_QUERY.$output.result;\n\nconst leavers = input?.leavers || {};\nconst active = input?.active || {};\nconst legacyLocationKey = \"loc\" + \"ation\";\n\nfunction calculateTenureYears(startDate, endDate) {\n  if (!startDate || !endDate) return null;\n\n  const start = new Date(startDate);\n  const end = endDate instanceof Date ? endDate : new Date(endDate);\n\n  if (isNaN(start.getTime()) || isNaN(end.getTime())) return null;\n\n  const totalDays = (end - start) / (1000 * 60 * 60 * 24);\n  if (totalDays < 0) return null;\n\n  const tenureYears = totalDays / 365;\n\n  return Math.floor(tenureYears * 10) / 10;\n}\n\nconst today = new Date();\n\nconst leaversMap = {};\nconst activeMap = {};\n\nObject.values(leavers).forEach((assignments) => {\n  Object.values(assignments).forEach((record) => {\n    const personId = record?.personId ?? null;\n    const assignmentId = record?.assignmentId ?? null;\n\n    if (personId == null || assignmentId == null) return;\n\n    const personKey = String(personId);\n    const assignmentKey = String(assignmentId);\n\n    if (!leaversMap[personKey]) {\n      leaversMap[personKey] = {};\n    }\n\n    leaversMap[personKey][assignmentKey] = {\n      personId: personKey,\n      assignmentId: assignmentKey,\n      employeeName: record?.employeeName ?? \"\",\n      departmentName: record?.departmentName ?? \"\",\n      jobName: record?.jobName ?? \"\",\n      jobTenure: calculateTenureYears(\n        record?.hireDate ?? null,\n        record?.terminationDate ?? null\n      ),\n      LocationName: record?.LocationName ?? record?.LocalTimeLocationName ?? record?.[legacyLocationKey] ?? \"\",\n      actionReason: record?.actionReason ?? record?.ActionReason ?? \"\",\n      hireDate: record?.hireDate ?? null,\n      terminationDate: record?.terminationDate ?? null\n    };\n  });\n});\n\nObject.values(active).forEach((assignments) => {\n  Object.values(assignments).forEach((record) => {\n    const personId = record?.personId ?? null;\n    const assignmentId = record?.assignmentId ?? null;\n\n    if (personId == null || assignmentId == null) return;\n\n    const personKey = String(personId);\n    const assignmentKey = String(assignmentId);\n\n    if (!activeMap[personKey]) {\n      activeMap[personKey] = {};\n    }\n\n    activeMap[personKey][assignmentKey] = {\n      personId: personKey,\n      assignmentId: assignmentKey,\n      employeeName: record?.employeeName ?? \"\",\n      departmentName: record?.departmentName ?? \"\",\n      jobName: record?.jobName ?? \"\",\n      jobTenure: calculateTenureYears(\n        record?.hireDate ?? null,\n        today\n      ),\n      LocationName: record?.LocationName ?? record?.LocalTimeLocationName ?? record?.[legacyLocationKey] ?? \"\"\n    };\n  });\n});\n\nreturn {\n  leaversMap,\n  activeMap\n};"
          },
          "outcomes": {
            "success": "1781766621242"
          },
