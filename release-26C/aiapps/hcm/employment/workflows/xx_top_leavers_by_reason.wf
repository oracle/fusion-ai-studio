            "sourceCode": "let leavers = $context.$nodes.CONSOLIDATING_REASON_EMPLOYEE_RESULTS.$output.result.employees || [];\n\nconst result = leavers.reduce((acc, emp) => {\n  const personId = emp?.personId ?? null;\n  const assignmentId = emp?.assignmentId ?? null;\n\n  if (personId == null || assignmentId == null) return acc;\n\n  const personKey = String(personId);\n  const assignmentKey = String(assignmentId);\n\n  if (!acc[personKey]) {\n    acc[personKey] = {};\n  }\n\n  const existing = acc[personKey][assignmentKey] || {};\n\n  acc[personKey][assignmentKey] = {\n    personId: personKey,\n    assignmentId: assignmentKey,\n    employeeName: emp?.employeeName ?? existing.employeeName ?? \"\",\n    departmentName: emp?.departmentName ?? existing.departmentName ?? \"\",\n    jobName: emp?.jobName ?? existing.jobName ?? \"\",\n    [\"location\"]: emp?.[\"location\"] ?? existing?.[\"location\"] ?? \"\",\n    actionReason: emp?.actionReason ?? emp?.ActionReason ?? existing.actionReason ?? \"\",\n    hireDate: emp?.hireDate ?? existing.hireDate ?? null,\n    terminationDate: emp?.terminationDate ?? existing.terminationDate ?? null\n  };\n\n  return acc;\n}, {});\n\nreturn result;"
          },
