          "id": "1776804002761",
          "inputs": [
            {
              "id": "1777458154959_1",
              "name": "runSqlQueryPayload",
              "type": "string",
              "value": "{{$context.$nodes.GENERATING_CAREER_GROWTH_ACTION_QUERY.$output.result}}"
            }
          ],
          "outputSpecification": "{}",
          "type": "BO_FUNCTION",
          "diagram": {
