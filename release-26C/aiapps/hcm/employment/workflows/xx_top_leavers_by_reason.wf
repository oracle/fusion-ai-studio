        {
          "metadata": {
            "name": "Generating OTBI Query",
            "returnType": "object",
            "sourceCode": "let payload = {\n          \"sqlQuery\": \"SELECT \\\"Workforce Management - Workforce Trend Real Time\\\".\\\"HR Action Reason\\\".\\\"Action Reason\\\" s_1, \\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Workforce Trend\\\".\\\"Termination Headcount\\\" s_2 FROM \\\"Workforce Management - Workforce Trend Real Time\\\" \\nWHERE\\n((\\\"Workforce Trend\\\".\\\"Termination Headcount\\\" > 0)  AND  (\\\"Business Unit\\\".\\\"Business Unit Id\\\" = 300100648781671) AND ( \\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Worker\\\".\\\"Termination Date\\\" BETWEEN TIMESTAMPADD(SQL_TSI_MONTH, -6, CURRENT_DATE) AND CURRENT_DATE))\\n ORDER BY 3 DESC NULLS FIRST, 4 ASC NULLS LAST, 2 ASC NULLS LAST\\nFETCH FIRST 75001 ROWS ONLY\",\n          \"outputFormat\": \"CollectionDataFormat\",\n          \"executionOptions\": {\n            \"async\": false,\n            \"refresh\": true,\n            \"presentationInfo\": true,\n            \"maxRowsPerPage\": 25\n          },\n          \"sessionId\": $context.$nodes.PERFORMING_LOGON.$output.token\n        };\n\n\nreturn payload;"
          },
          "outcomes": {
            "success": "1775557872641"
          },
          "code": "GENERATING_OTBI_QUERY",
          "id": "1775557603885",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "type": "CODE",
          "diagram": {
            "x": 9050,
            "y": 5872
          }
        },
        {
          "metadata": {
            "name": "Parsing Action Object",
            "returnType": "object",
            "sourceCode": "let oraAction = $context.$app.$OraAction;\nlet payload = {};\nlet parseError = \"\";\n\ntry {\n  payload = JSON.parse(oraAction || \"{}\");\n} catch (error) {\n  parseError = error && error.message ? error.message : \"Invalid action payload\";\n  payload = {};\n}\n\nlet action = payload && payload.command ? String(payload.command) : \"\";\nlet validActions = {\n  displayEmp: true,\n  rowNavigate: true\n};\nlet valid = !!validActions[action];\nlet validationError = \"\";\n\nif (!valid) {\n  action = \"INVALID_ACTION\";\n  validationError = \"Invalid action command\";\n}\n\nreturn {\n  command: action,\n  action,\n  data: valid && payload && payload.data ? payload.data : {},\n  payload: valid ? payload : {},\n  valid,\n  error: parseError || validationError\n};"
          },
          "outcomes": {
            "success": "1775731335063"
          },
          "code": "PARSING_ACTION_OBJECT",
          "id": "1775731246291",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "type": "CODE",
          "diagram": {
            "x": 7025,
            "y": 5872
          }
        },
        {
          "id": "1781766623126",
          "code": "VALIDATE_REST_REASON",
          "type": "CODE",
          "metadata": {
            "name": "Validate REST Reason",
            "returnType": "object",
            "sourceCode": "const rawReason = $context.$triggers.REST.$input.Reason;\n\nlet valid = true;\nlet invalid = false;\nlet reason = \"\";\nlet reasonName = \"\";\nlet sqlSafeReasonName = \"\";\n\nfunction markInvalid(message) {\n  valid = false;\n  invalid = true;\n  reason = message;\n}\n\nif (typeof rawReason !== \"string\") {\n  markInvalid(\"reason must be a string\");\n} else {\n  reasonName = rawReason.replace(/\\s+/g, \" \").trim();\n\n  if (!reasonName) {\n    markInvalid(\"reason cannot be empty\");\n  } else if (reasonName.length > 50) {\n    markInvalid(\"reason is too long\");\n  } else if (/[<>]/.test(reasonName)) {\n    markInvalid(\"reason contains invalid angular brackets\");\n  } else {\n    for (let i = 0; i < reasonName.length; i++) {\n      const code = reasonName.charCodeAt(i);\n\n      if ((code >= 0 && code <= 31) || code === 127) {\n        markInvalid(\"reason contains invalid control characters\");\n        break;\n      }\n    }\n\n    if (valid) {\n      sqlSafeReasonName = reasonName.split(\"'\").join(\"''\");\n    }\n  }\n}\n\nreturn {\n  valid: valid,\n  invalid: invalid,\n  reason: reason,\n  originalReasonName: reasonName,\n  sqlSafeReasonName: sqlSafeReasonName\n};"
          },
          "outcomes": {
            "success": "1781766623127"
          },
          "inputs": [],
          "diagram": {
            "x": 10850,
            "y": 5872
          },
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
