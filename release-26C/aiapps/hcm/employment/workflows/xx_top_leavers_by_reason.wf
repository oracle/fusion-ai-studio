        {
          "metadata": {
            "name": "Generating Compensation Workflow Query",
            "returnType": "object",
            "sourceCode": "const reason = $context.$nodes.VALIDATE_REST_REASON.$output.result.sqlSafeReasonName;\n\nlet payload = {\n  sqlQuery:\n    \" SELECT \" +\n    \"\\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Manager\\\".\\\"Manager Display Name\\\" s_1, \" +\n    \"\\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Worker\\\".\\\"Manager ID\\\" s_2, \" +\n    \"\\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Worker\\\".\\\"Manager Assignment ID\\\" s_3, \" +\n    \"\\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Workforce Trend\\\".\\\"Termination Headcount\\\" s_4, \" +\n    \"\\\"Workforce Management - Worker Assignment Event Real Time\\\".\\\"Worker\\\".\\\"Manager Department Name\\\" s_5 \" +\n    \"FROM \\\"Workforce Management - Workforce Trend Real Time\\\" \" +\n    \"WHERE ((\\\"Workforce Trend\\\".\\\"Termination Headcount\\\" > 0) \" +\n    \"AND ( \\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Worker\\\".\\\"Termination Date\\\" BETWEEN TIMESTAMPADD(SQL_TSI_MONTH, -6, CURRENT_DATE) AND CURRENT_DATE) \" +\n    \"AND (\\\"Business Unit\\\".\\\"Business Unit Id\\\" = 300100648781671) \" +\n    \"AND (\\\"HR Action Reason\\\".\\\"Action Reason\\\" = '\" + reason + \"')) \" +\n    \"FETCH FIRST 75001 ROWS ONLY\",\n  outputFormat: \"CollectionDataFormat\",\n  executionOptions: {\n    async: false,\n    refresh: true,\n    presentationInfo: true,\n    maxRowsPerPage: 25\n  },\n  sessionId: $context.$nodes.PERFORMING_LOGON.$output.token\n};\n\nreturn payload;"
          },
          "outcomes": {
            "success": "1777363736579"
          },
          "code": "GENERATING_COMPENSATION_WORKFLOW_QUERY",
          "id": "1777363605566",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "type": "CODE",
          "diagram": {
            "x": 10400,
            "y": 6538
          }
        },
        {
          "metadata": {
            "name": "Generating Reason Workflow Query",
            "returnType": "object",
            "sourceCode": "const reason = $context.$nodes.VALIDATE_REST_REASON.$output.result.sqlSafeReasonName;\n\nlet payload = {\n  sqlQuery:\n    \"SET VARIABLE PREFERRED_CURRENCY='User Preferred Currency 1'; SELECT 0 s_0, \" +\n    \"\\\"Workforce Management - Worker Assignment Event Real Time\\\".\\\"Worker\\\".\\\"Employee Display Name\\\" s_1, \" +\n    \"\\\"Workforce Management - Workforce Trend Real Time\\\".\\\"HR Action Reason\\\".\\\"Action Reason\\\" s_2, \" +\n    \"\\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Manager\\\".\\\"Manager Display Name\\\" s_3, \" +\n    \"CAST(\\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Time\\\".\\\"Calendar Year\\\" AS INT) s_4, \" +\n    \"CAST(RIGHT(\\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Time\\\".\\\"Month\\\",2) AS INT) s_5, \" +\n    \"\\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Workforce Trend\\\".\\\"Termination Headcount\\\" s_6, \" +\n    \"\\\"Workforce Management - Worker Assignment Event Real Time\\\".\\\"Worker\\\".\\\"Manager ID\\\" s_7, \" +\n    \"\\\"Workforce Management - Worker Assignment Event Real Time\\\".\\\"Worker\\\".\\\"Manager Assignment ID\\\" s_8, \" +\n    \"\\\"Workforce Management - Worker Assignment Event Real Time\\\".\\\"Location\\\".\\\"Worker Location Name\\\" s_9, \" +\n    \"\\\"Workforce Management - Worker Assignment Event Real Time\\\".\\\"Department\\\".\\\"Department Name\\\" s_10, \" +\n    \"\\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Job\\\".\\\"Job Name\\\" s_11, \" +\n    \"\\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Worker\\\".\\\"Termination Date\\\" s_12, \" +\n    \"\\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Worker\\\".\\\"Employee Hire Date\\\" s_13, \" +\n    \"\\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Worker\\\".\\\"Person ID\\\" s_14, \" +\n    \"\\\"Workforce Management - Worker Assignment Event Real Time\\\".\\\"Worker\\\".\\\"Assignment ID\\\" s_15, \" +\n    \"DESCRIPTOR_IDOF(\\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Job\\\".\\\"Job Name\\\") s_16, \" +\n    \"\\\"Workforce Management - Worker Assignment Event Real Time\\\".\\\"Worker\\\".\\\"Manager Department Name\\\" s_17 \" +\n    \"FROM \\\"Workforce Management - Workforce Trend Real Time\\\" \" +\n    \"WHERE ((\\\"Workforce Trend\\\".\\\"Termination Headcount\\\" > 0) \" +\n    \"AND ( \\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Worker\\\".\\\"Termination Date\\\" BETWEEN TIMESTAMPADD(SQL_TSI_MONTH, -6, CURRENT_DATE) AND CURRENT_DATE) \" +\n    \"AND (\\\"Business Unit\\\".\\\"Business Unit Id\\\" = 300100648781671) \" +\n    \"AND (\\\"HR Action Reason\\\".\\\"Action Reason\\\" = '\" + reason + \"')) \" +\n    \"ORDER BY 5 DESC NULLS FIRST, 6 ASC NULLS LAST, 3 ASC NULLS LAST, 4 ASC NULLS LAST \" +\n    \"FETCH FIRST 75001 ROWS ONLY\",\n  outputFormat: \"CollectionDataFormat\",\n  executionOptions: {\n    async: false,\n    refresh: true,\n    presentationInfo: true,\n    maxRowsPerPage: 25\n  },\n  sessionId: $context.$nodes.PERFORMING_LOGON.$output.token\n};\n\nreturn payload;"
          },
          "outcomes": {
            "success": "1777363797114"
          },
          "code": "GENERATING_REASON_WORKFLOW_QUERY",
          "id": "1777363671472",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "type": "CODE",
          "diagram": {
            "x": 10850,
            "y": 6538
          }
        },
        {
          "metadata": {
            "name": "Filtering Reason Results",
            "returnType": "object",
            "sourceCode": "const data = $context.$nodes.EXECUTING_LOGICAL_SQL_QUERY.$output;\n\n// Aggregate\nconst reasonMap = {};\nlet totalTerminationCount = 0;\n\n(data.Rows || []).forEach((row) => {\n  const reason = (row[\"Action Reason\"] || \"\").trim();\n  const count = Number(row[\"Termination Headcount\"] || 0);\n\n  if (!reason || reason.toUpperCase() === \"UNKNOWN\") {\n    return;\n  }\n\n  reasonMap[reason] = (reasonMap[reason] || 0) + count;\n  totalTerminationCount += count;\n});\n\n// Final object\nconst result = {\n  totalTerminationCount,\n  reasons: Object.entries(reasonMap).map(([reason, count]) => ({\n    reason,\n    count\n  }))\n};\n\nreturn result;"
          },
          "outcomes": {
            "success": "1781766623120"
          },
          "code": "FILTERING_REASON_RESULTS",
          "convergenceTargetId": "1775557872641",
          "id": "1775213536914",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "type": "CODE",
          "diagram": {
            "x": 9050,
            "y": 6316
          }
        },
        {
          "metadata": {
            "name": "Getting Reason from Action",
            "returnType": "string",
            "sourceCode": "let parsedAction = $context.$nodes.PARSING_ACTION_OBJECT.$output.result || {};\nlet data = parsedAction.data || {};\nreturn data.reason || \"\";"
          },
          "outcomes": {
