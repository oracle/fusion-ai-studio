        {
          "metadata": {
            "name": "Generating Career Growth Action Query",
            "returnType": "object",
            "sourceCode": "const managerId = String(\n  $context.$nodes.VALIDATING_MANAGER_ID.$output.result.managerPersonId || \"\"\n).trim();\n\nlet payload = {\n  sqlQuery:\n    \"SET VARIABLE PREFERRED_CURRENCY='User Preferred Currency 1'; SELECT 0 s_0, \" +\n    \"\\\"Workforce Management - Worker Assignment Event Real Time\\\".\\\"Assignment Event Details\\\".\\\"Effective Start Date\\\" s_1, \" +\n    \"\\\"Workforce Management - Worker Assignment Event Real Time\\\".\\\"Job\\\".\\\"Job Name\\\" s_2, \" +\n    \"\\\"Workforce Management - Worker Assignment Event Real Time\\\".\\\"Worker\\\".\\\"Assignment ID\\\" s_3, \" +\n    \"\\\"Workforce Management - Worker Assignment Event Real Time\\\".\\\"Worker\\\".\\\"Employee Display Name\\\" s_4, \" +\n    \"\\\"Workforce Management - Worker Assignment Event Real Time\\\".\\\"Worker\\\".\\\"Employee Hire Date\\\" s_5, \" +\n    \"\\\"Workforce Management - Worker Assignment Event Real Time\\\".\\\"Worker\\\".\\\"Person ID\\\" s_6, \" +\n    \"\\\"Workforce Management - Worker Assignment Event Real Time\\\".\\\"Worker\\\".\\\"Termination Date\\\" s_7, \" +\n    \"DESCRIPTOR_IDOF(\\\"Workforce Management - Worker Assignment Event Real Time\\\".\\\"Job\\\".\\\"Job Name\\\") s_8 \" +\n    \"FROM \\\"Workforce Management - Worker Assignment Event Real Time\\\" \" +\n    \"WHERE ((\\\"HR Action\\\".\\\"Action Code\\\" = 'PROMOTION') \" +\n    \"AND (\\\"Business Unit\\\".\\\"Business Unit Id\\\" = 300100648781671) \" +\n    \"AND (\\\"Workforce Management - Worker Assignment Event Real Time\\\".\\\"Worker\\\".\\\"Manager ID\\\" = \" + managerId + \")) \" +\n    \"ORDER BY 5 DESC NULLS FIRST, 2 DESC NULLS FIRST, 6 ASC NULLS LAST, 3 ASC NULLS LAST, 8 ASC NULLS LAST, 7 ASC NULLS LAST, 4 ASC NULLS LAST \" +\n    \"FETCH FIRST 75001 ROWS ONLY\",\n  outputFormat: \"CollectionDataFormat\",\n  executionOptions: {\n    async: false,\n    refresh: true,\n    presentationInfo: true,\n    maxRowsPerPage: 25\n  },\n  sessionId: $context.$nodes.PERFORMING_LOGON.$output.token\n};\n\nreturn payload;"
          },
          "outcomes": {
            "success": "1776804002761"
          },
          "code": "GENERATING_CAREER_GROWTH_ACTION_QUERY",
