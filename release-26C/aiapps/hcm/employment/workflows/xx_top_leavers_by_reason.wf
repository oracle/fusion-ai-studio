        {
          "metadata": {
            "name": "Setting Hint",
            "returnType": "object",
            "sourceCode": "let hint = $context.$app.$OraMessageHint;\nlet reason = $context.$triggers.REST.$input.Reason;\n\nlet hint1 = hint;\nlet hint2 = hint;\n\nif (hint === undefined) {\n  hint1 = \"default\";\n  hint2 = \"init\";\n} else if (\n  hint === \"InitDisplay\" ||\n  hint === \"AdditionalContent\" ||\n  hint === \"InitActions\" ||\n  hint === \"FillParameters\"\n) {\n  hint2 = \"init\";\n}\n\nif (reason !== null && reason !== undefined && String(reason).trim() !== \"\") {\n  hint2 = \"workflow\";\n}\n\nreturn {\n  hint1: hint1,\n  hint2: hint2\n};"
          },
          "outcomes": {
            "success": "1774942103471"
          },
          "code": "SETTING_HINT",
          "id": "1776327341144",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "type": "CODE",
          "diagram": {
