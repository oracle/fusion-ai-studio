        {
          "id": "1783000000003",
          "code": "SANITY_CHECK_SMART_ANSWERS_OUTPUT",
          "type": "CODE",
          "metadata": {
            "name": "Sanity Check Smart Answers Output",
            "returnType": "object",
            "sourceCode": "const smartAnswersOutput = $context.$nodes.EXECUTING_SMART_ANSWERS_EXPERT.$output || {};\nconst userInput = $context.$system.$inputMessage || \"\";\n\nfunction cleanString(value) {\n  return String(value)\n    .replace(/[\\u0000-\\u001F\\u007F]/g, \"\")\n    .replace(/[<>]/g, \"\")\n    .replace(/\\s+/g, \" \")\n    .trim();\n}\n\nfunction sanitize(value) {\n  if (typeof value === \"string\") return cleanString(value);\n  if (Array.isArray(value)) return value.map(item => sanitize(item));\n  if (value && typeof value === \"object\") {\n    const output = {};\n    Object.keys(value).forEach(key => {\n      output[key] = sanitize(value[key]);\n    });\n    return output;\n  }\n  return value;\n}\n\nreturn {\n  output: sanitize(smartAnswersOutput.output || \"\"),\n  userQuery: sanitize(userInput)\n};"
          },
          "outcomes": {
            "success": "1777019852927"
          },
