        {
          "metadata": {
            "name": "Getting Job from Action",
            "returnType": "string",
            "sourceCode": "let oraAction = $context.$app.$OraAction || \"{}\";\nlet payload = JSON.parse(oraAction);\n\nconst data = payload.data || {};\nconst job = String(data.job || \"\").trim();\n\nif (!/^[a-zA-Z0-9\\s,./&()_-]{1,100}$/.test(job)) {\n  throw new Error(\"Invalid job\");\n}\n\nreturn job;"
          },
          "outcomes": {
            "success": "1782321150019"
          },
          "code": "GETTING_JOB_FROM_ACTION",
          "convergenceTargetId": "1775638239097",
          "id": "1775551739927",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "type": "CODE",
          "diagram": {
            "x": 5285,
            "y": 6982
          }
        },
        {
          "id": "1782321150019",
          "code": "VALIDATE_JOB",
          "type": "CODE",
          "metadata": {
            "name": "Validate Job",
            "sourceCode": "const rawJobName =\n  $context.$nodes.GETTING_JOB_FROM_ACTION.$output.result;\n\nlet valid = true;\nlet invalid = false;\nlet reason = \"\";\nlet jobName = \"\";\nlet sqlSafeJobName = \"\";\n\nfunction markInvalid(message) {\n  valid = false;\n  invalid = true;\n  reason = message;\n}\n\nif (typeof rawJobName !== \"string\") {\n  markInvalid(\"jobName must be a string\");\n} else {\n  jobName = rawJobName.trim();\n\n  if (!jobName) {\n    markInvalid(\"jobName cannot be empty\");\n  } else if (jobName.length > 50) {\n    markInvalid(\"jobName is too long\");\n  } else {\n    // Reject hidden/control characters.\n    // Special characters like =, \", ', &, /, -, _, @, #, %, (, ), :, ; etc. are allowed.\n    for (let i = 0; i < jobName.length; i++) {\n      const code = jobName.charCodeAt(i);\n\n      if ((code >= 0 && code <= 31) || code === 127) {\n        markInvalid(\"jobName contains invalid control characters\");\n        break;\n      }\n    }\n\n    if (valid) {\n      // SQL string literal escaping.\n      // Example: O'Brien -> O''Brien\n      sqlSafeJobName = jobName.split(\"'\").join(\"''\");\n    }\n  }\n}\n\nreturn {\n  valid: valid,\n  invalid: invalid,\n  reason: reason,\n  originalJobName: jobName,\n  sqlSafeJobName: sqlSafeJobName\n};",
            "returnType": "object"
          },
          "diagram": {
            "x": 5285,
            "y": 7204
          },
          "outcomes": {
            "success": "1782321268018"
          },
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
