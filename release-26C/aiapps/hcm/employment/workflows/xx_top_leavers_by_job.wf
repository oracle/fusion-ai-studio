        {
          "metadata": {
            "name": "Filtering Results",
            "returnType": "object",
            "sourceCode": "const data = $context.$nodes.EXECUTING_OTBI_QUERY.$output;\n\n// Aggregate\nconst jobMap = {};\nlet totalTerminationCount = 0;\n\n// Iterate only if data.Rows exists and is not empty\nif (data?.Rows && Array.isArray(data.Rows) && data.Rows.length > 0) {\n  data.Rows.forEach(row => {\n    const jobName = row[\"Job Name\"];\n    const count = Number(row[\"Termination Headcount\"] || 0);\n\n    // Skip UNKNOWN / empty jobs\n    if (!jobName || jobName.trim() === \"\") return;\n\n    // Use jobName as key\n    if (!jobMap[jobName]) {\n      jobMap[jobName] = {\n        jobName: jobName,\n        count: 0\n      };\n    }\n\n    jobMap[jobName].count += count;\n    totalTerminationCount += count;\n  });\n}\n\n// Final object with sorting\nconst result = {\n  totalTerminationCount,\n  jobs: Object.values(jobMap).sort((a, b) => b.count - a.count)\n};\n\nreturn result;"
          },
          "outcomes": {
            "success": "1776331107298"
          },
          "code": "FILTERING_RESULTS",
