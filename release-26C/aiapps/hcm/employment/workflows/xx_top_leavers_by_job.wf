            "y": 8314
          },
          "outcomes": {
            "success": "1783238768724"
          },
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
        {
          "id": "1783238768724",
          "code": "EXECUTING_OTBI_QUERY_TO_GET_LEAVERS",
          "type": "BO_FUNCTION",
          "metadata": {
            "businessObjectCode": "ORA_HCM_GLOBALHUMA_XX_HR_ATTRITION_ANALYTIC_REPORTS",
            "functionName": "run_sql_query_using_payload",
            "processJson": true,
            "name": "Executing OTBI Query to get leavers"
          },
          "diagram": {
            "x": 5753.75,
            "y": 8536
          },
          "outcomes": {
            "success": "1783238783719"
          },
          "inputs": [
            {
              "id": "1777457762764_1",
              "name": "runSqlQueryPayload",
              "type": "string",
              "value": "{{$context.$nodes.GENERATING_OTBI_QUERY_TO_GET_LEAVERS.$output.result}}"
            }
          ]
        },
        {
          "id": "1783238783719",
          "code": "FILTERING_RESULTS_FOR_TO_GET_LEAVERS",
          "type": "CODE",
          "metadata": {
            "name": "Filtering Results for to get leavers",
            "returnType": "object",
            "sourceCode": "const data = $context?.$nodes?.EXECUTING_OTBI_QUERY_TO_GET_LEAVERS?.$output;\n\n// Supports both direct Rows and nested output.response.Rows\nconst rows =\n  (Array.isArray(data?.Rows) && data.Rows) ||\n  (Array.isArray(data?.response?.Rows) && data.response.Rows) ||\n  (Array.isArray(data?.output?.response?.Rows) && data.output.response.Rows) ||\n  [];\n\nfunction calculateTenureYears(hireDate, terminationDate) {\n  if (!hireDate || !terminationDate) return null;\n\n  const hire = new Date(hireDate);\n  const termination = new Date(terminationDate);\n\n  if (isNaN(hire.getTime()) || isNaN(termination.getTime())) return null;\n\n  const totalDays = (termination - hire) / (1000 * 60 * 60 * 24);\n  if (totalDays < 0) return null;\n\n  const tenureYears = totalDays / 365;\n\n  // Truncate to 1 decimal, do not round\n  return Math.floor(tenureYears * 10) / 10;\n}\n\nconst employees = rows.map((row) => {\n  const hireDate = row[\"Work Relationship Start Date\"] || null;\n  const terminationDate = row[\"Termination Date\"] || null;\n\n  return {\n    employeeName: row[\"Display Name\"] || \"UNKNOWN\",\n    actionReason: row[\"Action Reason\"] || \"\",\n    jobName: row[\"Job Name\"] || \"UNKNOWN\",\n    departmentName: row[\"Department Name\"] || \"\",\n    location: row[\"Location Name\"] || \"UNKNOWN\",\n    gradeCode: row[\"Grade Code\"] || \"\",\n    hireDate,\n    terminationDate,\n    tenure: calculateTenureYears(hireDate, terminationDate)\n  };\n});\n\nreturn employees;",
            "sourceType": "code"
          },
