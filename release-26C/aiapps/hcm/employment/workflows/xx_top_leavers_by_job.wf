        {
          "metadata": {
            "name": "Getting Action from App",
            "returnType": "object",
            "sourceCode": "let oraAction = $context.$app.$OraAction;\nlet payload = {};\nlet parseError = \"\";\n\ntry {\n  payload = JSON.parse(oraAction || \"{}\");\n} catch (error) {\n  parseError = error && error.message ? error.message : \"Invalid action payload\";\n  payload = {};\n}\n\nlet action = payload && payload.command ? String(payload.command) : \"\";\nlet validActions = {\n  displayEmp: true,\n  rowNavigate: true\n};\nlet valid = !!validActions[action];\nlet validationError = \"\";\nif (!valid) {\n  validationError = \"Invalid action command\";\n}\n\nlet data = payload && payload.data ? payload.data : {};\n\nif (!valid) {\n  action = \"INVALID_ACTION\";\n}\n\nreturn {\n  payload: valid ? payload : {},\n  action,\n  valid,\n  error: parseError || validationError\n};"
          },
          "outcomes": {
            "success": "1782321050579"
          },
