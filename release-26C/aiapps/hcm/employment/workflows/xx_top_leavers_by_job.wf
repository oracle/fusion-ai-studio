        {
          "metadata": {
            "name": "Generating OTBI Query",
            "returnType": "object",
            "sourceCode": "let payload = {\n  sqlQuery:\n    \"SET VARIABLE PREFERRED_CURRENCY='User Preferred Currency 1'; \" +\n    \"SELECT 0 s_0, \" +\n    \"\\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Job\\\".\\\"Job Name\\\" s_1, \" +\n    \"CAST(\\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Time\\\".\\\"Calendar Year\\\" AS INT) s_2, \" +\n    \"CAST(RIGHT(\\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Time\\\".\\\"Month\\\",2) AS INT) s_3, \" +\n    \"\\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Workforce Trend\\\".\\\"Termination Headcount\\\" s_4, \" +\n    \"DESCRIPTOR_IDOF(\\\"Workforce Management - Workforce Trend Real Time\\\".\\\"Job\\\".\\\"Job Name\\\") s_5 \" +\n    \"FROM \\\"Workforce Management - Workforce Trend Real Time\\\" \" +\n    \"WHERE ((\\\"Workforce Trend\\\".\\\"Termination Headcount\\\" > 0) \" +\n    \"AND (\\\"Workforce Management - Worker Assignment Event Real Time\\\".\\\"Worker\\\".\\\"Termination Date\\\" \" +\n    \"BETWEEN TIMESTAMPADD(SQL_TSI_MONTH, -6, CURRENT_DATE) AND CURRENT_DATE)) \" +\n    \"AND (\\\"Business Unit\\\".\\\"Business Unit Id\\\" = 300100648781671) \" +\n    \"ORDER BY 3 DESC NULLS FIRST, 4 ASC NULLS LAST, 2 ASC NULLS LAST \" +\n    \"FETCH FIRST 75001 ROWS ONLY\",\n  outputFormat: \"CollectionDataFormat\",\n  executionOptions: {\n    async: false,\n    refresh: true,\n    presentationInfo: true,\n    maxRowsPerPage: 25\n  },\n  sessionId: $context.$nodes.PERFORMING_LOGON.$output.token\n};\n\nreturn payload;"
          },
          "outcomes": {
            "success": "1775557872641"
          },
          "code": "GENERATING_OTBI_QUERY",
          "id": "1775557603885",
