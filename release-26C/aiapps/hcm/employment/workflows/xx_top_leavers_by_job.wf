            "returnType": "string",
            "sourceCode": "let oraAction = $context.$app.$OraAction || \"{}\";\nlet payload = JSON.parse(oraAction);\n\nconst data = payload.data || {};\nconst job = String(data.jobName || \"\").trim();\n\nif (!/^[a-zA-Z0-9\\s,./&()_-]{1,100}$/.test(job)) {\n  throw new Error(\"Invalid job\");\n}\n\nreturn job;"
