          "metadata": {
            "name": "Setting Hint for Display",
            "returnType": "object",
            "sourceCode": "let hint = $context.$app.$OraMessageHint;\nlet JobName = $context.$nodes.VALIDATING_JOB_FROM_INPUT.$output.result.sqlSafeJobName;\n\nlet hint1 = hint;\nlet hint2 = hint;\n\nif (hint === undefined) {\n  hint1 = \"default\";\n  hint2 = \"init\";\n} else if (\n  hint === \"InitDisplay\" ||\n  hint === \"AdditionalContent\" ||\n  hint === \"InitActions\" ||\n  hint === \"FillParameters\"\n) {\n  hint2 = \"init\";\n}\n\nif (JobName !== null && JobName !== undefined && String(JobName).trim() !== \"\") {\n  hint2 = \"workflow\";\n}\n\nreturn {\n  hint1: hint1,\n  hint2: hint2\n};"
          },
          "outcomes": {
            "success": "1774942103471"
          },
          "code": "SETTING_HINT_FOR_DISPLAY",
