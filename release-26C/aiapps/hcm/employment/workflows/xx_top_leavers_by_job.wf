            {
              "id": "1777362212892_1",
              "name": "prompt",
              "type": "string",
              "value": "You are given a JSON object containing employee termination records.\n\nInput:\n {{$context.$nodes.EXECUTING_SQL_QUERY.$output}} \n\nTask:\nCreate an aggregated JSON output with manager name, department, and count.\n\nRules:\n1. Read records from the \"Rows\" array.\n2. Use \"Manager Display Name\" as \"managerName\".\n3. Use \"Department Name\" as \"department\".\n4. Group records by the same managerName and department.\n5. For each group, calculate \"count\" by summing \"Termination Headcount\".\n6. If \"Termination Headcount\" is missing, count the row as 1.\n7. Return only valid JSON.\n8. Do not include explanation, markdown, or extra text.\n\nOutput format:\n[\n  {\n    \"managerName\": \"string\",\n    \"department\": \"string\",\n    \"count\": number\n  }\n]"
            }
          ],
          "type": "LLM",
          "diagram": {
            "x": 9362,
            "y": 6760
          }
        },
        {
          "id": "1783064937992",
          "code": "VALIDATING_JOB_FROM_INPUT",
          "type": "CODE",
          "metadata": {
            "name": "Validating job from input",
            "sourceCode": "const rawJobName = $context.$triggers.REST.$input.JobName;\nlet valid = true;\nlet invalid = false;\nlet reason = \"\";\nlet jobName = \"\";\nlet sqlSafeJobName = \"\";\n\nfunction markInvalid(message) {\n  valid = false;\n  invalid = true;\n  reason = message;\n}\n\nif (rawJobName === null || rawJobName === undefined || rawJobName == \"\") {\n  // JobName is optional. Null/undefined is valid.\n  valid = true;\n  invalid = false;\n  reason = \"\";\n  jobName = \"\";\n  sqlSafeJobName = \"\";\n} else if (typeof rawJobName !== \"string\") {\n  markInvalid(\"jobName must be a string\");\n} else {\n  jobName = rawJobName.trim();\n\n  if (!jobName) {\n    markInvalid(\"jobName cannot be empty\");\n  } else if (jobName.length > 50) {\n    markInvalid(\"jobName is too long\");\n  } else {\n    // Reject hidden/control characters.\n    // Special characters like =, \", ', &, /, -, _, @, #, %, (, ), :, ; etc. are allowed.\n    for (let i = 0; i < jobName.length; i++) {\n      const code = jobName.charCodeAt(i);\n\n      if ((code >= 0 && code <= 31) || code === 127) {\n        markInvalid(\"jobName contains invalid control characters\");\n        break;\n      }\n    }\n\n    if (valid) {\n      // SQL string literal escaping.\n      // Example: O'Brien -> O''Brien\n      sqlSafeJobName = jobName.split(\"'\").join(\"''\");\n    }\n  }\n}\n\nreturn {\n  valid: valid,\n  invalid: invalid,\n  reason: reason,\n  originalJobName: jobName,\n  sqlSafeJobName: sqlSafeJobName\n};",
            "returnType": "object"
          },
