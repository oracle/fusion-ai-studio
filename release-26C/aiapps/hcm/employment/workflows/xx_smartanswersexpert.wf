            "name": "StringifyQuery",
            "returnType": "string",
            "sourceCode": "const obj = $context.$nodes.CREATE_OTBI_QUERY.$output;\nconst metadata = $context.$nodes.SETMETADATA.$output.result;\nconst subjectArea = '\"Workforce Management - Worker Assignment Event Real Time\"';\nconst fetchClause = 'FETCH FIRST 75001 ROWS ONLY';\nconst trustedExecutionOptions = {\n  async: false,\n  refresh: true,\n  presentationInfo: true,\n  maxRowsPerPage: 25\n};\n\nif (!obj || typeof obj !== \"object\" || Array.isArray(obj)) {\n  throw new Error(\"Generated query payload must be an object\");\n}\n\nif (typeof obj.sqlQuery !== \"string\") {\n  throw new Error(\"Generated query payload must include sqlQuery as a string\");\n}\n\nif (!Array.isArray(metadata) || metadata.length === 0) {\n  throw new Error(\"Metadata allowlist is unavailable\");\n}\n\nconst sqlQuery = obj.sqlQuery.trim();\nif (!sqlQuery) {\n  throw new Error(\"Generated query payload sqlQuery cannot be empty\");\n}\n\nconst normalizedSql = sqlQuery.replace(/\\s+/g, \" \").trim();\nconst upperSql = normalizedSql.toUpperCase();\n\nconst blockedPatterns = [\n  /--/,\n  /\\/\\*/,\n  /\\*\\//,\n  /\\bUNION\\b/i,\n  /\\bJOIN\\b/i,\n  /\\bWITH\\b/i,\n  /\\bINSERT\\b/i,\n  /\\bUPDATE\\b/i,\n  /\\bDELETE\\b/i,\n  /\\bMERGE\\b/i,\n  /\\bDROP\\b/i,\n  /\\bALTER\\b/i,\n  /\\bTRUNCATE\\b/i,\n  /\\bCALL\\b/i,\n  /\\bEXEC(?:UTE)?\\b/i,\n  /\\bGRANT\\b/i,\n  /\\bREVOKE\\b/i\n];\n\nfor (const pattern of blockedPatterns) {\n  if (pattern.test(normalizedSql)) {\n    throw new Error(\"Generated query contains blocked SQL constructs\");\n  }\n}\n\nif (!/^SELECT\\s+0\\s+s_0\\b/i.test(normalizedSql) && !/^SET\\s+VARIABLE\\b[\\s\\S]*?;\\s*SELECT\\s+0\\s+s_0\\b/i.test(sqlQuery)) {\n  throw new Error(\"Generated query must begin with a supported OTBI SELECT statement\");\n}\n\nif (upperSql.indexOf(subjectArea.toUpperCase()) === -1) {\n  throw new Error(\"Generated query must use the approved subject area\");\n}\n\nconst fromMatches = normalizedSql.match(/\\bFROM\\b/gi) || [];\nif (fromMatches.length !== 1 || !new RegExp(`\\\\bFROM\\\\s+${subjectArea.replace(/[.*+?^${}()|[\\]\\\\]/g, \"\\\\$&\")}`, \"i\").test(normalizedSql)) {\n  throw new Error(\"Generated query must have exactly one approved FROM clause\");\n}\n\nif (!upperSql.endsWith(fetchClause)) {\n  throw new Error(\"Generated query must end with the approved row limit\");\n}\n\nconst semicolonCount = (sqlQuery.match(/;/g) || []).length;\nif (semicolonCount > 1) {\n  throw new Error(\"Generated query contains unexpected statement separators\");\n}\n\nif (semicolonCount === 1 && !/^SET\\s+VARIABLE\\b[\\s\\S]*?;\\s*SELECT\\s+0\\s+s_0\\b/i.test(sqlQuery)) {\n  throw new Error(\"Generated query may only use a SET VARIABLE preamble before SELECT\");\n}\n\nconst allowedColumns = new Set();\nfor (const item of metadata) {\n  if (!item || item.SubjectAreaName !== \"Workforce Management - Worker Assignment Event Real Time\") {\n    continue;\n  }\n\n  const tableName = item.TableName;\n  const columnName = item.ColumnName;\n  if (typeof tableName !== \"string\" || typeof columnName !== \"string\") {\n    continue;\n  }\n\n  allowedColumns.add(`\"${item.SubjectAreaName}\".\"${tableName}\".\"${columnName}\"`);\n\n  const slashTableName = tableName.includes(\"/\") ? tableName.split(\"/\").pop() : null;\n  if (slashTableName) {\n    allowedColumns.add(`\"${item.SubjectAreaName}\".\"${slashTableName}\".\"${columnName}\"`);\n  }\n}\n\nconst columnPattern = /\"Workforce Management - Worker Assignment Event Real Time\"\\.\"([^\"]+)\"\\.\"([^\"]+)\"/g;\nlet columnMatch;\nwhile ((columnMatch = columnPattern.exec(normalizedSql)) !== null) {\n  const fullyQualifiedColumn = `${subjectArea}.\"${columnMatch[1]}\".\"${columnMatch[2]}\"`;\n  if (!allowedColumns.has(fullyQualifiedColumn)) {\n    throw new Error(`Generated query references a column not present in metadata: ${fullyQualifiedColumn}`);\n  }\n}\n\nconst functionPattern = /\\b([A-Z_][A-Z0-9_]*)\\s*\\(/g;\nconst allowedFunctions = new Set([\n  \"CAST\",\n  \"CURRENT_DATE\",\n  \"DESCRIPTOR_IDOF\",\n  \"FILTER\",\n  \"IFNULL\",\n  \"LEFT\",\n  \"LOWER\",\n  \"MAX\",\n  \"MIN\",\n  \"RIGHT\",\n  \"SUBSTRING\",\n  \"TIMESTAMPADD\",\n  \"TIMESTAMPDIFF\",\n  \"UPPER\"\n]);\nconst disallowedFunctionNames = new Set([\n  \"EVALUATE\",\n  \"EVALUATE_AGGR\",\n  \"EVALUATE_ANALYTIC\",\n  \"EXTRACTXML\",\n  \"XMLAGG\",\n  \"XMLELEMENT\"\n]);\nlet functionMatch;\nwhile ((functionMatch = functionPattern.exec(upperSql)) !== null) {\n  const functionName = functionMatch[1];\n  if (disallowedFunctionNames.has(functionName)) {\n    throw new Error(`Generated query uses a blocked function: ${functionName}`);\n  }\n\n  if (!allowedFunctions.has(functionName) && !/^[A-Z]+COUNT$/.test(functionName) && !/^[A-Z]+SUM$/.test(functionName) && !/^[A-Z]+AVG$/.test(functionName)) {\n    throw new Error(`Generated query uses an unapproved function: ${functionName}`);\n  }\n}\n\nconst trustedPayload = {\n  sqlQuery: sqlQuery,\n  executionOptions: trustedExecutionOptions,\n  sessionId: $context.$nodes.LOGON.$output.token,\n  outputFormat: \"CollectionDataFormat\"\n};\n\nreturn JSON.stringify(trustedPayload);"
