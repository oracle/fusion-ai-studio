          "inputs": [
            {
              "id": "1775549290642",
              "name": "groupbyguidelines",
              "scope": "JOB",
              "type": "string",
              "value": "{\n  \"definition\": \"The Group By function is used in data analysis and databases to organize rows into groups based on the values of specified columns. This allows you to perform calculations such as sum, count, or average on each group separately.\",\n  \"purpose\": \"To summarize and analyze data by categorizing it based on one or more fields.\",\n  \"example\": {\n    \"table\": \"sales\",\n    \"columns\": [\"region\", \"amount\"],\n    \"query\": \"SELECT region, SUM(amount) AS total_sales FROM sales GROUP BY region;\",\n    \"description\": \"This query groups sales records by region and calculates the total sales (sum of amount) for each region.\",\n    \"sample_data\": [\n      { \"region\": \"North\", \"amount\": 100 },\n      { \"region\": \"South\", \"amount\": 150 },\n      { \"region\": \"North\", \"amount\": 200 }\n    ],\n    \"result\": [\n      { \"region\": \"North\", \"total_sales\": 300 },\n      { \"region\": \"South\", \"total_sales\": 150 }\n    ]\n  },\n  \"having\": {\n    \"definition\": \"The HAVING clause is used with GROUP BY to filter groups based on the results of aggregate functions (such as SUM, COUNT, AVG). It acts like a WHERE clause, but for groups instead of individual rows.\",\n    \"example_query\": \"SELECT region, SUM(amount) AS total_sales FROM sales GROUP BY region HAVING SUM(amount) > 200;\",\n    \"description\": \"This query groups sales records by region, calculates total sales for each, and then only shows regions where the total sales exceed 200.\",\n    \"result\": [\n      { \"region\": \"North\", \"total_sales\": 300 }\n    ]\n  }\n}"
            },
            {
              "id": "1775549266607",
              "name": "descriptoridofguidelines",
              "scope": "JOB",
              "type": "string",
              "value": "{\n  \"function\": \"DESCRIPTOR_IDOF\",\n  \"context\": \"Oracle Analytics Logical SQL\",\n  \"description\": \"Used for 'Double Column' data elements, allowing dashboards and prompts to display user-friendly text (descriptor) while filtering or querying on the internal numeric/code ID. This ensures     efficient query performance and supports localization for multilingual data. \n\"columns_using_descriptor_idof\": Use DESCRIPTOR_IDOF where ever the isDouble attribute for that column is set to true.\",\n  \"how_it_works\": {\n    \"double_columns\": \"A data element defined with both a descriptor (display text) and an ID (code).\",\n    \"filtering\": \"When filtering on a Double Column, DESCRIPTOR_IDOF() extracts the efficient code (ID) so the database uses code-based filters (e.g., WHERE ID=101) instead of text-based filters (e.g., WHERE Country='USA').\",\n    \"performance\": \"Improves query performance as filtering is done on indexed codes at the database layer, limiting large data transfers and performing early filtering.\",\n    \"localization\": \"Enables multilingual reporting by joining codes to language-specific descriptions using LOOKUP functions, as IDs remain constant across all languages.\"\n  },\n  \"purpose\": [\n    \"Link a display value (e.g., 'USA') to its underlying code (e.g., '101').\",\n    \"Display localized, user-friendly labels in dashboards without sacrificing backend query efficiency.\",\n    \"Support flexible filtering and reporting across multiple languages.\"\n  ]\n  \"example_sql\": \"-- Shows the product name (descriptor) but filters on Product ID (code): 'SELECT \\\"Product Name\\\", DESCRIPTOR_IDOF(\\\"Product Name\\\")\\nFROM \\\"Sales Data\\\"\\nWHERE DESCRIPTOR_IDOF(\\\"Product Name\\\") = 123; ' ---> In this case the column is invoked twice, one with just the name and the other with  DESCRIPTOR_IDOF(). \"\n}"
            },
            {
              "id": "1775549220762",
              "name": "payloadguidelines",
              "scope": "JOB",
              "type": "string",
              "value": "Escape all \" as \\\"\nReplace \\n with spaces.\nLimit to the first 500 user-returnable rows where appropriate.\nReturn the following JSON, inserting the completed logical SQL as {sqlQueryFromReport} and the session token as {sessionId}:\n```json\n{\"sqlQuery\":\"{sqlQueryFromReport}\",\"outputFormat\":\"CollectionDataFormat\",\"executionOptions\":{\"async\":\"false\",\"maxRowsPerPage\":\"25\",\"refresh\":\"true\",\"presentationInfo\":\"true\",\"type\":\"\"},\"sessionId\":\"{sessionId}\"}\n```\n\n- Escape all `\"` → `\\\"`\n- Replace `\\n` with spaces\nfor the query"
            },
            {
              "id": "1775549199324",
              "name": "generalguidelines",
              "scope": "JOB",
              "type": "array",
              "value": "[\n  {\n    \"guideline\": \"Use Unambiguous, Canonical Columns Where Duplicates Exist\",\n    \"Steps to be followed\": \"If multiple fields represent the same concept (e.g. multiple name-related columns), always opt for the most generic, clearly labeled, or explicitly described column.\"\n  },\n  {\n    \"guideline\": \"Choose 'Employee Display Name' for Worker Reference, if the prompt needs Employee name to be displayed\",\n    \"Steps to be followed\": \"Do NOT use 'First Name', 'Last Name', 'Known As', 'Name', or 'Person_Surname' as a proxy for an employee’s name. Always use 'Employee Display Name' from the Worker table when a display or full name is requested, unless a specific aspect (e.g. just 'First Name') is explicitly required. Use 'Employee Display Name' from 'Worker' table, when ever user addressed the question with respect to person name. This is important as using other column names will break the flow or lead to empty results.\"\n  },\n{\n\"guideline\": \"Choose 'Manager Display Name' for Manager Reference, if the prompt needs Manager name to be displayed or to be used in a where condition\"\n\"Steps to be followed\": \"Use 'Manager Display Name' from 'Manager' Table, when ever user addressed the question with respect to manager name or to get details of people reporting to a person. This is important as using other column names will break the flow or lead to empty results.\"\n}\n  {\n    \"guideline\": \"Use Codes for Reporting and Filtering, Descriptions for Display\",\n    \"Steps to be followed\": \"Where both code and description columns exist (e.g. 'Assignment Category Code' and 'Assignment Category'): Use the 'Code' column for joins, filtering, or system processing. Use the description column for presenting readable output to users.\"\n  },\n  {\n    \"guideline\": \"For Personal Details, prefer columns starting with 'Employee' or 'Personal' \",\n    \"Steps to be followed\": \"For phones, or emails, use 'Primary Phones Number' and 'Employee Email Address' columns respectively unless another specific type is requested. For employee identifiers, use 'Person Number' or 'Person ID' for unique references. For address of the employee, use 'Employee Mailing Address Line X', where X can be 1,2,3,4. NOTE: The 2nd line of the address alone has the name as 'Employee Mailing  Address Line2'. \"\n  },\n{\n\"guideline\": \"Salary Values\",\n\"Steps to be followed\": \"For salary, use 'Annualized Salary'. For comparisons, use 'Previous Salary', 'Salary Range High/Low/Midpoint'.\"\n},\n{\n\"guideline\":\"Department Details\",\n\"Steps to be followed\": \"Retrieve department details exclusively from the 'Department' table. Use only the columns that belong to this table. NOT ANY OTHER TABLE.\"\n}\n]"
            },
            {
              "id": "1775549159423",
              "name": "aggregationguidelines",
              "scope": "JOB",
              "type": "array",
              "value": "[\n  {\n    \"function_name\": \"SUM\",\n    \"query_syntax\": \"SUM(\\\"<Subject_Area>\\\".\\\"<TableName>\\\".\\\"<ColumnName>\\\") alias\",\n    \"description\": \"Calculates the total sum of values in the specified column.\"\n  },\n  {\n    \"function_name\": \"MAX\",\n    \"query_syntax\": \"MAX(\\\"<Subject_Area>\\\".\\\"<TableName>\\\".\\\"<ColumnName>\\\") alias\",\n    \"description\": \"Returns the maximum value in the specified column.\"\n  },\n  {\n    \"function_name\": \"MIN\",\n    \"query_syntax\": \"MIN(\\\"<Subject_Area>\\\".\\\"<TableName>\\\".\\\"<ColumnName>\\\") alias\",\n    \"description\": \"Returns the minimum value in the specified column.\"\n  },\n  {\n    \"function_name\": \"AVG\",\n    \"query_syntax\": \"AVG(\\\"<Subject_Area>\\\".\\\"<TableName>\\\".\\\"<ColumnName>\\\") alias\",\n    \"description\": \"Calculates the average value of the specified column.\"\n  },\n  {\n    \"function_name\": \"COUNT\",\n    \"query_syntax\": \"COUNT(\\\"<Subject_Area>\\\".\\\"<TableName>\\\".\\\"<ColumnName>\\\") alias\",\n    \"description\": \"Counts the number of rows with non-null values in the specified column.\"\n  },\n  {\n    \"function_name\": \"TOPN\",\n    \"query_syntax\": \"TOPN(\\\"<Subject_Area>\\\".\\\"<TableName>\\\".\\\"<ColumnName>\\\",N) alias\",\n    \"description\": \"Use this topN function if user wants top N  and used it while defining the columns with alias only. Returns the top N records based on the specified expression, such as the highest salaries. Don't use fetch first or fetch last functions when user input contains Top N. eg: Give me the department name of top 5 highest salaried employee names.\"\n  },\n  {\n    \"function_name\": \"BOTTOMN\",\n    \"query_syntax\": \"BOTTOMN(\\\"<Subject_Area>\\\".\\\"<TableName>\\\".\\\"<ColumnName>\\\",N) alias\",\n    \"description\": \"Use this bottomN function if user wants bottom N and used it while defining the columns with alias only. Returns the bottom N records based on the specified expression, such as the lowest salaries. Don't use fetch first or fetch last functions when user input contains Bottom N. eg: Give me the department name of top 5 lowest salaried employee names.\"\n  },\n  {\n    \"function_name\": \"TOPN_FILTER\",\n    \"query_syntax\": \"TOPN(\\\"<TableName>\\\".\\\"<ColumnName>\\\",N) <= N\",\n    \"description\": \"It should be always used after WHERE clause and if only user asks to find top N and not with joins then use this. Returns the top N records based on the specified expression, such as the highest salaries. Don't use fetch first or fetch last functions when user input contains Top N. eg: Give me the top 5 highest salaried employee names.\"\n  },\n  {\n    \"function_name\": \"BOTTOMN_FILTER\",\n    \"query_syntax\": \"BOTTOMN(\\\"<TableName>\\\".\\\"<ColumnName>\\\",N) <= N\",\n    \"description\": \"It should be always used after WHERE clause and if only user asks to find bottom N and not with joins then use this. Returns the bottom N records based on the specified expression, such as the lowest salaries. Don't use fetch first or fetch last functions when user input contains Bottom N. eg: Give me the top 5 lowest salaried employee names.\"\n  }\n]"
            },
            {
              "id": "1775549132086",
              "name": "filterguidelines",
              "scope": "JOB",
              "type": "array",
              "value": "[\n  {\n    \"filter\": \"is equal to / is in\",\n    \"syntax\": \"= or IN\"\n  },\n  {\n    \"filter\": \"is not equal to / is not in\",\n    \"syntax\": \"<> or NOT IN\"\n  },\n  {\n    \"filter\": \"is less than\",\n    \"syntax\": \"<\"\n  },\n  {\n    \"filter\": \"is greater than\",\n    \"syntax\": \">\"\n  },\n  {\n    \"filter\": \"is less than or equal to\",\n    \"syntax\": \"<=\"\n  },\n  {\n    \"filter\": \"is greater than or equal to\",\n    \"syntax\": \">=\"\n  },\n  {\n    \"filter\": \"is between\",\n    \"syntax\": \"BETWEEN\"\n  },\n  {\n    \"filter\": \"is null\",\n    \"syntax\": \"IS NULL\"\n  },\n  {\n    \"filter\": \"is not null\",\n    \"syntax\": \"IS NOT NULL\"\n  },\n  {\n    \"filter\": \"is ranked last\",\n    \"syntax\": \"(Usage depends on context, typically analytic functions)\"\n  },\n  {\n    \"filter\": \"is ranked first\",\n    \"syntax\": \"(Usage depends on context, typically analytic functions)\"\n  },\n  {\n    \"filter\": \"contains all\",\n    \"syntax\": \"LIKE '%Add%' AND LIKE '%sub%'\"\n  },\n  {\n    \"filter\": \"contains any\",\n    \"syntax\": \"LIKE '%Add%' OR LIKE '%sub%'\"\n  },\n  {\n    \"filter\": \"does not contain\",\n    \"syntax\": \"NOT LIKE '%Add%' AND NOT LIKE '%sub%'\"\n  },\n  {\n    \"filter\": \"begins with\",\n    \"syntax\": \"LIKE 'xyz%'\"\n  },\n  {\n    \"filter\": \"ends with\",\n    \"syntax\": \"LIKE '%xyz'\"\n  },\n  {\n    \"filter\": \"is LIKE (pattern match)\",\n    \"syntax\": \"LIKE 'xyz'\"\n  },\n  {\n    \"filter\": \"is not LIKE (pattern match)\",\n    \"syntax\": \"NOT LIKE 'xyz'\"\n  },\n  {\n    \"filter\": \"is prompted\",\n    \"syntax\": \"(Prompted in UI, value supplied at runtime)\"\n  },\n  {\n    \"filter\": \"is based on results of another analysis\",\n    \"syntax\": \"(Dependent on output from another analysis/query)\"\n  }\n]"
