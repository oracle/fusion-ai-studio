          "code": "FETCH_MISSING_PERSON_TIME_CARD_AGGREGATIONS",
          "type": "BO_FUNCTION",
          "metadata": {
            "name": "Fetch Missing Person Time Card Aggregations",
            "businessObjectCode": "ORA_HCM_TIMEANDLAB_XX_MISSINGPERSONTIMECARDAGGREGATIONSLOOKUP",
            "functionName": "getMissingPersonTimeCardAggregations",
            "processJson": true
          },
          "outcomes": {
            "success": "1782400000004"
          },
          "inputs": [
            {
              "id": "1782400000003_pDateBefore30Days",
