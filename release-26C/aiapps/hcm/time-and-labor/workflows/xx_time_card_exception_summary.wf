          }
        },
        {
          "id": "1783065100006",
          "code": "GENERATE_EXCEPTION_SEARCH_VALIDATION_ERROR_MESSAGE",
          "type": "LLM",
          "metadata": {
            "name": "Generate Exception Search Validation Error Message"
          },
          "outcomes": {
            "success": "end"
          },
          "inputs": [
            {
              "id": "1783065100006_prompt",
              "name": "prompt",
              "type": "string",
