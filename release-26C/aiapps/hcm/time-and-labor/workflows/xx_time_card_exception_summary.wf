        {
          "id": "1782500000010",
          "code": "DETERMINE_TIME_CARD_EXCEPTION_BRANCH",
          "type": "CODE",
          "metadata": {
            "name": "Determine Time Card Exception Branch",
            "description": "Returns initDisplay for normal load or viewExceptionTimeCards for clicked exception actions.",
            "returnType": "object",
            "sourceCode": "const hint = String(\n  $context.$app.$OraMessageHint ||\n  $context.$app.OraMessageHint ||\n  $context.$variables.OraMessageHint ||\n  \"\"\n);\n\nif (hint === \"InvokeAction\") \nreturn \"viewExceptionTimeCards\";\nelse if (hint === \"InitActions\")\nreturn \"initActions\";\nreturn \"initDisplay\";"
          },
          "outcomes": {
            "success": "1782500000007"
          },
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "diagram": {
            "x": 6081.5,
            "y": 5206
          }
        },
        {
          "id": "1782500000007",
          "code": "ROUTE_TIME_CARD_EXCEPTION_BRANCH",
          "type": "SWITCH",
          "convergenceTargetId": "end",
          "metadata": {
            "name": "Route Time Card Exception Branch",
            "description": "Routes initial display and invoked exception detail actions."
          },
          "outcomes": {
            "initDisplay": "1782500000001",
            "viewExceptionTimeCards": "1782500000008",
            "initActions": "1782392649092"
          },
          "inputs": [
            {
              "id": "1782500000007_caseExpression",
              "name": "caseExpression",
              "type": "string",
              "value": "{{$context.$nodes.DETERMINE_TIME_CARD_EXCEPTION_BRANCH.$output.result}}"
            }
          ],
          "diagram": {
            "x": 6099.5,
            "y": 5428
          }
        },
        {
          "id": "1782500000001",
          "code": "CALCULATE_TIME_CARD_DATE_RANGE",
          "type": "CODE",
          "metadata": {
            "name": "Calculate Time Card Date Range",
            "description": "Calculates current date and date before 30 days in YYYY-MM-DD format.",
            "returnType": "object",
            "sourceCode": "function pad(value) {\n  return String(value).padStart(2, \"0\");\n}\n\nfunction formatLocalDate(date) {\n  return date.getFullYear() + \"-\" + pad(date.getMonth() + 1) + \"-\" + pad(date.getDate());\n}\n\nconst today = new Date();\nconst dateBefore30Days = new Date(today.getTime());\ndateBefore30Days.setDate(dateBefore30Days.getDate() - 30);\n\nreturn {\n  currentDate: formatLocalDate(today),\n  dateBefore30Days: formatLocalDate(dateBefore30Days)\n};"
          },
          "outcomes": {
            "success": "1783065100001"
          },
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": { \"type\": \"object\" },\n    \"timeout\": { \"type\": \"boolean\" },\n    \"error\": { \"type\": \"string\" }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\"result\", \"timeout\", \"error\"]\n}",
          "diagram": {
            "x": 5606,
            "y": 5650
          }
        },
        {
          "id": "1783065100001",
          "code": "VALIDATE_TIME_CARD_EXCEPTION_DATE_RANGE",
          "type": "CODE",
          "metadata": {
            "name": "Validate Time Card Exception Date Range",
            "description": "Validates calculated date inputs before passing them to time card exception business objects.",
            "returnType": "boolean",
            "sourceCode": "function parseDateOnly(value) {\n  if (value === undefined || value === null) return null;\n  const text = String(value).trim();\n  const match = text.match(/^(\\d{4})-(\\d{2})-(\\d{2})$/);\n  if (!match) return null;\n\n  const year = Number(match[1]);\n  const month = Number(match[2]);\n  const day = Number(match[3]);\n  const date = new Date(year, month - 1, day);\n\n  if (date.getFullYear() !== year || date.getMonth() !== month - 1 || date.getDate() !== day) {\n    return null;\n  }\n\n  return date;\n}\n\nconst dateRange = ($context.$nodes.CALCULATE_TIME_CARD_DATE_RANGE.$output || {}).result || {};\nconst dateBefore30Days = parseDateOnly(dateRange.dateBefore30Days);\nconst currentDate = parseDateOnly(dateRange.currentDate);\n\nif (!dateBefore30Days || !currentDate) {\n  return false;\n}\n\nreturn dateBefore30Days.getTime() <= currentDate.getTime();"
          },
          "outcomes": {
            "success": "1783065100002"
          },
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "diagram": {
            "x": 5565.5,
            "y": 5872
          }
        },
