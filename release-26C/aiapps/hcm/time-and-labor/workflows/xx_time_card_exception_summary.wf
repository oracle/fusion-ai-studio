        {
          "id": "1782500000002",
          "code": "FETCH_TIME_CARD_EXCEPTION_AGGREGATIONS",
          "type": "BO_FUNCTION",
          "metadata": {
            "name": "Fetch Time Card Exception Aggregations",
            "businessObjectCode": "ORA_HCM_TIMEANDLAB_TIMECARDEXCEPTIONAGGREGATIONSLOOKUP",
            "functionName": "getTimeCardAggregationsByException",
            "processJson": true
          },
          "outcomes": {
            "success": "1782500000003"
          },
          "inputs": [
            {
              "id": "1782500000002_pDateBefore30Days",
              "name": "pDateBefore30Days",
              "value": "{{$context.$nodes.CALCULATE_TIME_CARD_DATE_RANGE.$output.result.dateBefore30Days}}",
              "required": false,
              "type": "string"
            },
            {
              "id": "1782500000002_pCurrentDate",
              "name": "pCurrentDate",
              "value": "{{$context.$nodes.CALCULATE_TIME_CARD_DATE_RANGE.$output.result.currentDate}}",
              "required": false,
              "type": "string"
            }
          ],
          "outputSpecification": "{}",
          "diagram": {
            "x": 5294,
            "y": 6316
          }
        },
        {
          "id": "1782500000003",
          "code": "PREPARE_EXCEPTION_CODE_TERMS",
          "type": "CODE",
          "metadata": {
            "name": "Prepare Exception Code Terms",
            "description": "Extracts exception codes from the aggregation response and returns a JSON array string for the time card search BO.",
            "returnType": "object",
            "sourceCode": "function findFacet(output, facetName) {\n  const root = output && output.result && output.result.facets ? output.result : output;\n  const nestedRoot = root && root.result && root.result.facets ? root.result : root;\n  const facets = nestedRoot && Array.isArray(nestedRoot.facets) ? nestedRoot.facets : [];\n  for (let i = 0; i < facets.length; i++) {\n    if (facets[i] && facets[i].name === facetName) {\n      return facets[i];\n    }\n  }\n  return { values: [] };\n}\n\nconst aggregationOutput = $context.$nodes.FETCH_TIME_CARD_EXCEPTION_AGGREGATIONS.$output || {};\nconst exceptionFacet = findFacet(aggregationOutput, \"Exception\");\nconst values = Array.isArray(exceptionFacet.values) ? exceptionFacet.values : [];\nconst codes = [];\n\nvalues.forEach(function(item) {\n  if (item && item.value !== undefined && item.value !== null && item.value !== \"\") {\n    const code = String(item.value).trim();\n    if (code && codes.indexOf(code) === -1) {\n      codes.push(code);\n    }\n  }\n});\n\nreturn {\n  exceptionCodes: codes,\n  exceptionCodeTerms: JSON.stringify(codes)\n};"
          },
          "outcomes": {
            "success": "1783065100004"
          },
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "diagram": {
            "x": 5339,
            "y": 6538
          }
        },
        {
          "id": "1783065100004",
          "code": "VALIDATE_EXCEPTION_TIME_CARD_SEARCH_INPUTS",
          "type": "CODE",
          "metadata": {
            "name": "Validate Exception Time Card Search Inputs",
            "description": "Validates date and exception code inputs before searching exception time cards.",
            "returnType": "boolean",
            "sourceCode": "function parseDateOnly(value) {\n  if (value === undefined || value === null) return null;\n  const text = String(value).trim();\n  const match = text.match(/^(\\d{4})-(\\d{2})-(\\d{2})$/);\n  if (!match) return null;\n\n  const year = Number(match[1]);\n  const month = Number(match[2]);\n  const day = Number(match[3]);\n  const date = new Date(year, month - 1, day);\n\n  if (date.getFullYear() !== year || date.getMonth() !== month - 1 || date.getDate() !== day) {\n    return null;\n  }\n\n  return date;\n}\n\nfunction validExceptionCode(value) {\n  const text = String(value || \"\").trim();\n  return text.length > 0 && text.length <= 100 && /^[A-Za-z0-9_ .:-]+$/.test(text);\n}\n\nconst dateRange = ($context.$nodes.CALCULATE_TIME_CARD_DATE_RANGE.$output || {}).result || {};\nconst dateBefore30Days = parseDateOnly(dateRange.dateBefore30Days);\nconst currentDate = parseDateOnly(dateRange.currentDate);\nif (!dateBefore30Days || !currentDate || dateBefore30Days.getTime() > currentDate.getTime()) {\n  return false;\n}\n\nconst prepared = ($context.$nodes.PREPARE_EXCEPTION_CODE_TERMS.$output || {}).result || {};\nconst terms = prepared.exceptionCodeTerms;\nlet codes;\ntry {\n  codes = JSON.parse(String(terms || \"[]\"));\n} catch (error) {\n  return false;\n}\n\nif (!Array.isArray(codes)) {\n  return false;\n}\n\nreturn codes.every(validExceptionCode);"
          },
          "outcomes": {
            "success": "1783065100005"
          },
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "diagram": {
            "x": 5276,
            "y": 6760
          }
        },
        {
          "id": "1783065100005",
          "code": "CHECK_VALID_EXCEPTION_TIME_CARD_SEARCH_INPUTS",
