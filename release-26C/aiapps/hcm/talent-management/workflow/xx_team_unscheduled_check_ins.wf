        {
          "id": "1782731419248",
          "code": "FETCH_TEAM_CHECK_IN_DATA",
          "type": "BO_FUNCTION",
          "metadata": {
            "name": "Fetch Team Check-In Data",
            "description": "Fetches check-in details for employees under the logged-in user, including last check-in date, performance, potential, and assignment name.",
            "businessObjectCode": "ORA_HCM_TALENT_XX_TEAMUNSCHEDULEDCHECKIN",
            "functionName": "getCheckIns",
            "errorNodeId": "1782737266634"
