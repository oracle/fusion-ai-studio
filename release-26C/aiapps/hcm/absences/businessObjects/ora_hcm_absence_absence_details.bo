    "tools": [
      {
        "name": "get_existing_absences",
        "description": "This business object function fetches the existing balances of a person",
        "operationType": "POST",
        "resourcePath": "/hcmRestApi/resources/11.13.18.05/absences/action/findByAdvancedSearchQuery",
        "resourceType": "ADF_BC_FIXED_QUERY",
        "bodyTemplate": "{\n    \"limit\": 25,\n    \"offset\": 0,\n    \"query\": \"\",\n    \"userContext\": \"{userContext}\",\n    \"searchFields\": [\n        \"absenceType\"\n    ],\n    \"displayFields\": [\n        \"absenceType\",\n        \"startDate\",\n        \"endDate\",\n        \"absenceDispStatusMeaning\",\n        \"assignmentName\",\n        \"formattedDuration\",\n        \"absenceDispStatus\",\n        \"bidId\",\n        \"bidFlag\",\n        \"employer\",\n        \"bidPreference\",\n        \"absenceUpdatableFlag\",\n        \"personAbsenceEntryId\"\n    ],\n    \"sort\": [\n        {\n            \"name\": \"startDate\",\n            \"direction\": \"desc\"\n        }\n    ],\n    \"filters\": [\n        {\n            \"name\": [\n                \"Date\"\n            ],\n            \"values\": [\n                \"{startDate}\"\n            ]\n        },\n        {\n            \"name\": [\n                \"PersonId\"\n            ],\n            \"value\": [\n                \"{personId}\"\n            ]\n        }\n    ]\n}",
        "useNativeAuthentication": true,
        "type": "BUS_OBJECT",
        "parameterDefinitions": [
          {
            "name": "userContext",
            "dataType": "string",
            "description": "Indicated weather the user is viewing the data as an employee or manager",
            "id": 2,
            "isToken": true,
            "location": "body",
            "source": "placeholder",
            "defaultValue": "EMP"
          },
          {
            "name": "startDate",
            "dataType": "string",
            "description": "Start date filter fo the absence",
            "id": 3,
            "isToken": true,
            "location": "body",
            "source": "placeholder",
            "defaultValue": ""
          },
          {
            "name": "personId",
            "dataType": "string",
            "description": "Person id filter for the absence",
            "id": 4,
            "isToken": true,
            "location": "body",
            "source": "placeholder",
            "defaultValue": ""
          }
        ],
        "headers": {
          "Content-Type": "application/vnd.oracle.action+json"
        },
