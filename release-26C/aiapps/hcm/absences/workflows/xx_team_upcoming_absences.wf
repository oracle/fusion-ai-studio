        {
          "id": "1785000002700",
          "code": "EXTRACT_SELECTED_EMPLOYEE_ACTION",
          "type": "CODE",
          "metadata": {
            "name": "Extract Selected Employee Action",
            "description": "Parses the row drilldown action payload for the selected employee.",
            "returnType": "object",
            "sourceCode": "function parseJson(value) {\n  if (typeof value !== \"string\") return value;\n  const text = value.trim();\n  if (text === \"\") return value;\n  try {\n    return JSON.parse(text);\n  } catch (e) {\n    return value;\n  }\n}\n\nfunction sanitizeDisplayText(value) {\n  return String(value || \"\")\n    .replace(/[\\u0000-\\u001F\\u007F]/g, \"\")\n    .replace(/[\\u202A-\\u202E\\u2066-\\u2069]/g, \"\")\n    .replace(/\\s+/g, \" \")\n    .trim();\n}\n\nfunction extractPayload(actionText) {\n  const text = String(actionText || \"\").trim();\n  if (!text) return {};\n  const firstBrace = text.indexOf(\"{\");\n  const lastBrace = text.lastIndexOf(\"}\");\n  if (firstBrace >= 0 && lastBrace > firstBrace) {\n    const parsed = parseJson(text.substring(firstBrace, lastBrace + 1));\n    if (parsed && typeof parsed === \"object\") return parsed;\n  }\n  const parsedWhole = parseJson(text);\n  return parsedWhole && typeof parsedWhole === \"object\" ? parsedWhole : {};\n}\n\nconst app = $context.$app || {};\nconst payload = extractPayload(app.$OraAction);\n\nreturn {\n  personId: sanitizeDisplayText(payload.personId),\n  employeeName: sanitizeDisplayText(payload.employeeName) || \"Employee\",\n  businessTitle: sanitizeDisplayText(payload.businessTitle),\n  absenceCount: Number(payload.absenceCount || 0),\n  totalAbsenceHours: Number(payload.totalAbsenceHours || 0),\n  absences: Array.isArray(payload.absences) ? payload.absences : []\n};"
          },
          "outcomes": {
            "success": "1785000002800"
          },
          "inputs": [],
          "diagram": {
            "x": 6275,
            "y": 5428
          },
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
        {
          "id": "1785000002800",
          "code": "PREPARE_SELECTED_EMPLOYEE_ABSENCES",
          "type": "CODE",
          "metadata": {
            "name": "Prepare Selected Employee Absences",
            "description": "Maps the selected employee action payload to a drilldown multiRecordWidget data payload.",
            "returnType": "object",
            "sourceCode": "function sanitizeDisplayText(value) {\n  return String(value || \"\")\n    .replace(/[\\u0000-\\u001F\\u007F]/g, \"\")\n    .replace(/[\\u202A-\\u202E\\u2066-\\u2069]/g, \"\")\n    .replace(/\\s+/g, \" \")\n    .trim();\n}\n\nfunction displayText(value) {\n  if (value === 0) return \"0\";\n  return sanitizeDisplayText(value);\n}\n\nfunction badgeColorForStatus(value) {\n  const key = displayText(value).toLowerCase();\n  const colorByStatus = {\n    \"awaiting approval\": \"Blue\",\n    \"awaiting withdrawal approval\": \"Blue\",\n    \"bid error\": \"Red\",\n    \"bid rejected\": \"Red\",\n    \"bid saved\": \"Blue\",\n    \"bid submitted\": \"Blue\",\n    \"bid withdrawn\": \"Gray\",\n    \"completed\": \"Green\",\n    \"denied\": \"Red\",\n    \"in progress\": \"Orange\",\n    \"pending reevaluation\": \"Orange\",\n    \"saved\": \"Gray\",\n    \"scheduled\": \"Green\",\n    \"withdrawn\": \"Gray\",\n    \"approval in-progress\": \"Orange\"\n  };\n  return colorByStatus[key] || \"Gray\";\n}\n\nfunction priorityForColor(color) {\n  if (color === \"Red\") return \"alert\";\n  if (color === \"Orange\") return \"warning\";\n  if (color === \"Green\") return \"success\";\n  if (color === \"Gray\") return \"neutral\";\n  return \"medium\";\n}\n\nconst selected = (($context.$nodes.EXTRACT_SELECTED_EMPLOYEE_ACTION || {}).$output || {}).result || {};\nconst absences = Array.isArray(selected.absences) ? selected.absences : [];\nconst rows = [];\n\nfor (let i = 0; i < absences.length; i++) {\n  const absence = absences[i] || {};\n  const statusText = displayText(absence.absenceDispStatusMeaning);\n  const statusBadge = {\n    type: \"badge\",\n    text: statusText,\n    priority: priorityForColor(badgeColorForStatus(statusText))\n  };\n\n  rows.push({\n    cells: [\n      displayText(absence.absenceType),\n      displayText(absence.dateRange),\n      displayText(absence.formattedDuration),\n      statusBadge\n    ]\n  });\n}\n\nreturn {\n  employeeName: displayText(selected.employeeName) || \"Employee\",\n  businessTitle: displayText(selected.businessTitle),\n  absenceCount: rows.length,\n  totalAbsenceHours: Number(selected.totalAbsenceHours || 0),\n  cols: [\n    \"Absence Type\",\n    \"Period\",\n    \"Duration\",\n    \"Status\"\n  ],\n  rows: rows\n};"
          },
          "outcomes": {
            "success": "1785000002900"
          },
          "inputs": [],
          "diagram": {
            "x": 6275,
            "y": 5650
          },
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
        {
          "id": "1785000002900",
          "code": "DISPLAY_SELECTED_EMPLOYEE_ABSENCES",
          "type": "LLM",
          "metadata": {
            "name": "Display Selected Employee Absences"
