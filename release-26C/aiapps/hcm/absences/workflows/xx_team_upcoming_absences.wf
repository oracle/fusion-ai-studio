            "y": 5872
          }
        },
        {
          "id": "1785000002000",
          "code": "PREPARE_DIRECT_REPORTS",
          "type": "CODE",
          "metadata": {
            "name": "Prepare Direct Reports",
            "description": "Filters valid direct-report person ids and keeps only fields needed by the absence fetch and display widgets.",
            "returnType": "object",
            "sourceCode": "function parseJson(value) {\n  if (typeof value !== \"string\") return value;\n  const text = value.trim();\n  if (text === \"\") return value;\n  if (text.charAt(0) !== \"{\" && text.charAt(0) !== \"[\") return value;\n  try {\n    return JSON.parse(text);\n  } catch (e) {\n    return value;\n  }\n}\n\nfunction toRecordList(value) {\n  const current = parseJson(value);\n  if (Array.isArray(current)) return current;\n  if (!current || typeof current !== \"object\") return [];\n  if (Array.isArray(current.items)) return current.items;\n  let nested = toRecordList(current.result);\n  if (nested.length > 0) return nested;\n  nested = toRecordList(current.query);\n  if (nested.length > 0) return nested;\n  nested = toRecordList(current.response);\n  if (nested.length > 0) return nested;\n  return [];\n}\n\nfunction sanitizeDisplayText(value) {\n  return String(value || \"\")\n    .replace(/[\\u0000-\\u001F\\u007F]/g, \"\")\n    .replace(/[\\u202A-\\u202E\\u2066-\\u2069]/g, \"\")\n    .replace(/\\s+/g, \" \")\n    .trim();\n}\n\nfunction displayText(value) {\n  if (value === 0) return \"0\";\n  return sanitizeDisplayText(value);\n}\n\nfunction firstPresent(record, keys) {\n  for (let i = 0; i < keys.length; i++) {\n    const value = record[keys[i]];\n    if (value !== undefined && value !== null && String(value).trim() !== \"\") {\n      return value;\n    }\n  }\n  return \"\";\n}\n\nconst rawOutput = $context.$nodes.FETCH_DIRECT_REPORTS.$output || {};\nconst records = toRecordList(rawOutput);\nconst directReports = [];\nconst seenPersonIds = {};\n\nfor (let i = 0; i < records.length; i++) {\n  const record = records[i] || {};\n  const personId = displayText(firstPresent(record, [\"PersonId\", \"personId\", \"PERSON_ID\"]));\n\n  if (!/^\\d+$/.test(personId) || seenPersonIds[personId]) {\n    continue;\n  }\n\n  seenPersonIds[personId] = true;\n  directReports.push({\n    personId: personId,\n    employeeName: displayText(firstPresent(record, [\"DisplayName\", \"displayName\", \"PersonName\", \"personName\", \"FullName\", \"fullName\"])) || \"Employee\",\n    businessTitle: displayText(firstPresent(record, [\"BusinessTitle\", \"businessTitle\", \"JobName\", \"jobName\", \"PositionName\", \"positionName\", \"AssignmentName\", \"assignmentName\"])),\n    personNumber: displayText(firstPresent(record, [\"PersonNumber\", \"personNumber\"])),\n    assignmentId: displayText(firstPresent(record, [\"AssignmentId\", \"assignmentId\"]))\n  });\n}\n\nreturn {\n  directReports: directReports,\n  count: directReports.length\n};"
          },
          "outcomes": {
            "success": "1785000002100"
          },
          "inputs": [],
          "diagram": {
            "x": 5225,
            "y": 6094
          },
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
