        {
          "id": "1785000001900",
          "code": "FETCH_DIRECT_REPORTS",
          "type": "BO_FUNCTION",
          "metadata": {
            "name": "Fetch Direct Reports",
            "businessObjectCode": "ORA_HCM_GLOBALHUMA_XX_PERSONSEARCHESGHR",
            "functionName": "GetWorkersByManager",
            "errorNodeId": "1785000001800"
          },
          "outcomes": {
            "success": "1785000002000"
          },
          "inputs": [
            {
              "id": "1785000001900_context",
              "name": "context",
              "type": "string",
              "value": "ManageAbsenceRecord",
              "required": false
            }
          ],
          "diagram": {
