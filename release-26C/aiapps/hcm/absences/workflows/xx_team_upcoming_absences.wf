                },
                {
                  "id": "1785000002120",
                  "code": "BUILD_DIRECT_REPORT_ABSENCE_RESULT",
                  "type": "CODE",
                  "metadata": {
                    "name": "Build Direct Report Absence Result",
                    "description": "Combines the current direct report with sanitized absence records returned by the absence business object.",
                    "returnType": "object",
                    "sourceCode": "function parseJson(value) {\n  if (typeof value !== \"string\") return value;\n  const text = value.trim();\n  if (text === \"\") return value;\n  if (text.charAt(0) !== \"{\" && text.charAt(0) !== \"[\") return value;\n  try {\n    return JSON.parse(text);\n  } catch (e) {\n    return value;\n  }\n}\n\nfunction toRecordList(value) {\n  const current = parseJson(value);\n  if (Array.isArray(current)) return current;\n  if (!current || typeof current !== \"object\") return [];\n  if (Array.isArray(current.items)) return current.items;\n  let nested = toRecordList(current.result);\n  if (nested.length > 0) return nested;\n  nested = toRecordList(current.query);\n  if (nested.length > 0) return nested;\n  nested = toRecordList(current.response);\n  if (nested.length > 0) return nested;\n  return [];\n}\n\nfunction sanitizeDisplayText(value) {\n  return String(value || \"\")\n    .replace(/[\\u0000-\\u001F\\u007F]/g, \"\")\n    .replace(/[\\u202A-\\u202E\\u2066-\\u2069]/g, \"\")\n    .replace(/\\s+/g, \" \")\n    .trim();\n}\n\nfunction displayText(value) {\n  if (value === 0) return \"0\";\n  return sanitizeDisplayText(value);\n}\n\nfunction readAbsenceOutput() {\n  const loopNode = $context.$nodes.FETCH_ABSENCES_FOR_DIRECTS || {};\n  const scopedOutput = loopNode.FETCH_DIRECT_REPORT_ABSENCES && loopNode.FETCH_DIRECT_REPORT_ABSENCES.$output;\n  const localOutput = $context.$nodes.FETCH_DIRECT_REPORT_ABSENCES && $context.$nodes.FETCH_DIRECT_REPORT_ABSENCES.$output;\n  return scopedOutput || localOutput || {};\n}\n\nconst current = $context.$nodes.FETCH_ABSENCES_FOR_DIRECTS.$currentItem || {};\nconst records = toRecordList(readAbsenceOutput());\nconst absences = [];\n\nfor (let i = 0; i < records.length; i++) {\n  const record = records[i] || {};\n  absences.push({\n    absenceType: displayText(record.absenceType),\n    startDate: displayText(record.startDate),\n    endDate: displayText(record.endDate),\n    formattedDuration: displayText(record.formattedDuration),\n    absenceDispStatusMeaning: displayText(record.absenceDispStatusMeaning),\n    assignmentName: displayText(record.assignmentName),\n    personAbsenceEntryId: displayText(record.personAbsenceEntryId),\n    absenceDispStatus: displayText(record.absenceDispStatus)\n  });\n}\n\nreturn {\n  personId: displayText(current.personId),\n  employeeName: displayText(current.employeeName) || \"Employee\",\n  businessTitle: displayText(current.businessTitle),\n  personNumber: displayText(current.personNumber),\n  assignmentId: displayText(current.assignmentId),\n  absences: absences,\n  absenceCount: absences.length\n};"
                  },
                  "outcomes": {
                    "success": "end_1785000002100"
                  },
                  "inputs": [],
                  "diagram": {
                    "x": 5225,
                    "y": 6779
                  },
                  "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
                },
                {
                  "id": "end_1785000002100",
