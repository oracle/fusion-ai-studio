                }
              ]
            }
          },
          "outcomes": {
            "success": "1785000002200"
          },
          "inputs": [
            {
              "id": "1785000002100_collection",
              "name": "collection",
              "type": "string",
              "value": "{{$context.$nodes.PREPARE_DIRECT_REPORTS.$output.result.directReports}}"
            }
          ],
          "diagram": {
            "x": 5075,
