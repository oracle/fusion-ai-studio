          "metadata": {
            "name": "Validate Person and Assignment",
            "sourceCode": "const pId = $context.$nodes.FETCH_LOGGEDIN_EMPLOYEE_CONTEXT.$output.items[0].PersonId;\n\nconst aId = $context.$nodes.FETCH_LOGGEDIN_EMPLOYEE_CONTEXT.$output.items[0].AssignmentId;\n\nreturn /^\\d+$/.test(pId) && /^\\d+$/.test(aId);",
