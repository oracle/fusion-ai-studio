        {
          "id": "1783065400001",
          "code": "VALIDATE_PERSON_AND_ASSIGNMENT",
          "type": "CODE",
          "metadata": {
            "name": "Validate Person and Assignment",
            "description": "Validates logged-in person and assignment identifiers before fetching team compensation details.",
            "returnType": "object",
            "sourceCode": "function validId(value) {\n  const text = String(value || \"\").trim();\n  return /^\\d{1,18}$/.test(text);\n}\n\nconst output = $context.$nodes.FETCH_LOGGEDIN_EMPLOYEE_CONTEXT.$output || {};\nconst items = Array.isArray(output.items) ? output.items : [];\nconst context = items[0] || {};\n\nconst personId = String(context.PersonId || \"\").trim();\nconst assignmentId = String(context.AssignmentId || \"\").trim();\nconst isValid = validId(personId) && validId(assignmentId);\n\nreturn {\n  isValid: isValid,\n  personId: isValid ? personId : \"\",\n  assignmentId: isValid ? assignmentId : \"\"\n};"
          },
          "outcomes": {
            "success": "1783065400002"
          },
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "diagram": {
            "x": 5243,
            "y": 5428
          }
        },
        {
          "id": "1783065400002",
          "code": "CHECK_VALID_PERSON_AND_ASSIGNMENT",
          "type": "CONDITION",
          "convergenceTargetId": "end",
          "metadata": {
            "name": "Check Valid Person and Assignment"
          },
          "outcomes": {
            "true": "1782500000002",
            "false": "1783065400003"
          },
          "inputs": [
            {
              "id": "1783065400002_condition",
              "name": "condition",
              "type": "string",
              "value": "{{$context.$nodes.VALIDATE_PERSON_AND_ASSIGNMENT.$output.result.isValid === true}}"
            }
          ],
          "diagram": {
            "x": 5229.5,
            "y": 5650
          }
        },
        {
