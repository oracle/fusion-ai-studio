        {
          "id": "1782500000001",
          "code": "FETCH_LOGGEDIN_EMPLOYEE_CONTEXT",
          "type": "BO_FUNCTION",
          "metadata": {
            "businessObjectCode": "ORA_HCM_EMPINFO_XX_LOGGEDINEMPLOYEECONTEXT",
            "functionName": "getLoggedInEmployeeInfo",
            "name": "Fetch Loggedin Employee Context",
