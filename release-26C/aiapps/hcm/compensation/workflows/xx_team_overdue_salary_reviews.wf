        {
          "id": "1782500000002",
          "code": "FETCH_MY_TEAM_COMPENSATION_DETAILS",
          "type": "BO_FUNCTION",
          "metadata": {
            "name": "Fetch My Team Compensation Details",
            "businessObjectCode": "ORA_HCM_COMP_XX_MYTEAMCOMPENSATIONDETAILSLOOKUP",
            "functionName": "findMyTeamCompensationDetails",
            "processJson": true
          },
          "outcomes": {
            "success": "1782500000003"
          },
          "inputs": [
            {
              "id": "1782500000002_pPersonId",
              "name": "pPersonId",
              "value": "{{$context.$nodes.VALIDATE_PERSON_AND_ASSIGNMENT.$output.result.personId}}",
              "required": false
            },
            {
              "id": "1782500000002_pAssignmentId",
              "name": "pAssignmentId",
              "value": "{{$context.$nodes.VALIDATE_PERSON_AND_ASSIGNMENT.$output.result.assignmentId}}",
