      {
        "name": "extractAV",
        "description": "Executes a specialized BOSS query to extract aggregated AV data within the General Ledger domain, enabling detailed financial insights through a secure POST operation.",
        "operationType": "POST",
        "resourcePath": "/api/erp/erpaggregatedataservice/api/v2/av/extract",
        "resourceType": "SPECTRA",
        "bodyTemplate": "{payload}",
        "useNativeAuthentication": true,
        "type": "BUS_OBJECT",
        "parameterDefinitions": [
          {
            "name": "payload",
            "dataType": "string",
            "description": "Payload",
            "id": 5,
            "isToken": true,
            "location": "body",
            "source": "placeholder",
            "defaultValue": ""
          }
        ],
        "sampleQueries": [
          {
            "description": "This example payload for the extractAV function demonstrates a POST request extracting aggregated AV data within the General Ledger domain, featuring ledgerLevelAvData with currentLevelAvData and childLevelAvData records. Key entities include financial balances (beginBalance, periodNetBalance, endingBalance) by accountingPeriod, currency, ledger, account, and company, supporting detailed financial insights for Sample Corporate Ledger and related business units. The payload also highlights metadata on core dimensions and chart of accounts segments used in the extraction.",
            "query": {
              "avExtractResult": {
                "ledgerLevelAvData": [
                  {
                    "currentLevelAvData": {
                      "records": [
                        {
                          "beginBalance": "1000000.00",
                          "beginBalanceSign": "Dr",
                          "periodNetBalance": "50000.00",
                          "periodNetBalanceSign": "Dr",
                          "endingBalance": "1050000.00",
                          "endingBalanceSign": "Dr",
                          "accountingPeriod": "Jan-26",
                          "currency": "USD",
                          "currencyType": "Total",
                          "ledger": "Sample Corporate Ledger",
                          "scenario": "Actual",
                          "account": "10000",
                          "accountDescription": "Sample Asset Account",
                          "company": "1000",
                          "companyDescription": "Sample Company",
                          "ledgerId": "1001",
                          "ledgerCurrency": "USD"
                        }
                      ],
                      "hasMore": false,
                      "count": 1
                    },
                    "childLevelAvData": {
                      "records": [
                        {
                          "beginBalance": "1000000.00",
                          "beginBalanceSign": "Dr",
                          "periodNetBalance": "50000.00",
                          "periodNetBalanceSign": "Dr",
                          "endingBalance": "1050000.00",
                          "endingBalanceSign": "Dr",
                          "accountingPeriod": "Jan-26",
                          "currency": "USD",
                          "currencyType": "Total",
                          "ledger": "Sample Corporate Ledger",
                          "scenario": "Actual",
                          "account": "10000",
                          "accountDescription": "Sample Asset Account",
                          "company": "1100",
                          "companyDescription": "Sample Business Unit",
                          "ledgerId": "1001",
                          "ledgerCurrency": "USD"
                        }
                      ],
                      "hasMore": false,
                      "count": 1
                    }
                  }
                ],
                "hasMore": false,
                "hierarchiesUsed": {
                  "Company": "Sample Company Hierarchy"
                },
                "timeStamp": "01-01-2026 12:00:00",
                "headLineMeasures": [
                  "endingBalance"
                ],
                "metaData": {
                  "coreDimensions": {
                    "currency": {
                      "label": "Currency"
                    },
                    "currencyType": {
                      "label": "Currency Type"
                    },
                    "ledger": {
                      "label": "Ledger"
                    },
                    "accountingPeriod": {
                      "label": "Accounting Period"
                    }
                  },
                  "chartOfAccounts": {
                    "segments": {
                      "company": {
                        "qualifiers": [
                          "GL_BALANCING"
                        ],
                        "label": "Company"
                      },
                      "costCenter": {
                        "qualifiers": [
                          "FA_COST_CTR"
                        ],
                        "label": "Cost Center"
                      },
                      "account": {
                        "qualifiers": [
                          "GL_ACCOUNT"
                        ],
                        "label": "Account"
                      }
                    }
                  },
                  "mandatoryCoaSegments": [
                    "company",
                    "account"
                  ]
                }
              }
            },
            "sampleType": "response"
          }
        ]
      }
    ]
  }
