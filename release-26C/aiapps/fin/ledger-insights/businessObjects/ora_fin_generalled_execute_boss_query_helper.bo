  "name": "Execute BOSS Query Helper",
  "description": "Insights - Execute BOSS Query Helper enables the execution of specialized BOSS queries within the General Ledger domain, supporting data extraction for various financial aggregates. It facilitates creating and managing query requests through multiple POST operations, including handling related child resources for detailed extraction processes. This Business Object streamlines access to aggregated financial insights by coordinating core and supporting query functions.",
  "objectCode": "ORA_FIN_GENERALLED_EXECUTE_BOSS_QUERY_HELPER",
  "family": "FIN",
  "product": "GENERAL_LEDGER",
  "objectSource": "SPECTRA",
  "restResourcePath": "/api/",
  "restResourceIdentifier": "identifier_not_known",
  "seededFlag": false,
  "mandatoryFlag": false,
  "objectProperties": {
    "jsonSchemaName": "supportedObjectProperties",
    "jsonSchemaVersion": 1,
    "baseUrlTMKey": "",
    "serviceNameOverride": "",
    "tools": [
      {
        "name": "bossExtract",
        "description": "Executes a specialized BOSS query to extract financial data within the General Ledger domain. This function submits a payload to initiate the extraction process, enabling access to aggregated financial insights through the Insights - Execute BOSS Query Helper.",
        "operationType": "POST",
        "resourcePath": "/api/boss/extraction/extract",
        "resourceType": "SPECTRA",
        "bodyTemplate": "{payload}",
        "useNativeAuthentication": true,
        "type": "BUS_OBJECT",
        "parameterDefinitions": [
          {
            "name": "payload",
            "dataType": "string",
            "description": "Payload for the boss extract",
            "id": 2,
            "isToken": true,
            "location": "body",
            "source": "placeholder",
            "defaultValue": ""
          }
        ],
        "sampleQueries": [
          {
            "description": "This example payload for the bossExtract function represents a collection of financial records detailing credit and debit amounts by supplier within the General Ledger domain. Key entities include the supplier name and associated financial fields such as unroundedEnteredCredit, unroundedAccountedCredit, unroundedAccountedDebit, netUnroundedAccountedAmount, netUnroundedEnteredAmount, and unroundedEnteredDebit, illustrating aggregated credit and debit values for each supplier.",
            "query": [
              {
                "supplier": "Supplier A",
                "unroundedEnteredCredit": 50000,
                "unroundedAccountedDebit": 0,
                "unroundedAccountedCredit": 50000,
                "netUnroundedAccountedAmount": -50000,
                "netUnroundedEnteredAmount": -50000,
                "unroundedEnteredDebit": 0
              },
              {
                "supplier": "Supplier B",
                "unroundedEnteredCredit": 125000,
                "unroundedAccountedDebit": 0,
                "unroundedAccountedCredit": 125000,
                "netUnroundedAccountedAmount": -125000,
                "netUnroundedEnteredAmount": -125000,
                "unroundedEnteredDebit": 0
              },
              {
                "supplier": "Supplier C",
                "unroundedEnteredCredit": 350000,
                "unroundedAccountedDebit": 0,
                "unroundedAccountedCredit": 350000,
                "netUnroundedAccountedAmount": -350000,
                "netUnroundedEnteredAmount": -350000,
                "unroundedEnteredDebit": 0
              },
              {
                "supplier": "Supplier D",
                "unroundedEnteredCredit": 650000,
                "unroundedAccountedDebit": 0,
                "unroundedAccountedCredit": 650000,
                "netUnroundedAccountedAmount": -650000,
                "netUnroundedEnteredAmount": -650000,
                "unroundedEnteredDebit": 0
              },
              {
                "supplier": "Supplier E",
                "unroundedEnteredCredit": 850000,
                "unroundedAccountedDebit": 0,
                "unroundedAccountedCredit": 850000,
                "netUnroundedAccountedAmount": -850000,
                "netUnroundedEnteredAmount": -850000,
                "unroundedEnteredDebit": 0
              },
              {
                "supplier": "Supplier F",
                "unroundedEnteredCredit": 1200000,
                "unroundedAccountedDebit": 0,
                "unroundedAccountedCredit": 1200000,
                "netUnroundedAccountedAmount": -1200000,
                "netUnroundedEnteredAmount": -1200000,
                "unroundedEnteredDebit": 0
              },
              {
                "supplier": "Supplier G",
                "unroundedEnteredCredit": 1800000,
                "unroundedAccountedDebit": 0,
                "unroundedAccountedCredit": 1800000,
                "netUnroundedAccountedAmount": -1800000,
                "netUnroundedEnteredAmount": -1800000,
                "unroundedEnteredDebit": 0
              },
              {
                "supplier": "Supplier H",
                "unroundedEnteredCredit": 2500000,
                "unroundedAccountedDebit": 0,
                "unroundedAccountedCredit": 2500000,
                "netUnroundedAccountedAmount": -2500000,
                "netUnroundedEnteredAmount": -2500000,
