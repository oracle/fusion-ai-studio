      {
        "name": "getAccountingExceptions",
        "description": "Gets accounting exception totals grouped by issue category for a selected ledger and accounting period.",
        "operationType": "POST",
        "resourcePath": "/api/boss/extraction/extract",
        "resourceType": "SPECTRA",
        "bodyTemplate": "{\n  \"viewQueries\": {\n    \"autorunError\": {\n      \"module\": \"oraErpCoreAccountingSetup\",\n      \"businessObject\": \"AccountingAutomationError\",\n      \"view\": \"accountingAutomationErrorList\",\n      \"fieldAliases\": {\n        \"transactionName\": \"transactionName\",\n        \"programCode\": \"programCode\",\n        \"accountingDate\": \"accountingDate\",\n        \"timeCreated\": \"creationDate\",\n        \"timeUpdated\": \"timeUpdated\",\n        \"ledger.ledgerId\": \"ledgerId\",\n        \"ledger.name\": \"ledgerName\",\n        \"journalSource.userJeSourceName\": \"source\",\n        \"errorCategory.meaning\": \"errorCategory\",\n        \"errorCategory.lookupCode\": \"errorCategoryCode\",\n        \"amount\": \"amount\",\n        \"accountingAutomationErrorCode.errorCode\": \"errorCode\",\n        \"errorText\": \"errorMessage\",\n        \"statusCode\": \"statusCode\",\n        \"amountKey\": \"amountKey\",\n        \"autorunRequestId\": \"autorunRequestId\",\n        \"errorKey\": \"errorKey\",\n        \"errorDetailText3\": \"errorDetailText3\",\n        \"errorDetailText4\": \"errorDetailText4\",\n        \"errorDetailText5\": \"errorDetailText5\",\n        \"errorDetailText6\": \"errorDetailText6\",\n        \"errorDetailText7\": \"errorDetailText7\",\n        \"errorDetailText8\": \"errorDetailText8\",\n        \"errorDetailDate1\": \"errorDetailDate1\"\n      }\n    },\n    \"glPeriods\": {\n      \"module\": \"oraErpCoreStructure\",\n      \"businessObject\": \"AccountingPeriod\",\n      \"view\": \"accountingPeriodList\",\n      \"fieldAliases\": {\n        \"periodName\": \"periodName\",\n        \"calendar.periodSetName\": \"periodSetName\",\n        \"calendar.periodType\": \"periodType\",\n        \"startDate\": \"startDate\",\n        \"endDate\": \"endDate\"\n      }\n    },\n    \"glLedgers\": {\n      \"module\": \"oraErpCoreStructure\",\n      \"businessObject\": \"Ledger\",\n      \"view\": \"ledgerList\",\n      \"fieldAliases\": {\n        \"ledgerId\": \"ledgerId\",\n        \"name\": \"ledgerName\",\n        \"calendar.periodSetName\": \"periodSetName\",\n        \"calendar.periodType\": \"periodType\",\n        \"chartOfAccount.structureInstanceNumber\": \"chartOfAccountsId\",\n        \"currency.currencyCode\": \"currencyCode\"\n      }\n    }\n  },\n  \"namedSelects\": [\n    {\n      \"name\": \"autorunErrors\",\n      \"select\": \"SELECT ledgerId, ledgerName, errorCategory, errorCategoryCode, source, accountingDate, creationDate, timeUpdated, amount, errorCode, errorMessage, programCode, transactionName, statusCode, amountKey, autorunRequestId, errorKey, errorDetailText3, errorDetailText4, errorDetailText5, errorDetailText6, errorDetailText7, errorDetailText8, errorDetailDate1 FROM autorunError WHERE ledgerId=nvl('{ledgerId}',ledgerId) and programCode=decode('{programCode}','null',programCode,null,programCode,'{programCode}') and (statusCode = 'ORA_NEEDS_ACTION' or statusCode like 'ORA_AUTO_ACTION%')\"\n    }\n  ],\n  \"select\": \"SELECT err.ledgerName as ledger, err.errorCategory as exceptionCategory, err.errorCategoryCode as exceptionCategoryCode, count(*) as exceptionCount, sum(case when err.statusCode like 'ORA_AUTO_ACTION%' then 1 else 0 end) as autoActionedCount, sum(case when err.statusCode = 'ORA_NEEDS_ACTION' then 1 else 0 end) as actionRequiredCount, nvl(sum(err.amount),0) as totalAmount, p.periodName as accountingPeriod, max(err.statusCode) as statusCode FROM autorunErrors err JOIN glLedgers gl ON err.ledgerId=gl.ledgerId JOIN glPeriods p ON gl.periodType=p.periodType AND gl.periodSetName=p.periodSetName AND nvl(err.accountingDate,err.creationDate)>=p.startDate AND nvl(err.accountingDate,err.creationDate)<=p.endDate WHERE p.periodName=nvl('{period}',p.periodName) GROUP BY err.ledgerName, err.errorCategory, err.errorCategoryCode, p.periodName HAVING count(*) > 0 ORDER BY totalAmount desc FETCH FIRST 25 ROWS ONLY\"\n}",
        "useNativeAuthentication": true,
        "type": "BUS_OBJECT",
        "parameterDefinitions": [
          {
            "name": "ledgerId",
            "dataType": "string",
            "description": "Ledger Id",
            "id": 16,
            "isToken": true,
            "location": "body",
            "source": "placeholder",
            "defaultValue": ""
          },
          {
            "name": "programCode",
            "dataType": "string",
            "description": "Program Code",
            "id": 17,
            "isToken": true,
            "location": "body",
            "source": "placeholder",
            "defaultValue": ""
          },
          {
            "name": "period",
            "dataType": "string",
            "description": "Accounting Period",
            "id": 18,
            "isToken": true,
            "location": "body",
            "source": "placeholder",
            "defaultValue": ""
          }
        ],
        "sampleQueries": [
          {
            "description": "This sample payload demonstrates a request to retrieve accounting exception totals grouped by issue category for a specified ledger and accounting period, using the parameters ledgerId, programCode, and period. It represents the input needed to look up exception summaries within the Accounting Exceptions Lookup business object.",
            "query": {
              "ledgerId": "<LEDGER_ID>",
              "programCode": "",
              "period": "<PERIOD>"
            }
          }
        ]
      }
    ]
