        "sampleQueries": [
          {
            "description": "This example shows a request payload for retrieving accounting exception counts grouped by transaction category within a specified errorCategory, period, and ledgerId, using optional programCode and transactionNumber filters. It represents the input parameters needed to summarize transaction categories for a selected issue category in the Accounting Exceptions Lookup business object.",
            "query": {
              "programCode": "",
              "transactionNumber": "",
              "period": "<PERIOD>",
              "errorCategory": "<ERROR_CATEGORY>",
              "ledgerId": "<LEDGER_ID>"
