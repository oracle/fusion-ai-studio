        ],
        "sampleQueries": [
          {
            "description": "This sample payload demonstrates a request to retrieve transaction-level accounting exception details filtered by period, errorCategory, and ledgerId, with optional programCode and transactionNumber parameters to refine the search. It highlights the key entities used to specify the accounting period, issue category, and ledger for the lookup.",
            "query": {
              "programCode": "",
