    "tools": [
      {
        "name": "getTransactionCategorySummaryforErrorCategory",
        "description": "Gets accounting exception counts grouped by transaction category for a selected issue category.",
        "operationType": "POST",
        "resourcePath": "/api/boss/extraction/extract",
        "resourceType": "SPECTRA",
        "bodyTemplate": "{\n    \"viewQueries\": {\n      \"autorunError\": {\n        \"module\": \"oraErpCoreAccountingSetup\",\n        \"businessObject\": \"AccountingAutomationError\",\n        \"view\": \"accountingAutomationErrorList\",\n        \"fieldAliases\": {\n          \"transactionName\": \"transactionName\",\n          \"ledger.ledgerId\": \"ledgerId\",\n          \"timeUpdated\": \"timeUpdated\",\n          \"accountingDate\": \"accountingDate\",\n          \"accountingAutomationErrorCode.errorCode\": \"errorCode\",\n          \"errorText\": \"errorMessage\",\n          \"statusCode\": \"statusCode\",\n          \"journalSource.userJeSourceName\": \"source\",\n          \"errorCategory.meaning\": \"errorCategory\",\n          \"ledger.name\": \"ledgerName\",\n          \"autorunRequestId\": \"autorunRequestId\",\n          \"programCode\": \"programCode\",\n          \"amount\": \"amount\"\n        }\n      },\n      \"xlaErrors\": {\n        \"module\": \"oraErpCoreSubledgerAccountingEntries\",\n        \"businessObject\": \"SubledgerAccountingError\",\n        \"view\": \"subledgerAccountingErrorDetail\",\n        \"fieldAliases\": {\n          \"subledgerApplication.applicationName\": \"subledger\",\n          \"subledgerTransactionEntity.transactionNumber\": \"transactionNumber\",\n          \"ledger.ledgerId\": \"ledgerId\",\n          \"timeUpdated\": \"timeUpdated\",\n          \"subledgerAccountingEntryHeader.accountingDate\": \"accountingDate\",\n          \"subledgerJournalLineNumber\": \"journalLineNumber\",\n          \"accountingAutomationErrorCode.errorCode\": \"messageName\",\n          \"errorMessage\": \"errorMessage\",\n          \"ledger.name\": \"ledgerName\",\n          \"accountingAutomationErrorCode.lookupErrorCategory.meaning\": \"errorCategory\"\n        }\n      },\n      \"errorActions\": {\n        \"module\": \"oraErpCoreAccountingSetup\",\n        \"businessObject\": \"AccountingAutomationErrorAction\",\n        \"view\": \"accountingErrorActionList\",\n        \"fieldAliases\": {\n          \"errorCode\": \"errorCode\",\n          \"lookupUserActionCode.meaning\": \"recommendation\"\n        }\n      },\n      \"erpLookup\": {\n        \"module\": \"oraErpCoreCommonObjects\",\n        \"businessObject\": \"ERPLookupCode\",\n        \"view\": \"lookupList\",\n        \"filter\": \" lookupType = 'ORA_TRANSACTION_TYPE'\",\n        \"fieldAliases\": {\n          \"lookupCode\": \"lookupCode\",\n          \"meaning\": \"meaning\"\n        }\n      },\n      \"glPeriods\": {\n        \"module\": \"oraErpCoreStructure\",\n        \"businessObject\": \"AccountingPeriod\",\n        \"view\": \"accountingPeriodList\",\n        \"fieldAliases\": {\n          \"periodName\": \"periodName\",\n          \"periodSetName\": \"periodSetName\",\n          \"calendar.periodSetName\": \"calPeriodSetName\",\n          \"calendar.periodType\": \"periodType\",\n          \"startDate\": \"startDate\",\n          \"endDate\": \"endDate\"\n        }\n      },\n      \"glLedgers\": {\n        \"module\": \"oraErpCoreStructure\",\n        \"businessObject\": \"Ledger\",\n        \"view\": \"ledgerList\",\n        \"fieldAliases\": {\n          \"ledgerId\": \"ledgerId\",\n          \"name\": \"ledgerName\",\n          \"calendar.periodSetName\": \"periodSetName\",\n          \"calendar.periodType\": \"periodType\"\n        }\n      }\n    },\n    \"namedSelects\": [\n      {\n        \"name\": \"autorunErrors\",\n        \"select\": \"SELECT decode(programCode, 'POSTING', 'ORA_GL_JOURNAL', 'JOURNAL_IMPORT', 'ORA_JOURNAL_INTERFACE', 'SLA_APPROVAL', 'ORA_ACCOUNTING_ENTRY', 'JOURNAL_APPROVAL', 'ORA_GL_JOURNAL', 'JOURNAL_TRANSFER', 'ORA_ACCOUNTING_ENTRY', 'IMPORT_DAILY_RATES', 'ORA_DAILY_RATES_IMPORT') AS programCodes, transactionName, errorCode, errorMessage, source, errorCategory AS errorCategory, ledgerName, autorunRequestId AS autorunRequest, ledgerId, accountingDate, timeUpdated, amount, statusCode FROM autorunError WHERE programCode NOT IN ('CREATE_ACCOUNTING', 'AUTORUN') AND programCode = nvl('{programCode}', programCode) AND transactionName LIKE '%{transactionNumber}%' AND nvl(statusCode, 'UNPROCESSED') NOT IN ('ORA_USER_ACTION')\"\n      },\n      {\n        \"name\": \"createAccountingErrors\",\n        \"select\": \"SELECT 'ORA_SUBLEDGER_TRANSACTION' AS programCodes, ('Application:' || subledger || ';' || ' Transaction Number:' || transactionNumber || ';' || ' Accounting Date: ' || accountingDate || ';' || ' Journal Line Number:' || journalLineNumber) AS transactionName, messageName AS errorCode, errorMessage, subledger AS source, errorCategory, ledgerName, 0 AS autorunRequest, ledgerId, accountingDate, timeUpdated, NULL AS amount, NULL AS statusCode FROM xlaErrors WHERE transactionNumber = nvl('{transactionNumber}', transactionNumber) AND 'CREATE_ACCOUNTING' = nvl('{programCode}', 'CREATE_ACCOUNTING')\"\n      }\n    ],\n    \"select\": \"SELECT el.meaning AS transactionCategory, err.source AS source, err.errorCategory AS errorCategory, COUNT(*) AS exceptionCount, MAX(err.statusCode) AS statusCode FROM (SELECT programCodes, transactionName, errorCode, errorMessage, source, errorCategory, ledgerName, autorunRequest, ledgerId, accountingDate, timeUpdated, amount, statusCode FROM autorunErrors UNION ALL SELECT programCodes, transactionName, errorCode, errorMessage, source, errorCategory, ledgerName, autorunRequest, ledgerId, accountingDate, timeUpdated, amount, statusCode FROM createAccountingErrors) err LEFT JOIN glLedgers gl ON err.ledgerId = gl.ledgerId JOIN glPeriods p ON gl.periodType = p.periodType AND gl.periodSetName = p.periodSetName AND (('{period}' IS NOT NULL AND p.periodName = nvl('{period}', p.periodName)) OR ('{period}' IS NULL AND err.timeUpdated > SYSDATE - 10)) AND nvl(err.accountingDate, err.timeUpdated) >= p.startDate AND nvl(err.accountingDate, err.timeUpdated) <= p.endDate LEFT JOIN errorActions ea ON err.errorCode = ea.errorCode LEFT JOIN erpLookup el ON err.programCodes = el.lookupCode WHERE err.errorCategory = nvl('{errorCategory}', err.errorCategory) AND err.ledgerId = nvl('{ledgerId}', err.ledgerId) GROUP BY el.meaning, err.source, err.errorCategory ORDER BY el.meaning FETCH FIRST 100 ROWS ONLY\"\n  }",
        "useNativeAuthentication": true,
        "type": "BUS_OBJECT",
        "parameterDefinitions": [
          {
            "name": "programCode",
            "dataType": "string",
            "description": "Program Code",
            "id": 2,
            "isToken": true,
            "location": "body",
            "source": "placeholder",
            "defaultValue": ""
          },
          {
            "name": "transactionNumber",
            "dataType": "string",
            "description": "Transaction Number",
            "id": 3,
            "isToken": true,
            "location": "body",
            "source": "placeholder",
            "defaultValue": ""
          },
          {
            "name": "period",
            "dataType": "string",
            "description": "Accounting Period",
            "id": 4,
            "isToken": true,
            "location": "body",
            "source": "placeholder",
            "defaultValue": ""
          },
          {
            "name": "errorCategory",
            "dataType": "string",
            "description": "Error Category",
            "id": 5,
            "isToken": true,
            "location": "body",
            "source": "placeholder",
            "defaultValue": ""
          },
          {
            "name": "ledgerId",
            "dataType": "string",
