      {
        "name": "getAllPrimaryLedgers",
        "description": "Retrieves a list of all primary ledgers accessible within the General Ledger system, providing key details such as ledger ID, name, category, currency, and related accounting information. This function supports comprehensive ledger data extraction through the Ledger Search business object.",
        "operationType": "POST",
        "resourcePath": "/api/boss/extraction/extract",
        "resourceType": "SPECTRA",
        "bodyTemplate": "{\n    \"viewQueries\": {\n        \"glDataAccessSetLedgers\": {\n            \"module\": \"oraErpCoreGeneralLedgerSetup\",\n            \"businessObject\": \"DataAccessSetLedger\",\n            \"view\": \"dataAccessSetLedgerList\",\n            \"fieldAliases\": {\n                \"accessSetId\": \"accessSetId\",\n                \"ledger.ledgerId\": \"ledgerId\",\n                \"ledger.name\": \"ledgerName\"\n            }\n        },\n        \"glAccessSets\": {\n            \"module\": \"oraErpCoreGeneralLedgerSetup\",\n            \"businessObject\": \"DataAccessSet\",\n            \"view\": \"dataAccessSetList\",\n            \"fieldAliases\": {\n                \"accessSetId\": \"accessSetId\",\n                \"name\": \"accessSetName\",\n                \"defaultLedger.ledgerId\": \"defaultLedgerId\",\n                \"chartOfAccount.structureInstanceNumber\": \"chartOfAccountsId\"\n            }\n        },\n        \"ledger\": {\n            \"module\": \"oraErpCoreStructure\",\n            \"businessObject\": \"Ledger\",\n            \"view\": \"ledgerList\",\n            \"fieldAliases\": {\n                \"calendar.periodSetName\": \"periodSetName\",\n                \"calendar.calendarId\": \"calendarId\",\n                \"currency.currencyCode\": \"currencyCode\",\n                \"ledgerId\": \"ledgerId\",\n                \"ledgerCategory.meaning\": \"ledgerCategory\",\n                \"name\": \"ledgerName\",\n                \"chartOfAccount.structureInstanceNumber\": \"chartOfAccountsId\"\n            }\n        }\n    },\n    \"select\": \"SELECT DISTINCT ledger.ledgerId, ledger.ledgerCategory, ledger.chartOfAccountsId, ledger.ledgerName, ledger.periodSetName, ledger.calendarId, ledger.currencyCode, 'Y' as suspenseAllowedFlag FROM  ledger, glDataAccessSetLedgers WHERE ledger.ledgerId = glDataAccessSetLedgers.ledgerId and glDataAccessSetLedgers.accessSetId IN (select glAccessSets.accessSetId from glAccessSets) and glDataAccessSetLedgers.accessSetId IN (select glAccessSets.accessSetId from glAccessSets) AND ledger.ledgerCategory = 'Primary' order by ledger.ledgerName asc FETCH FIRST 250 ROWS ONLY\",\n    \"return\": [\n        {\n            \"type\": \"string\",\n            \"name\": \"ledgerId\"\n        },\n        {\n            \"type\": \"string\",\n            \"name\": \"ledgerCategory\"\n        },\n        {\n            \"type\": \"string\",\n            \"name\": \"chartOfAccountsId\"\n        },\n        {\n            \"type\": \"string\",\n            \"name\": \"ledgerName\"\n        },\n        {\n            \"type\": \"string\",\n            \"name\": \"periodSetName\"\n        },\n        {\n            \"type\": \"string\",\n            \"name\": \"calendarId\"\n        },\n         {\n            \"type\": \"string\",\n            \"name\": \"currencyCode\"\n        },\n        {\n            \"type\": \"string\",\n            \"name\": \"suspenseAllowedFlag\"\n        }\n    ]\n}",
        "useNativeAuthentication": true,
        "type": "BUS_OBJECT",
        "parameterDefinitions": [],
        "sampleQueries": [
          {
            "description": "This example payload represents a collection of primary ledgers retrieved by the getAllPrimaryLedgers function, showing key entities such as ledgerName and ledgerId for each ledger within the Ledger Search business object.",
            "query": [
              {
                "ledgerName": "Ledger 1",
                "ledgerId": "1001"
              },
              {
                "ledgerName": "Ledger 2",
                "ledgerId": "1002"
              },
              {
                "ledgerName": "Ledger 3",
                "ledgerId": "1003"
