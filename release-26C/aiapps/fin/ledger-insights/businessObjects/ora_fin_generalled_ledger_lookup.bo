s) and glDataAccessSetLedgers.accessSetId IN (select glAccessSets.accessSetId from glAccessSets) order by ledger.ledgerName asc FETCH FIRST 250 ROWS ONLY\",\n    \"return\": [\n        {\n            \"type\": \"string\",\n            \"name\": \"ledgerId\"\n        },\n        {\n            \"type\": \"string\",\n            \"name\": \"ledgerCategory\"\n        },\n        {\n            \"type\": \"string\",\n            \"name\": \"chartOfAccountsId\"\n        },\n        {\n            \"type\": \"string\",\n            \"name\": \"ledgerName\"\n        },\n        {\n            \"type\": \"string\",\n            \"name\": \"periodSetName\"\n        },\n        {\n            \"type\": \"string\",\n            \"name\": \"calendarId\"\n        },\n         {\n            \"type\": \"string\",\n            \"name\": \"currencyCode\"\n        },\n        {\n            \"type\": \"string\",\n            \"name\": \"suspenseAllowedFlag\"\n        }\n    ]\n}",
