        {
          "metadata": {
            "name": "Select Ledger"
          },
          "outcomes": {
            "false": "1779098596165",
            "true": "1781174690641"
          },
          "code": "SELECT_LEDGER",
          "convergenceTargetId": "end",
          "id": "1779101086470",
          "inputs": [
            {
              "id": "1779101086470_condition",
              "name": "condition",
              "type": "string",
              "value": "{{$context.$nodes.FETCH_LEDGERS_FOR_USER_QUERY.$output.length === 1}}"
            }
          ],
          "type": "CONDITION"
        },
        {
          "metadata": {
            "name": "Prepare Ledger List Information",
            "returnType": "object",
            "sourceCode": "const ledgerList = Array.isArray($context.$nodes.FETCH_LEDGERS_FOR_USER_QUERY.$output)\n  ? $context.$nodes.FETCH_LEDGERS_FOR_USER_QUERY.$output\n  : [];\n\nlet message = String($context.$nodes.EXTRACT_LEDGER_INFORMATION.$output.message) || \"\";\n\nif (ledgerList.length === 0) {\n    return {\n        message: \"No matches found, when \" + message,\n//        message: \"No Matching, when \" + message,\n        hasMany: false,\n        appContextUpdated: true,\n        refreshApp: false\n    };\n}\n\nlet currentPeriodName = $context.$nodes.EXTRACT_LEDGER_INFORMATION.$output.periodName || \"\";\n\nconst context = {\n  ledgers: ledgerList.map( ledger => ({\n    ledgerName: ledger.ledgerName,\n    ledgerId: ledger.ledgerId\n  })),\n  periodName: currentPeriodName,\n  message: message,\n  hasMany: true,\n  appContextUpdated: true,\n  refreshApp: false\n};\n\nreturn context;"
          },
          "outcomes": {
            "success": "end"
          },
          "code": "PREPARE_LEDGER_LIST_INFORMATION",
          "id": "1779098596165",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "type": "CODE"
        },
        {
          "metadata": {
            "businessObjectCode": "ORA_FIN_GENERALLED_FETCH_ACCOUNTING_PERIODS",
            "functionName": "getAccountingPeriods",
            "name": "Fetch Accounting Periods for Selected Ledger"
          },
          "outcomes": {
            "success": "1778592548442"
          },
          "code": "FETCH_ACCOUNTING_PERIODS_FOR_SELECTED_LEDGER",
          "id": "1781174690641",
          "inputs": [
            {
              "id": "1777371860638_1",
              "name": "periodSetName",
              "type": "string",
              "value": "{{$context.$nodes.FETCH_LEDGERS_FOR_USER_QUERY.$output[0].periodSetName}}"
            },
            {
              "id": "1777371860639_2",
              "name": "date",
              "value": "{{$context.$system.$currentDate}}"
            }
          ],
          "type": "BO_FUNCTION"
        },
        {
          "metadata": {
            "name": "Prepare Ledger Information For Refreshing Application Context",
            "returnType": "object",
            "sourceCode": "let validatedLedgerandPeriods = $context.$nodes.FETCH_ACCOUNTING_PERIODS_FOR_SELECTED_LEDGER.$output?.items || [];\n\nlet message = String($context.$nodes.EXTRACT_LEDGER_INFORMATION.$output.message) || \"\";\n\nif (validatedLedgerandPeriods.length === 0) {\n    return {\n        message: \"No open periods, when \" + message,\n//        message: \"Validation failed, No Open Periods when \" + message,\n        hasMany: false,\n        appContextUpdated: true,\n        refreshApp: false\n    };\n}\n\n\n\nlet currentLedgerId = $context.$nodes.FETCH_LEDGERS_FOR_USER_QUERY.$output[0].ledgerId;\nlet currentPeriodName = validatedLedgerandPeriods[0].periodName;\n\nconst context = {\n  ledgerId: currentLedgerId,\n  periodName: currentPeriodName,\n  message: message,\n  hasMany: false,\n  appContextUpdated: true,\n  refreshApp: true\n};\n\nreturn context;"
          },
          "outcomes": {
            "success": "end"
          },
          "code": "PREPARE_LEDGER_INFORMATION_FOR_REFRESHING_APPLICATION_CONTEXT",
          "id": "1778592548442",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "type": "CODE"
        },
        {
          "metadata": {
            "name": "Process Selected Period Name",
            "returnType": "string",
            "sourceCode": "let app_context = $context.$app.$OraAppContext || $context.$triggers.REST.$input.OraAppContext || \"{}\";\n\napp_context = JSON.parse(app_context);\n\nlet periodName = app_context?.periodName || $context.$nodes.FETCH_ACCOUNTING_PERIODS_DATA.$output.items[0].periodName || \"\";\n\nreturn periodName;"
          },
          "outcomes": {
            "success": "1778683589432"
          },
          "code": "PROCESS_SELECTED_PERIOD_NAME",
          "id": "1778684001885",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "type": "CODE"
        },
        {
          "metadata": {
            "businessObjectCode": "ORA_FIN_GENERALLED_LEDGER_OPEN_PERIODS",
            "functionName": "openPeriodsList",
            "name": "Fetch Period End Date"
          },
          "outcomes": {
            "success": "1781000252395"
          },
          "code": "FETCH_PERIOD_END_DATE",
          "id": "1778683589432",
          "inputs": [
            {
              "id": "1778683589432_periodName",
              "name": "periodName",
              "value": "{{$context.$nodes.PROCESS_SELECTED_PERIOD_NAME.$output.result}}"
            },
            {
              "id": "1778683589432_ledgerId",
              "name": "ledgerId",
              "value": "{{$context.$nodes.PROCESS_DEFAULT_LEDGER.$output.result.ledgerId}}"
            }
          ],
          "type": "BO_FUNCTION"
        },
        {
          "metadata": {
            "name": "Prepare Payload For Metadata",
            "returnType": "object",
            "sourceCode": "let currentLedger = $context.$nodes.PROCESS_DEFAULT_LEDGER.$output.result;\n\nlet query = {\n    \"select\": `SELECT  funAvMetadata.analyticViewName,funAvMetadata.analyticViewId,funAvMetadata.setupFlag,funAvMetadata.usageCode,funAvMetadata.userDefinedName,funAvMetadata.chartOfAccountId,funAvMetadata.accountingCalendarId,funAvMetadataDetail.segmentTypeCode,funAvMetadataDetail.dimensionDisplayName,funAvMetadataDetail.dimensionSequenceNumber,funAvMetadataDetail.dimensionAttributes,funAvMetadataDetail.hierarchyDisplayName,funAvMetadataDetail.hierarchyName,funAvMetadataDetail.dimensionLevelAttributes,funAvMetadataDetail.hierarchyAttributes,funAvMetadataDetail.uiFlag,funAvMetadataDetail.dimensionLevelDescriptions,funAvMetadataDetail.dimensionAttributeName,funAvMetadataDetail.valueSetId,funAvMetadataDetail.treeVersionId  FROM  funAvMetadata,funAvMetadataDetail  WHERE funAvMetadata.analyticViewId IN (SELECT analyticViewId from funAvMetadata WHERE chartOfAccountId='${currentLedger.chartOfAccountsId}' AND usageCode='GL_BALANCES_AV' AND accountingCalendarId='${currentLedger.calendarId}') AND funAvMetadata.analyticViewId =funAvMetadataDetail.analyticViewId AND funAvMetadataDetail.segmentTypeCode='MD'`,\n    \"viewQueries\": {\n        \"funAvMetadata\": {\n            \"module\": \"oraErpCoreCommonObjects\",\n            \"businessObject\": \"AnalyticViewMetadata\",\n            \"view\": \"analyticViewMetadataList\",\n            \"fieldAliases\": {\n                \"usageCode\": \"usageCode\",\n                \"setupFlag\": \"setupFlag\",\n                \"userDefinedName\": \"userDefinedName\",\n                \"analyticViewName\": \"analyticViewName\",\n                \"calendar.calendarId\": \"accountingCalendarId\",\n                \"structureInstance.structureInstanceNumber\": \"chartOfAccountId\",\n                \"analyticViewId\": \"analyticViewId\"\n            }\n        },\n        \"funAvMetadataDetail\": {\n            \"module\": \"oraErpCoreCommonObjects\",\n            \"businessObject\": \"AnalyticViewMetadataDetail\",\n            \"view\": \"analyticViewMetadataDetailList\",\n            \"fieldAliases\": {\n                \"segmentTypeCode\": \"segmentTypeCode\",\n                \"dimensionLevelAttributes\": \"dimensionLevelAttributes\",\n                \"hierarchyDisplayName\": \"hierarchyDisplayName\",\n                \"dimensionLevelDescriptions\": \"dimensionLevelDescriptions\",\n                \"dimensionSequenceNumber\": \"dimensionSequenceNumber\",\n                \"dimensionAttributes\": \"dimensionAttributes\",\n                \"hierarchyName\": \"hierarchyName\",\n                \"valueSet.valueSetId\": \"valueSetId\",\n                \"dimensionDisplayName\": \"dimensionDisplayName\",\n                \"hierarchyAttributes\": \"hierarchyAttributes\",\n                \"uiFlag\": \"uiFlag\",\n                \"dimensionAttributeName\": \"dimensionAttributeName\",\n                \"tree.treeVersionGUID\": \"treeVersionId\",\n                \"analyticViewId\": \"analyticViewId\"\n            }\n        }\n    }\n}\n\nreturn query;"
          },
          "outcomes": {
            "success": "1781000252396"
          },
          "code": "PREPARE_PAYLOAD_FOR_METADATA",
