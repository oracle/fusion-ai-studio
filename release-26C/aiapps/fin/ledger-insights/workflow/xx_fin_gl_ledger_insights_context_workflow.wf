        {
          "metadata": {
            "name": "Process Default Ledger",
            "returnType": "object",
            "sourceCode": "const ledgers_list = Array.isArray($context.$nodes.FETCH_LEDGERS_FOR_LOGGED_IN_USER.$output) ? $context.$nodes.FETCH_LEDGERS_FOR_LOGGED_IN_USER.$output : [];\n\nlet app_context = $context.$app.$OraAppContext || $context.$triggers.REST.$input.OraAppContext || \"{}\";\n\napp_context = JSON.parse(app_context);\n\nconst preference_output = $context.$nodes.FETCH_USER_PREFERENCE_FOR_DEFAULT_LEDGER?.$output;\n\nconst pref_ledger_id = Array.isArray(preference_output) && \n  preference_output.length > 0 &&\n  preference_output[0]?.value != null\n  ? preference_output[0].value\n  : null;\n\nconst final_ledger_id =\n  app_context?.ledgerId ||\n  pref_ledger_id ||\n  null;\n\nlet default_ledger = ledgers_list[0];\n\nif (ledgers_list.length > 0) {  \n    for (let i = 0; i < ledgers_list.length; i++) {\n      const ledger = ledgers_list[i];\n      if (ledger && ledger.ledgerId == final_ledger_id) {\n        default_ledger = ledger;\n        break;\n    }\n  }\n}\n\nreturn default_ledger;"
          },
          "outcomes": {
            "success": "1777371775298"
          },
          "code": "PROCESS_DEFAULT_LEDGER",
          "id": "1777370755811",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "type": "CODE"
        },
        {
          "metadata": {
            "businessObjectCode": "ORA_FIN_GENERALLED_FETCH_ACCOUNTING_PERIODS",
            "functionName": "getAccountingPeriods",
            "name": "Fetch Accounting Periods Data"
          },
          "outcomes": {
            "success": "1779099931574"
          },
          "code": "FETCH_ACCOUNTING_PERIODS_DATA",
          "id": "1777371775298",
          "inputs": [
            {
              "id": "1777371860638_1",
              "name": "periodSetName",
              "type": "string",
              "value": "{{$context.$nodes.PROCESS_DEFAULT_LEDGER.$output.result.periodSetName}}"
            },
