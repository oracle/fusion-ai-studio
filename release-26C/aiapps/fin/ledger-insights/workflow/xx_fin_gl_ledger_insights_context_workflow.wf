        {
          "metadata": {
            "name": "Process Action Code",
            "returnType": "object",
            "sourceCode": "let oraAction = $context.$app.$OraAction || $context.$triggers.REST.$input.OraAction || \"{}\";\n\ntry {\n  oraAction = JSON.parse(oraAction);\n}catch(e) {\n  oraAction = {};\n}\n\nreturn oraAction;"
          },
          "outcomes": {
            "success": "1781183665623"
          },
          "code": "PROCESS_ACTION_CODE",
          "id": "1779099931574",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "type": "CODE"
        },
        {
          "metadata": {
            "name": "Extract Intent for Selecting Ledger"
          },
          "outcomes": {
            "success": "1778591184091"
          },
          "code": "EXTRACT_INTENT_FOR_SELECTING_LEDGER",
          "id": "1781183665623",
          "inputs": [
            {
              "id": "1781183665623_prompt",
              "name": "prompt",
              "type": "string",
              "value": "You are an intent classification assistant.\n\nClassify whether the user is trying to modify the active ledger context.\n\nReturn only one boolean value:\ntrue\nfalse\n\nReturn true only when the user message clearly expresses an intent to set, change, update, select, choose, switch, or use a ledger as the active ledger.\n\nReturn false when the user is asking to create alerts, view insights, analyze balances, fetch reports, monitor activity, compare data, summarize information, or update non-ledger content.\n\nRules:\n- The action words set, change, update, select, choose, switch, and use are not sufficient by themselves.\n- The message must clearly target ledger selection or active ledger context.\n- Do not match substrings inside other words.\n- Do not infer ledger-setting intent from OraMessageHint alone.\n- If OraAction command is exactly \"selectLedger\", return true.\n- If the user message does not clearly indicate changing the active ledger, return false.\n- If uncertain, return false.\n\nInput:\nUser message: {{$context.$system.$inputMessage}}\nOraMessageHint: {{$context.$app.$OraMessageHint}}\nOraAction command: {{$context.$nodes.PROCESS_ACTION_CODE.$output.result.command}}\n\nOutput:\nReturn only true or false."
            }
          ],
          "outputSpecification": "",
          "type": "LLM"
        },
        {
          "metadata": {
            "name": "Determine Intent Route",
            "returnType": "boolean",
            "sourceCode": "const oraMessageHint =\n  $context?.$app?.$OraMessageHint ??\n  $context?.$triggers?.REST?.$input?.OraMessageHint ??\n  null;\n\nconst extractLedger = $context.$nodes.EXTRACT_INTENT_FOR_SELECTING_LEDGER.$output || false;\n\nconst inputMessage = String($context?.$system?.$inputMessage ?? \"\").trim();\n\nconst isQueryContextIntent = (oraMessageHint === \"Query\" && extractLedger) || (oraMessageHint === \"InvokeAction\" && $context.$nodes.PROCESS_ACTION_CODE.$output.result?.command === \"selectLedger\");\n\nreturn isQueryContextIntent;"
          },
          "outcomes": {
            "success": "1778591408829"
          },
          "code": "DETERMINE_INTENT_ROUTE",
          "id": "1778591184091",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "type": "CODE"
        },
        {
          "metadata": {
            "name": "Check For Ledger Switch"
          },
          "outcomes": {
            "true": "1778591642425",
            "false": "1778684001885"
          },
          "code": "CHECK_FOR_LEDGER_SWITCH",
          "convergenceTargetId": "end",
          "id": "1778591408829",
          "inputs": [
            {
              "id": "1778591408829_condition",
              "name": "condition",
              "type": "string",
              "value": "{{$context.$nodes.DETERMINE_INTENT_ROUTE.$output.result}}"
            }
          ],
          "type": "CONDITION"
        },
        {
          "aiAppOutputSpecification": {
            "dataDisplay": {
              "customNotes": ""
            }
          },
          "metadata": {
            "name": "Extract Ledger Information"
          },
          "outcomes": {
            "success": "1781171897110"
          },
          "code": "EXTRACT_LEDGER_INFORMATION",
          "id": "1778591642425",
          "inputs": [
            {
              "id": "1778591642425_systemPrompt",
              "name": "systemPrompt",
              "type": "string",
              "value": ""
            },
            {
              "id": "1778591642425_prompt",
              "name": "prompt",
              "type": "string",
              "value": "**Inputs**\n\nInput_Message = {{$context.$system.$inputMessage}} or {{$context.$triggers.REST.$input.inputMessage}}\nAction_Payload = {{$context.$nodes.PROCESS_ACTION_CODE.$output.result}}\n\nResolve `ledgerName` from `Input_Message` or `Action_Payload`.\n\n**Ledger resolution:**\n1. If the user asks to set, change, use, or switch ledger, extract the ledger name.\n2. Extract ledger names with or without quotes.\n   - `Set ledger to Vision.` means ledgerName is `Vision`.\n   - `Set ledger to \"Vision\".` means ledgerName is `Vision`.\n3. For unquoted ledger names, take the text after words like `ledger to`, `ledger`, or `for ledger`.\n4. Stop ledger extraction before another field or clause.\n5. Remove wrapping quotes and trailing punctuation.\n6. If the user did not ask to change ledger, return an empty string for `ledgerName`.\n7. Never include ledgerId.\n8. Never mention that a returned value is empty.\n\n**Message:**\n- Write one short user-facing sentence describing the ledger action.\n- Use ledger name when available.\n- If no ledger was requested, write a neutral sentence without saying the value is empty.\n\nReturn only valid JSON in this exact shape:\n\n{\n  \"ledgerName\": \"\",\n  \"message\": \"\"\n}\n\nPopulate values with the resolved results.\nDo not include markdown, commentary, or explanation."
            }
          ],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"ledgerName\": {\n      \"type\": \"string\"\n    },\n    \"periodName\": {\n      \"type\": \"string\"\n    },\n    \"message\": {\n      \"type\": \"string\"\n    }\n  },\n  \"required\": [\n    \"ledgerName\",\n    \"periodName\",\n    \"message\"\n  ],\n  \"additionalProperties\": false\n}",
          "type": "LLM"
        },
        {
          "metadata": {
            "name": "Prepare Payload Query For Ledger Selection",
            "returnType": "object",
            "sourceCode": "let partialLedgerName = $context.$nodes.EXTRACT_LEDGER_INFORMATION.$output.ledgerName || \"\";\n\nlet payload = {\n    \"viewQueries\": {\n        \"glDataAccessSetLedgers\": {\n            \"module\": \"oraErpCoreGeneralLedgerSetup\",\n            \"businessObject\": \"DataAccessSetLedger\",\n            \"view\": \"dataAccessSetLedgerList\",\n            \"fieldAliases\": {\n                \"accessSetId\": \"accessSetId\",\n                \"ledger.ledgerId\": \"ledgerId\",\n                \"ledger.name\": \"ledgerName\"\n            }\n        },\n        \"glAccessSets\": {\n            \"module\": \"oraErpCoreGeneralLedgerSetup\",\n            \"businessObject\": \"DataAccessSet\",\n            \"view\": \"dataAccessSetList\",\n            \"fieldAliases\": {\n                \"accessSetId\": \"accessSetId\",\n                \"name\": \"accessSetName\",\n                \"defaultLedger.ledgerId\": \"defaultLedgerId\",\n                \"chartOfAccount.structureInstanceNumber\": \"chartOfAccountsId\"\n            }\n        },\n        \"ledger\": {\n            \"module\": \"oraErpCoreStructure\",\n            \"businessObject\": \"Ledger\",\n            \"view\": \"ledgerList\",\n            \"fieldAliases\": {\n                \"calendar.periodSetName\": \"periodSetName\",\n                \"calendar.calendarId\": \"calendarId\",\n                \"currency.currencyCode\": \"currencyCode\",\n                \"ledgerId\": \"ledgerId\",\n                \"ledgerCategory.meaning\": \"ledgerCategory\",\n                \"name\": \"ledgerName\",\n                \"chartOfAccount.structureInstanceNumber\": \"chartOfAccountsId\"\n            }\n        }\n    },\n    \"select\": `SELECT DISTINCT ledger.ledgerId, ledger.ledgerCategory, ledger.chartOfAccountsId, ledger.ledgerName, ledger.periodSetName, ledger.calendarId, ledger.currencyCode, 'Y' as suspenseAllowedFlag FROM  ledger, glDataAccessSetLedgers WHERE ledger.ledgerId = glDataAccessSetLedgers.ledgerId and glDataAccessSetLedgers.accessSetId IN (select glAccessSets.accessSetId from glAccessSets) and glDataAccessSetLedgers.accessSetId IN (select glAccessSets.accessSetId from glAccessSets) AND UPPER(ledger.ledgerName) LIKE UPPER('%${partialLedgerName}%') order by ledger.ledgerName asc FETCH FIRST 10 ROWS ONLY`,\n    \"return\": [\n        {\n            \"type\": \"string\",\n            \"name\": \"ledgerId\"\n        },\n        {\n            \"type\": \"string\",\n            \"name\": \"ledgerCategory\"\n        },\n        {\n            \"type\": \"string\",\n            \"name\": \"chartOfAccountsId\"\n        },\n        {\n            \"type\": \"string\",\n            \"name\": \"ledgerName\"\n        },\n        {\n            \"type\": \"string\",\n            \"name\": \"periodSetName\"\n        },\n        {\n            \"type\": \"string\",\n            \"name\": \"calendarId\"\n        },\n         {\n            \"type\": \"string\",\n            \"name\": \"currencyCode\"\n        },\n        {\n            \"type\": \"string\",\n            \"name\": \"suspenseAllowedFlag\"\n        }\n    ]\n}\n\nreturn payload;"
          },
          "outcomes": {
            "success": "1779095940484"
          },
          "code": "PREPARE_PAYLOAD_QUERY_FOR_LEDGER_SELECTION",
          "id": "1781171897110",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "type": "CODE"
        },
        {
          "metadata": {
            "businessObjectCode": "ORA_FIN_GENERALLED_LEDGER_LOOKUP",
