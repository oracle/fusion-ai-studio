        {
          "metadata": {
            "name": "Build Application Context",
            "returnType": "object",
            "sourceCode": "let currentLedger = $context.$nodes.PROCESS_DEFAULT_LEDGER.$output.result;\nlet periodName = $context.$nodes.PROCESS_SELECTED_PERIOD_NAME.$output.result;\n\nlet validatedLedgerandPeriods = Array.isArray($context.$nodes.FETCH_PERIOD_END_DATE.$output) ? $context.$nodes.FETCH_PERIOD_END_DATE.$output : [];\nlet endDateforPeriod = validatedLedgerandPeriods[0]?.ENDDATE || $context.$nodes.FETCH_ACCOUNTING_PERIODS_DATA.$output.items[0].endDate ||\"-1\";\n\nif(endDateforPeriod === \"-1\") {\n\n}\n\nlet ORA_GL_RULE_CATEGORY = $context.$nodes.PROCESS_RULE_CATEGORY_RESPONSE.$output.result;\n\nlet ORA_FUN_RULE_PRIORITY = $context.$nodes.PROCESS_RULE_PRIORITY_RESPONSE.$output.result;\n\nlet ORA_FUN_RULE_FREQUENCY = $context.$nodes.PROCESS_RULE_FREQUENCY_RESPONSE.$output.result;\n\nlet avMetadata = $context.$nodes.FETCH_METADATA_INFORMATION.$output;\n\nlet mdEntry = avMetadata?.[0] || {};\nlet dimensionAttr = mdEntry.DIMENSIONATTRIBUTES;\n\nif(typeof dimensionAttr == 'string'){\n  dimensionAttr = JSON.parse(dimensionAttr);\n}\nlet bossAv = { bossAvName : dimensionAttr?.avMetadata?.bossAvName };\n\n\nconst context = {\n  ...currentLedger,\n  ...bossAv,\n  periodName: periodName,\n  endDate : endDateforPeriod,\n  ORA_GL_RULE_CATEGORY : ORA_GL_RULE_CATEGORY,\n  ORA_FUN_RULE_PRIORITY : ORA_FUN_RULE_PRIORITY,\n  ORA_FUN_RULE_FREQUENCY : ORA_FUN_RULE_FREQUENCY,\n  hasMany: false,\n  appContextUpdated: false,\n  refreshApp: false\n};\n\nreturn context;"
          },
          "outcomes": {
            "success": "end"
          },
