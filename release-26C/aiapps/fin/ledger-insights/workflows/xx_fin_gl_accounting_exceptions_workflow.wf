        {
          "metadata": {
            "name": "Prepare Submission Request",
            "returnType": "object",
            "sourceCode": "/* subledgerAccounting, journalImport, postJournals. */\n\nlet currentCode = $context.$nodes.READ_SELECTED_ACTION.$output.result.code || \"\"; \n\nlet essParams = $context.$nodes.READ_SELECTED_ACTION.$output.result.data || \"\";\n\nlet obj = {\n    \"OperationName\": \"submitESSJobRequest\",\n    \"JobPackageName\": \"\",\n    \"JobDefName\": \"\",\n    \"ESSParameters\": \"\"\n}\n\nif (currentCode === \"subledgerAccounting\") {\n    obj.JobPackageName = \"oracle/apps/ess/financials/subledgerAccounting/shared\";\n    obj.JobDefName = \"XLAFSNAPRPT\";\n    obj.ESSParameters = essParams;\n}\nelse if (currentCode === \"journalImport\") {\n    obj.JobPackageName = \"oracle/apps/ess/financials/generalLedger/programs/common\";\n    obj.JobDefName = \"JournalImportLauncher\";\n    obj.ESSParameters = essParams;\n}\nelse if (currentCode === \"postJournals\") {\n    obj.JobPackageName = \"oracle/apps/ess/financials/generalLedger/programs/common\";\n    obj.JobDefName = \"PostingSingleLedger\";\n    obj.ESSParameters = essParams;\n}\n\nobj;"
          },
