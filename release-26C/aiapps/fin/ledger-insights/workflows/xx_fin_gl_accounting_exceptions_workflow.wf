        {
          "metadata": {
            "name": "Prepare Transaction Actions",
            "returnType": "array",
            "sourceCode": "let transactions = $context.$nodes.COUNT_TRANSACTIONS_BY_CATEGORY.$output || [];\n\nlet exceptionCategory = $context.$nodes.READ_SELECTED_ACTION.$output.result.data.category || \"\";\nlet journalSource = $context.$nodes.READ_SELECTED_ACTION.$output.result.data.journal || \"\";\n\nlet applicationId = 140;\nlet accessSetId = -1;\nlet ledgerId = $context.$nodes.READ_APPLICATION_CONTEXT.$output.result.ledgerId;\nlet suspenseFlag = $context.$nodes.READ_APPLICATION_CONTEXT.$output.result.suspenseAllowedFlag;\nlet currentDate = $context.$system.$currentDate;\nlet chartOfAccountsId = $context.$nodes.READ_APPLICATION_CONTEXT.$output.result.chartOfAccountsId;\nlet calendarId = $context.$nodes.READ_APPLICATION_CONTEXT.$output.result.calendarId;\nlet coaCalendarKey = `${chartOfAccountsId}X${calendarId}`;\n\nlet suspenseEnabled = false;\nlet hasJournalInterface = false;\nlet hasSubledger = false;\nlet hasGLJournal = false;\n\nconst isAccountStatus = exceptionCategory === \"Account Status\";\nconst isCurrencyConversion = exceptionCategory === \"Currency Conversion\";\n\nfor (const transaction of transactions) {\n    const category = transaction.TRANSACTIONCATEGORY;\n\n    if (isAccountStatus && suspenseFlag === \"Y\") {\n        suspenseEnabled = true;\n    }  \n\n    if (category === \"Journal Interface\") {\n      hasJournalInterface = true;\n    } else if (category === \"Subledger Transaction\") {\n        hasSubledger = true;\n    } else if (category === \"General Ledger Journal\") {\n        hasGLJournal = true;\n    }\n\n    // Early exit\n    if (\n        suspenseEnabled &&\n        hasJournalInterface &&\n        hasSubledger &&\n        hasGLJournal\n    ) {\n        break;\n    }\n}\n\n// Adding Actions\n\nlet actions = [];\n\nconst toCsv = (obj) => Object.keys(obj).map(key => `${obj[key] || \"\"}`).join(\",\");\n\nif (isAccountStatus) {\n    const provideAlternateAccountPayload = {\n        action: \"Provide Alternate Account\",\n        code: \"provideAlternateAccount\",\n        command: \"validateFields\",\n        data: toCsv({})\n    };\n\n    actions.push({\n        title: \"Provide Alternate Account\",\n        shortDescription: \"Provide an alternate account for the transaction\",\n        actionText: \"Provide Alternate Account\",\n        followUpCommand: `ora.Invoke(\"validateFields\", ${JSON.stringify(provideAlternateAccountPayload)})`\n    });\n\n    const reactivateAccountPayload = {\n        action: \"Reactivate Account\",\n        code: \"reactivateAccount\",\n        command: \"validateFields\",\n        data: toCsv({})\n    };\n\n    actions.push({\n        title: \"Reactivate Account\",\n        shortDescription: \"Reactivate the account for the transaction\",\n        actionText: \"Reactivate Account\",\n        followUpCommand: `ora.Invoke(\"validateFields\", ${JSON.stringify(reactivateAccountPayload)})`\n    });\n}\n\nif (hasSubledger) {\n\n    const createDraftSubledgerAccountingPayload = {\n        action: \"Create Draft Subledger Accounting\",\n        code: \"subledgerAccounting\",\n        command: \"validateFields\",\n        data: toCsv({\n            argument1: null,\n            argument2: null,\n            applicationId: applicationId,\n            ledgerId: ledgerId,\n            argument5: null,\n            accountingEndDate: currentDate,\n            parameter7: \"Y\",\n            accountingMode: \"D\",\n            processEvents: \"N\",\n            reportStyle: \"N\",\n            transferToGeneralLedger: \"N\",\n            postInGeneralLedger: \"N\",\n            argument13: null,\n            argument14: null,\n            argument15: \"N\"\n        })\n    };\n\n    actions.push({\n        title: \"Create Draft Subledger Accounting\",\n        shortDescription: \"Create draft subledger accounting for the transaction\",\n        actionText: \"Create Draft Subledger Accounting\",\n        followUpCommand: `ora.Invoke(\"validateFields\", ${JSON.stringify(createDraftSubledgerAccountingPayload)})`\n    });\n\n    const createAndPostSubledgerAccountingPayload = {\n        action: \"Create and Post Subledger Accounting\",\n        code: \"subledgerAccounting\",\n        command: \"validateFields\",\n        data: toCsv({\n            argument1: null,\n            argument2: null,\n            applicationId: applicationId,\n            ledgerId: ledgerId,\n            argument5: null,\n            accountingEndDate: currentDate,\n            parameter7: \"Y\",\n            accountingMode: \"F\",\n            processEvents: \"N\",\n            reportStyle: \"N\",\n            transferToGeneralLedger: \"Y\",\n            postInGeneralLedger: \"Y\",\n            argument13: null,\n            argument14: null,\n            argument15: \"N\"\n        })\n    };\n\n    actions.push({\n        title: \"Create and Post Subledger Accounting\",\n        shortDescription: \"Create and post subledger accounting for the transaction\",\n        actionText: \"Create and Post Subledger Accounting\",\n        followUpCommand: `ora.Invoke(\"validateFields\", ${JSON.stringify(createAndPostSubledgerAccountingPayload)})`\n    });\n}\n\nif (suspenseEnabled && isAccountStatus && hasSubledger) {\n    const createAccountingUsingSuspenseAccountPayload = {\n        action: \"Create Accounting Using Suspense Account\",\n        code: \"subledgerAccounting\",\n        command: \"validateFields\",\n        data: toCsv({})\n    };\n\n    actions.push({\n        title: \"Create Accounting Using Suspense Account\",\n        shortDescription: \"Create accounting using suspense account for the transaction\",\n        actionText: \"Create Accounting Using Suspense Account\",\n        followUpCommand: `ora.Invoke(\"validateFields\", ${JSON.stringify(createAccountingUsingSuspenseAccountPayload)})`\n    });\n}\n\nif (hasJournalInterface) {\n    const importJournalsPayload = {\n        action: \"Import Journals\",\n        code: \"journalImport\",\n        command: \"validateFields\",\n        data: toCsv({\n            accessSetId: accessSetId,\n            journalSource: journalSource,\n            ledgerId: ledgerId,\n            groupId: \"ALL\",\n            postAccountErrorsToSuspense: \"N\",\n            createSummaryJournals: \"N\",\n            importDescriptiveFlexfields: \"N\"\n        })\n    };\n\n    actions.push({\n        title: \"Import Journals\",\n        shortDescription: \"Import journals for the transaction\",\n        actionText: \"Import Journals\",\n        followUpCommand: `ora.Invoke(\"validateFields\", ${JSON.stringify(importJournalsPayload)})`\n    });\n}\n\nif (hasGLJournal) {\n    const postJournalsPayload = {\n        action: \"Post Journals\",\n        code: \"postJournals\",\n        command: \"validateFields\",\n        data: toCsv({\n            ledgerId: ledgerId,\n            accessSetId: accessSetId,\n            chartOfAccountsId: chartOfAccountsId,\n            argument4: null,\n            calendarId: calendarId,\n            coaCalendarKey: coaCalendarKey\n        })\n    };\n\n    actions.push({\n        title: \"Post Journals\",\n        shortDescription: \"Post journals for the transaction\",\n        actionText: \"Post Journals\",\n        followUpCommand: `ora.Invoke(\"validateFields\", ${JSON.stringify(postJournalsPayload)})`\n    });\n}\n\nif (suspenseEnabled && isAccountStatus && hasJournalInterface) {\n    const importJournalsAndPostErrorsToSuspensePayload = {\n        action: \"Import Journals and Post Errors to Suspense\",\n        code: \"journalImport\",\n        command: \"validateFields\",\n        data: toCsv({\n            accessSetId: accessSetId,\n            journalSource: journalSource,\n            ledgerId: ledgerId,\n            groupId: \"ALL\",\n            postAccountErrorsToSuspense: \"Y\",\n            createSummaryJournals: \"N\",\n            importDescriptiveFlexfields: \"N\"\n        })\n    };\n\n    actions.push({\n        title: \"Import Journals and Post Errors to Suspense\",\n        shortDescription: \"Import journals and post errors to suspense for the transaction\",\n        actionText: \"Import Journals and Post Errors to Suspense\",\n        followUpCommand: `ora.Invoke(\"validateFields\", ${JSON.stringify(importJournalsAndPostErrorsToSuspensePayload)})`\n    });\n}\n\n\nif (isCurrencyConversion) {\n    const createCurrencyConversionRatePayload = {\n        action: \"Create Currency Conversion Rate\",\n        code: \"createCurrencyConversionRate\",\n        command: \"validateFields\",        \n        data: toCsv({})\n    };\n\n    actions.push({\n        title: \"Create Currency Conversion Rate\",\n        shortDescription: \"Create currency conversion rate for the transaction\",\n        actionText: \"Create Currency Conversion Rate\",\n        followUpCommand: `ora.Invoke(\"validateFields\", ${JSON.stringify(createCurrencyConversionRatePayload)})`\n    });\n}\n\nreturn actions;"
          },
