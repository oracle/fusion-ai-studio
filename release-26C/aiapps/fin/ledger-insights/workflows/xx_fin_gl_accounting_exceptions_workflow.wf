            "y": 7426
          },
          "code": "PREPARE_TRANSACTION_ACTIONS",
          "id": "1777982725853",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "type": "CODE"
        },
        {
          "metadata": {
            "name": "Choose Transaction Display"
          },
          "outcomes": {
            "true": "1777988227057",
            "false": "1780630348793"
          },
          "diagram": {
            "x": 7121,
            "y": 7648
          },
          "code": "CHOOSE_TRANSACTION_DISPLAY",
          "convergenceTargetId": "end",
          "id": "1777988176558",
          "inputs": [
            {
              "id": "1777988176560_1",
              "name": "condition",
              "type": "string",
              "value": "{{$context.$nodes.READ_SELECTED_ACTION.$output.result.showMore}}"
            }
          ],
          "type": "CONDITION"
        },
        {
          "aiAppOutputSpecification": {
            "dataDisplay": {
              "layouts": [
                "ORA_LAYOUT_MESSAGES_LIST"
              ],
              "enableActions": true,
              "enableCommunications": true,
              "customNotes": "",
              "enablePowerPoints": false
            }
          },
          "metadata": {
            "name": "Show All Transactions"
          },
