        {
          "id": "c0c874e4-4ef2-4af2-85d1-2df5ba964f5e",
          "name": "Drill Down",
          "type": "rest",
          "agenticAppMode": "query",
          "restConfigJson": "{\n    \"OraAction\": \"{\\\"command\\\": \\\"drillDownToTransactions\\\", \\\"showMore\\\": \\\"false\\\", \\\"data\\\": {\\\"category\\\": \\\"Subledger Transaction Data\\\", \\\"code\\\": \\\"ORA_SUBLEDGER_TRANSACTION_DATA\\\", \\\"metrics\\\": {\\\"exceptionCount\\\": 1, \\\"totalAmount\\\": 0}}}\",\n    \"OraMessageHint\": \"InvokeAction\",\n    \"OraUserContext\": \"{\\\"userId\\\":\\\"100010026335772\\\",\\\"guId\\\":\\\"D07276AD44A627628E80A4B424BD3C3D\\\",\\\"fullName\\\":\\\"Mary Johnson\\\",\\\"userName\\\":\\\"FINUSER1\\\",\\\"isAuthenticated\\\":true,\\\"loginUrl\\\":\\\"https://cptcoelqy.fusionapps.ocs.oc-test.com:443/fscmUI/faces/FuseWelcome\\\",\\\"isAdmin\\\":true,\\\"idcsTimeOut\\\":30,\\\"locale\\\":\\\"en\\\"}\",\n    \"triggerType\": \"REST\",\n    \"aiAppOutputSpecification\": \"[\\\"infoDisplay\\\",\\\"actions\\\",\\\"enableCommunications\\\"]\"\n}",
          "inputMessage": "Hi"
        },
        {
          "id": "b2e0eb0c-e53b-4748-88c6-51e6e81cfa4d",
          "name": "Drill Down, Txns 6",
