        {
          "metadata": {
            "name": "Resolve Application Context",
            "sourceCode": "const numericOnly = (value) => {\n  const text = value == null ? \"\" : String(value).trim();\n  return /^\\d+$/.test(text) ? text : \"\";\n};\n\nlet result = $context.$nodes.FETCH_APPLICATION_CONTEXT.$output.output || \"\";\n\nlet res = JSON.parse(result);\nlet context = res?.result || {};\n\nreturn {\n  ...context,\n  ledgerId: numericOnly(context?.ledgerId)\n};\n",
            "returnType": "object"
          },
          "diagram": {
