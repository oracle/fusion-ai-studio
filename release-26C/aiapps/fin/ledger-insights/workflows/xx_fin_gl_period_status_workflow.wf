        {
          "metadata": {
            "name": "Process Period Category Information",
            "returnType": "array",
            "sourceCode": "let response = $context.$nodes.FETCH_PERIOD_STATUS_INFORMATION.$output;\n\n/* response= response?.filter(item => item.APPLICATIONID !== 10037).map(item => {\n    if (item.APPLICATIONID === 101) {\n      item.SUBLEDGERORLEDGER = \"General Ledger\";\n    }\n\n    return item;\n  }); */\nconst updatedResponse = response?.map(item => ({\n\n  ...item,\n\n  category: \"LEDGER\"\n\n}));\n\nreturn updatedResponse;"
          },
