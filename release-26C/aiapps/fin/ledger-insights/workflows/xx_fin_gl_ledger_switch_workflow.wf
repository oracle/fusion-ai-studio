        {
          "id": "1782297418708",
          "code": "DEFAULT_APPLICATION_CONTEXT",
          "type": "CODE",
          "metadata": {
            "name": "Default Application Context",
            "returnType": "object",
            "sourceCode": "// return {};\n\nlet appContext = {\n    ledgerId : $context.$nodes.PROCESS_APPLICATION_CONTEXT.$output.result.ledgerId,\n    periodName : $context.$nodes.PROCESS_APPLICATION_CONTEXT.$output.result.periodName\n  };\n\n\nreturn {\n  name: $context.$nodes.PROCESS_APPLICATION_CONTEXT.$output.result.ledgerName,\n  appContext: JSON.stringify(appContext)\n};\n"
          },
          "diagram": {
            "x": 6800,
            "y": 6094
          },
          "outcomes": {
            "success": "end"
          },
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
        {
          "id": "1782297418709",
          "code": "PROCESS_USER_INPUT",
          "type": "CODE",
          "metadata": {
            "name": "Process User Input",
            "sourceCode": "let inputMsg = $context.$system.$inputMessage;\ninputMsg = inputMsg || \"\";\n\nconst parseInputMsg = (value) => {\n  if (typeof value !== \"string\") {\n    return \"\";\n  }\n\n  const lastNewlineIndex = value.lastIndexOf(\"\\n\");\n\n  if (lastNewlineIndex === -1) {\n    return value;\n  }\n\n  return value.slice(lastNewlineIndex + 1);\n};\n\nreturn parseInputMsg(inputMsg)",
            "returnType": "string"
          },
          "diagram": {
            "x": 6350,
            "y": 6094
          },
          "outcomes": {
            "success": "1782297418710"
          },
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
        {
          "id": "1782297418710",
          "code": "FETCH_LEDGERS_FOR_LOGGED_IN_USER",
          "type": "BO_FUNCTION",
          "metadata": {
            "businessObjectCode": "ORA_FIN_GL_XX_LEDGER_LOOKUP",
            "functionName": "getAllLedgersMatchByPattern",
            "name": "Fetch Ledgers For Logged In User"
          },
          "diagram": {
            "x": 6350,
            "y": 6316
