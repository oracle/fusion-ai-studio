        {
          "metadata": {
            "name": "Get where clause from hierarchies and defaults",
            "returnType": "array",
            "sourceCode": "const conditions_clause = $context.$nodes.PARSE_JOURNALS_AV_FILTER.$output.result.ora_condition_clause || [];\n\nconst hierarchies = $context.$nodes.BUILD_HIERARCHIES.$output.result || {};\nconst parsedFilter = $context.$nodes.PARSE_JOURNALS_AV_FILTER.$output.result.parsedFilter || {};\n\nconst filterSegmentMetadata = $context.$nodes.FILTER_SEGMENT_METADATA.$output.result || {};\n\nconst buildWhere = (segmentMetadata = {}, parsedFilter = {}, hierarchies = {}) =>\n  Object.keys(parsedFilter).reduce((result, key) => {\n    const segment = segmentMetadata?.[key];\n\n    if (key === \"fiscalDate\") {\n      const member = parsedFilter?.[key]?.$memberName;\n\n      if (member?.operator && member?.value !== undefined) {\n        const value = Array.isArray(member.value)\n          ? `('${member.value.join(\"','\")}')`\n          : `'${member.value}'`;\n\n        result.push(`periodName ${member.operator} ${value}`);\n      }\n\n      return result;\n    }\n\n    if (!segment?.DIMENSIONATTRIBUTENAME || !hierarchies?.[key]) {\n      return result;\n    }\n\n    result.push(`fact.${segment.DIMENSIONATTRIBUTENAME} = ${key}.leafValue`);\n\n    return result;\n  }, []);\n\nconst hierarchyWhere = buildWhere(filterSegmentMetadata, parsedFilter, hierarchies);\nconst defaultWhere = $context.$triggers.REST.$input.inputParams.defaultWhere || [];\n\nreturn [...hierarchyWhere, ...conditions_clause, ...defaultWhere];"
          },
          "outcomes": {
            "success": "1779024723592"
          },
          "code": "GET_WHERE_CLAUSE_FROM_HIERARCHIES_AND_DEFAULTS",
          "id": "1779029683680",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "type": "CODE",
          "diagram": {
