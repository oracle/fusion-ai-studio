        {
          "metadata": {
            "name": "Filter Segment Metadata",
            "returnType": "object",
            "sourceCode": "const camelCaseToSegmentLabel = key =>\n  key\n    .replace(/([a-z0-9])([A-Z])/g, \"$1_$2\")\n    .toUpperCase();\n\nconst parseSegmentLabels = segmentLabels => {\n  if (Array.isArray(segmentLabels)) {\n    return segmentLabels;\n  }\n\n  if (typeof segmentLabels === \"string\") {\n    return segmentLabels\n      .replace(\"[\", \"\")\n      .replace(\"]\", \"\")\n      .split(\",\")\n      .map(label => label.trim());\n  }\n\n  return [];\n};\n\nconst buildMetadataBySequence = (\n  chartOfAccountsMetadata = [],\n  avMetadata = []\n) => {\n  const avMetadataBySequence = new Map(\n    avMetadata.map(avItem => [\n      String(avItem.DIMENSIONSEQUENCENUMBER),\n      avItem,\n    ])\n  );\n\n  return chartOfAccountsMetadata.map(coaItem => {\n    const sequenceNumber = String(coaItem.sequenceNumber);\n\n    return {\n      ...coaItem,\n      ...(avMetadataBySequence.get(sequenceNumber) || {}),\n      segmentLabels: parseSegmentLabels(coaItem.segmentLabels),\n    };\n  });\n};\n\nconst buildFilterSegmentMetadata = ({\n  chartOfAccountsMetadata = [],\n  avMetadata = [],\n  parsedFilter = {},\n}) => {\n  const combinedMetadata = buildMetadataBySequence(\n    chartOfAccountsMetadata,\n    avMetadata\n  );\n\n  return Object.keys(parsedFilter).reduce((result, filterKey) => {\n    const segmentLabel = camelCaseToSegmentLabel(filterKey);\n\n    const matchedSegment = combinedMetadata.find(metadataItem =>\n      metadataItem.segmentLabels?.includes(segmentLabel)\n    );\n\n    if (matchedSegment) {\n      result[filterKey] = {\n        ...matchedSegment,\n      };\n    }\n\n    return result;\n  }, {});\n};\n\nconst buildSegmentAliasMap = (filterSegmentMetadata = {}, chartOfAccountId) =>\n  Object.values(filterSegmentMetadata).reduce((result, obj) => {\n    result[\n      `subledgerAccountingEntryLine.account<${chartOfAccountId}>.${obj.fieldName}.value`\n    ] = `${obj.segmentName}Value`;\n\n    return result;\n  }, {});\n\nlet parsedFilter = $context.$nodes.PARSE_JOURNALS_AV_FILTER.$output.result.parsedFilter;\n\nlet chartOfAccountsId = $context.$triggers.REST.$input.inputParams.chartOfAccountsId;\nlet chartOfAccountsMetadata = $context.$triggers.REST.$input.inputParams.chartOfAccountsMetadata;\nlet avMetadata = $context.$triggers.REST.$input.inputParams.avMetadata;\n\nconst filterSegmentMetadata = buildFilterSegmentMetadata({\n  chartOfAccountsMetadata,\n  avMetadata,\n  parsedFilter,\n});\n\nreturn filterSegmentMetadata;"
          },
          "outcomes": {
            "success": "1779563790579"
          },
          "code": "FILTER_SEGMENT_METADATA",
