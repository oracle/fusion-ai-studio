          "restConfigJson": "{\n  \"inputParams\": {\n    \"journalSource\": \"Receivables\",\n    \"balancesAVRequest\": {\n      \"analyticViews\": {\n        \"avUsage1\": {\n          \"measureAliases\": {\n            \"periodNetBalance\": \"C9\"\n          },\n          \"dimensions\": {\n            \"currencyType\": {\n              \"currencyType\": {\n                \"aliases\": {\n                  \"$levelName\": \"C27\",\n                  \"$memberName\": \"C7\",\n                  \"$memberDescription\": \"C8\"\n                }\n              }\n            },\n            \"ledger\": {\n              \"ledger\": {\n                \"aliases\": {\n                  \"$levelName\": \"C29\",\n                  \"$memberName\": \"C5\",\n                  \"$memberDescription\": \"C6\",\n                  \"ledgerSetName\": \"C46\",\n                  \"ledgerId\": \"ledgerId\",\n                  \"ledgerCurrency\": \"ledgerCurrency\"\n                }\n              }\n            },\n            \"vFCompany\": {\n              \"vFCompany\": {\n                \"aliases\": {\n                  \"$levelName\": \"C31\",\n                  \"treeVersionName\": \"C30\",\n                  \"$memberName\": \"C10\",\n                  \"$memberDescription\": \"C11\"\n                }\n              }\n            },\n            \"vFProgram\": {\n              \"vFProgram\": {\n                \"aliases\": {\n                  \"$levelName\": \"C33\",\n                  \"treeVersionName\": \"C32\",\n                  \"$memberName\": \"C12\",\n                  \"$memberDescription\": \"C13\"\n                }\n              }\n            },\n            \"vFCostCenter\": {\n              \"vFCostCenter\": {\n                \"aliases\": {\n                  \"$levelName\": \"C35\",\n                  \"treeVersionName\": \"C34\",\n                  \"$memberName\": \"C14\",\n                  \"$memberDescription\": \"C15\"\n                }\n     