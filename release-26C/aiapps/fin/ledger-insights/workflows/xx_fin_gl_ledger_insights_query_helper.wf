        {
          "metadata": {
            "name": "Get Field Aliases",
            "returnType": "object",
            "sourceCode": "const buildSegmentAliasMap = (filterSegmentMetadata = {}, chartOfAccountId) =>\n  Object.values(filterSegmentMetadata).reduce((result, obj) => {\n    result[\n      `account<${chartOfAccountId}>.${obj.fieldName}.value`\n    ] = `${obj.DIMENSIONATTRIBUTENAME}`;\n\n    return result;\n  }, {});\n\nlet parsedFilter = $context.$nodes.PARSE_JOURNALS_AV_FILTER.$output.result.parsedFilter;\n\nlet chartOfAccountsId = $context.$triggers.REST.$input.inputParams.chartOfAccountsId;\nlet chartOfAccountsMetadata = $context.$triggers.REST.$input.inputParams.chartOfAccountsMetadata;\nlet avMetadata = $context.$triggers.REST.$input.inputParams.avMetadata;\n\nconst filterSegmentMetadata = $context.$nodes.FILTER_SEGMENT_METADATA.$output.result\n\nconst dyn_field_aliases = buildSegmentAliasMap(\n  filterSegmentMetadata,\n  chartOfAccountsId\n);\n\nconst static_field_aliases = $context.$triggers.REST.$input.inputParams.fieldAliases;\n\nreturn {...(dyn_field_aliases || {}), ...static_field_aliases};;"
          },
