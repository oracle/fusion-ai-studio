      "profiles": [
        {
          "id": "c8749166-3e3c-4914-a4d5-a6f8eb99af69",
          "name": "New run profile 1",
          "type": "rest",
          "agenticAppMode": "query",
          "restConfigJson": "{\n    \"inputParams\": {\n        \"journalSource\": \"MOCK_JOURNALSOURCE\",\n        \"balancesAVRequest\": {\n            \"analyticViews\": {\n                \"mockUsage\": {\n                    \"measureAliases\": {\n                        \"periodNetBalance\": \"MOCK_PERIODNETBALANCE\"\n                    },\n                    \"dimensions\": {\n                        \"ledger\": {\n                            \"ledger\": {\n                                \"aliases\": {\n                                    \"$levelName\": \"MOCK_LEVELNAME\",\n                                    \"$memberName\": \"MOCK_MEMBERNAME\",\n                                    \"$memberDescription\": \"MOCK_MEMBERDESCRIPTION\",\n                                    \"ledgerSetName\": \"MOCK_LEDGERSETNAME\",\n                                    \"ledgerId\": \"MOCK_LEDGERID\",\n                                    \"ledgerCurrency\": \"MOCK_LEDGERCURRENCY\"\n                                }\n                            }\n                        },\n                        \"accountingPeriod\": {\n                            \"accountingPeriod\": {\n                                \"aliases\": {\n                                    \"$memberName\": \"MOCK_MEMBERNAME\",\n                                    \"$memberDescription\": \"MOCK_MEMBERDESCRIPTION\"\n                                }\n                            }\n                        },\n                        \"mockCompany\": {\n                            \"mockCompany\": {\n                                \"aliases\": {\n                                    \"$levelName\": \"MOCK_LEVELNAME\",\n                                    \"$memberName\": \"MOCK_MEMBERNAME\",\n                                    \"$memberDescription\": \"MOCK_MEMBERDESCRIPTION\"\n                                }\n                            }\n                        },\n                        \"mockAccount\": {