        {
          "metadata": {
            "name": "Parse Journals AV Filter",
            "returnType": "object",
            "sourceCode": "const ORA_CONDITION_CLAUSE = \"ora_condition_clause\";\n\nconst parseFilterFromPayload = (payload) => {\n  const filter = getFilterFromPayload(payload);\n\n  return filter\n    ? parseFilter(filter)\n    : {\n      parsedFilter: {},\n      ora_condition_clause: []\n    };\n};\n\n// Fetches filter string from the Journals AV query\nconst getFilterFromPayload = (payload) => {\n  const analyticViews = payload?.analyticViews;\n\n  if (!analyticViews || typeof analyticViews !== \"object\") {\n    return \"\";\n  }\n\n  const firstAnalyticView = Object.values(analyticViews)[0];\n\n  return typeof firstAnalyticView?.filter === \"string\"\n    ? firstAnalyticView.filter\n    : \"\";\n};\n\n\nconst parseFilter = (filter) => {\n  const conditions = splitByLogicalAnd(filter);\n\n  const parsedFilter = {};\n  const ora_condition_clause = [];\n\n  for (const condition of conditions) {\n    const trimmedCondition = condition.trim();\n\n    let parsedCondition;\n\n    try {\n      parsedCondition = parseCondition(trimmedCondition);\n    } catch (error) {\n      ora_condition_clause.push(trimmedCondition);\n      continue;\n    }\n\n    const {\n      dimension,\n      attribute,\n      operator,\n      value,\n      original,\n      expression\n    } = parsedCondition;\n\n    parsedFilter[dimension] ??= {};\n\n    parsedFilter[dimension][attribute] = {\n      operator,\n      value,\n      original,\n      expression\n    };\n  }\n\n  return {\n    parsedFilter,\n    [ORA_CONDITION_CLAUSE]: ora_condition_clause\n  };\n};\n\n// Splits by AND, but ignores AND inside quotes or parentheses.\nconst splitByLogicalAnd = (filter) => {\n  const conditions = [];\n\n  let current = \"\";\n  let insideQuote = false;\n  let parenthesesDepth = 0;\n\n  for (let i = 0; i < filter.length; i++) {\n    const char = filter[i];\n\n    if (char === \"'\") {\n      insideQuote = !insideQuote;\n      current += char;\n      continue;\n    }\n\n    if (!insideQuote) {\n      if (char === \"(\") {\n        parenthesesDepth++;\n      } else if (char === \")\") {\n        parenthesesDepth--;\n      }\n\n      const remaining = filter.slice(i);\n      const andMatch = remaining.match(/^\\s+\\band\\b\\s+/i);\n\n      if (parenthesesDepth === 0 && andMatch) {\n        conditions.push(current.trim());\n        current = \"\";\n\n        i += andMatch[0].length - 1;\n        continue;\n      }\n    }\n\n    current += char;\n  }\n\n  if (current.trim()) {\n    conditions.push(current.trim());\n  }\n\n  return conditions;\n};\n\n// Parses one condition like: currency.$memberName = 'USD'\nconst parseCondition = (condition) => {\n  const original = condition.trim();\n  const operatorMatch = findOperator(original);\n\n  if (!operatorMatch) {\n    throw new Error(`Unsupported condition: ${condition}`);\n  }\n\n\n  const operator = normalizeOperator(operatorMatch.operator);\n\n  const leftSide = original.slice(0, operatorMatch.index).trim();\n\n  const rightSide = original\n    .slice(operatorMatch.index + operatorMatch.raw.length)\n    .trim();\n\n  const { dimension, attribute } = parseLeftSide(leftSide);\n\n  return {\n    dimension,\n    attribute,\n    operator,\n    value: parseValue(operator, rightSide),\n    original,\n    expression: `${operator} ${rightSide}`\n  };\n};\n\n// Finds supported operators: =, !=, IN, NOT IN\nconst findOperator = (condition) => {\n  const match = condition.match(\n    /\\s+(not\\s+in|in)\\s*(?=\\()|\\s+(not\\s+in|in)\\s+|\\s*(>=|<=|!=|>|<|=)\\s*/i\n  );\n\n  if (!match) {\n    return null;\n  }\n\n  return {\n    index: match.index,\n    raw: match[0],\n    operator: match[1] || match[2] || match[3]\n  };\n};\n\n// Normalizes operator casing: \"not   in\" -> \"NOT IN\"\nconst normalizeOperator = (operator) => {\n  return operator\n    .trim()\n    .replace(/\\s+/g, \" \")\n    .toUpperCase();\n};\n\n// Splits left side into dimension and attribute.\nconst parseLeftSide = (leftSide) => {\n  const dotIndex = leftSide.indexOf(\".\");\n\n  if (dotIndex === -1) {\n    throw new Error(`Invalid condition left side: ${leftSide}`);\n  }\n\n  return {\n    dimension: leftSide.slice(0, dotIndex).trim(),\n    attribute: leftSide.slice(dotIndex + 1).trim()\n  };\n};\n\n// Parses right-side value based on operator.\nconst parseValue = (operator, rawValue) => {\n  if (operator === \"IN\" || operator === \"NOT IN\") {\n    return parseListValue(rawValue);\n  }\n\n  return stripOuterQuotes(rawValue);\n};\n\n// Parses values inside IN (...).\nconst parseListValue = (rawValue) => {\n  const trimmed = rawValue.trim();\n\n  if (!trimmed.startsWith(\"(\") || !trimmed.endsWith(\")\")) {\n    throw new Error(`Invalid list value: ${rawValue}`);\n  }\n\n  const innerValue = trimmed.slice(1, -1);\n  const parts = splitCommaSeparatedValues(innerValue);\n\n  return parts.map(stripOuterQuotes);\n};\n\n// Splits comma-separated values, ignoring commas inside quotes.\nconst splitCommaSeparatedValues = (value) => {\n  const result = [];\n\n  let current = \"\";\n  let insideQuote = false;\n\n  for (let i = 0; i < value.length; i++) {\n    const char = value[i];\n\n    if (char === \"'\") {\n      insideQuote = !insideQuote;\n      current += char;\n      continue;\n    }\n\n    if (char === \",\" && !insideQuote) {\n      result.push(current.trim());\n      current = \"\";\n      continue;\n    }\n\n    current += char;\n  }\n\n  if (current.trim()) {\n    result.push(current.trim());\n  }\n\n  return result;\n};\n\n// Removes surrounding single quotes.\nconst stripOuterQuotes = (value) => {\n  const trimmed = String(value).trim();\n\n  if (trimmed.startsWith(\"'\") && trimmed.endsWith(\"'\")) {\n    return trimmed.slice(1, -1);\n  }\n\n  return trimmed;\n};\n\n// parsing journals av filter\nlet balancesAVRequest = $context.$triggers.REST.$input.inputParams.balancesAVRequest;\n\nreturn parseFilterFromPayload(balancesAVRequest);"
          },
          "outcomes": {
            "success": "1779567184333"
          },
          "code": "PARSE_JOURNALS_AV_FILTER",
          "id": "1779447630463",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
