        {
          "metadata": {
            "name": "Build Hierarchies",
            "returnType": "object",
            "sourceCode": "const capitalizeFirst = (value) => {\n  if (!value) return value;\n  return value.charAt(0).toUpperCase() + value.slice(1);\n};\n\nconst isLevelValue = (levelName) => {\n  const upper = String(levelName || \"\").toUpperCase();\n  return upper.startsWith(\"LEVEL\") && upper.endsWith(\"VALUE\");\n};\n\nconst levelNameToField = (levelName) => {\n  const lower = String(levelName || \"\").toLowerCase();\n\n  return lower.endsWith(\"value\")\n    ? lower.slice(0, -5) + \"Value\"\n    : lower;\n};\n\nconst toHierarchyName = (dimensionName) =>\n  `ora_erp_core_structure_runtime_x__${capitalizeFirst(dimensionName)}`;\n\nconst buildHierarchies = (parsed_filter, filterSegmentMetadata) => {\n  const hierarchies = {};\n\n  Object.entries(parsed_filter || {}).forEach(([dimensionName, filters]) => {\n    const levelName = filters?.$levelName?.value;\n\n    if (!isLevelValue(levelName)) {\n      return;\n    }\n\n    const memberName = filters?.$memberName?.value;\n\n    if (memberName === undefined || memberName === null || memberName === \"\") {\n      return;\n    }\n\n    const metadata = filterSegmentMetadata?.[dimensionName];\n    const segmentCode = metadata?.segmentCode;\n    const treeFilter = filters?.treeFilter?.value;\n\n    const levelValueField = levelNameToField(levelName);\n    const levelValueSetCodeField = `${levelValueField}SetCode`;\n\n    const filterParts = [];\n\n    if (treeFilter) {\n      filterParts.push(`treeFilter = '${treeFilter}'`);\n    }\n\n    filterParts.push(`$levelName = 'LEVEL0VALUE'`);\n    filterParts.push(`${levelValueField} = '${memberName}'`);\n\n    if (segmentCode) {\n      filterParts.push(`${levelValueSetCodeField} = '${segmentCode}'`);\n    }\n\n    hierarchies[dimensionName] = {\n      module: \"oraErpCoreStructureRuntime\",\n      name: toHierarchyName(dimensionName),\n      aliases: {\n        \"$memberName\": \"leafValue\"\n      },\n      filter: filterParts.join(\" AND \")\n    };\n  });\n\n  return hierarchies;\n};\n\nconst parsedFilter = $context.$nodes.PARSE_JOURNALS_AV_FILTER.$output.result?.parsedFilter;\n\nconst filterSegmentMetadata = $context.$nodes.FILTER_SEGMENT_METADATA.$output.result;\n\nconst hierarchies = buildHierarchies(parsedFilter, filterSegmentMetadata);\nreturn hierarchies;"
          },
          "outcomes": {
            "success": "1779029683680"
          },
          "code": "BUILD_HIERARCHIES",
