        {
          "metadata": {
            "name": "Construct Payload",
            "returnType": "object",
            "sourceCode": "const hierarchies = $context.$nodes.BUILD_HIERARCHIES.$output.result;\nconst chartOfAccountsId = $context.$triggers.REST.$input.inputParams.chartOfAccountsId;\nconst fieldAliases = $context.$nodes.GET_FIELD_ALIASES.$output.result ;\nconst select = $context.$nodes.PREPARE_SELECT.$output.result;\n\nconst returnArr = Object.values(fieldAliases).map((name) => ({\n  name,\n  type: \"string\",\n}));\n\nconst buildAccountingPayload = ({ hierarchies, chartOfAccountsId, select }) => ({\n  hierarchies,\n  viewQueries: {\n    fact: {\n      module: $context.$triggers.REST.$input.inputParams.module,\n      businessObject: $context.$triggers.REST.$input.inputParams.businessObject,\n      view: $context.$triggers.REST.$input.inputParams.view,\n      fieldAliases: $context.$nodes.GET_FIELD_ALIASES.$output.result ,\n      viewParamMappings: {\n        chartOfAccountsId: [String(chartOfAccountsId)],\n      },\n    },\n  },\n  return: returnArr,\n  select,\n});\n\nreturn buildAccountingPayload({\n  hierarchies,\n  chartOfAccountsId,\n  select\n});"
          },
