        {
          "metadata": {
            "name": "Prepare Select",
            "returnType": "string",
            "sourceCode": "let hierarchies = $context.$nodes.BUILD_HIERARCHIES.$output.result;\n\nlet sortCriteria = 'fetch first 15 rows only'; \n\nlet views = ['fact', ...Object.keys(hierarchies)].join(\",\");\nconst ledgerName = $context.$triggers.REST.$input.inputParams.ledgerName;\nconst fieldAliases = $context.$nodes.GET_FIELD_ALIASES.$output.result ;\nconst select = Object.values(fieldAliases).join(\", \");\n\nconst expWhere = $context.$nodes.GET_WHERE_CLAUSE_FROM_HIERARCHIES_AND_DEFAULTS.$output.result;\n\nlet where = [\n  ...expWhere,\n  [`ledgerName = '${ledgerName}'`]\n].join(\" AND \");\n\n\nconst sql = `select ${select} from ${views} where ${where} ORDER BY (accountedDebit - accountedCredit) desc ${sortCriteria}`;\nreturn sql;"
          },
          "outcomes": {
            "success": "1779023033608"
          },
          "code": "PREPARE_SELECT",
          "id": "1779024723592",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
