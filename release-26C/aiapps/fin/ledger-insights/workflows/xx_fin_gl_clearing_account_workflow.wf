              "type": "string",
              "value": ""
            },
            {
              "id": "1778704929597_prompt",
              "name": "prompt",
              "type": "string",
              "value": "**INPUT**\n- Dismiss Action Data : {{$context.$nodes.DISMISS_INSIGHT.$output}} \n\n**ROOT CONFIGURATION**\n- The root `oraInfoDisplay` must include a `title` property\n- The root `oraInfoDisplay` must not include a `description` property\n\n**DIRECTIVE**\n1. When dismiss action is completed successfully\n   - `title` for `oraInfoDisplay` should be \"Insight dismissed successfully.\"\n2. When dismiss action is not completed successfully\n   - `title` for `oraInfoDisplay` should be  \"An unknown error occured. Please try again later.\"\n\n**OUTPUT RULES**\n\n- Output only the final `oraInfoDisplay` content.\n- Output shoud not contain any `items` in `messageListWidget` widget\n- Output shoud not contain any `description` in `messageListWidget` widget"
            }
          ],
          "type": "LLM"
        },
        {
          "metadata": {
            "name": "Read Review Comments",
            "returnType": "object",
            "sourceCode": "const numericOnly = (value) => {\n  const text = value == null ? \"\" : String(value).trim();\n  return /^\\d+$/.test(text) ? text : \"\";\n};\n\ntry {\n\n  const str = $context?.$app?.$OraAction || \"\";\n\n  if (!str || typeof str !== \"string\") {\n\n    return {};\n\n  }\n\n  // Extract JSON content safely\n\n  const jsonMatch = str.match(/<oraFormSubmit[^>]*>([\\s\\S]*?)<\\/oraFormSubmit>/);\n\n  if (!jsonMatch || !jsonMatch[1]) {\n\n    return {};\n\n  }\n\n  const jsonString = jsonMatch[1].trim();\n\n  if (!jsonString) {\n\n    return {};\n\n  }\n\n  const data = JSON.parse(jsonString);\n\n  if (!Array.isArray(data)) {\n\n    return {};\n\n  }\n\n  // Convert array into key-value object\n\n  return data.reduce((result, item) => {\n\n    if (item?.id) {\n\n      result[item.id] = item.id === \"InsightRecipientId\" ? numericOnly(item.value) : item.value;\n\n    }\n\n    return result;\n\n  }, {});\n\n} catch (error) {\n\n  return {};\n\n}"
          },
          "outcomes": {
            "success": "1778838416905"
          },
          "diagram": {
            "x": 6800,
            "y": 7648
          },
          "code": "READ_REVIEW_COMMENTS",
          "id": "1778837786044",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "type": "CODE"
        },
