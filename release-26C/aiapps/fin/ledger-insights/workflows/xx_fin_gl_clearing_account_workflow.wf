          "type": "CODE"
        },
        {
          "metadata": {
            "name": "Prepare Period Filter Request",
            "returnType": "object",
            "sourceCode": "let payload = {};\n\npayload.query = $context.$nodes.READ_INSIGHT_FILTERS.$output.result?.bossExtract;\npayload.moduleId = \"47110F64AC0B08E2E040449823C60DB6\";\n\npayload.contextAttribute = \"ledgerId\";\npayload.contextValue = $context.$nodes.READ_APPLICATION_CONTEXT.$output.result.ledgerId;\n\npayload.categoryCode = $context.$nodes.READ_INSIGHT_FILTERS.$output.result.bossExtract?.categoryCode;\npayload.resolveExpression = true;\npayload.conditions = [];\npayload.logicalOperator = \"AND\";\npayload.transformQuery = false;\n\nreturn payload;"
