          "code": "PREPARE_JOURNAL_DETAIL_REQUEST",
          "type": "CODE",
          "metadata": {
            "name": "Prepare Journal Detail Request",
            "returnType": "object",
            "sourceCode": "let bossQ =  JSON.parse( $context.$nodes.RESOLVE_PERIOD_FILTERS.$output || '');\nlet queries = [];\n\nif(typeof bossQ == \"string\"){\n    bossQ = JSON.parse(bossQ);\n}\nreturn bossQ;\n/*\nqueries.push(bossQ);\n\nlet payload = {\n    \"rowLimit\": 25,\n    \"ledgerId\": $context.$nodes.READ_APPLICATION_CONTEXT.$output.result.ledgerId,\n    \"includeData\":true,\n    \"varianceColumn\": \"accountingPeriod.$memberName\",\n    \"expandAggregateDataByOneLevel\": true,\n    \"useCase\": \"LedgerInsights\",\n    \"expandBasedOnAccountType\": true,\n    \"queries\": queries\n};\n\npayload;\n*/"
          },
