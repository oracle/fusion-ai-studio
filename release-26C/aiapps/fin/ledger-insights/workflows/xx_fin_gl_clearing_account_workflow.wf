            "returnType": "string",
            "sourceCode": "let bossQ =  JSON.parse( $context.$nodes.RESOLVE_PERIOD_FILTERS.$output || '');\nlet queries = [];\n\nif(typeof bossQ == \"string\"){\n    bossQ = JSON.parse(bossQ);\n}\n\nif(bossQ.viewQueries) return 'JournalsBV';\nelse if( bossQ.analyticViews ){\n  let name = bossQ.analyticViews.avUsage1.name || '';\n  if( name.endsWith('JournalSummary') ){\n    return 'JournalsAV';\n  }  \n return 'BalancesAV';\n}\n\nreturn '';"
          },
