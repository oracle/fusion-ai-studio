          ],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"avExtractResult\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"ledgerLevelAvData\": {\n          \"type\": \"array\",\n          \"items\": {\n            \"type\": \"object\",\n            \"properties\": {\n              \"currentLevelAvData\": {\n                \"type\": \"object\",\n                \"properties\": {\n                  \"records\": {\n                    \"type\": \"array\",\n                    \"items\": {\n                      \"type\": \"object\",\n                      \"properties\": {\n                        \"beginBalance\": {\n                          \"type\": \"string\"\n                        },\n                        \"beginBalanceSign\": {\n                          \"type\": \"string\"\n                        },\n                        \"periodNetBalance\": {\n                          \"type\": \"string\"\n                        },\n                        \"periodNetBalanceSign\": {\n                          \"type\": \"string\"\n                        },\n                        \"endingBalance\": {\n                          \"type\": \"string\"\n                        },\n                        \"endingBalanceSign\": {\n                          \"type\": \"string\"\n                        },\n                        \"accountingPeriod\": {\n                          \"type\": \"string\"\n                        },\n                        \"currency\": {\n                          \"type\": \"string\"\n                        },\n                        \"currencyType\": {\n                          \"type\": \"string\"\n                        },\n                        \"ledger\": {\n                          \"type\": \"string\"\n                        },\n                        \"scenario\": {\n                          \"type\": \"string\"\n                        },\n                        \"account\": {\n                          \"type\": \"string\"\n                        },\n                        \"accountDescription\": {\n                          \"type\": \"string\"\n                        },\n                        \"company\": {\n                          \"type\": \"string\"\n                        },\n                        \"companyDescription\": {\n                          \"type\": \"string\"\n                        },\n                        \"ledgerId\": {\n                          \"type\": \"string\"\n                        },\n                        \"ledgerCurrency\": {\n                          \"type\": \"string\"\n                        }\n                      },\n                      \"required\": [\n                        \"beginBalance\",\n                        \"beginBalanceSign\",\n                        \"periodNetBalance\",\n                        \"periodNetBalanceSign\",\n                        \"endingBalance\",\n                        \"endingBalanceSign\",\n                        \"accountingPeriod\",\n                        \"currency\",\n                        \"currencyType\",\n                        \"ledger\",\n                        \"scenario\",\n                        \"account\",\n                        \"accountDescription\",\n                        \"company\",\n                        \"companyDescription\",\n                        \"ledgerId\",\n                        \"ledgerCurrency\"\n                      ],\n                      \"additionalProperties\": false\n                    }\n                  },\n                  \"hasMore\": {\n                    \"type\": \"boolean\"\n                  },\n                  \"count\": {\n                    \"type\": \"number\"\n                  }\n                },\n                \"required\": [\n                  \"records\",\n                  \"hasMore\",\n                  \"count\"\n                ],\n                \"additionalProperties\": false\n              },\n              \"childLevelAvData\": {\n                \"type\": \"object\",\n                \"properties\": {\n                  \"records\": {\n                    \"type\": \"array\",\n                    \"items\": {\n                      \"type\": \"object\",\n                      \"properties\": {\n                        \"beginBalance\": {\n                          \"type\": \"string\"\n                        },\n                        \"beginBalanceSign\": {\n                          \"type\": \"string\"\n                        },\n                        \"periodNetBalance\": {\n                          \"type\": \"string\"\n                        },\n                        \"periodNetBalanceSign\": {\n                          \"type\": \"string\"\n                        },\n                        \"endingBalance\": {\n                          \"type\": \"string\"\n                        },\n                        \"endingBalanceSign\": {\n                          \"type\": \"string\"\n                        },\n                        \"accountingPeriod\": {\n                          \"type\": \"string\"\n                        },\n                        \"currency\": {\n                          \"type\": \"string\"\n                        },\n                        \"currencyType\": {\n                          \"type\": \"string\"\n                        },\n                        \"ledger\": {\n                          \"type\": \"string\"\n                        },\n                        \"scenario\": {\n                          \"type\": \"string\"\n                        },\n                        \"account\": {\n                          \"type\": \"string\"\n                        },\n                        \"accountDescription\": {\n                          \"type\": \"string\"\n                        },\n                        \"company\": {\n                          \"type\": \"string\"\n                        },\n                        \"companyDescription\": {\n                          \"type\": \"string\"\n                        },\n                        \"ledgerId\": {\n                          \"type\": \"string\"\n                        },\n                        \"ledgerCurrency\": {\n                          \"type\": \"string\"\n                        }\n                      },\n                      \"required\": [\n                        \"beginBalance\",\n                        \"beginBalanceSign\",\n                        \"periodNetBalance\",\n                        \"periodNetBalanceSign\",\n                        \"endingBalance\",\n                        \"endingBalanceSign\",\n                        \"accountingPeriod\",\n                        \"currency\",\n                        \"currencyType\",\n                        \"ledger\",\n                        \"scenario\",\n                        \"account\",\n                        \"accountDescription\",\n                        \"company\",\n                        \"companyDescription\",\n                        \"ledgerId\",\n                        \"ledgerCurrency\"\n                      ],\n                      \"additionalProperties\": false\n                    }\n                  },\n                  \"hasMore\": {\n                    \"type\": \"boolean\"\n                  },\n                  \"count\": {\n                    \"type\": \"number\"\n                  }\n                },\n                \"required\": [\n                  \"records\",\n                  \"hasMore\",\n                  \"count\"\n                ],\n                \"additionalProperties\": false\n              }\n            },\n            \"required\": [\n              \"currentLevelAvData\",\n              \"childLevelAvData\"\n            ],\n            \"additionalProperties\": false\n          }\n        },\n        \"hasMore\": {\n          \"type\": \"boolean\"\n        },\n        \"hierarchiesUsed\": {\n          \"type\": \"object\",\n          \"properties\": {\n            \"Company\": {\n              \"type\": \"string\"\n            }\n          },\n          \"required\": [\n            \"Company\"\n          ],\n          \"additionalProperties\": false\n        },\n        \"timeStamp\": {\n          \"type\": \"string\"\n        },\n        \"headLineMeasures\": {\n          \"type\": \"array\",\n          \"items\": {\n            \"type\": \"string\"\n          }\n        },\n        \"metaData\": {\n          \"type\": \"object\",\n          \"properties\": {\n            \"coreDimensions\": {\n              \"type\": \"object\",\n              \"properties\": {\n                \"currency\": {\n                  \"type\": \"object\",\n                  \"properties\": {\n                    \"label\": {\n                      \"type\": \"string\"\n                    }\n                  },\n                  \"required\": [\n                    \"label\"\n                  ],\n                  \"additionalProperties\": false\n                },\n                \"currencyType\": {\n                  \"type\": \"object\",\n                  \"properties\": {\n                    \"label\": {\n                      \"type\": \"string\"\n                    }\n                  },\n                  \"required\": [\n                    \"label\"\n                  ],\n                  \"additionalProperties\": false\n                },\n                \"ledger\": {\n                  \"type\": \"object\",\n                  \"properties\": {\n                    \"label\": {\n                      \"type\": \"string\"\n                    }\n                  },\n                  \"required\": [\n                    \"label\"\n                  ],\n                  \"additionalProperties\": false\n                },\n                \"accountingPeriod\": {\n                  \"type\": \"object\",\n                  \"properties\": {\n                    \"label\": {\n                      \"type\": \"string\"\n                    }\n                  },\n                  \"required\": [\n                    \"label\"\n                  ],\n                  \"additionalProperties\": false\n                }\n              },\n              \"required\": [\n                \"currency\",\n                \"currencyType\",\n                \"ledger\",\n                \"accountingPeriod\"\n              ],\n              \"additionalProperties\": false\n            },\n            \"chartOfAccounts\": {\n              \"type\": \"object\",\n              \"properties\": {\n                \"segments\": {\n                  \"type\": \"object\",\n                  \"properties\": {\n                    \"company\": {\n                      \"type\": \"object\",\n                      \"properties\": {\n                        \"qualifiers\": {\n                          \"type\": \"array\",\n                          \"items\": {\n                            \"type\": \"string\"\n                          }\n                        },\n                        \"label\": {\n                          \"type\": \"string\"\n                        }\n                      },\n                      \"required\": [\n                        \"qualifiers\",\n                        \"label\"\n                      ],\n                      \"additionalProperties\": false\n                    },\n                    \"costCenter\": {\n                      \"type\": \"object\",\n                      \"properties\": {\n                        \"qualifiers\": {\n                          \"type\": \"array\",\n                          \"items\": {\n                            \"type\": \"string\"\n                          }\n                        },\n                        \"label\": {\n                          \"type\": \"string\"\n                        }\n                      },\n                      \"required\": [\n                        \"qualifiers\",\n                        \"label\"\n                      ],\n                      \"additionalProperties\": false\n                    },\n                    \"account\": {\n                      \"type\": \"object\",\n                      \"properties\": {\n                        \"qualifiers\": {\n                          \"type\": \"array\",\n                          \"items\": {\n                            \"type\": \"string\"\n                          }\n                        },\n                        \"label\": {\n                          \"type\": \"string\"\n                        }\n                      },\n                      \"required\": [\n                        \"qualifiers\",\n                        \"label\"\n                      ],\n                      \"additionalProperties\": false\n                    }\n                  },\n                  \"required\": [\n                    \"company\",\n                    \"costCenter\",\n                    \"account\"\n                  ],\n                  \"additionalProperties\": false\n                }\n              },\n              \"required\": [\n                \"segments\"\n              ],\n              \"additionalProperties\": false\n            },\n            \"mandatoryCoaSegments\": {\n              \"type\": \"array\",\n              \"items\": {\n                \"type\": \"string\"\n              }\n            }\n          },\n          \"required\": [\n            \"coreDimensions\",\n            \"chartOfAccounts\",\n            \"mandatoryCoaSegments\"\n          ],\n          \"additionalProperties\": false\n        }\n      },\n      \"required\": [\n        \"ledgerLevelAvData\",\n        \"hasMore\",\n        \"hierarchiesUsed\",\n        \"timeStamp\",\n        \"headLineMeasures\",\n        \"metaData\"\n      ],\n      \"additionalProperties\": false\n    }\n  },\n  \"required\": [\n    \"avExtractResult\"\n  ],\n  \"additionalProperties\": false\n}"
