          ],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"analyticViews\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"avUsage1\": {\n          \"type\": \"object\",\n          \"properties\": {\n            \"measureAliases\": {\n              \"type\": \"object\",\n              \"properties\": {\n                \"periodNetBalance\": {\n                  \"type\": \"string\"\n                }\n              },\n              \"required\": [\n                \"periodNetBalance\"\n              ],\n              \"additionalProperties\": false\n            },\n            \"dimensions\": {\n              \"type\": \"object\",\n              \"properties\": {\n                \"accountingPeriod\": {\n                  \"type\": \"object\",\n                  \"properties\": {\n                    \"accountingPeriod\": {\n                      \"type\": \"object\",\n                      \"properties\": {\n                        \"aliases\": {\n                          \"type\": \"object\",\n                          \"properties\": {\n                            \"$memberName\": {\n                              \"type\": \"string\"\n                            },\n                            \"$memberDescription\": {\n                              \"type\": \"string\"\n                            },\n                            \"$depth\": {\n                              \"type\": \"string\"\n                            }\n                          },\n                          \"required\": [\n                            \"$memberName\",\n                            \"$memberDescription\",\n                            \"$depth\"\n                          ],\n                          \"additionalProperties\": false\n                        }\n                      },\n                      \"required\": [\n                        \"aliases\"\n                      ],\n                      \"additionalProperties\": false\n                    }\n                  },\n                  \"required\": [\n                    \"accountingPeriod\"\n                  ],\n                  \"additionalProperties\": false\n                },\n                \"currency\": {\n                  \"type\": \"object\",\n                  \"properties\": {\n                    \"currency\": {\n                      \"type\": \"object\",\n                      \"properties\": {\n                        \"aliases\": {\n                          \"type\": \"object\",\n                          \"properties\": {\n                            \"$levelName\": {\n                              \"type\": \"string\"\n                            },\n                            \"$memberName\": {\n                              \"type\": \"string\"\n                            },\n                            \"$memberDescription\": {\n                              \"type\": \"string\"\n                            }\n                          },\n                          \"required\": [\n                            \"$levelName\",\n                            \"$memberName\",\n                            \"$memberDescription\"\n                          ],\n                          \"additionalProperties\": false\n                        }\n                      },\n                      \"required\": [\n                        \"aliases\"\n                      ],\n                      \"additionalProperties\": false\n                    }\n                  },\n                  \"required\": [\n                    \"currency\"\n                  ],\n                  \"additionalProperties\": false\n                },\n                \"currencyType\": {\n                  \"type\": \"object\",\n                  \"properties\": {\n                    \"currencyType\": {\n                      \"type\": \"object\",\n                      \"properties\": {\n                        \"aliases\": {\n                          \"type\": \"object\",\n                          \"properties\": {\n                            \"$levelName\": {\n                              \"type\": \"string\"\n                            },\n                            \"$memberName\": {\n                              \"type\": \"string\"\n                            },\n                            \"$memberDescription\": {\n                              \"type\": \"string\"\n                            }\n                          },\n                          \"required\": [\n                            \"$levelName\",\n                            \"$memberName\",\n                            \"$memberDescription\"\n                          ],\n                          \"additionalProperties\": false\n                        }\n                      },\n                      \"required\": [\n                        \"aliases\"\n                      ],\n                      \"additionalProperties\": false\n                    }\n                  },\n                  \"required\": [\n                    \"currencyType\"\n                  ],\n                  \"additionalProperties\": false\n                },\n                \"ledger\": {\n                  \"type\": \"object\",\n                  \"properties\": {\n                    \"ledger\": {\n                      \"type\": \"object\",\n                      \"properties\": {\n                        \"aliases\": {\n                          \"type\": \"object\",\n                          \"properties\": {\n                            \"$levelName\": {\n                              \"type\": \"string\"\n                            },\n                            \"$memberName\": {\n                              \"type\": \"string\"\n                            },\n                            \"ledgerSetName\": {\n                              \"type\": \"string\"\n                            },\n                            \"$memberDescription\": {\n                              \"type\": \"string\"\n                            },\n                            \"ledgerId\": {\n                              \"type\": \"string\"\n                            },\n                            \"ledgerCurrency\": {\n                              \"type\": \"string\"\n                            }\n                          },\n                          \"required\": [\n                            \"$levelName\",\n                            \"$memberName\",\n                            \"ledgerSetName\",\n                            \"$memberDescription\",\n                            \"ledgerId\",\n                            \"ledgerCurrency\"\n                          ],\n                          \"additionalProperties\": false\n                        }\n                      },\n                      \"required\": [\n                        \"aliases\"\n                      ],\n                      \"additionalProperties\": false\n                    }\n                  },\n                  \"required\": [\n                    \"ledger\"\n                  ],\n                  \"additionalProperties\": false\n                },\n                \"scenario\": {\n                  \"type\": \"object\",\n                  \"properties\": {\n                    \"scenario\": {\n                      \"type\": \"object\",\n                      \"properties\": {\n                        \"aliases\": {\n                          \"type\": \"object\",\n                          \"properties\": {\n                            \"$levelName\": {\n                              \"type\": \"string\"\n                            },\n                            \"$memberName\": {\n                              \"type\": \"string\"\n                            },\n                            \"$memberDescription\": {\n                              \"type\": \"string\"\n                            }\n                          },\n                          \"required\": [\n                            \"$levelName\",\n                            \"$memberName\",\n                            \"$memberDescription\"\n                          ],\n                          \"additionalProperties\": false\n                        }\n                      },\n                      \"required\": [\n                        \"aliases\"\n                      ],\n                      \"additionalProperties\": false\n                    }\n                  },\n                  \"required\": [\n                    \"scenario\"\n                  ],\n                  \"additionalProperties\": false\n                },\n                \"account\": {\n                  \"type\": \"object\",\n                  \"properties\": {\n                    \"account\": {\n                      \"type\": \"object\",\n                      \"properties\": {\n                        \"aliases\": {\n                          \"type\": \"object\",\n                          \"properties\": {\n                            \"$levelName\": {\n                              \"type\": \"string\"\n                            },\n                            \"$memberName\": {\n                              \"type\": \"string\"\n                            },\n                            \"treeVersionName\": {\n                              \"type\": \"string\"\n                            },\n                            \"$memberDescription\": {\n                              \"type\": \"string\"\n                            }\n                          },\n                          \"required\": [\n                            \"$levelName\",\n                            \"$memberName\",\n                            \"treeVersionName\",\n                            \"$memberDescription\"\n                          ],\n                          \"additionalProperties\": false\n                        }\n                      },\n                      \"required\": [\n                        \"aliases\"\n                      ],\n                      \"additionalProperties\": false\n                    }\n                  },\n                  \"required\": [\n                    \"account\"\n                  ],\n                  \"additionalProperties\": false\n                },\n                \"company\": {\n                  \"type\": \"object\",\n                  \"properties\": {\n                    \"company\": {\n                      \"type\": \"object\",\n                      \"properties\": {\n                        \"aliases\": {\n                          \"type\": \"object\",\n                          \"properties\": {\n                            \"$levelName\": {\n                              \"type\": \"string\"\n                            },\n                            \"$memberName\": {\n                              \"type\": \"string\"\n                            },\n                            \"treeVersionName\": {\n                              \"type\": \"string\"\n                            },\n                            \"$memberDescription\": {\n                              \"type\": \"string\"\n                            }\n                          },\n                          \"required\": [\n                            \"$levelName\",\n                            \"$memberName\",\n                            \"treeVersionName\",\n                            \"$memberDescription\"\n                          ],\n                          \"additionalProperties\": false\n                        }\n                      },\n                      \"required\": [\n                        \"aliases\"\n                      ],\n                      \"additionalProperties\": false\n                    }\n                  },\n                  \"required\": [\n                    \"company\"\n                  ],\n                  \"additionalProperties\": false\n                }\n              },\n              \"required\": [\n                \"accountingPeriod\",\n                \"currency\",\n                \"currencyType\",\n                \"ledger\",\n                \"scenario\",\n                \"account\",\n                \"company\"\n              ],\n              \"additionalProperties\": false\n            },\n            \"module\": {\n              \"type\": \"string\"\n            },\n            \"name\": {\n              \"type\": \"string\"\n            },\n            \"filter\": {\n              \"type\": \"string\"\n            }\n          },\n          \"required\": [\n            \"measureAliases\",\n            \"dimensions\",\n            \"module\",\n            \"name\",\n            \"filter\"\n          ],\n          \"additionalProperties\": false\n        }\n      },\n      \"required\": [\n        \"avUsage1\"\n      ],\n      \"additionalProperties\": false\n    },\n    \"select\": {\n      \"type\": \"string\"\n    },\n    \"return\": {\n      \"type\": \"array\"\n    }\n  },\n  \"required\": [\n    \"analyticViews\",\n    \"select\",\n    \"return\"\n  ],\n  \"additionalProperties\": false\n}",
