          "code": "PREPARE_SELECTED_INSIGHT_DETAILS",
          "id": "1778706138446",
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "type": "CODE"
        },
        {
          "metadata": {
            "name": "Read Insight Filters",
            "returnType": "object",
            "sourceCode": "let insight = $context.$nodes.GET_SELECTED_INSIGHT_DETAILS.$output?.items[0];\nlet policy = insight.sensorSignal.policy;\nlet ruleName = policy?.ruleName;\nlet categoryCode = policy?.categoryCode;\n  let filter = policy?.bossFilter;\n  let decoded = atob(filter || \"\");\n  let parsed = JSON.parse(decoded);\n  let bossExtract = parsed?.steps?.[0]?.bossExtract;\nbossExtract = JSON.stringify(bossExtract);\n\nlet output = {};\noutput.categoryCode = categoryCode;\noutput.bossExtract = bossExtract;\n\nreturn output;"
          },
          "outcomes": {
