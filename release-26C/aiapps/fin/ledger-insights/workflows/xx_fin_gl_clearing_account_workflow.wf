          "code": "PREPARE_JOURNAL_DRILLDOWN_REQUEST",
          "type": "CODE",
          "metadata": {
            "name": "Prepare Journal Drilldown Request",
            "returnType": "object",
            "sourceCode": "let payload = {};\n\npayload.module = 'oraErpCoreAccountingEntries';\npayload.businessObject = 'JournalLine';\npayload.view = 'generalLedgerJournalDetail';\n\npayload.balancesAVRequest = $context.$nodes.PREPARE_BALANCE_EXPLANATION_REQUEST.$output.result.queries[0];\npayload.balancesAVResponse = $context.$nodes.GET_BALANCE_EXPLANATION_DETAILS.$output;\npayload.avMetadata  = $context.$nodes.GET_BALANCE_SETUP_DETAILS.$output;\n\npayload.chartOfAccountsMetadata = $context.$nodes.GET_CHART_OF_ACCOUNTS_DETAILS.$output?.result;\n\npayload.ledgerName = $context.$nodes.READ_APPLICATION_CONTEXT.$output.result.ledgerName;\n\npayload.chartOfAccountsId  = $context.$nodes.READ_APPLICATION_CONTEXT.$output.result.chartOfAccountsId;\n\npayload.READ_APPLICATION_CONTEXT = $context.$nodes.READ_APPLICATION_CONTEXT.$output.result;\n\npayload.insightDetails = $context.$nodes.PREPARE_SELECTED_INSIGHT_DETAILS.$output.result;\n\npayload.defaultQueries = [\n  \"(accountedCredit != 0 OR accountedDebit != 0 OR enteredDebit != 0 OR enteredCredit != 0 )\",\n  \"batchStatusCode = 'P'\"\n];\n\npayload.fieldAliases = {\n\"header.batch.description\": \"batchDescription\",\n          \"ledger.ledgerId\": \"ledgerId\",\n          \"header.batch.errorMessage\": \"errorMessage\",\n          \"periodName\": \"periodName\",\n          \"description\": \"lineDescription\",\n          \"header.batch.name\": \"batchName\",\n          \"netEnteredAmount\": \"netEnteredAmount\",\n          \"ledger.name\": \"ledgerName\",\n          \"netAccountedAmount\": \"netAccountedAmount\",\n          \"header.name\": \"journalName\",\n          \"dateCreated\": \"dateCreated\",\n          \"currency.currencyCode\": \"enteredCurrency\",\n          \"account.concatenatedSegments\": \"concatenatedSegments\",\n          \"journalLineNumber\": \"journalLineNumber\",\n          \"currencyConversionDate\": \"currencyConversionDate\",\n          \"accountingDate\": \"accountingDate\",\n          \"updatedBy\": \"updatedBy\",\n          \"accountedCredit\": \"accountedCredit\",\n          \"header.journalSource.userJeSourceName\": \"journalSource\",\n          \"header.description\": \"journalDescription\",\n          \"ledger.currency.currencyCode\": \"ledgerCurrencyCode\",\n          \"header.batch.lookupBatchStatus.meaning\": \"batchStatus\",\n          \"dateUpdated\": \"dateUpdated\",\n          \"createdBy\": \"createdBy\",\n          \"header.batch.lookupBatchStatus.lookupCode\": \"batchStatusCode\",\n          \"accountedDebit\": \"accountedDebit\",\n          \"enteredDebit\": \"enteredDebit\",\n          \"enteredCredit\": \"enteredCredit\",\n          \"currencyConversionRate\": \"currencyConversionRate\",\n          \"header.journalCategory.userJeCategoryName\": \"journalCategory\"\n        }\n\nreturn payload;"
          },
