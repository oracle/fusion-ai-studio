          "metadata": {
            "name": "Prepare Lookup Values",
            "returnType": "object",
            "sourceCode": "let ORA_GL_RULE_CATEGORY = $context.$nodes.READ_APPLICATION_CONTEXT.$output.result?.ORA_GL_RULE_CATEGORY;\n\n/* {\n    \"items\": [{\n            \"LookupCode\": \"ORA_ACCOUNTING_CONTROLS\",\n            \"Meaning\": \"Accounting controls\"\n        },\n        {\n            \"LookupCode\": \"ORA_ACCOUNT_ANALYSIS\",\n            \"Meaning\": \"Account analysis\"\n        },\n        {\n            \"LookupCode\": \"ORA_INTERCOMPANY\",\n            \"Meaning\": \"Intercompany\"\n        },\n        {\n            \"LookupCode\": \"ORA_OPERATIONAL\",\n            \"Meaning\": \"Operational\"\n        },\n        {\n            \"LookupCode\": \"ORA_PERIOD_END_CONTROLS\",\n            \"Meaning\": \"Period end controls\"\n        },\n        {\n            \"LookupCode\": \"ORA_PROCESS_EXCEPTIONS\",\n            \"Meaning\": \"Process Exceptions\"\n        },\n        {\n            \"LookupCode\": \"ORA_RECONCILIATION\",\n            \"Meaning\": \"Reconciliation\"\n        },\n        {\n            \"LookupCode\": \"ORA_VARIANCE\",\n            \"Meaning\": \"Variance\"\n        }\n    ]\n};\n*/\n\nlet ORA_FUN_RULE_PRIORITY = $context.$nodes.READ_APPLICATION_CONTEXT.$output.result?.ORA_FUN_RULE_PRIORITY;\n/*\n{\n    \"items\": [{\n            \"LookupCode\": \"ORA_HIGH\",\n            \"Meaning\": \"High\"\n        },\n        {\n            \"LookupCode\": \"ORA_MEDIUM\",\n            \"Meaning\": \"Medium\"\n        },\n        {\n            \"LookupCode\": \"ORA_LOW\",\n            \"Meaning\": \"Low\"\n        }\n    ]\n};\n*/\n\nlet toLabelValueArray = (input) => {\n    if (!input || !Array.isArray(input.items)) return [];\n\n    return input.items.map(item => ({\n        label: item.Meaning,\n        value: item.LookupCode\n    }));\n}\n\nconst ORA_GL_RULE_CATEGORY_result = toLabelValueArray(ORA_GL_RULE_CATEGORY);\nconst ORA_FUN_RULE_PRIORITY_result = toLabelValueArray(ORA_FUN_RULE_PRIORITY);\n\nlet finalResult = {\n    ORA_GL_RULE_CATEGORY: ORA_GL_RULE_CATEGORY_result,\n    ORA_FUN_RULE_PRIORITY: ORA_FUN_RULE_PRIORITY_result\n}\n\nreturn finalResult;"
          },
