        {
          "id": "1779964551004",
          "code": "PREPARE_BALANCE_SETUP_REQUEST",
          "type": "CODE",
          "metadata": {
            "name": "Prepare Balance Setup Request",
            "returnType": "object",
            "sourceCode": "let ledgerId = $context.$nodes.READ_APPLICATION_CONTEXT.$output.result?.ledgerId;\nlet payload = {\n    \"parameters\": {\n        \"ledgerId\": ledgerId\n    },\n    \"select\": \"SELECT  funAvMetadata.analyticViewName,funAvMetadataDetail.dimensionDisplayName, funAvMetadataDetail.dimensionSequenceNumber,funAvMetadataDetail.hierarchyDisplayName,funAvMetadataDetail.hierarchyName, funAvMetadataDetail.dimensionAttributeName  FROM  ledger, funAvMetadata,funAvMetadataDetail  WHERE ledger.ledgerId = :ledgerId and ledger.chartOfAccountsId = funAvMetadata.chartOfAccountsId and ledger.calendarId = funAvMetadata.accountingCalendarId and funAvMetadata.usageCode = 'GL_BALANCES_AV' and funAvMetadata.analyticViewId = funAvMetadataDetail.analyticViewId and funAvMetadataDetail.segmentTypeCode = 'COA' order by funAvMetadataDetail.dimensionSequenceNumber\",\n    \"viewQueries\": {\n        \"ledger\": {\n            \"module\": \"oraErpCoreStructure\",\n            \"businessObject\": \"Ledger\",\n            \"view\": \"ledgerList\",\n            \"fieldAliases\": {\n                \"ledgerId\": \"ledgerId\",\n                \"chartOfAccount.structureInstanceNumber\": \"chartOfAccountsId\",\n                \"calendar.calendarId\": \"calendarId\"\n            }\n        },\n        \"funAvMetadata\": {\n            \"module\": \"oraErpCoreCommonObjects\",\n            \"businessObject\": \"AnalyticViewMetadata\",\n            \"view\": \"analyticViewMetadataList\",\n            \"fieldAliases\": {\n                \"usageCode\": \"usageCode\",\n                \"setupFlag\": \"setupFlag\",\n                \"userDefinedName\": \"userDefinedName\",\n                \"analyticViewName\": \"analyticViewName\",\n                \"calendar.calendarId\": \"accountingCalendarId\",\n                \"structureInstance.structureInstanceNumber\": \"chartOfAccountsId\",\n                \"analyticViewId\": \"analyticViewId\"\n            }\n        },\n        \"funAvMetadataDetail\": {\n            \"module\": \"oraErpCoreCommonObjects\",\n            \"businessObject\": \"AnalyticViewMetadataDetail\",\n            \"view\": \"analyticViewMetadataDetailList\",\n            \"fieldAliases\": {\n                \"segmentTypeCode\": \"segmentTypeCode\",\n                \"dimensionLevelAttributes\": \"dimensionLevelAttributes\",\n                \"hierarchyDisplayName\": \"hierarchyDisplayName\",\n                \"dimensionLevelDescriptions\": \"dimensionLevelDescriptions\",\n                \"dimensionSequenceNumber\": \"dimensionSequenceNumber\",\n                \"dimensionAttributes\": \"dimensionAttributes\",\n                \"hierarchyName\": \"hierarchyName\",\n                \"valueSet.valueSetId\": \"valueSetId\",\n                \"dimensionDisplayName\": \"dimensionDisplayName\",\n                \"hierarchyAttributes\": \"hierarchyAttributes\",\n                \"uiFlag\": \"uiFlag\",\n                \"sourceViewName\": \"sourceViewName\",\n                \"dimensionAttributeName\": \"dimensionAttributeName\",\n                \"tree.treeVersionGUID\": \"treeVersionId\",\n                \"analyticViewId\": \"analyticViewId\"\n            }\n        }\n    }\n};\n\nreturn payload;"
          },
          "diagram": {
            "x": 6350,
            "y": 10572
          },
          "outcomes": {
            "success": "1779964551005"
          },
          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}"
        },
        {
          "id": "1779964551005",
          "code": "GET_BALANCE_SETUP_DETAILS",
          "type": "BO_FUNCTION",
          "metadata": {
