          "inputs": [],
          "outputSpecification": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"result\": {\n      \"type\": \"object\"\n    },\n    \"timeout\": {\n      \"type\": \"boolean\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"result\",\n    \"timeout\",\n    \"error\"\n  ]\n}",
          "type": "CODE"
        },
        {
          "metadata": {
            "name": "Read Selected Insight",
            "returnType": "string",
            "sourceCode": "const numericOnly = (value) => {\n  const text = value == null ? \"\" : String(value).trim();\n  return /^\\d+$/.test(text) ? text : \"\";\n};\n\nlet rowData = {};\n\ntry {\n  const rawInput = $context.$app.$OraAction || \"\";\n\n  if (rawInput) {\n    let parsedInput = JSON.parse(rawInput);\n\n    // handle double-encoded JSON\n    if (typeof parsedInput === \"string\") {\n      parsedInput = JSON.parse(parsedInput);\n    }\n\n    rowData = parsedInput?.rowData || {};\n  }\n} catch (e) { }\nreturn numericOnly(rowData.insightRecipientId);"
          },
