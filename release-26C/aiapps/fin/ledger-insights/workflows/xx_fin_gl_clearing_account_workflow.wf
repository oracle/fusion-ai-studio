          "id": "1780405482207",
          "code": "SUMMARIZE_JOURNAL_DETAILS",
          "type": "LLM",
          "metadata": {
            "name": "Summarize Journal Details",
            "modelConfiguration": {
              "code": "ORA_MODEL_CONFIG_PREMIUM_OPEN_AI_GPT_4_1_MINI",
              "modelName": "GPT-5 Mini (Premium)",
              "provider": "CERT_PREMIUM",
              "model": "OCI_GPT_5_MINI",
              "modelProperties": {
                "max_completion_tokens": 32000,
                "reasoning_effort": "low"
              }
            },
            "answerInUserLanguage": true
          },
          "diagram": {
