            "name": "Prepare Journal Search Details",
            "sourceCode": "let result = {};\ntry {\n  if ($context.$nodes?.IDENTIFY_DETAIL_TYPE?.$output?.result === 'JournalsBV') {\n    let balancesAVReq = $context.$nodes?.RESOLVE_PERIOD_FILTERS?.$output || '';\n    if (typeof balancesAVReq === 'string') {\n      balancesAVReq = JSON.parse(balancesAVReq);\n    }\n    result = balancesAVReq;\n  } else {\n    const payloadString = $context.$nodes?.BUILD_JOURNAL_DRILLDOWN_REQUEST?.$output?.output || '';\n    if (typeof payloadString === 'string' && payloadString.trim().length > 0) {\n      const parsedPayload = JSON.parse(payloadString);\n      result = parsedPayload.result || {};\n    } else {\n      result = {};\n    }\n  }\n} catch (error) {\n  result = {};\n}\nreturn result;",
            "returnType": "object"
          },
